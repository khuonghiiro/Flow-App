<UserControl x:Class="FlowMy.Controls.RadioListBoxUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:FlowMy.Controls"
             xmlns:conv="clr-namespace:FlowMy.Converters"
             x:Name="UserControlRoot">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

    </UserControl.Resources>

    <GroupBox Header="{Binding Title, ElementName=UserControlRoot}"
              Style="{Binding ContainerStyle, ElementName=UserControlRoot, 
                          TargetNullValue={StaticResource DefaultContainerStyle}}">

        <Grid>
            <ListBox x:Name="RadioListBox"
                     Style="{Binding ListBoxStyle, ElementName=UserControlRoot, 
                    TargetNullValue={StaticResource DefaultRadioListBoxStyle}}"
                     ItemsSource="{Binding ItemsSource, ElementName=UserControlRoot}"
                     SelectedItem="{Binding SelectedItem, ElementName=UserControlRoot, Mode=TwoWay}"
                     SelectionMode="Single"
                     Background="{Binding Background, ElementName=UserControlRoot}"
                     BorderThickness="{Binding BorderThickness, ElementName=UserControlRoot}"
                     Height="{Binding Height, ElementName=UserControlRoot}"
                     MaxHeight="{Binding MaxHeight, ElementName=UserControlRoot}"
                     MinHeight="{Binding MinHeight, ElementName=UserControlRoot}">

                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="ScrollChanged">
                        <b:InvokeCommandAction Command="{Binding ScrollChangedCommand, ElementName=UserControlRoot}"
                                               PassEventArgsToCommand="True"/>
                    </b:EventTrigger>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding SelectionChangedCommand, ElementName=UserControlRoot}"
                                               PassEventArgsToCommand="True"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="Transparent"
                                CornerRadius="6"
                                Padding="16,4"
                                Margin="8,4"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                Value="True">
                                            <Setter Property="Background"
                                                    Value="#F9FAFB"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <StackPanel>
                                <!-- Row: RadioButton + Badge -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- RadioButton với TextBlock -->
                                    <Grid Grid.Column="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Custom Radio Button -->
                                        <Grid Grid.Column="0"
                                                Width="16"
                                                Height="16"
                                              Margin="0,0,8,0"
                                                VerticalAlignment="Top">
                                            <Ellipse Stroke="#FF707070"
                                                     StrokeThickness="1.5"
                                                     Fill="White"/>
                                            <Ellipse Width="8"
                                                    Height="8"
                                                     Fill="#3B82F6">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                                                         Value="True">
                                                                <Setter Property="Visibility"
                                                                        Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                        </Grid>

                                        <!-- Text Content với Path binding -->
                                        <TextBlock Grid.Column="1"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Top">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                    <Binding/>
                                                    <Binding Path="DisplayTextPath"
                                                            Source="{x:Reference UserControlRoot}"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>

                                    <!-- AdditionalInfo Badge với Path binding -->
                                    <Border Grid.Column="1"
                                            Background="#3B82F6"
                                            CornerRadius="12"
                                            Padding="10,4"
                                            Margin="12,0,0,0"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Value="">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                                <Binding/>
                                                                <Binding Path="AdditionalInfoPath"
                                                                        Source="{x:Reference UserControlRoot}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Value="{x:Null}">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                                <Binding/>
                                                                <Binding Path="AdditionalInfoPath"
                                                                        Source="{x:Reference UserControlRoot}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="10"
                                                   Foreground="White"
                                                   FontWeight="Medium">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                    <Binding/>
                                                    <Binding Path="AdditionalInfoPath"
                                                            Source="{x:Reference UserControlRoot}"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Border>
                                </Grid>

                                <!-- Description với Path binding -->
                                <TextBlock FontSize="11"
                                           Foreground="#6B7280"
                                           Margin="24,4,0,8"
                                           TextWrapping="Wrap">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                            <Binding/>
                                            <Binding Path="DescriptionPath"
                                                    Source="{x:Reference UserControlRoot}"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="DescriptionPath"
                                                                    Source="{x:Reference UserControlRoot}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Value="{x:Null}">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="DescriptionPath"
                                                                    Source="{x:Reference UserControlRoot}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer x:Name="ScrollViewer"
                                      Focusable="False"
                                      Background="{TemplateBinding Background}"
                                      Padding="0">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>
            </ListBox>
        </Grid>

    </GroupBox>

</UserControl>