<UserControl x:Class="FlowMy.Controls.LoadingUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
              xmlns:helper="clr-namespace:FlowMy.Helpers"
             xmlns:conv="clr-namespace:FlowMy.Converters"
             mc:Ignorable="d" 
             d:Height="auto" d:Width="auto">

    <UserControl.Resources>
        <DropShadowEffect x:Key="DropShadowEffect" 
                          ShadowDepth="8" 
                          BlurRadius="16" 
                          Opacity="0.2" 
                          Direction="270"/>

        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Modern Color Brushes -->
        <SolidColorBrush x:Key="LoadingCardBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LoadingPrimaryText" Color="#1F2937"/>
        <SolidColorBrush x:Key="LoadingSecondaryText" Color="#6B7280"/>
        <SolidColorBrush x:Key="LoadingAccent" Color="#3B82F6"/>
        <SolidColorBrush x:Key="LoadingAccentLight" Color="#93C5FD"/>
        <SolidColorBrush x:Key="ProgressBackground" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="CardBorder" Color="#E5E7EB"/>
    </UserControl.Resources>

    <!-- Main Border với nền mờ và góc bo tròn -->
    <Border x:Name="LoadingOverlay"
            Background="{DynamicResource OverlayBackgroundReverse}"
            Visibility="{Binding IsVisible, RelativeSource={RelativeSource AncestorType=UserControl}, 
                        Converter={StaticResource BoolToVisibilityConverter}}"
            Panel.ZIndex="9999"
            IsHitTestVisible="True"
            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}"
            BorderBrush="#40FFFFFF"
            BorderThickness="1">

        <!-- Container Grid cho tất cả content -->
        <Grid>
            <!-- Background Blur Effect (Optional - tạo hiệu ứng blur) -->
            <Rectangle Fill="Black" 
                   Opacity="0.3">
                <Rectangle.Effect>
                    <BlurEffect Radius="8"/>
                </Rectangle.Effect>
            </Rectangle>

            <!-- Loading Card với Border Radius và màu sắc cải thiện -->
            <Border Background="{StaticResource LoadingCardBackground}"
                BorderBrush="{StaticResource CardBorder}" 
                BorderThickness="1"
                CornerRadius="24"
                Padding="20,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="250"
                MaxWidth="350">

                <!-- Drop Shadow cho card -->
                <!--<Border.Effect>
                    <DropShadowEffect ShadowDepth="12" 
                                  BlurRadius="24" 
                                  Opacity="0.15" 
                                  Direction="270"
                                  Color="#1F2937"/>
                </Border.Effect>-->

                <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <!-- Loading Animation Ring -->
                    <Grid Width="60"
    Height="60"
    Margin="0,0,0,20">
                        <!-- Outer ring với gradient -->
                        <Ellipse Width="55"
        Height="55"
         StrokeThickness="4"
         StrokeDashArray="8,4"
         RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Stroke>
                                <LinearGradientBrush>
                                    <GradientStop Color="#2196F3"
                    Offset="0"/>
                                    <GradientStop Color="#64B5F6"
                    Offset="0.5"/>
                                    <GradientStop Color="#90CAF9"
                    Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                     From="0"
                            To="360"
                            Duration="0:0:2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Middle ring -->
                        <Ellipse Width="35"
        Height="35"
         StrokeThickness="3"
         StrokeDashArray="6,3"
         RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Stroke>
                                <LinearGradientBrush>
                                    <GradientStop Color="#64B5F6"
                    Offset="0"/>
                                    <GradientStop Color="#90CAF9"
                    Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Stroke>
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                     From="360"
                            To="0"
                            Duration="0:0:1.5"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Inner ring -->
                        <Ellipse Width="20"
        Height="20"
         StrokeThickness="2"
         StrokeDashArray="4,2"
         Stroke="#90CAF9"
         RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                     From="0"
                            To="360"
                            Duration="0:0:1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Center pulse dot -->
                        <Ellipse Width="8"
        Height="8"
         Fill="#2196F3"
         RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                     From="1"
                            To="1.5"
                            Duration="0:0:0.75"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                     From="1.5"
                            To="1"
                            Duration="0:0:0.75"
                            BeginTime="0:0:0.75"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                     From="1"
                            To="1.5"
                            Duration="0:0:0.75"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                     From="1.5"
                            To="1"
                            Duration="0:0:0.75"
                            BeginTime="0:0:0.75"/>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="1"
                            To="0.5"
                            Duration="0:0:0.75"/>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0.5"
                            To="1"
                            Duration="0:0:0.75"
                            BeginTime="0:0:0.75"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>

                    <!-- Loading Text với Typing Animation - Bindable -->
                    <TextBlock FontSize="{Binding MessageFontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource LoadingPrimaryText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0}{1}">
                                <Binding Path="LoadingText" 
                                         RelativeSource="{RelativeSource AncestorType=UserControl}"
                                         FallbackValue="Đang tải dữ liệu"/>
                                <Binding Source="{x:Static helper:LoadingDotHelper.Instance}"
                                         Path="Dots"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>

                    <!-- Sub Text - Bindable -->
                    <TextBlock Text="{Binding SubText, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue='Vui lòng chờ trong giây lát...'}"
                           FontSize="12"
                           FontWeight="Normal"
                           Foreground="{StaticResource LoadingSecondaryText}"
                           HorizontalAlignment="Center"/>

                    <!-- Modern Loading Dots Animation -->
                    <Grid Width="120" Height="20" Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Dot 1 -->
                        <Ellipse Grid.Column="0" 
                                 Width="8" Height="8" 
                                 Fill="{StaticResource LoadingAccent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Dot 2 -->
                        <Ellipse Grid.Column="1" 
                                 Width="8" Height="8" 
                                 Fill="{StaticResource LoadingAccent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Dot 3 -->
                        <Ellipse Grid.Column="2" 
                                 Width="8" Height="8" 
                                 Fill="{StaticResource LoadingAccent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Dot 4 -->
                        <Ellipse Grid.Column="3" 
                                 Width="8" Height="8" 
                                 Fill="{StaticResource LoadingAccent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.6">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>

                        <!-- Dot 5 -->
                        <Ellipse Grid.Column="4" 
                                 Width="8" Height="8" 
                                 Fill="{StaticResource LoadingAccent}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <ScaleTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.8">
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1.3"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity"
                                                                          Duration="0:0:1.2">
                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="0.7"/>
                                                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.7"/>
                                            </DoubleAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                    </Grid>
                    
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>