<UserControl x:Class="FlowMy.Controls.CheckBoxListViewUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:local="clr-namespace:FlowMy.Controls"
             mc:Ignorable="d"
             xmlns:conv="clr-namespace:FlowMy.Converters"
             x:Name="UserControlRoot">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Sửa lại CompactListBoxStyle -->
        <Style x:Key="CompactListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="ScrollViewer"
                                  Focusable="False"
                                  CanContentScroll="{TemplateBinding ScrollViewer.CanContentScroll}"
                                  HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                  VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Improved Item Style with proper selection handling -->
        <Style x:Key="CompactListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder" 
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PopupHoverBrush}"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                            </Trigger>
                            <!-- Selected -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho Border item với hover và selected effects -->
        <Style x:Key="SelectableItemBorderStyle"
                TargetType="Border">
            <Setter Property="Background"
                    Value="Transparent"/>
            <Setter Property="BorderBrush"
                    Value="Transparent"/>
            <Setter Property="BorderThickness"
                    Value="2"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Style.Triggers>
                <!-- Hover effect -->
                <Trigger Property="IsMouseOver"
                        Value="True">
                    <Setter Property="Background"
                            Value="Transparent"/>
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource BorderColor}"/>
                </Trigger>

                <!-- Selected state -->
                <DataTrigger Binding="{Binding IsSelected}"
                        Value="True">
                    <Setter Property="Background"
                            Value="Transparent"/>
                    <Setter Property="BorderBrush"
                            Value="{DynamicResource BorderColor}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Enhanced CheckBox style -->
        <Style x:Key="ModernCheckBoxStyle"
                TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="CheckBoxBorder"
                                Width="20"
                                Height="20"
                                Background="Transparent"
                                BorderBrush="#D1D5DB"
                                BorderThickness="2"
                                CornerRadius="4">
                            <Path x:Name="CheckMark"
                                  Width="12"
                                  Height="12"
                                  Stretch="Uniform"
                                  Data="M 0 4 L 3 7 L 9 1"
                                  Stroke="White"
                                  StrokeThickness="1.5"
                                  Visibility="Collapsed"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <ScaleTransform x:Name="CheckMarkScale"
                                            ScaleX="0"
                                            ScaleY="0"/>
                                </Path.RenderTransform>
                            </Path>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Checked state -->
                            <Trigger Property="IsChecked"
                                    Value="True">
                                <Setter TargetName="CheckBoxBorder"
                                        Property="Background"
                                        Value="#10B981"/>
                                <Setter TargetName="CheckBoxBorder"
                                        Property="BorderBrush"
                                        Value="#10B981"/>
                                <Setter TargetName="CheckMark"
                                        Property="Visibility"
                                        Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                             Storyboard.TargetProperty="ScaleX"
                                                             To="1"
                                                    Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut"
                                                            Amplitude="0.4"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                             Storyboard.TargetProperty="ScaleY"
                                                             To="1"
                                                    Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut"
                                                            Amplitude="0.4"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>

                            <!-- Hover state -->
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="CheckBoxBorder"
                                        Property="BorderBrush"
                                        Value="#6366F1"/>
                                <Setter Property="Cursor"
                                        Value="Hand"/>
                            </Trigger>

                            <!-- Hover when unchecked -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver"
                                            Value="True"/>
                                    <Condition Property="IsChecked"
                                            Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CheckBoxBorder"
                                        Property="Background"
                                        Value="#F9FAFB"/>
                                <Setter TargetName="CheckBoxBorder"
                                        Property="BorderBrush"
                                        Value="#6366F1"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource SurfaceColor}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Enhanced Header với CheckBox "Chọn tất cả" -->
            <Border Grid.Row="0"
                    Background="{DynamicResource CardColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="8,8,0,0"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Enhanced CheckBox "Chọn tất cả" -->
                    <CheckBox x:Name="SelectAllCheckBox"
                              Grid.Column="0"
                              VerticalAlignment="Center"
                              Margin="0,0,12,0"
                              Checked="SelectAllCheckBox_Checked"
                              Unchecked="SelectAllCheckBox_Unchecked">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Background"
                                        Value="Transparent"/>
                                <Setter Property="BorderBrush"
                                        Value="#D1D5DB"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource TextBrush}"/>
                                <Setter Property="FontSize"
                                        Value="13"/>
                                <Setter Property="FontWeight"
                                        Value="Medium"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="CheckBox">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="CheckBoxBorder"
                                                        Grid.Column="0"
                                                        Width="18"
                                                        Height="18"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="1.5"
                                                        CornerRadius="4"
                                                        VerticalAlignment="Center"
                                                        Margin="0,0,8,0">
                                                    <Path x:Name="CheckMark"
                                                          Width="12"
                                                          Height="12"
                                                          Stretch="Uniform"
                                                          Data="M 0 4 L 3 7 L 9 1"
                                                          Stroke="white"
                                                          StrokeThickness="1.5"
                                                          Visibility="Collapsed"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <ScaleTransform x:Name="CheckMarkScale"
                                                                    ScaleX="0"
                                                                    ScaleY="0"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>

                                                <ContentPresenter Grid.Column="1"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"/>
                                            </Grid>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked"
                                                        Value="True">
                                                    <Setter TargetName="CheckBoxBorder"
                                                            Property="Background"
                                                            Value="#4F46E5"/>
                                                    <Setter TargetName="CheckBoxBorder"
                                                            Property="BorderBrush"
                                                            Value="#4F46E5"/>
                                                    <Setter TargetName="CheckMark"
                                                            Property="Visibility"
                                                            Value="Visible"/>
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                                                 Storyboard.TargetProperty="ScaleX"
                                                                                 To="1"
                                                                        Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <BackEase EasingMode="EaseOut"
                                                                                Amplitude="0.3"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                                <DoubleAnimation Storyboard.TargetName="CheckMarkScale"
                                                                                 Storyboard.TargetProperty="ScaleY"
                                                                                 To="1"
                                                                        Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <BackEase EasingMode="EaseOut"
                                                                                Amplitude="0.3"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                </Trigger>
                                                <Trigger Property="IsChecked"
                                                        Value="{x:Null}">
                                                    <Setter TargetName="CheckBoxBorder"
                                                            Property="Background"
                                                            Value="#F59E0B"/>
                                                    <Setter TargetName="CheckBoxBorder"
                                                            Property="BorderBrush"
                                                            Value="#F59E0B"/>
                                                    <Setter TargetName="CheckMark"
                                                            Property="Data"
                                                            Value="M 2 2 L 6 6 M 6 2 L 2 6"/>
                                                    <Setter TargetName="CheckMark"
                                                            Property="Visibility"
                                                            Value="Visible"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver"
                                                        Value="True">
                                                    <Setter TargetName="CheckBoxBorder"
                                                            Property="BorderBrush"
                                                            Value="#4F46E5"/>
                                                    <Setter Property="Cursor"
                                                            Value="Hand"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <!-- Enhanced Title -->
                    <TextBlock Grid.Column="1"
                               Text="{Binding Title, ElementName=UserControlRoot}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2">
                        <ContentPresenter x:Name="AdditionaluttonNewPresenter"
                            Content="{Binding AdditionalButtonNew, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Enhanced Content Area -->
            <ListBox x:Name="MainListBox"
                 Grid.Row="1"
                 Style="{StaticResource CompactListBoxStyle}"
                 ItemContainerStyle="{StaticResource CompactListBoxItemStyle}"
                 ItemsSource="{Binding ItemsSource, ElementName=UserControlRoot}"
                 SelectedItem="{Binding SelectedItem, ElementName=UserControlRoot, Mode=TwoWay}"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.CanContentScroll="True"
                 MaxHeight="{Binding MaxHeight, ElementName=UserControlRoot}"
                 MinHeight="{Binding MinHeight, ElementName=UserControlRoot}">

                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="SelectionChanged">
                        <b:InvokeCommandAction Command="{Binding SelectionChangedCommand, ElementName=UserControlRoot}"
                                               PassEventArgsToCommand="True"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemBorder"
                                Style="{StaticResource SelectableItemBorderStyle}"
                                BorderThickness="0,0,0,0.5"
                                Padding="0">

                            <!-- Enhanced click handling -->
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick"
                                              Command="{Binding DataContext.ToggleItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding}"/>
                            </Border.InputBindings>

                            <!-- Enhanced content layout -->
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Enhanced CheckBox -->
                                <CheckBox x:Name="ItemCheckBox"
                                          Grid.Column="0"
                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,16,0"
                                          Style="{DynamicResource ModernCheckBoxStyle}"
                                          Checked="ItemCheckBox_Changed"
                                          Unchecked="ItemCheckBox_Changed"/>

                                <!-- enhanced content with better typography -->
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center">
                                    <!-- Main Text -->
                                    <TextBlock FontWeight="Medium"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               LineHeight="20"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                <Binding/>
                                                <Binding Path="DisplayTextPath"
                                                        Source="{x:Reference UserControlRoot}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource TextPrimary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}"
                                                            Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource SunsetBrush}"/>
                                                        <Setter Property="FontWeight"
                                                                Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Description -->
                                    <TextBlock FontSize="12"
                                               Margin="0,4,0,0"
                                               TextWrapping="Wrap"
                                               LineHeight="16"
                                               Opacity="0.8">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                <Binding/>
                                                <Binding Path="DescriptionPath"
                                                        Source="{x:Reference UserControlRoot}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground"
                                                        Value="{DynamicResource TextSecondary}"/>
                                                <Setter Property="Visibility"
                                                        Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}"
                                                            Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="#3B82F6"/>
                                                    </DataTrigger>
                                                    <DataTrigger Value="">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                                <Binding/>
                                                                <Binding Path="DescriptionPath"
                                                                        Source="{x:Reference UserControlRoot}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Value="{x:Null}">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                                <Binding/>
                                                                <Binding Path="DescriptionPath"
                                                                        Source="{x:Reference UserControlRoot}"/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="Visibility"
                                                                Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Enhanced Badge -->
                                <Border Grid.Column="2"
                                        Background="#EF4444"
                                        CornerRadius="12"
                                        Padding="10,4"
                                        Margin="16,0,0,0"
                                        VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6"
                                                          ShadowDepth="2"
                                                          Color="#40000000"
                                                          Opacity="0.25"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="AdditionalInfoPath"
                                                                    Source="{x:Reference UserControlRoot}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Value="{x:Null}">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="AdditionalInfoPath"
                                                                    Source="{x:Reference UserControlRoot}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility"
                                                            Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11"
                                               Foreground="White"
                                               FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                <Binding/>
                                                <Binding Path="AdditionalInfoPath"
                                                        Source="{x:Reference UserControlRoot}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>

                                <!-- Enhanced Badge 2-->
                                <Border Grid.Column="3"
         Background="#0052CC"
         CornerRadius="12"
         Padding="10,4"
         Margin="16,0,0,0"
         VerticalAlignment="Center">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="6"
                           ShadowDepth="2"
                           Color="#40000000"
                           Opacity="0.25"/>
                                    </Border.Effect>
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility"
                     Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="AdditionalInfoPath2"
                                     Source="{x:Reference UserControlRoot}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility"
                             Value="Collapsed"/>
                                                </DataTrigger>
                                                <DataTrigger Value="{x:Null}">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                            <Binding/>
                                                            <Binding Path="AdditionalInfoPath2"
                                     Source="{x:Reference UserControlRoot}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="Visibility"
                             Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="11"
                Foreground="White"
                FontWeight="SemiBold">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{x:Static conv:PathValueConverter.Instance}">
                                                <Binding/>
                                                <Binding Path="AdditionalInfoPath2"
                         Source="{x:Reference UserControlRoot}"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </Border>
                                
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</UserControl>