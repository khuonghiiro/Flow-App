<UserControl x:Class="FlowMy.Controls.IconSelectorUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:controls="clr-namespace:FlowMy.Controls"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
xmlns:conv="clr-namespace:FlowMy.Converters"
             xmlns:local="clr-namespace:FlowMy.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="400">

    <UserControl.Resources>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TextBox và Button container -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Border thay thế TextBox -->
            <!-- Border với Style -->
            <Border Grid.Column="0"
        x:Name="IconDisplayBorder"
        Height="{Binding ButtonHeight, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=44}"
        Style="{DynamicResource IconDisplayBorderStyle}"
        ToolTip="Icon đã chọn">

                <Grid>
                    <!-- Khi đã chọn: icon SVG + tên icon (dynamic theo TextBrush) -->
                    <StackPanel x:Name="SelectedIconPanel"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Margin="10,0,32,0"
                                Visibility="Collapsed">
                        <local:SvgViewboxEx x:Name="IconDisplaySvg"
                             Width="18"
                             Height="18"
                             VerticalAlignment="Center"
                             Fill="{DynamicResource TextBrush}"/>
                        <TextBlock x:Name="SelectedIconNameText"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Placeholder khi chưa chọn -->
                    <TextBlock x:Name="PlaceholderText"
                   Text="Chọn icon..."
                   Foreground="{DynamicResource TextBrush}"
                   Opacity="0.55"
                   Margin="10,0,0,0"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"
                   IsHitTestVisible="False"
                   FontSize="14"
                   Visibility="Visible"/>

                    <!-- Clear Button - LUÔN HIỆN KHI CÓ ICON -->
                    <Button x:Name="ClearButton"
    Width="20"
    Height="20"
    HorizontalAlignment="Right"
    VerticalAlignment="Center"
    Margin="0,0,10,0"
    Background="Transparent"
    BorderThickness="0"
    Content="✕"
    FontSize="12"
    Foreground="{DynamicResource TextBrush}"
    Cursor="Hand"
    Visibility="Collapsed"
    Click="ClearButton_Click"
    ToolTip="Xóa icon">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Width="20"
                                                    Height="20">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Button chọn icon -->
            <Button Grid.Column="1"
                    x:Name="SelectButton"
                    Width="{Binding ButtonHeight, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=40}"
                    Height="{Binding ButtonHeight, RelativeSource={RelativeSource AncestorType=UserControl}, FallbackValue=40}"
                    Margin="-1,0,0,0"
                    Background="{DynamicResource PrimaryBrush}"
                    Foreground="{DynamicResource TextOnPrimaryBrush}"
                    BorderThickness="0"
                    Padding="10,5"
                    Cursor="Hand"
                    Click="SelectIcon_Click"
                    ToolTip="Chọn icon">

                <local:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                             Converter={StaticResource IconKeyToPathConverter}, 
                                             ConverterParameter='folder-open duotone-light'}"
                                    Width="18"
                                    Height="18"
                                    Fill="{DynamicResource TextOnPrimaryBrush}"/>

                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="0,6,6,0"
                                            Width="{TemplateBinding Width}"
                                            Height="{TemplateBinding Height}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryHoverBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource PrimaryPressedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <!-- Popup chọn icon -->
        <Popup x:Name="IconPopup"
               PlacementTarget="{Binding ElementName=IconDisplayBorder}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">

            <!-- Hai lớp: shadow (không text) + border nội dung -->
            <Grid Margin="8"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                <Border CornerRadius="12"
                        Background="Transparent"
                        Margin="0,0,2,4"
                        SnapsToDevicePixels="True"
                        UseLayoutRounding="True">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2"
                                          BlurRadius="8"
                                          Opacity="0.12"
                                          Direction="270"
                                          Color="{DynamicResource ShadowColor}"/>
                    </Border.Effect>
                </Border>
                <Border Style="{DynamicResource CardBorderBase}"
                        BorderThickness="1"
                        CornerRadius="12">
                <!-- Nội dung popup -->
                <StackPanel Margin="20">

                    <!-- Header -->
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Chọn Biểu Tượng"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   Style="{DynamicResource TextBlockCenterBase}"/>
                    </Grid>

                    <!-- Divider line -->
                    <Rectangle Height="1"
                               Fill="{DynamicResource ControlBorderBrush}"
                               Margin="0,0,0,15"/>

                    <!-- Search box -->
                    <Grid Margin="0,0,0,15">
                        <TextBox Style="{DynamicResource RoundedSearchTextBoxWithIcon}"
                                 x:Name="SearchIconKeywordBox"
                                 Height="40"
                                 FontSize="14"
                                 Padding="15,0,22,0"
                                 TextChanged="SearchTextBox_TextChanged"/>

                        <TextBlock Text="Tìm kiếm icon..."
                                   Foreground="{DynamicResource TextBrush}"
                                   Opacity="0.55"
                                   Margin="30,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding Text, ElementName=SearchIconKeywordBox, Converter={StaticResource StringNullOrEmptyToVisibilityConverter}}"/>
                    </Grid>

                    <!-- Icons Grid với ScrollViewer -->
                    <ScrollViewer MaxHeight="320"
                                  MaxWidth="380"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent">
                        <UniformGrid x:Name="IconGrid" 
                                     Columns="8"
                                     Margin="0"/>
                    </ScrollViewer>

                    <!-- Pagination Controls -->
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Previous Button -->
                        <Button Grid.Column="0"
                                x:Name="PrevPageButton"
                                Content="◀ Trước"
                                Height="32"
                                Padding="10,5"
                                Click="PrevPage_Click"
                                IsEnabled="False"
                                Style="{DynamicResource PaginationButtonStyle}"
                                Margin="0,0,10,0"/>

                        <!-- Page Info -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock x:Name="PageInfoText"
                                       Text="Trang 1 / 1"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock x:Name="TotalIconsText"
                                       Text="(0 icons)"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.65"
                                       HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Next Button -->
                        <Button Grid.Column="2"
                                x:Name="NextPageButton"
                                Content="Sau ▶"
                                Height="32"
                                Padding="10,5"
                                Click="NextPage_Click"
                                IsEnabled="False"
                                Style="{DynamicResource PaginationButtonStyle}"
                                Margin="10,0,0,0"/>
                    </Grid>

                    <!-- Footer info -->
                    <TextBlock Text="Click vào biểu tượng để chọn"
                               FontSize="12"
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.65"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>

                </StackPanel>
                </Border>
            </Grid>
        </Popup>
    </Grid>
</UserControl>