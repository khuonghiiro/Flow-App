<UserControl x:Class="FlowMy.Controls.TreeComboBoxUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:FlowMy.Converters"
             mc:Ignorable="d"
             d:DesignHeight="45">

    <UserControl.Resources>
        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:LevelToMarginConverter x:Key="LevelToMarginConverter"/>

        <!-- Subtle Shadow for Hover -->
        <DropShadowEffect x:Key="HoverShadowEffect"
                          Color="#3B82F6"
                          Opacity="0.2"
                          BlurRadius="6"
                          ShadowDepth="0"
                          Direction="270"/>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernTreeComboBoxStyle"
                TargetType="ComboBox"
                BasedOn="{StaticResource BaseComboBox}">
            <Setter Property="FontSize"
                    Value="14"/>
            <Setter Property="Height"
                    Value="45"/>
            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="FontFamily"
                    Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Content Area with Grid container -->
                                    <Grid x:Name="ContentArea"
                                            Grid.Column="0">
                                        <ContentPresenter x:Name="ContentSite"
                                                          IsHitTestVisible="False"
                                                          Content="{Binding SelectedDisplayText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          Margin="{TemplateBinding Padding}"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"/>

                                        <!-- Placeholder Text -->
                                        <TextBlock x:Name="PlaceholderText"
                                                   Text="{Binding PlaceholderText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   Foreground="{DynamicResource PlaceholderBrush}"
                                                   FontStyle="Italic"
                                                   Margin="{TemplateBinding Padding}"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"
                                                   Visibility="Collapsed"/>
                                    </Grid>

                                    <!-- Dropdown Button -->
                                    <ToggleButton x:Name="ToggleButton"
                                                  Grid.Column="1"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Cursor="Hand">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border x:Name="ArrowContainer"
                                                        Background="Transparent"
                                                        CornerRadius="8"
                                                        Width="32"
                                                        Height="32">
                                                    <Path x:Name="Arrow"
                                                          Fill="{StaticResource SecondaryBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Data="M 2 6 L 6 10 L 10 6"
                                                          Stroke="{StaticResource SecondaryBrush}"
                                                          StrokeThickness="1.5"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform x:Name="ArrowRotation"
                                                                    Angle="0"/>
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver"
                                                            Value="True">
                                                        <Setter TargetName="ArrowContainer"
                                                                Property="Background"
                                                                Value="Transparent"/>
                                                        <Setter TargetName="Arrow"
                                                                Property="Fill"
                                                                Value="{StaticResource LavenderBrush}"/>
                                                        <Setter TargetName="Arrow"
                                                                Property="Stroke"
                                                                Value="{StaticResource LavenderBrush}"/>
                                                    </Trigger>

                                                    <!-- Move the animation here -->
                                                    <Trigger Property="IsChecked"
                                                            Value="True">
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ArrowRotation"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     To="180"
                                                                                     Duration="0:0:0.3">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetName="ArrowRotation"
                                                                                     Storyboard.TargetProperty="Angle"
                                                                                     To="0"
                                                                                     Duration="0:0:0.3">
                                                                        <DoubleAnimation.EasingFunction>
                                                                            <CubicEase EasingMode="EaseOut"/>
                                                                        </DoubleAnimation.EasingFunction>
                                                                    </DoubleAnimation>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <!-- Dropdown Popup -->
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   VerticalOffset="4">
                                <Border x:Name="DropDownBorder"
                                        Background="{StaticResource CardBackgroundBrush}"
                                        BorderThickness="2"
                                        BorderBrush="{StaticResource ControlBorderBrush}"
                                        CornerRadius="6"
                                        Effect="{StaticResource DropShadowEffect}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="320">
                                    <ScrollViewer x:Name="DropDownScrollViewer"
                                                  Margin="6"
                                                  CanContentScroll="True"
                                                  HorizontalScrollBarVisibility="Auto"
                                                  VerticalScrollBarVisibility="Auto">

                                        <TreeView x:Name="PART_TreeView"
                                                  ItemsSource="{Binding HierarchicalItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                  ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                            <TreeView.ItemContainerStyle>
                                                <Style TargetType="TreeViewItem">
                                                    <Setter Property="IsExpanded"
                                                            Value="{Binding IsExpanded}"/>
                                                    <Setter Property="IsSelected"
                                                            Value="{Binding IsSelected}"/>
                                                    <Setter Property="Padding"
                                                            Value="0"/>
                                                    <Setter Property="Margin"
                                                            Value="0,2"/>
                                                    <EventSetter Event="MouseLeftButtonUp"
                                                            Handler="TreeViewItem_MouseLeftButtonUp"/>
                                                    <EventSetter Event="KeyDown"
                                                            Handler="TreeViewItem_KeyDown"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="TreeViewItem">
                                                                <StackPanel>
                                                                    <!-- Item Header -->
                                                                    <Border x:Name="ItemBorder"
                                                                            Background="Transparent"
                                                                            Padding="12,10"
                                                                            Margin="{Binding Level, Converter={StaticResource LevelToMarginConverter}}"
                                                                            CornerRadius="8"
                                                                            Cursor="Hand">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <!-- Expand/Collapse Button -->
                                                                            <ToggleButton x:Name="Expander"
                                                                                          Grid.Column="0"
                                                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                                          Width="20"
                                                                                    Height="20"
                                                                                          Margin="0,0,10,0"
                                                                                          Background="Transparent"
                                                                                          BorderThickness="0"
                                                                                          VerticalAlignment="Center">
                                                                                <ToggleButton.Template>
                                                                                    <ControlTemplate TargetType="ToggleButton">
                                                                                        <Border Background="Transparent"
                                                                                                CornerRadius="4">
                                                                                            <Path x:Name="ExpanderArrow"
                                                                                                  Fill="{StaticResource TextBrush}"
                                                                                                  Stroke="{StaticResource TextBrush}"
                                                                                                  StrokeThickness="1.2"
                                                                                                  HorizontalAlignment="Center"
                                                                                                  VerticalAlignment="Center"
                                                                                                  Data="M 3 6 L 6 9 L 9 6"
                                                                                                  RenderTransformOrigin="0.5,0.5">
                                                                                                <Path.RenderTransform>
                                                                                                    <RotateTransform x:Name="ExpanderRotation"
                                                                                                            Angle="-90"/>
                                                                                                </Path.RenderTransform>
                                                                                            </Path>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsChecked"
                                                                                                    Value="True">
                                                                                                <Trigger.EnterActions>
                                                                                                    <BeginStoryboard>
                                                                                                        <Storyboard>
                                                                                                            <DoubleAnimation Storyboard.TargetName="ExpanderRotation"
                                                                                                                             Storyboard.TargetProperty="Angle"
                                                                                                                             To="0"
                                                                                                                             Duration="0:0:0.25">
                                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                                                                </DoubleAnimation.EasingFunction>
                                                                                                            </DoubleAnimation>
                                                                                                        </Storyboard>
                                                                                                    </BeginStoryboard>
                                                                                                </Trigger.EnterActions>
                                                                                                <Trigger.ExitActions>
                                                                                                    <BeginStoryboard>
                                                                                                        <Storyboard>
                                                                                                            <DoubleAnimation Storyboard.TargetName="ExpanderRotation"
                                                                                                                             Storyboard.TargetProperty="Angle"
                                                                                                                             To="-90"
                                                                                                                             Duration="0:0:0.25">
                                                                                                                <DoubleAnimation.EasingFunction>
                                                                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                                                                </DoubleAnimation.EasingFunction>
                                                                                                            </DoubleAnimation>
                                                                                                        </Storyboard>
                                                                                                    </BeginStoryboard>
                                                                                                </Trigger.ExitActions>
                                                                                            </Trigger>
                                                                                            <Trigger Property="IsMouseOver"
                                                                                                    Value="True">
                                                                                                <Setter TargetName="ExpanderArrow"
                                                                                                        Property="Fill"
                                                                                                        Value="{StaticResource TextOnIndigoBrush}"/>
                                                                                                <Setter TargetName="ExpanderArrow"
                                                                                                        Property="Stroke"
                                                                                                        Value="{StaticResource TextOnIndigoBrush}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </ToggleButton.Template>
                                                                            </ToggleButton>

                                                                            <!-- Item Content -->
                                                                            <ContentPresenter x:Name="PART_Header"
                                                                                              Grid.Column="1"
                                                                                              ContentSource="Header"
                                                                                              VerticalAlignment="Center"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <!-- Children Container -->
                                                                    <ItemsPresenter x:Name="ItemsHost"
                                                                                    Margin="0,0,0,0"/>
                                                                </StackPanel>

                                                                <ControlTemplate.Triggers>
                                                                    <!-- Hide expander if no children -->
                                                                    <Trigger Property="HasItems"
                                                                            Value="False">
                                                                        <Setter TargetName="Expander"
                                                                                Property="Visibility"
                                                                                Value="Hidden"/>
                                                                    </Trigger>

                                                                    <!-- Hover effect -->
                                                                    <Trigger Property="IsMouseOver"
                                                                            Value="True">
                                                                        <Setter TargetName="ItemBorder"
                                                                                Property="Background"
                                                                                Value="{StaticResource LavenderHoverBrush}"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource TextOnLavenderBrush}"/>
                                                                    </Trigger>

                                                                    <!-- Selection effect -->
                                                                    <Trigger Property="IsSelected"
                                                                            Value="True">
                                                                        <Setter TargetName="ItemBorder"
                                                                                Property="Background"
                                                                                Value="{StaticResource LavenderPressedBrush}"/>
                                                                        <Setter Property="Foreground"
                                                                                Value="{StaticResource TextOnLavenderBrush}"/>
                                                                    </Trigger>

                                                                    <!-- Expanded state animation -->
                                                                    <Trigger Property="IsExpanded"
                                                                            Value="False">
                                                                        <Setter TargetName="ItemsHost"
                                                                                Property="Visibility"
                                                                                Value="Collapsed"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </TreeView.ItemContainerStyle>

                                            <TreeView.ItemTemplate>
                                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <TextBlock Grid.Column="0"
                       Text="{Binding DisplayText}"
                       Foreground="{StaticResource TextBrush}"
                       FontSize="14"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Center"/>

                                                        <TextBlock Grid.Column="1"
                       Text="{Binding PathInfo}"
                       Foreground="{StaticResource SecondaryBrush}"
                       FontSize="12"
                       FontFamily="Segoe UI"
                       FontStyle="Italic"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="200"/>
                                                    </Grid>
                                                </HierarchicalDataTemplate>
                                            </TreeView.ItemTemplate>
                                        </TreeView>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Show placeholder when no selection -->
                            <DataTrigger Binding="{Binding SelectedTreeItem, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Value="{x:Null}">
                                <Setter TargetName="PlaceholderText"
                                        Property="Visibility"
                                        Value="Visible"/>
                                <Setter TargetName="ContentSite"
                                        Property="Visibility"
                                        Value="Collapsed"/>
                            </DataTrigger>

                            <!-- Hover effects -->
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="MainBorder"
                                        Property="Effect"
                                        Value="{StaticResource DropShadowEffect}"/>
                            </Trigger>

                            <!-- Focus effects -->
                            <Trigger Property="IsFocused"
                                    Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                                <Setter TargetName="MainBorder"
                                        Property="BorderThickness"
                                        Value="2"/>
                            </Trigger>

                            <Trigger Property="IsDropDownOpen"
                                    Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="{StaticResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Main ComboBox -->
    <ComboBox x:Name="MainComboBox"
              HorizontalAlignment="Stretch"
              Style="{StaticResource ModernTreeComboBoxStyle}"
              IsEditable="False"/>
</UserControl>