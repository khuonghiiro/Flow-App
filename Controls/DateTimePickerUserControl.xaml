<UserControl x:Class="FlowMy.Controls.DateTimePickerUserControl"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:FlowMy.Converters"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             mc:Ignorable="d">

    <UserControl.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <conv:NullToBooleanConverter x:Key="NullToBoolConverter"/>

        <!-- Shadow Effects -->
        <DropShadowEffect x:Key="PopupShadowEffect"
                          BlurRadius="10" 
                          ShadowDepth="2" 
                          Opacity="0.3"/>

        <Style x:Key="TimePickerButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                        CornerRadius="6" Margin="6,0" Padding="5">
                            <TextBlock x:Name="textBlock"
                              Text="{TemplateBinding Content}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              FontSize="16" Foreground="Black"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LavenderHoverBrush}"/>
                                <Setter TargetName="textBlock" Property="Foreground" Value="{DynamicResource TextOnLavenderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LavenderPressedBrush}"/>
                                <Setter TargetName="textBlock" Property="Foreground" Value="{DynamicResource TextOnLavenderBrush}"/>
                                <Setter TargetName="textBlock" Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Button Styles -->
        <Style x:Key="TimeButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="black"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LavenderHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource LavenderPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource IndigoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnIndigoBrush}"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="black"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Main Button with modern design -->
        <Button x:Name="MainButton"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            Background="{DynamicResource SurfaceColor}"
            Height="{Binding ControlHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
            Cursor="Hand"
            Click="MainButton_Click"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            IsEnabled="{Binding IsReadOnly, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
            Padding="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ContentPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="border" Property="Background" Value="{DynamicResource TextBoxHoverBackground}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="border" Property="BorderThickness" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="25"/>
                </Grid.ColumnDefinitions>

                <!-- TextBox with modern placeholder -->
                <TextBox x:Name="MainTextBox"
                     Grid.Column="0"
                     IsReadOnly="True"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="10,0 , 5, 0"
                     VerticalContentAlignment="Center"
                     FontSize="14"
                     FontFamily="Segoe UI"
                     Foreground="black"
                     IsHitTestVisible="False">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="Chọn ngày giờ..." 
                                                              Foreground="{DynamicResource PlaceholderBrush}" 
                                                              FontStyle="Normal"
                                                              FontWeight="Normal"
                                                              Padding="12,0"
                                                              VerticalAlignment="Center"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <!-- Modern Clear Button -->
                <Button x:Name="ClearButton"
                    Grid.Column="1"
                    Width="20" Height="20"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="ClearButton_Click"
                    Cursor="Hand"
                    ToolTip="Xóa"
                    Margin="0,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="11">
                                            <Path Data="M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z"
                                                  Fill="#FF475569"
                                                  Stretch="Uniform"
                                                  Width="12" Height="12"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource TransparentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding ShowClearButton, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"/>
                                        <Condition Binding="{Binding SelectedDateTime, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToBoolConverter}}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <!-- Calendar Icon -->
                <Border Grid.Column="2"
                    Width="20" Height="20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Path Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V20C3,21.1 3.89,22 5,22H19C20.1,22 21,21.1 21,20V6C21,4.9 20.1,4 19,4M19,20H5V10H19V20M19,8H5V6H19V8M12,13H17V18H12V13Z"
                      Fill="{DynamicResource SecondaryBrush}"
                      Stretch="Uniform"
                      Width="15" Height="15"/>
                </Border>
            </Grid>
        </Button>

        <!-- Modern Popup with shadow -->
        <Popup x:Name="PickerPopup" 
               PlacementTarget="{Binding ElementName=MainButton}"
               Placement="{Binding PopupPlacement, RelativeSource={RelativeSource AncestorType=UserControl}}"
               StaysOpen="False"
               AllowsTransparency="True"
               VerticalOffset="8">
            <Border Background="White"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Effect="{StaticResource PopupShadowEffect}">
                <Grid x:Name="PopupContent">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- DateTime Mode -->
                    <Grid Grid.Row="0" x:Name="DateTimePanel" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="1"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <!--<RowDefinition Height="auto"/>-->
                        </Grid.RowDefinitions>

                        <!-- Left: Calendar -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Chọn ngày" 
                                       FontWeight="SemiBold" 
                                       FontSize="14"
                                       Foreground="Black"
                                       Margin="0,0,0,12"/>
                            <Calendar x:Name="CalendarControl"
                                      SelectionMode="SingleDate"
                                      
                                      SelectedDatesChanged="Calendar_SelectedDatesChanged"
                                                               BorderThickness="0"
BorderBrush="Transparent"
                                      Style="{StaticResource ModernCalendarStyle}"
                                       CalendarItemStyle="{StaticResource ModernCalendarItemStyle}"
                                      CalendarDayButtonStyle="{StaticResource ModernCalendarDayButtonStyle}" />
                        </StackPanel>

                        <!-- Separator -->
                        <Separator Grid.Row="0"  Grid.Column="1" 
                                   Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                                   Background="#FFC8BEAE"
                                   Margin="0,8"/>

                        <!-- Right: Time Picker -->
                        <StackPanel Grid.Row="0"  Grid.Column="2" VerticalAlignment="Top" Margin="10,0,0,0">
                            <TextBlock Text="Chọn thời gian" 
                                       FontWeight="SemiBold" 
                                       FontSize="14"
                                       Foreground="black"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>

                            <Grid HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Hour Column -->
                                <StackPanel Grid.Column="0" Margin="6">
                                    <TextBlock Text="Giờ" 
                                               HorizontalAlignment="Center" 
                                               Margin="0,0,0,10"
                                               FontWeight="Medium"
                                               FontSize="13"
                                               Foreground="#FF475569"/>
                                    <Border BorderBrush="#FFC8BEAE"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="#FFF8FAFC">
                                        <Grid Width="70" Height="200">
                                            <Border VerticalAlignment="Center"
                                                    Height="40"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Opacity="0.5"
                                                    CornerRadius="6"
                                                    Margin="6,0"/>

                                            <ScrollViewer x:Name="HourScrollViewer"
                                                          Style="{StaticResource HiddenAndDisabledScrollViewer}"
                                                          PreviewMouseWheel="TimeScroll_PreviewMouseWheel"
                                                          Tag="Hour">
                                                <ItemsControl x:Name="HourItemsControl"
                                                              Margin="0,80,0,80">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Button Content="{Binding}"
                                                                Click="TimeButton_Click"
                                                                Tag="Hour"
                                                                Style="{StaticResource TimePickerButtonStyle}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                           Text=":" 
                                           VerticalAlignment="Center" 
                                           FontSize="20" 
                                           FontWeight="Bold" 
                                           Margin="4,28,4,0"
                                           Foreground="#FF475569"/>

                                <!-- Minute Column -->
                                <StackPanel Grid.Column="2" Margin="6">
                                    <TextBlock Text="Phút"  
                                               HorizontalAlignment="Center" 
                                               Margin="0,0,0,8"
                                               FontWeight="Medium"
                                               FontSize="12"
                                               Foreground="#FF475569"/>
                                    <Border BorderBrush="#FFC8BEAE"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="#FFF8FAFC">
                                        <Grid Width="70" Height="200">
                                            <Border VerticalAlignment="Center"
                                                    Height="40"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Opacity="0.5"
                                                    CornerRadius="6"
                                                    Margin="6,0"/>

                                            <ScrollViewer x:Name="MinuteScrollViewer"
                                                          Style="{StaticResource HiddenAndDisabledScrollViewer}"
                                                          PreviewMouseWheel="TimeScroll_PreviewMouseWheel"
                                                          Tag="Minute">
                                                <ItemsControl x:Name="MinuteItemsControl"
                                                              Margin="0,80,0,80">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>

                                                            <Button Content="{Binding}"
                                                                Click="TimeButton_Click"
                                                                Tag="Minute"
                                                                Style="{StaticResource TimePickerButtonStyle}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <TextBlock Grid.Column="3"
                                           Text=":" 
                                           VerticalAlignment="Center" 
                                           FontSize="20" 
                                           FontWeight="Bold" 
                                           Margin="4,28,4,0"
                                           Foreground="#FF475569"/>

                                <!-- Second Column -->
                                <StackPanel Grid.Column="4" Margin="6">
                                    <TextBlock Text="Giây" 
                                               HorizontalAlignment="Center" 
                                               Margin="0,0,0,8"
                                               FontWeight="Medium"
                                               FontSize="12"
                                               Foreground="#FF475569"/>
                                    <Border BorderBrush="#FFC8BEAE"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Background="#FFF8FAFC">
                                        <Grid Width="70" Height="200">
                                            <Border VerticalAlignment="Center"
                                                    Height="40"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Opacity="0.5"
                                                    CornerRadius="6"
                                                    Margin="6,0"/>

                                            <ScrollViewer x:Name="SecondScrollViewer"
                                                          Style="{StaticResource HiddenAndDisabledScrollViewer}"
                                                          PreviewMouseWheel="TimeScroll_PreviewMouseWheel"
                                                          Tag="Second">
                                                <ItemsControl x:Name="SecondItemsControl"
                                                              Margin="0,80,0,80">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>

                                                            <Button Content="{Binding}"
     Click="TimeButton_Click"
     Tag="Second"
     Style="{StaticResource TimePickerButtonStyle}"/>
                                                            
                                                           
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Date Only Mode -->
                    <StackPanel Grid.Row="0" x:Name="DatePanel" Visibility="Collapsed">
                        <TextBlock Text="Chọn ngày" 
                                   FontWeight="SemiBold" 
                                   FontSize="14"
                                   Foreground="black"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>
                        <Calendar x:Name="DateCalendar"
                                  SelectionMode="SingleDate"
                                  SelectedDatesChanged="Calendar_SelectedDatesChanged"
                                  Style="{StaticResource ModernCalendarStyle}"
                                  CalendarDayButtonStyle="{StaticResource ModernCalendarDayButtonStyle}"/>
                    </StackPanel>

                    <!-- Time Only Mode -->
                    <StackPanel Grid.Row="0" x:Name="TimePanel" Visibility="Collapsed">
                        <TextBlock Text="Chọn thời gian" 
                                   FontWeight="SemiBold" 
                                   FontSize="14"
                                   Foreground="black"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,12"/>

                        <Grid HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Similar structure for Time Only mode -->
                            <StackPanel Grid.Column="0" Margin="6">
                                <TextBlock Text="Giờ" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,8"
                                           FontWeight="Medium"
                                           FontSize="12"
                                           Foreground="#FF475569"/>
                                <Border BorderBrush="#FFC8BEAE"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Background="#FFF8FAFC">
                                    <Grid Width="70" Height="200">
                                        <Border VerticalAlignment="Center"
                                                Height="40"
                                                Background="{DynamicResource PrimaryBrush}"
                                                Opacity="0.5"
                                                CornerRadius="6"
                                                Margin="6,0"/>

                                        <ScrollViewer x:Name="TimeHourScrollViewer"
                                                      Style="{StaticResource HiddenAndDisabledScrollViewer}"
                                                      PreviewMouseWheel="TimeScroll_PreviewMouseWheel"
                                                      Tag="Hour">
                                            <ItemsControl x:Name="TimeHourItemsControl"
                                                          Margin="0,80,0,80">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}"
    Click="TimeButton_Click"
    Tag="Hour"
    Style="{StaticResource TimePickerButtonStyle}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text=":" 
                                       VerticalAlignment="Center" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Margin="4,28,4,0"
                                       Foreground="#FF475569"/>

                            <!-- Minute -->
                            <StackPanel Grid.Column="2" Margin="4">
                                <TextBlock Text="Phút" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,8"
                                           FontWeight="Medium"
                                           FontSize="12"
                                           Foreground="#FF475569"/>
                                <Border BorderBrush="#FFC8BEAE"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="Transparent">
                                    <Grid Width="70" Height="200">
                                        <Border VerticalAlignment="Center"
                                                Height="40"
                                                Background="{DynamicResource PrimaryBrush}"
                                                Opacity="0.5"
                                                CornerRadius="4"
                                                Margin="5,0"/>

                                        <ScrollViewer x:Name="TimeMinuteScrollViewer"
                                                      Style="{StaticResource HiddenAndDisabledScrollViewer}"
                                                      PreviewMouseWheel="TimeScroll_PreviewMouseWheel"
                                                      Tag="Minute">
                                            <ItemsControl x:Name="TimeMinuteItemsControl"
                                                          Margin="0,80,0,80">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>

                                                        <Button Content="{Binding}"
                                                                Click="TimeButton_Click"
                                                                Tag="Minute"
                                                                Style="{StaticResource TimePickerButtonStyle}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <TextBlock Grid.Column="3"
                                       Text=":" 
                                       VerticalAlignment="Center" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Margin="4,28,4,0"
                                       Foreground="#FF475569"/>

                            <!-- Second -->
                            <StackPanel Grid.Column="4" Margin="4">
                                <TextBlock Text="Giây" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,0,0,8"
                                           FontWeight="Medium"
                                           FontSize="12"
                                           Foreground="black"/>
                                <Border BorderBrush="#FFC8BEAE"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="Transparent">
                                    <Grid Width="70" Height="200">
                                        <Border VerticalAlignment="Center"
                                                Height="40"
                                                Background="{DynamicResource PrimaryBrush}"
                                                Opacity="0.5"
                                                CornerRadius="4"
                                                Margin="5,0"/>

                                        <ScrollViewer x:Name="TimeSecondScrollViewer"
                                                      Style="{StaticResource HiddenAndDisabledScrollViewer}"
                                                      PreviewMouseWheel="TimeScroll_PreviewMouseWheel"
                                                      Tag="Second">
                                            <ItemsControl x:Name="TimeSecondItemsControl"
                                                          Margin="0,80,0,80">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding}"
Click="TimeButton_Click"
Tag="Second"
Style="{StaticResource TimePickerButtonStyle}"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Modern Action Buttons -->
                    <StackPanel Orientation="Horizontal" Grid.Row="1"
            HorizontalAlignment="Right" 
            Margin="0,12,0,0"
            VerticalAlignment="Bottom">
                        <Button x:Name="TodayButton"
            Content="Hôm nay" 
            Width="80" 
                                Height="35"
            Margin="0,0,8,0" 
            Click="Today_Click"
            Style="{StaticResource SecondaryButton}"
            Visibility="{Binding ShowTodayButton, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVisConverter}}"/>
                        <Button Content="Hủy" 
            Width="80" 
            Margin="0,0,8,0" 
            Click="Cancel_Click"
                                Height="35"
            Style="{StaticResource DangerButton}"/>
                        <Button Content="Chọn" 
            Width="80" 
            Click="OK_Click"
                                Height="35"
            Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>