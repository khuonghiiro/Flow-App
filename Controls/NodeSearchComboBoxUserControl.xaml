<UserControl x:Class="FlowMy.Controls.NodeSearchComboBoxUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:FlowMy.Converters"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             x:Name="Root">
    <UserControl.Resources>
        <conv:IconKeyToPathConverter x:Key="IconPathConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Border BorderBrush="{DynamicResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource HeaderBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="8,5,6,5">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasSelection, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Width="18"
                                Height="18"
                                CornerRadius="4"
                                Background="{Binding SelectedNodeBrush, ElementName=Root, FallbackValue={StaticResource SecondaryBrush}}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"
                                Margin="0,0,6,0">
                            <controls:SvgViewboxEx Width="12"
                                                   Height="12"
                                                   Fill="{Binding SelectedNodeTextBrush, ElementName=Root, FallbackValue={StaticResource TextOnPrimaryBrush}}"
                                                   Source="{Binding SelectedIconKey, ElementName=Root, Converter={StaticResource IconPathConverter}}" />
                        </Border>
                        <TextBlock Text="{Binding SelectedDisplayText, ElementName=Root}"
                                   Foreground="{DynamicResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <TextBlock Text="{Binding PlaceholderText, ElementName=Root}"
                               Foreground="{DynamicResource TextSecondary}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelection, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <ToggleButton x:Name="DropDownButton"
                              Grid.Column="1"
                              Background="Transparent"
                              BorderThickness="0"
                              Cursor="Hand"
                              IsChecked="{Binding IsDropDownOpen, ElementName=Root, Mode=TwoWay}">
                    <TextBlock Text="▾"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </ToggleButton>
            </Grid>
        </Border>

        <Popup PlacementTarget="{Binding ElementName=Root}"
               Placement="Bottom"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="False"
               IsOpen="{Binding IsDropDownOpen, ElementName=Root, Mode=TwoWay}">
            <Border Margin="0,4,0,0"
                    MinWidth="{Binding ActualWidth, ElementName=Root}"
                    MaxHeight="320"
                    CornerRadius="8"
                    Background="{DynamicResource WindowBodyBackground}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Height="30"
                             Margin="0,0,0,8"
                             Style="{DynamicResource BaseTextBoxV2}"
                             Text="{Binding SearchText, ElementName=Root, UpdateSourceTrigger=PropertyChanged}" />

                    <ListBox x:Name="ItemsListBox"
                             Grid.Row="1"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemsSource="{Binding FilteredItems, ElementName=Root}"
                             SelectionChanged="ItemsListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="6"
                                        Margin="0,0,0,4"
                                        CornerRadius="6"
                                        Background="Transparent">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="26"
                                                Height="26"
                                                CornerRadius="6"
                                                Background="{Binding NodeBrush, FallbackValue={StaticResource SecondaryBrush}}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                VerticalAlignment="Center"
                                                Margin="0,0,8,0">
                                            <controls:SvgViewboxEx Width="14"
                                                                   Height="14"
                                                                   Fill="{Binding NodeTextBrush, FallbackValue={StaticResource TextOnPrimaryBrush}}"
                                                                   Source="{Binding IconKey, Converter={StaticResource IconPathConverter}}" />
                                        </Border>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
