<Window x:Class="FlowMy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowMy.Views"
        xmlns:vm="clr-namespace:FlowMy.ViewModels"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        mc:Ignorable="d"
        Title="FlowMy"
        Height="720"
        Width="1080"
        MinHeight="520"
        MinWidth="860"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:InverseStringNullOrEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>

        <!-- Subtle drop shadow for cards -->
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="14" ShadowDepth="2" Direction="270" Opacity="0.18"/>
        <DropShadowEffect x:Key="HeroShadow" Color="#000000" BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.22"/>

        <!-- Pill / chip button style for workflow-level actions -->
        <Style x:Key="PillPrimary" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="{DynamicResource PrimaryBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillOutline" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (32x32 circle) -->
        <Style x:Key="IconCircleButton" TargetType="Button">
            <Setter Property="Foreground"                Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="Transparent"
                                BorderBrush="{DynamicResource CanvasGridBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconCircleButtonPrimary" TargetType="Button" BasedOn="{StaticResource IconCircleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="{DynamicResource PrimaryBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconCircleButtonSuccess" TargetType="Button" BasedOn="{StaticResource IconCircleButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextOnSuccessBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="{DynamicResource SuccessBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SuccessPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- Hero header -->
            <RowDefinition Height="Auto"/>    <!-- Section title -->
            <RowDefinition Height="*"/>       <!-- Widget grid -->
        </Grid.RowDefinitions>

        <!-- ═══ HERO HEADER ═══ -->
        <Border Grid.Row="0"
                Padding="32,24,32,28"
                Effect="{StaticResource HeroShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#EC4899" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: title + stats -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="12"
                                Background="#33FFFFFF"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                            <controls:SvgViewboxEx Width="24" Height="24"
                                                   Fill="White"
                                                   Source="{Binding Source={x:Static sys:String.Empty},
                                                            Converter={StaticResource IconKeyToPathConverter},
                                                            ConverterParameter='chart-diagram duotone-light'}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="FlowMy Launcher"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Mở workflow editor hoặc kích hoạt floating widget đã cấu hình."
                                       Foreground="White"
                                       Opacity="0.82"
                                       FontSize="13"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="Mẹo: nút ⚙ bên phải mở lại cấu hình widget gần nhất."
                                       Foreground="White"
                                       Opacity="0.72"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Stat pills -->
                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Border Background="#33FFFFFF" CornerRadius="20" Padding="14,6" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📌" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="{Binding WidgetEnabledCount, Mode=OneWay}"/>
                                    <Run Text=" widget"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#33FFFFFF" CornerRadius="20" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="{Binding WorkflowCount, Mode=OneWay}"/>
                                    <Run Text=" workflow"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Right: primary actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ConfigureLastWidgetCommand}"
                            Width="40" Height="40"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            ToolTip="Mở lại cấu hình widget gần nhất bạn vừa chỉnh"
                            IsEnabled="{Binding HasLastConfiguredWidget}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="#33FFFFFF">
                                    <Grid>
                                        <TextBlock Text="⚙"
                                                   FontSize="16"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsConfigureLastWidgetLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="⏳"
                                                   FontSize="14"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsConfigureLastWidgetLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#55FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding RefreshWidgetShortcutsCommand}"
                            Width="40" Height="40"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            ToolTip="Quét lại danh sách widget">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="#33FFFFFF">
                                    <TextBlock Text="↻"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#55FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding OpenWorkflowEditorCommand}"
                            Cursor="Hand"
                            Padding="18,9"
                            MinWidth="200">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="White"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="🛠"
                                                   FontSize="14"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Mở Workflow Editor"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#7C3AED"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SECTION TITLE ═══ -->
        <Grid Grid.Row="1" Margin="32,24,32,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📌"
                           FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Floating Widgets đã cấu hình"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Grid.Column="1"
                       Text="⚙ cấu hình nhanh, 🛠 mở editor, 📌 chỉ bật widget (ngầm)"
                       Foreground="{DynamicResource TextBrush}"
                       Opacity="0.55"
                       FontSize="12"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"/>
        </Grid>

        <!-- ═══ WIDGET LIST ═══ -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <!-- Empty state -->
            <Border Visibility="{Binding HasWidgetShortcuts, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    MaxWidth="560"
                    Margin="0,30,0,0"
                    Padding="28,24"
                    CornerRadius="14"
                    Background="{DynamicResource CardColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🪄"
                               FontSize="40"
                               TextAlignment="Center"
                                Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Chưa có widget nào được cấu hình"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Mở Workflow Editor, vào Cấu hình Floating Widget và bật &quot;Bật chế độ Floating Widget&quot; để widget xuất hiện ở đây."
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.6"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,0"
                          Visibility="{Binding HasWidgetShortcuts, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding WidgetGroups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkflowWidgetGroupItem}">
                            <!-- Card = 1 workflow -->
                            <Border Margin="0,0,16,16"
                                    Padding="18,16"
                                    CornerRadius="14"
                                    MinWidth="340"
                                    MaxWidth="400"
                                    Background="{DynamicResource CardColor}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1">
                                <StackPanel>
                                    <!-- Workflow header -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="40" Height="40"
                                                CornerRadius="10"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#8B5CF6" Offset="0"/>
                                                    <GradientStop Color="#6366F1" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <TextBlock Text="📂"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding WorkflowName}"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="15"
                                                       FontWeight="Bold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Foreground="{DynamicResource TextBrush}"
                                                       Opacity="0.55"
                                                       FontSize="11"
                                                       Margin="0,1,0,0">
                                                <Run Text="Workflow · "/>
                                                <Run Text="{Binding WidgetCount, Mode=OneWay}"/>
                                                <Run Text=" widget"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Divider -->
                                    <Border Height="1"
                                            Margin="0,14,0,14"
                                            Background="{DynamicResource BorderColor}"
                                            Opacity="0.4"/>

                                    <!-- Actions trên workflow -->
                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding DataContext.OpenWorkflowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{DynamicResource PillPrimary}"
                                                Margin="0,0,8,0"
                                                ToolTip="Mở Workflow Editor (hiển thị canvas + tự bật các widget)">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="🛠" Margin="0,0,6,0" FontSize="13"/>
                                                <TextBlock Text="Mở Editor"/>
                                            </StackPanel>
                                        </Button>

                                        <Button Command="{Binding DataContext.LaunchAllWidgetsHeadlessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource PillOutline}"
                                                ToolTip="Chỉ mở tất cả widget của workflow này (chạy ngầm)">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="📌" Margin="0,0,6,0" FontSize="13"/>
                                                <TextBlock Text="Mở tất cả widget"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <!-- Widget list trong workflow -->
                                    <ItemsControl ItemsSource="{Binding Widgets}" Margin="0,14,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:WidgetShortcutItem}">
                                                <Border Margin="0,0,0,8"
                                                        Padding="12,10"
                                                        CornerRadius="10"
                                                        Background="{DynamicResource WindowBackgroundBrush}"
                                                        BorderBrush="{DynamicResource BorderColor}"
                                                        BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon -->
                                                        <Border Grid.Column="0"
                                                                Width="38" Height="38"
                                                                CornerRadius="12"
                                                                VerticalAlignment="Center"
                                                                Margin="0,0,12,0">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#7C3AED" Offset="0"/>
                                                                    <GradientStop Color="#EC4899" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <controls:SvgViewboxEx Width="18" Height="18"
                                                                                    Fill="{DynamicResource TextBrush}"
                                                                                   Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}"/>
                                                        </Border>

                                                        <!-- Texts -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding WidgetName, FallbackValue=Widget}"
                                                                       Foreground="{DynamicResource TextBrush}"
                                                                       FontWeight="SemiBold"
                                                                       FontSize="13"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding NodeTitle}"
                                                                       Foreground="{DynamicResource TextBrush}"
                                                                       Opacity="0.55"
                                                                       FontSize="11"
                                                                       Margin="0,2,0,0"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Visibility="{Binding NodeTitle, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                                        </StackPanel>

                                                        <!-- Per-widget actions -->
                                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Button Command="{Binding DataContext.ConfigureWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,0,6,0"
                                                                    ToolTip="Mở nhanh màn cấu hình widget này"
                                                                    IsEnabled="True">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource IconCircleButton}">
                                                                        <Setter Property="IsEnabled" Value="True"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsConfiguring}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Grid>
                                                                    <TextBlock Text="⚙"
                                                                               FontSize="13"
                                                                               Visibility="{Binding IsConfiguring, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                    <TextBlock Text="⏳"
                                                                               FontSize="12"
                                                                               Visibility="{Binding IsConfiguring, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                </Grid>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.LaunchWidgetHeadlessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,0,6,0"
                                                                    ToolTip="Chỉ mở widget này (ngầm)"
                                                                    IsEnabled="True">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource IconCircleButton}">
                                                                        <Setter Property="IsEnabled" Value="True"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsLaunchingHeadless}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsWidgetOpen}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="False"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <Grid>
                                                                    <TextBlock Text="📌"
                                                                               FontSize="14"
                                                                               Visibility="{Binding IsLaunchingHeadless, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                    <TextBlock Text="⏳"
                                                                               FontSize="12"
                                                                               Visibility="{Binding IsLaunchingHeadless, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                </Grid>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.ReopenHeadlessWorkflowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Margin="0,0,6,0"
                                                                    ToolTip="Mở lại workflow đang chạy ngầm để debug">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource IconCircleButtonSuccess}">
                                                                        <Setter Property="IsEnabled" Value="False"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsWidgetOpen}" Value="True">
                                                                                <Setter Property="IsEnabled" Value="True"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                                <TextBlock Text="🪟"
                                                                           FontSize="13"/>
                                                            </Button>
                                                            <Button Command="{Binding DataContext.LaunchWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"
                                                                    Style="{DynamicResource IconCircleButtonPrimary}"
                                                                    ToolTip="Mở Editor + bật widget này">
                                                                <TextBlock Text="🛠"
                                                                           FontSize="13"
                                                                           Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
