<Window x:Class="FlowMy.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowMy.Views"
        xmlns:vm="clr-namespace:FlowMy.ViewModels"
        xmlns:controls="clr-namespace:FlowMy.Controls"
       xmlns:helper="clr-namespace:FlowMy.Helpers"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        mc:Ignorable="d"
        Title="FlowMy"
        Height="720"
        Width="900"
        MinHeight="520"
        MinWidth="500"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
        <conv:StringStartsWithConverter x:Key="StringStartsWithConverter"/>
        <conv:InverseStringNullOrEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>

        <!-- Subtle drop shadow for cards -->
        <DropShadowEffect x:Key="CardShadow" Color="#000000" BlurRadius="14" ShadowDepth="2" Direction="270" Opacity="0.18"/>
        <DropShadowEffect x:Key="HeroShadow" Color="#000000" BlurRadius="24" ShadowDepth="4" Direction="270" Opacity="0.22"/>

        <!-- Pill / chip button style for workflow-level actions -->
        <Style x:Key="PillPrimary" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="{DynamicResource PrimaryBrush}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillOutline" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="Transparent"
                                BorderBrush="{DynamicResource PrimaryBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button (32x32 circle) -->
        <Style x:Key="IconCircleButton" TargetType="Button">
            <Setter Property="Foreground"                Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="Transparent"
                                BorderBrush="{DynamicResource CanvasGridBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconCircleButtonPrimary" TargetType="Button" BasedOn="{StaticResource IconCircleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="{DynamicResource PrimaryBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconCircleButtonSuccess" TargetType="Button" BasedOn="{StaticResource IconCircleButton}">
            <Setter Property="Foreground" Value="{DynamicResource TextOnSuccessBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="16"
                                Background="{DynamicResource SuccessBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SuccessHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource SuccessPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>    <!-- Hero header -->
            <RowDefinition Height="Auto"/>    <!-- Section title -->
            <RowDefinition Height="*"/>       <!-- Widget grid -->
        </Grid.RowDefinitions>

        <!-- ═══ HERO HEADER ═══ -->
        <Border Grid.Row="0"
                Padding="32,24,32,28"
                Effect="{StaticResource HeroShadow}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="0.5"/>
                    <GradientStop Color="#EC4899" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: title + stats -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44" Height="44" CornerRadius="12"
                                Background="#33FFFFFF"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                            <controls:SvgViewboxEx Width="24" Height="24"
                                                   Fill="White"
                                                   Source="{Binding Source={x:Static sys:String.Empty},
                                                            Converter={StaticResource IconKeyToPathConverter},
                                                            ConverterParameter='chart-diagram duotone-light'}"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="FlowMy Launcher"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Mở workflow editor hoặc kích hoạt floating widget đã cấu hình."
                                       Foreground="White"
                                       Opacity="0.82"
                                       FontSize="13"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="Mẹo: nút ⚙ bên phải mở lại cấu hình widget gần nhất."
                                       Foreground="White"
                                       Opacity="0.72"
                                       FontSize="11"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Stat pills -->
                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                        <Border Background="#33FFFFFF" CornerRadius="20" Padding="14,6" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📌" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="{Binding WidgetEnabledCount, Mode=OneWay}"/>
                                    <Run Text=" widget"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                        <Border Background="#33FFFFFF" CornerRadius="20" Padding="14,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center">
                                    <Run Text="{Binding WorkflowCount, Mode=OneWay}"/>
                                    <Run Text=" workflow"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Right: primary actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Command="{Binding ConfigureLastWidgetCommand}"
                            Width="40" Height="40"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            ToolTip="Mở lại cấu hình widget gần nhất bạn vừa chỉnh"
                            IsEnabled="{Binding HasLastConfiguredWidget}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="#33FFFFFF">
                                    <Grid>
                                        <TextBlock Text="⚙"
                                                   FontSize="16"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsConfigureLastWidgetLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                        <TextBlock Text="⏳"
                                                   FontSize="14"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsConfigureLastWidgetLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#55FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding RefreshWidgetShortcutsCommand}"
                            Width="40" Height="40"
                            Cursor="Hand"
                            Margin="0,0,10,0"
                            ToolTip="Quét lại danh sách widget">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="#33FFFFFF">
                                    <TextBlock Text="↻"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#55FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- 🧱 Node Generator Button (Debug only) -->
                    <Button x:Name="OpenNodeGeneratorButton"
                            Cursor="Hand"
                            Padding="18,9"
                            MinWidth="160"
                            Margin="0,0,10,0"
                            Visibility="Collapsed"
                            Click="OpenNodeGeneratorButton_Click"
                            ToolTip="[DEBUG] Mở công cụ tạo base node files tự động">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="#22FFFFFF"
                                        BorderBrush="#55FFFFFF"
                                        BorderThickness="1"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="🧱"
                                                   FontSize="14"
                                                   Margin="0,0,8,0"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Tạo Base Node"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#44FFFFFF"/>
                                        <Setter TargetName="bd" Property="BorderBrush" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Command="{Binding OpenWorkflowEditorCommand}"
                            Cursor="Hand"
                            Padding="18,9"
                            MinWidth="200">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        CornerRadius="20"
                                        Background="White"
                                        Padding="{TemplateBinding Padding}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="🛠"
                                                   FontSize="14"
                                                   Margin="0,0,8,0"
                                                   Foreground="Black"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Mở Workflow Editor"
                                                   FontWeight="SemiBold"
                                                   FontSize="13"
                                                   Foreground="#7C3AED"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SECTION TITLE ═══ -->
        <Grid Grid.Row="1" Margin="32,24,32,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📌"
                           FontSize="18"
                            Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,10,0"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Floating Widgets đã cấu hình"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="⚙ cấu hình nhanh, 🛠 mở editor, 📌 chỉ bật widget (ngầm)"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.55"
                           FontSize="12"
                           VerticalAlignment="Center"/>
                <ComboBox x:Name="ThemeSelector"
                          Width="140"
                          Height="32"
                          Style="{DynamicResource BaseComboBox}"
                          Margin="12,0,0,0"
                          VerticalAlignment="Center"
                          SelectionChanged="ThemeSelector_SelectionChanged">
                    <ComboBoxItem Tag="Light">☀️ Light</ComboBoxItem>
                    <ComboBoxItem Tag="Dark">🌙 Dark</ComboBoxItem>
                    <ComboBoxItem Tag="SoftLight">🌿 Soft Light</ComboBoxItem>
                    <ComboBoxItem Tag="SoftDark">🌑 Soft Dark</ComboBoxItem>
                    <ComboBoxItem Tag="Dracula">🧛 Dracula</ComboBoxItem>
                    <ComboBoxItem Tag="Monokai">🎨 Monokai</ComboBoxItem>
                    <ComboBoxItem Tag="Night">🌌 Night</ComboBoxItem>
                    <ComboBoxItem Tag="Modern">✨ Modern</ComboBoxItem>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- ═══ WIDGET LIST ═══ -->
        <Grid Grid.Row="2" Margin="20,0,20,20">
            <!-- Empty state -->
            <Border Visibility="{Binding HasWidgetShortcuts, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Center"
                    MaxWidth="560"
                    Margin="0,30,0,0"
                    Padding="28,24"
                    CornerRadius="14"
                    Background="{DynamicResource CardColor}"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="🪄"
                               FontSize="40"
                               TextAlignment="Center"
                                Foreground="{DynamicResource TextBrush}"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Chưa có widget nào được cấu hình"
                               FontSize="15"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="Mở Workflow Editor, vào Cấu hình Floating Widget và bật &quot;Bật chế độ Floating Widget&quot; để widget xuất hiện ở đây."
                               Foreground="{DynamicResource TextBrush}"
                               Opacity="0.6"
                               FontSize="12"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="12,0"
                          Visibility="{Binding HasWidgetShortcuts, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding WidgetGroups}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:WorkflowWidgetGroupItem}">
                            <!-- Card = 1 workflow, fixed width grid -->
                            <Border Margin="0,0,16,16"
                                    Padding="18,16"
                                    CornerRadius="14"
                                    Width="360"
                                    VerticalAlignment="Top"
                                    Background="{DynamicResource CardColor}"
                                    BorderThickness="1.5">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                <Setter Property="BorderBrush" Value="#7C3AED"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <!-- Grid bọc ngoài để overlay badge ★ -->
                                <Grid>
                                    <StackPanel>
                                        <!-- Workflow header -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Width="40" Height="40"
                                                    CornerRadius="10"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,12,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#8B5CF6" Offset="0"/>
                                                        <GradientStop Color="#6366F1" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="&#x1F4C2;"
                                                           Foreground="White"
                                                           FontSize="20"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding WorkflowName}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Foreground="{DynamicResource TextBrush}"
                                                           Opacity="0.55"
                                                           FontSize="11"
                                                           Margin="0,1,0,0">
                                                    <Run Text="Workflow &#xB7; "/>
                                                    <Run Text="{Binding WidgetCount, Mode=OneWay}"/>
                                                    <Run Text=" widget"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Divider -->
                                        <Border Height="1"
                                                Margin="0,14,0,14"
                                                Background="{DynamicResource BorderColor}"
                                                Opacity="0.4"/>

                                        <!-- Actions trên workflow -->
                                        <StackPanel Orientation="Horizontal">
                                            <Button Command="{Binding DataContext.OpenWorkflowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    helper:ButtonHelper.ColorTheme="Primary"
                                                    Style="{DynamicResource DynamicOutlineCircleButton}"
                                                    Margin="0,0,8,0"
                                                    ToolTip="Mở workflow này trong editor (không tự bật widget)">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x1F6E0;" Margin="0,0,6,0" FontSize="13"/>
                                                    <TextBlock Text="Mở Workflow"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Command="{Binding DataContext.ClearWorkflowWidgetConfigsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    helper:ButtonHelper.ColorTheme="Danger"
                                                    Style="{DynamicResource DynamicOutlineCircleButton}"
                                                    ToolTip="Xóa toàn bộ cấu hình widget của workflow này">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#x1F5D1;" Margin="0,0,6,0" FontSize="13"/>
                                                    <TextBlock Text="Xóa cấu hình widget"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                        <!-- Widget list trong workflow -->
                                        <ItemsControl ItemsSource="{Binding Widgets}" Margin="0,14,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:WidgetShortcutItem}">
                                                    <Border Margin="0,0,0,8"
                                                            Padding="12,10"
                                                            CornerRadius="10"
                                                            Background="{DynamicResource WindowBackgroundBrush}"
                                                            BorderBrush="{DynamicResource BorderColor}"
                                                            BorderThickness="1">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- Icon -->
                                                            <Border Grid.Column="0"
                                                                    Width="38" Height="38"
                                                                    CornerRadius="12"
                                                                    VerticalAlignment="Center"
                                                                    Margin="0,0,12,0">
                                                                <Border.Background>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                        <GradientStop Color="#7C3AED" Offset="0"/>
                                                                        <GradientStop Color="#EC4899" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </Border.Background>
                                                                <Grid>
                                                                    <controls:SvgViewboxEx Width="18" Height="18"
                                                                                           Fill="White"
                                                                                           Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}">
                                                                        <controls:SvgViewboxEx.Style>
                                                                            <Style TargetType="controls:SvgViewboxEx">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IconKey, Converter={StaticResource StringStartsWithConverter}}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </controls:SvgViewboxEx.Style>
                                                                    </controls:SvgViewboxEx>
                                                                    <TextBlock Text="{Binding IconKey}"
                                                                               FontSize="18"
                                                                               Foreground="White"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IconKey, Converter={StaticResource StringStartsWithConverter}}" Value="False">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Texts -->
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                                                <TextBlock Text="{Binding WidgetName, FallbackValue=Widget}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Text="{Binding NodeTitle}"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           Opacity="0.55"
                                                                           FontSize="11"
                                                                           Margin="0,2,0,0"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Visibility="{Binding NodeTitle, Converter={StaticResource StringNotEmptyToVisibilityConverter}}"/>
                                                            </StackPanel>

                                                            <!-- Per-widget actions -->
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Button Command="{Binding DataContext.ConfigureWidgetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="0,0,6,0"
                                                                        Height="35"
                                                                        helper:ButtonHelper.ColorTheme="ChocolateBrown"
                                                                        ToolTip="Mở nhanh màn cấu hình widget này"
                                                                        IsEnabled="True">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DynamicOutlineCircleButton}">
                                                                            <Setter Property="IsEnabled" Value="True"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsConfiguring}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Grid>
                                                                        <controls:SvgViewboxEx Width="18" Height="18"
                                                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                               Source="{Binding Source={x:Static sys:String.Empty},
                                                                                        Converter={StaticResource IconKeyToPathConverter},
                                                                                        ConverterParameter='gear-complex light'}"
                                                                               Visibility="{Binding IsConfiguring, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="&#x23F3;"
                                                                                   FontSize="12"
                                                                                   Visibility="{Binding IsConfiguring, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    </Grid>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.LaunchWidgetHeadlessCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="0,0,6,0"
                                                                        Height="35"
                                                                        helper:ButtonHelper.ColorTheme="Primary"
                                                                        ToolTip="Chỉ mở widget này (ngầm)">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DynamicOutlineCircleButton}">
                                                                            <Setter Property="IsEnabled" Value="True"/>
                                                                            <Style.Triggers>
                                                                                <Trigger Property="IsEnabled" Value="False">
                                                                                    <Setter Property="Opacity" Value="0.45"/>
                                                                                </Trigger>
                                                                                <DataTrigger Binding="{Binding IsLaunchingHeadless}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsWidgetOpen}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Grid>
                                                                        <TextBlock Text="&#x26A1;"
                                                                                   FontSize="14"
                                                                                   Visibility="{Binding IsLaunchingHeadless, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="&#x23F3;"
                                                                                   FontSize="12"
                                                                                   Visibility="{Binding IsLaunchingHeadless, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    </Grid>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.ReopenHeadlessWorkflowCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Margin="0,0,6,0"
                                                                        Height="35"
                                                                        helper:ButtonHelper.ColorTheme="NavyDeep"
                                                                        ToolTip="Mở lại workflow đang chạy ngầm để debug">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DynamicOutlineCircleButton}">
                                                                            <Setter Property="IsEnabled" Value="False"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsWidgetOpen}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="True"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsReopeningHeadless}" Value="True">
                                                                                    <Setter Property="IsEnabled" Value="False"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Grid>
                                                                        <controls:SvgViewboxEx Width="18" Height="18"
                                                                           Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                                                           Source="{Binding Source={x:Static sys:String.Empty},
                                                                                    Converter={StaticResource IconKeyToPathConverter},
                                                                                    ConverterParameter='folder-open duotone-light'}"
                                                                           Visibility="{Binding IsReopeningHeadless, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="&#x23F3;"
                                                                                   FontSize="12"
                                                                                   Foreground="{DynamicResource TextOnSuccessBrush}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Visibility="{Binding IsReopeningHeadless, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                        <Ellipse Width="8"
                                                                                 Height="8"
                                                                                 Fill="{DynamicResource SuccessBrush}"
                                                                                 Stroke="{DynamicResource TextOnSuccessBrush}"
                                                                                 StrokeThickness="1"
                                                                                 HorizontalAlignment="Right"
                                                                                 VerticalAlignment="Top"
                                                                                 Margin="0,-2,-2,0"
                                                                                 Visibility="{Binding IsHeadlessDebugVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    </Grid>
                                                                </Button>
                                                                <Button Command="{Binding DataContext.TogglePinToTrayCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Height="35"
                                                                        helper:ButtonHelper.ColorTheme="NavyDeep"
                                                                        ToolTip="Ghim/bỏ ghim widget vào menu tray">
                                                                    <Button.Style>
                                                                        <Style TargetType="Button" BasedOn="{StaticResource DynamicOutlineCircleButton}">
                                                                            <Setter Property="Background" Value="Transparent"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsPinnedToTray}" Value="True">
                                                                                    <Setter Property="Background" Value="{DynamicResource NavyDeepBrush}"/>
                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource NavyDeepBrush}"/>
                                                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnNavyDeepBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Button.Style>
                                                                    <Grid>
                                                                        <TextBlock Text="&#x1F4CC;"
                                                                                   FontSize="13"
                                                                                   Visibility="{Binding IsPinnedToTray, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                                                        <TextBlock Text="&#x1F4CD;"
                                                                                   FontSize="13"
                                                                                   Visibility="{Binding IsPinnedToTray, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                                    </Grid>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- ★ Pin badge: góc trên phải card, hiện khi group có widget ghim -->
                                    <Border HorizontalAlignment="Right"
                                            VerticalAlignment="Top"
                                            Margin="0,-8,-8,0"
                                            Width="26" Height="26"
                                            CornerRadius="13"
                                            Background="#7C3AED"
                                            ToolTip="Workflow này có widget đang ghim vào tray">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="0"/>
                                                <Setter Property="IsHitTestVisible" Value="False"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                        <Setter Property="IsHitTestVisible" Value="True"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="&#x2605;"
                                                   FontSize="13"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-1,0,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
