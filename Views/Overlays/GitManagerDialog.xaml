<Window x:Class="FlowMy.Views.Overlays.GitManagerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FlowMy.Controls"
    xmlns:local="clr-namespace:FlowMy.Views.Overlays"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:conv="clr-namespace:FlowMy.Converters"
    Title="Git Manager"
    WindowStyle="SingleBorderWindow"
    ResizeMode="CanResize"
    ShowInTaskbar="True"
    WindowStartupLocation="CenterScreen"
    Width="620" MinWidth="500" MaxWidth="900" MinHeight="520" Height="620"
    Background="{DynamicResource WindowBackground}"
    StateChanged="Window_StateChanged">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <!-- Main tab radio style -->
        <Style x:Key="GitTabRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="12,10"
                                BorderBrush="Transparent" BorderThickness="0,0,0,3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter Property="Opacity" Value="0.85"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sub-tab radio style -->
        <Style x:Key="GitSubTabRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="Transparent" Padding="10,8"
                                BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource MenuItemHoverBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TAB HEADER BAR ═══ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundMainBrush}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="0,0,0,0">
            <UniformGrid Rows="1" HorizontalAlignment="Stretch">
                <RadioButton x:Name="TabTongHop" Content="📋 Tổng hợp" GroupName="MainTab"
                             IsChecked="True" Checked="MainTab_Checked"
                             Style="{StaticResource GitTabRadioStyle}"/>
                <RadioButton x:Name="TabGit" Content="🔀 Git" GroupName="MainTab"
                             Checked="MainTab_Checked"
                             Style="{StaticResource GitTabRadioStyle}"/>
            </UniformGrid>
        </Border>

        <!-- ═══ CONTENT AREA ═══ -->
        <Grid Grid.Row="1">

            <!-- PAGE: TỔNG HỢP -->
            <Border x:Name="PageTongHop" Padding="16" Visibility="Visible">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Danh sách Git Repos đã lưu"
                                   Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Width="30" Height="30" Padding="0" Margin="2"
                                    Style="{DynamicResource PrimaryButton}" Cursor="Hand" ToolTip="Import JSON"
                                    Command="{Binding ImportConfigJsonCommand}">
                                <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='file-arrow-down duotone-light'}"
                                                       Width="22" Height="22"  Opacity="1"/>
                            </Button>
                            <Button Width="30" Height="30" Padding="0" Margin="2"
                                    Style="{DynamicResource SuccessButton}" Cursor="Hand" ToolTip="Export JSON"
                                    Command="{Binding ExportConfigJsonCommand}">
                                <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='file-arrow-up duotone-light'}"
                                                       Width="22" Height="22"  Opacity="1"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SavedRepos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="12" CornerRadius="8"
                                            Background="{DynamicResource CardColor}"
                                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8"
                                                    Background="{Binding NodeBrush}" Margin="0,0,12,0"
                                                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                                                    VerticalAlignment="Center">
                                                <Grid>
                                                    <controls:SvgViewboxEx Width="18" Height="18"
                                                                           Fill="{Binding IconBrushResolved}"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                           Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}"/>
                                                    <!-- Status dot: xanh blue = đã clone, xám = chưa clone -->
                                                    <Ellipse Width="15" Height="15" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                             Margin="0,0,-4,-4" Stroke="{DynamicResource CardColor}" StrokeThickness="1.5">
                                                        <Ellipse.Style>
                                                            <Style TargetType="Ellipse">
                                                                <Setter Property="Fill" Value="#9E9E9E"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsGitRepoCloned}" Value="True">
                                                                        <Setter Property="Fill" Value="#2196F3"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Ellipse.Style>
                                                    </Ellipse>
                                                </Grid>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="13"
                                                           Foreground="{DynamicResource TextBrush}" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock FontSize="10" Opacity="0.6" Foreground="{DynamicResource TextSecondary}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0">
                                                    <Run Text="🌿"/><Run Text="{Binding Branch, Mode=OneWay}"/>
                                                    <Run Text="  📁"/><Run Text="{Binding LocalPath, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Width="28" Height="28" Padding="0" Margin="2"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.RunRepoCommandCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsGitRepoCloned, Converter={StaticResource BoolToVisibility}}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Setter Property="ToolTip" Value="Start"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                                    <Setter Property="ToolTip" Value="Stop"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Grid Width="15" Height="15">
                                                        <!-- Play icon: hiện khi không chạy -->
                                                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='play regular'}"
                                                                               Width="15" Height="15" Fill="White" Opacity="0.9">
                                                            <controls:SvgViewboxEx.Style>
                                                                <Style TargetType="controls:SvgViewboxEx">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </controls:SvgViewboxEx.Style>
                                                        </controls:SvgViewboxEx>
                                                        <!-- Pause icon: hiện khi đang chạy -->
                                                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='pause sharp-light'}"
                                                                               Width="15" Height="15" Fill="White" Opacity="0.9">
                                                            <controls:SvgViewboxEx.Style>
                                                                <Style TargetType="controls:SvgViewboxEx">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </controls:SvgViewboxEx.Style>
                                                        </controls:SvgViewboxEx>
                                                    </Grid>
                                                </Button>
                                                <!-- Clone button: hiện khi chưa có .git -->
                                                <Button Width="28" Height="28" Padding="0" Margin="2"
                                                        Style="{DynamicResource PrimaryButton}" Cursor="Hand" ToolTip="Clone"
                                                        Command="{Binding DataContext.CloneSavedRepoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsGitRepoCloned, Converter={StaticResource InverseBoolToVisibility}}">
                                                    <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='clone-plus duotone'}"
                                                                           Width="15" Height="15" Fill="White" Opacity="0.9"/>
                                                </Button>
                                                <!-- Pull button: hiện khi đã có .git -->
                                                <Button Width="28" Height="28" Padding="0" Margin="2"
                                                        Style="{DynamicResource SecondaryButton}" Cursor="Hand" ToolTip="Pull"
                                                        Command="{Binding DataContext.PullSavedRepoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsGitRepoCloned, Converter={StaticResource BoolToVisibility}}">
                                                    <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='code-pull-request duotone-light'}"
                                                                           Width="15" Height="15" Fill="{DynamicResource TextBrush}" Opacity="0.8"/>
                                                </Button>
                                                <Button Width="28" Height="28" Padding="0" Margin="2"
                                                        Style="{DynamicResource SecondaryButton}" Cursor="Hand" ToolTip="VS Code"
                                                        Command="{Binding DataContext.OpenVsCodeForRepoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Visibility="{Binding IsGitRepoCloned, Converter={StaticResource BoolToVisibility}}">
                                                    <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='code duotone-regular'}"
                                                                           Width="15" Height="15" Fill="{DynamicResource TextBrush}" Opacity="0.8"/>
                                                </Button>
                                                <Button Width="28" Height="28" Padding="0" Margin="2"
                                                        Style="{DynamicResource SuccessButton}" Cursor="Hand" ToolTip="Sửa"
                                                        Command="{Binding DataContext.EditRepoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='pen-to-square duotone-light'}"
                                                                           Width="15" Height="15" Fill="White" Opacity="0.9"/>
                                                </Button>
                                                <Button Width="28" Height="28" Padding="0" Margin="2"
                                                        Style="{DynamicResource DangerButton}" Cursor="Hand" ToolTip="Xóa"
                                                        Command="{Binding DataContext.RemoveRepoCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='trash-can light'}"
                                                                           Width="15" Height="15" Fill="White" Opacity="0.9"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- PAGE: GIT -->
            <Grid x:Name="PageGit" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sub-tab header -->
                <Border Grid.Row="0" Background="{DynamicResource CardColor}"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                    <UniformGrid Rows="1" HorizontalAlignment="Stretch">
                        <RadioButton x:Name="SubTabClone" Content="Clone" GroupName="SubTab"
                                     IsChecked="True" Checked="SubTab_Checked"
                                     Style="{StaticResource GitSubTabRadioStyle}"/>
                        <RadioButton x:Name="SubTabDisplay" Content="Hiển thị" GroupName="SubTab"
                                     Checked="SubTab_Checked"
                                     Style="{StaticResource GitSubTabRadioStyle}"/>
                        <RadioButton x:Name="SubTabSettings" Content="Cài đặt" GroupName="SubTab"
                                     Checked="SubTab_Checked"
                                     Style="{StaticResource GitSubTabRadioStyle}"/>
                    </UniformGrid>
                </Border>

                <!-- Sub-tab content -->
                <Grid Grid.Row="1">
                    <!-- Clone page -->
                    <ScrollViewer x:Name="SubPageClone" VerticalScrollBarVisibility="Auto" Padding="16,12" Visibility="Visible">
                        <StackPanel MaxWidth="500">
                            <TextBlock Text="Repository URL:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding RepoUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}" Height="34" Margin="0,0,0,12"/>

                            <TextBlock Text="Thư mục local:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding LocalPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource BaseTextBoxV2}" Height="34"/>
                                <Button Grid.Column="1" Padding="0" Content="📁" Width="34" Height="34" Margin="6,0,0,0"
                                        Style="{DynamicResource SecondaryButton}" Cursor="Hand"
                                        Command="{Binding BrowseLocalPathCommand}"/>
                            </Grid>

                            <TextBlock Text="Branch:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox x:Name="BranchComboBox" Height="34" Style="{DynamicResource BaseComboBox}"
                                      SelectedItem="{Binding Branch, Mode=TwoWay}"
                                      ItemsSource="{Binding AvailableBranches}"
                                      DropDownClosed="BranchComboBox_DropDownClosed"
                                      Margin="0,0,0,14"/>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Height="34" MinWidth="90" Margin="0,0,6,0"
                                        Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                        Command="{Binding CloneRepoCommand}"
                                        IsEnabled="{Binding IsOperating, Converter={StaticResource InverseBoolConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='clone-plus duotone'}"
                                                               Width="14" Height="14" Fill="White" Opacity="0.9" Margin="0,0,5,0"/>
                                        <TextBlock Text="Clone" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" MinWidth="90" Margin="0,0,6,0"
                                        Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                        Command="{Binding PullRepoCommand}"
                                        IsEnabled="{Binding IsOperating, Converter={StaticResource InverseBoolConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='code-pull-request duotone-light'}"
                                                               Width="14" Height="14" Fill="White" Opacity="0.9" Margin="0,0,5,0"/>
                                        <TextBlock Text="Pull" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" MinWidth="110" Margin="0,0,6,0"
                                        Style="{DynamicResource SecondaryButton}" Cursor="Hand"
                                        ToolTip="Mở folder Git có sẵn và load thông tin"
                                        Command="{Binding ImportLocalRepoCommand}"
                                        IsEnabled="{Binding IsOperating, Converter={StaticResource InverseBoolConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='folder-open duotone'}"
                                                               Width="14" Height="14" Fill="{DynamicResource TextBrush}" Opacity="0.85" Margin="0,0,5,0"/>
                                        <TextBlock Text="Import folder" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="34" MinWidth="60"
                                        Style="{DynamicResource DangerButton}" Cursor="Hand"
                                        Command="{Binding CancelOperationCommand}"
                                        Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='xmark regular'}"
                                                               Width="12" Height="12" Fill="White" Opacity="0.9" Margin="0,0,4,0"/>
                                        <TextBlock Text="Huỷ" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Border Margin="0,0,0,10" CornerRadius="6" Padding="10,8"
                                    Background="{DynamicResource CardColor}"
                                    BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                    Visibility="{Binding IsOperating, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding ProgressStatusText}" Foreground="{DynamicResource AccentBrush}"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                    <ProgressBar IsIndeterminate="True" Height="3" Foreground="{DynamicResource AccentBrush}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6" Padding="8" MaxHeight="120">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding OperationLog}" FontSize="10" FontFamily="Consolas"
                                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Hiển thị page -->
                    <ScrollViewer x:Name="SubPageDisplay" VerticalScrollBarVisibility="Auto" Padding="16,12" Visibility="Collapsed">
                        <StackPanel MaxWidth="500">
                            <TextBlock Text="Tên hiển thị:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}" Height="34" Margin="0,0,0,12"/>

                            <TextBlock Text="Icon:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <controls:IconSelectorUserControl x:Name="IconSelector" ButtonHeight="32" Margin="0,0,0,12"
                                                              SelectedIcon="{Binding IconKey, Mode=TwoWay}"/>

                            <TextBlock Text="Màu icon:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="32" Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}" SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding IconColorKey, Mode=TwoWay}" SelectionChanged="IconColorComboBox_SelectionChanged"/>
                                <Button Grid.Column="1" Content="🎨" Width="32" Height="32" Padding="0" Margin="6,0,0,0" Cursor="Hand" Click="PickIconColor_Click"/>
                                <Border x:Name="IconColorPreview" Grid.Column="2" Width="32" Height="32" CornerRadius="6" Margin="6,0,0,0"
                                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>
                            </Grid>

                            <TextBlock Text="Màu node:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="32" Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}" SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding NodeColorKey, Mode=TwoWay}" SelectionChanged="NodeColorComboBox_SelectionChanged"/>
                                <Button Grid.Column="1" Content="🎨" Width="32" Height="32" Padding="0" Margin="6,0,0,0" Cursor="Hand" Click="PickNodeColor_Click"/>
                                <Border x:Name="NodeColorPreview" Grid.Column="2" Width="32" Height="32" CornerRadius="6" Margin="6,0,0,0"
                                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"/>
                            </Grid>

                            <TextBlock Text="Mô tả:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding TooltipText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}" Height="50" Margin="0,0,0,14"
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

                            <TextBlock Text="Xem trước:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1" CornerRadius="8" Padding="14" HorizontalAlignment="Left" MinWidth="260">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="PreviewNodeBorder" Width="44" Height="44" CornerRadius="10"
                                            Background="{Binding PreviewNodeBrush}"
                                            BorderBrush="{DynamicResource BorderColor}" BorderThickness="1.5">
                                        <controls:SvgViewboxEx x:Name="PreviewIcon" Width="22" Height="22"
                                                               Fill="{Binding PreviewIconBrush}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}"/>
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName, TargetNullValue='Git Source'}"
                                                   FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="{Binding TooltipText, TargetNullValue='Mô tả...'}"
                                                   FontSize="10" Opacity="0.6" TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Cài đặt page -->
                    <ScrollViewer x:Name="SubPageSettings" VerticalScrollBarVisibility="Auto" Padding="16,12" Visibility="Collapsed">
                        <StackPanel MaxWidth="500">
                            <TextBlock Text="Command Line:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="Lệnh chạy khi nhấn ▶ ở tab Tổng hợp (mỗi dòng = 1 lệnh, chạy tuần tự)" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}" MinHeight="70" MaxHeight="160"
                                     AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" FontSize="12" Margin="0,0,0,12"/>

                            <CheckBox IsChecked="{Binding ShowCmdWindow}" Margin="0,0,0,12" Cursor="Hand"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12">
                                <TextBlock Text="Hiện cửa sổ CMD khi chạy (bỏ tick = chạy ngầm)" Foreground="{DynamicResource TextBrush}"/>
                            </CheckBox>

                            <Button Height="34" MinWidth="110" HorizontalAlignment="Left"
                                    Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                    Command="{Binding TestRunCommandCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='play regular'}"
                                                           Width="14" Height="14" Fill="White" Opacity="0.9" Margin="0,0,6,0"/>
                                    <TextBlock Text="Test chạy" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Text="Output:" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,14,0,6"/>
                            <Border Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1" CornerRadius="6" Padding="8" MaxHeight="180">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding CommandOutput}" FontFamily="Consolas" FontSize="10"
                                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Save notification -->
                <Border Grid.Row="2" Padding="8,5" CornerRadius="6" Margin="16,4,16,4"
                        Background="{DynamicResource SuccessBrush}" Opacity="0.9"
                        Visibility="{Binding ShowSaveSuccess, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="✅ Đã lưu thành công!" FontWeight="SemiBold"
                               FontSize="11" Foreground="White" HorizontalAlignment="Center"/>
                </Border>

                <!-- Save button -->
                <Border Grid.Row="3" Padding="14,8" BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderColor}" Background="{DynamicResource CardColor}">
                    <Button Height="36" MinWidth="150" HorizontalAlignment="Center"
                            Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                            Command="{Binding SaveRepoCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💾" FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Lưu vào Tổng hợp" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
