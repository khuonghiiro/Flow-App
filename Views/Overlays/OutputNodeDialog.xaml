<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.OutputNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Output Node"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        Height="700"
        MinWidth="420"
        MaxWidth="900"
        MinHeight="420">
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                          Grid.Column="0"
                          Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource BaseTextBoxV2}"
                          FontSize="16"
                          Padding="0,4,0,4"
                          VerticalContentAlignment="Center"
                          MinWidth="150"
                          Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="✕" 
                            FontSize="12" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: 2 tab Logic + Tái sử dụng flow -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <!-- 🎨 Cấu hình hiển thị -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🎨 Cấu hình hiển thị" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Hiển thị tiêu đề" 
                                       Foreground="{DynamicResource TextMuted}" 
                                       FontSize="10" Margin="0,0,0,4"/>
                            <ComboBox x:Name="TitleDisplayModeComboBox"
                                      Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <TextBlock Text="Màu tiêu đề" 
                                       Foreground="{DynamicResource TextMuted}" 
                                       FontSize="10" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TitleColorComboBox"
                                          Grid.Column="0"
                                          Height="32"
                                          MinWidth="150"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                          SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                <Border Grid.Column="1" 
                                        x:Name="TitleColorPreview"
                                        Width="32" Height="32" 
                                        CornerRadius="6"
                                        Margin="8,0,0,0"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- 🔑 Output Key -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🔑 Output Key"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <TextBox Text="{Binding OutputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Height="32"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 📍 Input Variables -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <TextBlock Text="📍 Input Variables"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                
                                <Button x:Name="AddVariableButton"
                                        Grid.Column="1"
                                        Content="+ Thêm"
                                        Width="70"
                                        Height="32"
                                        FontSize="12"
                                        Foreground="{DynamicResource TextBrush}"
                                        Background="{DynamicResource PrimaryBrush}"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Command="{Binding AddVariableCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                    CornerRadius="6" 
                                                    Padding="8,4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Variables List -->
                            <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="6" Padding="10">
                        <StackPanel>
                            <ItemsControl x:Name="VariablesItemsControl" ItemsSource="{Binding Variables}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Row 1: Variable Key -->
                                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                                    <TextBlock Text="Variable Key:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                                    <TextBox Text="{Binding VariableKey, UpdateSourceTrigger=PropertyChanged}"
                                                             Style="{DynamicResource BaseTextBoxV2}"
                                                             Height="32"
                                                             FontSize="13"/>
                                                </StackPanel>

                                                <!-- Remove Button -->
                                                <Button Grid.Row="0" Grid.Column="1"
                                                        Content="-"
                                                        Width="28" Height="28"
                                                        FontSize="18" FontWeight="Bold"
                                                        Foreground="{DynamicResource TextBrush}"
                                                        Background="{DynamicResource DangerBrush}"
                                                        BorderThickness="0"
                                                        Cursor="Hand"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0,0,0,8"
                                                        Command="{Binding RemoveCommand}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Row 2: Source Node -->
                                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,8">
                                                    <TextBlock Text="Source Node:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl ItemsSource="{Binding AvailableSourceNodes}"
                                                              SelectedValue="{Binding SelectedSourceNodeId, Mode=TwoWay}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              Height="32"/>
                                                </StackPanel>

                                                <!-- Row 3: Source Output Key -->
                                                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                                    <TextBlock Text="Source Key:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                                    <ComboBox ItemsSource="{Binding AvailableOutputKeys}"
                                                              SelectedValue="{Binding SelectedSourceOutputKey, Mode=TwoWay}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="Key"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              Height="32"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            
                            <!-- Empty state -->
                            <TextBlock x:Name="EmptyStateText"
                                       Text="Chưa có variable nào. Nhấn '+ Thêm' để tạo input variable."
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="12"
                                       FontStyle="Italic"
                                       HorizontalAlignment="Center"
                                       Margin="0,8"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- 📝 Format String -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📝 Format String"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10"/>
                            <TextBox Text="{Binding FormatString, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     MinHeight="100"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     FontSize="10"/>
                        </StackPanel>
                    </Border>

                    <!-- 📋 Save to Clipboard -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <CheckBox Content="Lưu vào clipboard (Ctrl+V để paste)"
                                  IsChecked="{Binding SaveToClipboard, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  FontSize="11"/>
                    </Border>

                    <!-- Info -->
                    <Border Background="{DynamicResource CardColor}" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="💡 Hướng dẫn Format String:" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            
                            <!-- Basic Usage -->
                            <TextBlock Text="1. Giá trị thường:" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" LineHeight="18" Margin="0,0,0,8">
                                <Run>• Sử dụng {variableKey} để chèn giá trị</Run>
                                <LineBreak/>
                                <Run>• Ví dụ: "Xin chào {name}" → "Xin chào John"</Run>
                            </TextBlock>
                            
                            <!-- Array Usage -->
                            <TextBlock Text="2. Mảng (Array):" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" LineHeight="18" Margin="0,0,0,8">
                                <Run>• {variableKey[0...n]} - Hiển thị tất cả phần tử: [item1, item2, ...]</Run>
                                <LineBreak/>
                                <Run>• {variableKey[0]} - Lấy phần tử đầu tiên (index 0)</Run>
                                <LineBreak/>
                                <Run>• {variableKey[1]} - Lấy phần tử thứ hai (index 1)</Run>
                                <LineBreak/>
                                <Run>• Ví dụ: "Danh sách: {items[0...n]}" → "Danh sách: [apple, banana, orange]"</Run>
                            </TextBlock>
                            
                            <!-- Object Usage -->
                            <TextBlock Text="3. JSON Object:" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" LineHeight="18" Margin="0,0,0,8">
                                <Run>• {variableKey[fieldName]} - Lấy trường của object</Run>
                                <LineBreak/>
                                <Run>• Ví dụ: "Tên: {user[name]}" → "Tên: John" (nếu user = {"name": "John", "age": 30})</Run>
                            </TextBlock>
                            
                            <!-- Nested Array in Object -->
                            <TextBlock Text="4. Mảng trong Object (Nested Array):" Foreground="{DynamicResource TextSecondary}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" LineHeight="18" Margin="0,0,0,8">
                                <Run>• {variableKey[fieldName][index]} - Lấy phần tử tại index của mảng trong object field</Run>
                                <LineBreak/>
                                <Run>• {variableKey[fieldName][0...n]} - Hiển thị tất cả phần tử của mảng trong object field</Run>
                            </TextBlock>
                            
                            <!-- Detailed Example -->
                            <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="📌 Ví dụ chi tiết với JSON Object:" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="10" LineHeight="16" FontFamily="Consolas">
                                        <Run>Giả sử có JSON object:</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource WarningColor}">{"name": "John", "items": ["apple", "banana", "orange"]}</Run>
                                        <LineBreak/>
                                        <LineBreak/>
                                        <Run>Kết quả khi sử dụng:</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource SuccessColor}">• {data[name]}</Run>
                                        <Run> → </Run>
                                        <Run Foreground="{DynamicResource WarningColor}">"John"</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource SuccessColor}">• {data[items][0]}</Run>
                                        <Run> → </Run>
                                        <Run Foreground="{DynamicResource WarningColor}">"apple"</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource SuccessColor}">• {data[items][1]}</Run>
                                        <Run> → </Run>
                                        <Run Foreground="{DynamicResource WarningColor}">"banana"</Run>
                                        <LineBreak/>
                                        <Run Foreground="{DynamicResource SuccessColor}">• {data[items][0...n]}</Run>
                                        <Run> → </Run>
                                        <Run Foreground="{DynamicResource WarningColor}">"[apple, banana, orange]"</Run>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            
                            <!-- Examples -->
                            <TextBlock Text="📋 Ví dụ tổng hợp Format String:" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,4"/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" LineHeight="18">
                                <Run>• "{name} có {count} mục: {items[0...n]}"</Run>
                                <LineBreak/>
                                <Run>• "User: {user[name]}, Age: {user[age]}"</Run>
                                <LineBreak/>
                                <Run>• "Item đầu tiên: {data[items][0]}"</Run>
                                <LineBreak/>
                                <Run>• "{data[name]} có {data[items][0...n]} trong giỏ hàng"</Run>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 📊 Outputs -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📊 Outputs (tự động tạo từ OutputKey)" 
                                       Foreground="{DynamicResource TextBrush}" 
                                       FontSize="12" 
                                       FontWeight="SemiBold" 
                                       Margin="0,0,0,10"/>
                            <StackPanel x:Name="OutputsPanel"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Tái sử dụng flow -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Port IN -->
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Port IN"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <!-- Port OUT -->
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Port OUT"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Cấu hình tái sử dụng flow -->
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" MinWidth="100" />
                                                    <ColumnDefinition Width="2*" MinWidth="100" />
                                                    <ColumnDefinition Width="2*" MinWidth="100" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Node IN -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Node OUT -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <!-- Kiểu line OUT -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>

