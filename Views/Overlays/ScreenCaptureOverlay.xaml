<Window x:Class="FlowMy.Views.Overlays.ScreenCaptureOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Screen Capture"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        Cursor="None"
        MouseDown="Window_MouseDown"
        MouseMove="Window_MouseMove"
        MouseUp="Window_MouseUp"
        KeyDown="Window_KeyDown">

    <Grid>
        <!--
            Lớp phủ tối kiểu Snipping Tool:
            Dùng Path với CombinedGeometry để "đục lỗ" vùng chọn.
            Code-behind sẽ cập nhật _holeGeometry theo vùng kéo.
        -->
        <Path x:Name="DimPath"
              IsHitTestVisible="False"
              Fill="#88000000">
            <Path.Data>
                <CombinedGeometry GeometryCombineMode="Exclude">
                    <!-- Nền toàn màn hình – code-behind sẽ gán kích thước thực -->
                    <CombinedGeometry.Geometry1>
                        <RectangleGeometry x:Name="FullScreenGeometry"/>
                    </CombinedGeometry.Geometry1>
                    <!-- Lỗ trống (vùng chọn sáng) – ban đầu rỗng -->
                    <CombinedGeometry.Geometry2>
                        <RectangleGeometry x:Name="HoleGeometry"/>
                    </CombinedGeometry.Geometry2>
                </CombinedGeometry>
            </Path.Data>
        </Path>

        <!-- Viền xanh quanh vùng chọn -->
        <Canvas x:Name="SelectionCanvas">
            <Rectangle x:Name="SelectionBorder"
                       Stroke="#00D4FF"
                       StrokeThickness="2"
                       Fill="Transparent"
                       Visibility="Collapsed"/>

            <!-- Info panel: kích thước vùng chọn -->
            <Border x:Name="InfoPanel"
                    Background="#DD111827"
                    BorderBrush="#00D4FF"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,4"
                    Visibility="Collapsed">
                <TextBlock x:Name="InfoText"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFF"/>
            </Border>
        </Canvas>

        <!-- Hướng dẫn -->
        <Border x:Name="HintPanel"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,20,0,0"
                Background="#DD111827"
                BorderBrush="#00D4FF"
                BorderThickness="1"
                CornerRadius="6"
                Padding="16,8">
            <TextBlock FontSize="14"
                       Foreground="#FFFFFF"
                       FontWeight="Medium">
                <Run Text="Kéo chuột để chọn vùng cần chụp"/>
                <Run Text="   •   " Foreground="#00D4FF"/>
                <Run Text="ESC để hủy"/>
            </TextBlock>
        </Border>

        <!-- Custom cursor: crosshair ngắn quanh con trỏ -->
        <Canvas x:Name="CrosshairCanvas" IsHitTestVisible="False">
            <Line x:Name="CH_Left"  Stroke="White" StrokeThickness="1.5"/>
            <Line x:Name="CH_Right" Stroke="White" StrokeThickness="1.5"/>
            <Line x:Name="CH_Up"    Stroke="White" StrokeThickness="1.5"/>
            <Line x:Name="CH_Down"  Stroke="White" StrokeThickness="1.5"/>
            <Ellipse x:Name="CH_Dot"
                     Width="4" Height="4"
                     Fill="#00D4FF"/>
        </Canvas>
    </Grid>
</Window>
