<Window x:Class="FlowMy.Views.Overlays.ScreenPositionPickerOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chọn vị trí trên màn hình"
        WindowState="Maximized"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#01000000"
        Topmost="True"
        ShowInTaskbar="False"
        Cursor="Cross"
        MouseMove="Window_MouseMove"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        KeyDown="Window_KeyDown">

    <Grid>
        <!-- Crosshair (dấu + ở vị trí chuột) -->
        <Canvas x:Name="CrosshairCanvas">
            <!-- Đường ngang -->
            <Line x:Name="HorizontalLine"
                  Stroke="Red"
                  StrokeThickness="2"
                  X1="0" Y1="0"
                  X2="100" Y2="0">
                <Line.Effect>
                    <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="5" Opacity="0.8"/>
                </Line.Effect>
            </Line>

            <!-- Đường dọc -->
            <Line x:Name="VerticalLine"
                  Stroke="Red"
                  StrokeThickness="2"
                  X1="0" Y1="0"
                  X2="0" Y2="100">
                <Line.Effect>
                    <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="5" Opacity="0.8"/>
                </Line.Effect>
            </Line>

            <!-- Tâm (điểm nhỏ ở giữa) -->
            <Ellipse x:Name="CenterDot"
                     Width="8" Height="8"
                     Fill="Red"
                     Stroke="White"
                     StrokeThickness="2">
                <Ellipse.Effect>
                    <DropShadowEffect Color="Black" ShadowDepth="0" BlurRadius="5" Opacity="0.8"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- Hiển thị tọa độ -->
        <Border x:Name="CoordinateDisplay"
                Background="#DD000000"
                CornerRadius="5"
                Padding="10,5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10">
            <StackPanel>
                <TextBlock x:Name="CoordinateText"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Bold"
                           Text="X: 0, Y: 0"/>
                <TextBlock Foreground="#CCCCCC"
                           FontSize="11"
                           Margin="0,5,0,0"
                           Text="Click chuột trái để chọn vị trí"/>
                <TextBlock Foreground="#CCCCCC"
                           FontSize="11"
                           Text="Nhấn ESC để hủy"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

