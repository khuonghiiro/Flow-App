<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.LoopNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:converters="clr-namespace:FlowMy.Converters"
        Title="Loop Node Dialog"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="400"
        MinWidth="300"
        MaxWidth="700"
        MinHeight="400">
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseStringNullOrEmptyToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                          Grid.Column="0"
                          Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource BaseTextBoxV2}"
                          FontSize="16"
                          Padding="0,4,0,4"
                          VerticalContentAlignment="Center"
                          Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="×" 
                            FontSize="12" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: 2 tab Logic + Tái sử dụng flow -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic (giữ nguyên nội dung cũ) -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>

                    <!-- Title Display Mode -->
                    <TextBlock Text="Hiển thị tiêu đề:"
           Foreground="{DynamicResource TextBrush}"
           FontSize="14"
           FontWeight="SemiBold"
           Margin="0,0,0,8"/>

                    <ComboBox x:Name="TitleDisplayModeComboBox"
          Height="36"
          Style="{DynamicResource BaseComboBox}"
          Margin="0,0,0,16"
          ItemsSource="{Binding TitleDisplayModeOptions}"
          SelectedValuePath="Value"
          DisplayMemberPath="DisplayName"
          SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                    <!-- TitleColorMode Section -->
                    <TextBlock Text="Màu tiêu đề:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox x:Name="TitleColorComboBox"
                                  Grid.Column="0"
                                  Height="36"
                                  Style="{DynamicResource BaseComboBox}"
                                  ItemsSource="{Binding TitleColorOptions}"
                                  SelectedValuePath="Key"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                        
                        <!-- Color Preview -->
                        <Border Grid.Column="1" 
                                x:Name="TitleColorPreview"
                                Width="36" Height="36" 
                                CornerRadius="6"
                                Margin="8,0,0,0"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"/>
                    </Grid>
                    
                    <!-- Loop Type Selection -->
                    <TextBlock Text="Loại vòng lặp:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    
                    <ComboBox x:Name="LoopTypeComboBox"
                              Height="36"
                              Style="{DynamicResource BaseComboBox}"
                              Margin="0,0,0,16"
                              ItemsSource="{Binding LoopTypeOptions}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              SelectedValue="{Binding LoopType, Mode=TwoWay}"/>

                    <!-- Repeat N Times Configuration -->
                    <StackPanel x:Name="RepeatNPanel" Margin="0,0,0,16">
                        <TextBlock Text="Số lần lặp:"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        
                        <TextBox x:Name="RepeatCountTextBox"
                                 Height="36"
                                 Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource BaseTextBoxV2}"
                                 FontSize="13"
                                 Padding="8,0,8,0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsTextBoxesEnabled}"/>
                        
                        <!-- Error message khi có kết nối nhưng output không phải số -->
                        <TextBlock Text="{Binding LoopCountErrorMessage}"
                                   Foreground="{DynamicResource DangerColor}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LoopCountErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- For Loop Configuration -->
                    <StackPanel x:Name="ForLoopPanel" Margin="0,0,0,16">
                        <TextBlock Text="Chỉ số bắt đầu:"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        
                        <TextBox x:Name="StartIndexTextBox"
                                 Height="36"
                                 Text="{Binding StartIndex, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource BaseTextBoxV2}"
                                 FontSize="13"
                                 Padding="8,0,8,0"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Chỉ số kết thúc:"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        
                        <TextBox x:Name="EndIndexTextBox"
                                 Height="36"
                                 Text="{Binding EndIndex, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource BaseTextBoxV2}"
                                 FontSize="13"
                                 Padding="8,0,8,0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsTextBoxesEnabled}"/>
                        
                        <!-- Error message khi có kết nối nhưng output không phải số -->
                        <TextBlock Text="{Binding LoopCountErrorMessage}"
                                   Foreground="{DynamicResource DangerColor}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LoopCountErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- For Each Array Info -->
                    <StackPanel x:Name="ForEachArrayPanel" Margin="0,0,0,16">
                        <TextBlock Text="Sử dụng Chrome input (≡) để kết nối mảng dữ liệu từ node khác"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Opacity="0.8"
                                   Margin="0,8,0,0"/>

                        <!-- Outputs available in loop -->
                        <TextBlock Text="Outputs trong vòng lặp:"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Margin="0,10,0,4"/>
                        <TextBlock Text="• index: chỉ số hiện tại (0..n-1)"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   Opacity="0.8"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="• item: giá trị phần tử hiện tại"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   Opacity="0.8"
                                   Margin="0,0,0,6"/>
                        
                        <!-- Error message khi có kết nối nhưng output không phải mảng -->
                        <TextBlock Text="{Binding LoopArrayErrorMessage}"
                                   Foreground="{DynamicResource DangerColor}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LoopArrayErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Inputs Section -->
                    <TextBlock Text="Inputs:" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Style="{DynamicResource DialogOuterBorder}" CornerRadius="8" Padding="12" Margin="0,0,0,16">
                        <StackPanel x:Name="InputsPanel"/>
                    </Border>

                    <!-- Outputs Section -->
                    <TextBlock Text="Outputs:" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" x:Name="TextBlockOutputPanel"/>
                    <Border Style="{DynamicResource DialogOuterBorder}" CornerRadius="8" Padding="12" Margin="0,0,0,8" x:Name="BorderOutputPanel">
                        <StackPanel>
                            <StackPanel x:Name="OutputsPanel"/>
                            <!-- Output tùy chỉnh: chọn node + key trong body -->
                            <TextBlock Text="Output tùy chỉnh (từ node trong body):" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.9" Margin="0,12,0,6"/>
                            <StackPanel x:Name="CustomOutputsPanel"/>
                            <Button x:Name="AddCustomOutputButton" Content="+" Width="28" Height="28" FontSize="16" FontWeight="Bold"
                                    Margin="0,6,0,0" Click="AddCustomOutputButton_Click"
                                    Style="{DynamicResource PrimaryButton}" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- Gán dữ liệu trong vòng lặp -->
                    <TextBlock Text="Gán dữ liệu trong vòng lặp:" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Gán giá trị từ output của node nguồn sang key của node đích (mỗi iteration)." 
                               Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <Border Style="{DynamicResource DialogOuterBorder}" CornerRadius="8" Padding="12" Margin="0,0,0,8" x:Name="BorderAssignPanel">
                        <StackPanel>
                            <StackPanel x:Name="DataAssignmentsPanel"/>
                            <Button x:Name="AddAssignmentButton" Content="+" Width="28" Height="28" FontSize="16" FontWeight="Bold"
                                    Margin="0,8,0,0" Click="AddAssignmentButton_Click"
                                    Style="{DynamicResource PrimaryButton}" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Tái sử dụng flow -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Chỉ cấu hình vị trí cổng IN cho LoopNode (cổng OUT do renderer chuyên biệt quản lý) -->
                            <TextBlock Text="Vị trí cổng IN:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Port IN (cổng vào)"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           Opacity="0.8"
                                           Margin="0,0,0,4"/>
                                <ComboBox Height="32"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding PortPositionOptions}"
                                          SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                            </StackPanel>

                            <!-- Cấu hình tái sử dụng flow -->
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Cột 1: Node IN (readonly) -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Cột 2: Node OUT -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <!-- Cột 3: Kiểu line -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
