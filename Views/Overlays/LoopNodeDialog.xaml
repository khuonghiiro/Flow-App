<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.LoopNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:converters="clr-namespace:FlowMy.Converters"
        Title="Loop Node Dialog"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MaxWidth="700"
        MinHeight="420">
    <Window.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converters:InverseStringNullOrEmptyToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                          Grid.Column="0"
                          Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource BaseTextBoxV2}"
                          FontSize="16"
                          Padding="0,4,0,4"
                          VerticalContentAlignment="Center"
                          Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="×" 
                            FontSize="12" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: 2 tab Logic + Tái sử dụng flow -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic (giữ nguyên nội dung cũ) -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>

                    <!-- Cấu hình hiển thị -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🎨 Cấu hình hiển thị" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Hiển thị tiêu đề" 
                                       Foreground="{DynamicResource TextMuted}" 
                                       FontSize="10" Margin="0,0,0,4"/>
                            <ComboBox x:Name="TitleDisplayModeComboBox"
                                      Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,8"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <TextBlock Text="Màu tiêu đề" 
                                       Foreground="{DynamicResource TextMuted}" 
                                       FontSize="10" Margin="0,0,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="32"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}"
                                          SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                          SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                <Border x:Name="TitleColorPreview" Grid.Column="1"
                                        Width="32" Height="32" CornerRadius="6" Margin="8,0,0,0"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" 
                                        BorderThickness="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 🔄 Loop Configuration -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🔄 Loop Configuration" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            
                            <TextBlock Text="Loại vòng lặp" 
                                       Foreground="{DynamicResource TextMuted}" 
                                       FontSize="10" Margin="0,0,0,4"/>
                            <ComboBox x:Name="LoopTypeComboBox"
                                      Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,0"
                                      ItemsSource="{Binding LoopTypeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding LoopType, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- Repeat N Times Configuration -->
                    <StackPanel x:Name="RepeatNPanel" Margin="0,0,0,12">
                        <TextBlock Text="Số lần lặp" 
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        
                        <TextBox x:Name="RepeatCountTextBox"
                                 Height="32"
                                 Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource BaseTextBoxV2}"
                                 FontSize="13"
                                 Padding="8,0,8,0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsTextBoxesEnabled}"/>
                        
                        <!-- Error message khi có kết nối nhưng output không phải số -->
                        <TextBlock Text="{Binding LoopCountErrorMessage}"
                                   Foreground="{DynamicResource DangerColor}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LoopCountErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- For Loop Configuration -->
                    <StackPanel x:Name="ForLoopPanel" Margin="0,0,0,12">
                        <TextBlock Text="Chỉ số bắt đầu" 
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        
                        <TextBox x:Name="StartIndexTextBox"
                                 Height="32"
                                 Text="{Binding StartIndex, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource BaseTextBoxV2}"
                                 FontSize="13"
                                 Padding="8,0,8,0"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Chỉ số kết thúc" 
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        
                        <TextBox x:Name="EndIndexTextBox"
                                 Height="32"
                                 Text="{Binding EndIndex, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource BaseTextBoxV2}"
                                 FontSize="13"
                                 Padding="8,0,8,0"
                                 VerticalContentAlignment="Center"
                                 IsEnabled="{Binding IsTextBoxesEnabled}"/>
                        
                        <!-- Error message khi có kết nối nhưng output không phải số -->
                        <TextBlock Text="{Binding LoopCountErrorMessage}"
                                   Foreground="{DynamicResource DangerColor}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LoopCountErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- For Each Array Info -->
                    <StackPanel x:Name="ForEachArrayPanel" Margin="0,0,0,12">
                        <TextBlock Text="Sử dụng Chrome input (≡) để kết nối mảng dữ liệu từ node khác"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"/>

                        <!-- Outputs available in loop -->
                        <TextBlock Text="Outputs trong vòng lặp" 
                                   Foreground="{DynamicResource TextBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="• index: chỉ số hiện tại (0..n-1)"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="10"
                                   Margin="0,0,0,2"/>
                        <TextBlock Text="• item: giá trị phần tử hiện tại"
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="10"
                                   Margin="0,0,0,6"/>
                        
                        <!-- Error message khi có kết nối nhưng output không phải mảng -->
                        <TextBlock Text="{Binding LoopArrayErrorMessage}"
                                   Foreground="{DynamicResource DangerColor}"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding LoopArrayErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- 📊 Inputs/Outputs -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📊 Inputs/Outputs" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <StackPanel x:Name="InputsPanel"/>
                            <StackPanel x:Name="OutputsPanel"/>
                            <!-- Output tùy chỉnh: chọn node + key trong body -->
                            <TextBlock Text="Output tùy chỉnh (từ node trong body)" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,12,0,6"/>
                            <StackPanel x:Name="CustomOutputsPanel"/>
                            <Button x:Name="AddCustomOutputButton" Content="+" Width="28" Height="28" FontSize="16" FontWeight="Bold"
                                    Margin="0,6,0,0" Click="AddCustomOutputButton_Click"
                                    Style="{DynamicResource PrimaryButton}" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔄 Gán dữ liệu trong vòng lặp -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12" x:Name="BorderAssignPanel">
                        <StackPanel>
                            <TextBlock Text="🔄 Gán dữ liệu trong vòng lặp" 
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Gán giá trị từ output của node nguồn sang key của node đích (mỗi iteration)" 
                                       Foreground="{DynamicResource TextMuted}" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <StackPanel x:Name="DataAssignmentsPanel"/>
                            <Button x:Name="AddAssignmentButton" Content="+" Width="28" Height="28" FontSize="16" FontWeight="Bold"
                                    Margin="0,8,0,0" Click="AddAssignmentButton_Click"
                                    Style="{DynamicResource PrimaryButton}" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Tái sử dụng flow -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN -->
                            <TextBlock Text="Vị trí cổng IN"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Port IN"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                    <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10" TextWrapping="Wrap" Margin="0,8,0,0">
                                        <Run Text="LoopNode có cổng OUT do renderer chuyên biệt quản lý"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Cấu hình tái sử dụng flow -->
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Cột 1: Node IN (readonly) -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Cột 2: Node OUT -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <!-- Cột 3: Kiểu line -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
