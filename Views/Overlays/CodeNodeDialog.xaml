                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: 2 tab Logic + T�i s? d?ng flow -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <TextBlock Text="Hi?n th? ti�u d?:"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="TitleDisplayModeComboBox" Height="36"
                              Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                              ItemsSource="{Binding TitleDisplayModeOptions}"
                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                    <TextBlock Text="M�u ti�u d?:" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="36"
                                  Style="{DynamicResource BaseComboBox}"
                                  ItemsSource="{Binding TitleColorOptions}"
                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                        <Border Grid.Column="1" x:Name="TitleColorPreview"
                                Width="36" Height="36" CornerRadius="6" Margin="8,0,0,0"
                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                    </Grid>

                    <!-- Input: nhi?u d�ng Node + Key + Key t�y ch?nh -->
                    <TextBlock Text="Input (node ngu?n + key) � m?i d�ng = m?t bi?n trong code:"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ItemsControl x:Name="InputMappingsItemsControl" ItemsSource="{Binding InputMappingsList}" Margin="0,0,0,6">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,8">
                                    <!-- Checkbox cho ph�p ch?y l?i logic -->
                                    <CheckBox IsChecked="{Binding ShouldReExecute, Mode=TwoWay}"
                                              Margin="0,0,0,6"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="12">
                                        <TextBlock TextWrapping="Wrap">
                                            <Run Text="Cho ph�p ch?y l?i logic node ngu?n d? l?y d? li?u m?i nh?t"/>
                                            <Run Text=" (b? t�ch = ch? l?y data c� s?n, kh�ng re-execute)" Foreground="{DynamicResource TextSecondary}" FontSize="11"/>
                                        </TextBlock>
                                    </CheckBox>
                                    
                                    <!-- D�ng input mapping -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Node" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                            <ComboBox Height="36" Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding DataContext.AvailableNodeOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                      SelectedValue="{Binding SourceNodeId, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Key" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                            <ComboBox Height="36" Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding AvailableOutputKeyOptions}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValue="{Binding SourceOutputKey, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="4">
                                            <TextBlock Text="Bi?n trong code (tr?ng = d�ng key d� ch?n)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBox Text="{Binding InputKeyOverride, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource BaseTextBoxV2}" Height="36"
                                                     ToolTip="T�n bi?n trong code. �? tr?ng th� d�ng key t? combobox Key."/>
                                        </StackPanel>
                                        <Button Grid.Column="5" Content="-" Width="28" Height="28" Margin="8,0,0,0" VerticalAlignment="Bottom"
                                                Command="{Binding DataContext.RemoveInputMappingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Foreground="{DynamicResource TextBrush}" Background="{DynamicResource DangerBrush}" BorderThickness="0" Cursor="Hand"/>
                                    </Grid>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ Th�m input" Height="32" Margin="0,0,0,8"
                            Command="{Binding AddInputMappingCommand}"
                            Width="120" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left"/>
                    <TextBlock Margin="0,0,0,12" Foreground="{DynamicResource TextSecondary}" FontSize="12">
                        <Run Text="Bi?n trong code: "/>
                        <Run Text="{Binding EffectiveInputKeyDisplay, Mode=OneWay}" FontWeight="SemiBold"/>
                    </TextBlock>

                    <!-- Code editor: font size + ph�ng to popup -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Code (JavaScript). return { key: value }; ho?c d�ng function main()."
                                   Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"
                                   ToolTip="Xem th�m: m? 'V� d? ch?y code &amp; G?i �' d? bi?t c�ch tr? v? khi c� nhi?u h�m."/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button x:Name="ExpandCodeButton" Content="? Ph�ng to" Width="90" Height="28" Margin="0,0,6,0"
                                    ToolTip="M? c?a s? so?n code l?n hon"
                                    Foreground="{DynamicResource TextBrush}" Background="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                    Cursor="Hand" Padding="8,0" FontSize="12" Click="ExpandCodeButton_Click"/>
                            <Button Content="A-" Width="28" Height="28" Margin="0,0,4,0"
                                    Command="{Binding DecreaseCodeFontSizeCommand}"
                                    Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                    Cursor="Hand" Padding="0" FontSize="14"/>
                            <Button Content="A+" Width="28" Height="28"
                                    Command="{Binding IncreaseCodeFontSizeCommand}"
                                    Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                    Cursor="Hand" Padding="0" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Margin="0,0,0,4" Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap">
                        <Run Text="Tip: Output 'js' g?i sang WebNode c� th? ch?nh timeout ch? outputs b?ng comment:"/>
                        <LineBreak/>
                        <Run Text="// AC_RESPONSE_TIMEOUT_MS=0" FontFamily="Consolas" Foreground="{DynamicResource WarningColor}"/>
                        <Run Text="  (kh�ng ch? outputs, b? qua timeout)"/>
                        <LineBreak/>
                        <Run Text="// AC_RESPONSE_TIMEOUT_MS=3000" FontFamily="Consolas" Foreground="{DynamicResource WarningColor}"/>
                        <Run Text="  (ch? t?i da 3000ms, n?u kh�ng ghi d�ng n�y th� d�ng timeout m?c d?nh c?a WebNode)."/>
                    </TextBlock>
                    <controls:SyntaxHighlightCodeEditor x:Name="CodeEditor"
                             Text="{Binding ScriptCode, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                             IsAutoHighlightEnabled="False"
                             MinHeight="140" MaxHeight="320" Margin="0,0,0,12"/>

                    <!-- V� d? & G?i � -->
                    <Expander x:Name="ExampleHintsExpander" IsExpanded="False" Margin="0,0,0,12">
                        <Expander.Header>
                            <TextBlock Text="V� d? ch?y code &amp; G?i �" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
                        </Expander.Header>
                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="8" Padding="14" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="C�ch ch?y:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="1) Ch?n Node + Key l�m input (v� d? node HttpRequest, key responseBody)."/>
                                    <LineBreak/>
                                    <Run Text="2) Bi?n trong code = t�n key (ho?c key t�y ch?nh). Ch?y workflow ? node Code l?y data t? node ngu?n, g�n v�o bi?n r?i ch?y script."/>
                                    <LineBreak/>
                                    <Run Text="3) Script ph?i tr? v? object { key: value }. C�c key tr�ng v?i Output keys s? du?c dua ra node."/>
                                </TextBlock>
                                <TextBlock Text="Nhi?u input c�ng t�n bi?n:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="Khi c� nhi?u input d�ng c�ng t�n bi?n (vd. 2 node d?u map v�o bi?n &quot;input&quot;): h? th?ng s? �p d?ng bi?n t? node dang c� logic ch?y d?n Code node. Node kh�c chua ch?y t?i kh�ng �p d?ng. Bi?n kh�c t�n th� �p d?ng b�nh thu?ng."/>
                                </TextBlock>
                                <TextBlock Text="Nhi?u h�m � c�ch tr? v? (d�ng main):" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6">
                                    <Run Text="Khi b?n vi?t nhi?u h�m (v� d? processOrder, helper...) m� kh�ng c� bi?u th?c return ? cu?i script, h? th?ng s? t? t�m v� g?i "/>
                                    <Run Text="function main()" FontWeight="SemiBold" Foreground="{DynamicResource SuccessColor}"/>
                                    <Run Text=". B?n ch? c?n d?nh nghia main() v� trong d� return object k?t qu?."/>
                                </TextBlock>
                                <Border Background="{DynamicResource CardColor}" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="� C�ch 1 (khuy?n ngh?): �?nh nghia function main() v� return object trong main." Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                            <Run Text="function processOrder(order) { ... }"/>
                                            <LineBreak/>
                                            <Run Text="function main() { return processOrder("/>
                                            <Run Text="{Binding EffectiveInputKeyDisplay, Mode=OneWay}" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text="); }"/>
                                        </TextBlock>
                                        <TextBlock Text="� C�ch 2: Vi?t bi?u th?c cu?i c�ng l� l?i g?i h�m tr? object (v� d? processOrder(input);)." Foreground="{DynamicResource TextSecondary}"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Bi?n &amp; h�m g?i �:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource CardColor}" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,4">
                                            <Run Text="� Bi?n input: " Foreground="{DynamicResource TextSecondary}"/>
                                            <Run Text="{Binding EffectiveInputKeyDisplay, Mode=OneWay}" Foreground="{DynamicResource WarningColor}" FontWeight="SemiBold"/>
                                            <Run Text=" (chu?i t? node ngu?n)" Foreground="{DynamicResource TextSecondary}"/>
                                        </TextBlock>
                                        <TextBlock Text="� JSON.parse(str) � chuy?n chu?i JSON th�nh object" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="� JSON.stringify(obj) � chuy?n object th�nh chu?i JSON" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="� return { key1: value1, key2: value2 }; � b?t bu?c d? tr? output" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="� Output 'js' ch?y trong WebView2 (kh�ng c� bi?n t? input): nh�ng gi� tr? b?ng string concatenation:" Foreground="{DynamicResource WarningColor}" Margin="0,4,0,2"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,4">
                                            <Run Text="const textToInput = JSON.stringify("/>
                                            <Run Text="{Binding FirstInputVariableName, Mode=OneWay}" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text=");"/>
                                            <LineBreak/>
                                            <Run Text="return { js: 'const textToInput = ' + textToInput + '; ...' };"/>
                                        </TextBlock>
                                        <TextBlock Text="Ho?c d�ng template literal (n?u Jint h? tr?):" Foreground="{DynamicResource TextSecondary}" FontSize="10" Margin="0,4,0,2"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                            <Run Text="return { js: `const textToInput = ${JSON.stringify("/>
                                            <Run Text="{Binding FirstInputVariableName, Mode=OneWay}" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text=")}; ...` };"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="V� d? (input l� chu?i JSON c� m?ng items):" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="{DynamicResource CardColor}" Padding="10" CornerRadius="6">
                                    <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                        <Run Text="var data = JSON.parse("/>
                                        <Run Text="{Binding EffectiveInputKeyDisplay, Mode=OneWay}" Foreground="{DynamicResource WarningColor}"/>
                                        <Run Text=");"/>
                                        <LineBreak/>
                                        <Run Text="var count = data.items ? data.items.length : 0;"/>
                                        <LineBreak/>
                                        <Run Text="var first = data.items &amp;&amp; data.items[0] ? data.items[0] : '';"/>
                                        <LineBreak/>
                                        <Run Text="return { count: count, first: first };"/>
                                    </TextBlock>
                                </Border>
                                <Button Content="Ch�n m?u co b?n" Command="{Binding InsertExampleSnippetCommand}"
                                        Width="140" Height="28" Margin="0,10,0,0" HorizontalAlignment="Left"
                                        Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" Cursor="Hand" Padding="8,0" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Expander>

                    <!-- Output keys -->
                    <TextBlock Text="Output keys (tr�ng v?i key trong object return):"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <ItemsControl x:Name="OutputKeysItemsControl" ItemsSource="{Binding OutputKeysList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{DynamicResource BaseTextBoxV2}" Height="32"
                                                     FontSize="13"/>
                                            <Button Grid.Column="1" Content="-" Width="28" Height="28" Margin="8,0,0,0"
                                                    Command="{Binding DataContext.RemoveOutputKeyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Foreground="{DynamicResource TextBrush}" Background="{DynamicResource DangerBrush}" BorderThickness="0" Cursor="Hand"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Content="+ Th�m output key" Height="32" Margin="0,8,0,0"
                                    Command="{Binding AddOutputKeyCommand}"
                                    Width="120"
                                    Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <StackPanel x:Name="InputsPanel" Visibility="Collapsed"/>
                    <StackPanel x:Name="OutputsPanel" Visibility="Collapsed"/>
                </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: T�i s? d?ng flow -->
                <TabItem Header="T�i s? d?ng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- C?u h�nh v? tr� c?ng IN/OUT -->
                            <TextBlock Text="V? tr� c?ng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Port IN -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN (c?ng v�o)"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Port OUT -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT (c?ng ra)"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <!-- C?u h�nh t�i s? d?ng flow -->
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Ki?u line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
