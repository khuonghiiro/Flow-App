<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.ConditionalNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        Title="Điều kiện If-Else"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="480"
        MinWidth="350"
        MaxWidth="900"
        MinHeight="400">
    <local:BaseNodeDialog.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
    </local:BaseNodeDialog.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             Cursor="IBeam"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>

                                            <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="×" 
                            FontSize="12" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Visual Mode Selector -->
            <Border Grid.Row="1" Padding="16,8,16,8">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Kiểu giao diện:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <ComboBox x:Name="VisualModeComboBox"
                              Height="30"
                              MinWidth="160"
                              Style="{DynamicResource BaseComboBox}"
                              ItemsSource="{Binding VisualModeOptions}"
                              SelectedItem="{Binding SelectedVisualMode, Mode=TwoWay}"
                              VerticalContentAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Content: 2 tab Logic + Tái sử dụng flow -->
            <TabControl Grid.Row="2"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <TextBlock Text="Các điều kiện (số bên cạnh port out tương ứng với tiêu đề Điều kiện N):"
                               Foreground="{DynamicResource TextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <ItemsControl x:Name="ConditionsItemsControl" ItemsSource="{Binding Conditions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#22FFFFFF" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                        CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Title + OR/AND + nút xóa -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0"
                                                    Background="#33FFFFFF"
                                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="10"
                                                    Padding="8,2"
                                                    Margin="0,0,8,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayOrder, StringFormat=Điều kiện #{0}}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="11"
                                                           FontWeight="Bold"/>
                                            </Border>
                                            <TextBox Grid.Column="1" Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                       Style="{DynamicResource BaseTextBoxV2}"
                                                       Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold"
                                                       VerticalContentAlignment="Center" Padding="8,4"
                                                       MinWidth="120" Cursor="IBeam"/>
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0"
                                                        Visibility="{Binding IsElse, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                <Button Content="OR" Width="50" Height="24" FontSize="11" FontWeight="SemiBold"
                                                        ToolTip="Thêm điều kiện kết hợp || (OR)"
                                                        Command="{Binding AddWithOrCommand}"
                                                        Style="{DynamicResource PrimaryButton}" Cursor="Hand" Margin="0,0,4,0"/>
                                                <Button Content="AND" Width="50" Height="24" FontSize="11" FontWeight="SemiBold"
                                                        ToolTip="Thêm điều kiện kết hợp &amp;&amp; (AND)"
                                                        Command="{Binding AddWithAndCommand}"
                                                        Style="{DynamicResource PrimaryButton}" Cursor="Hand"/>
                                            </StackPanel>
                                            <Button Grid.Column="3" Content="−" Width="24" Height="24" FontSize="14" FontWeight="Bold"
                                                    Command="{Binding DataContext.RemoveConditionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Visibility="{Binding CanRemove, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Style="{DynamicResource WarningButton}" Cursor="Hand" Margin="8,0,0,0"/>
                                        </Grid>
                                        <!-- Sub-conditions với scroll -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="280" Margin="0,0,0,0"
                                                      Visibility="{Binding IsElse, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                            <ItemsControl ItemsSource="{Binding SubConditions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#18FFFFFF" BorderBrush="#28FFFFFF" BorderThickness="1"
                                                                CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="Auto"/>
                                                                </Grid.RowDefinitions>
                                                                <!-- Badge OR/AND + nút xóa (ẩn khi IsFirst) -->
                                                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6"
                                                                            Visibility="{Binding IsFirst, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                                    <Border Background="#44FF9800" CornerRadius="4" Padding="8,4" Margin="0,0,8,0">
                                                                        <TextBlock Text="{Binding OperatorLabel}" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="Bold"/>
                                                                    </Border>
                                                                    <Button Content="×" Width="20" Height="20" FontSize="12"
                                                                            Command="{Binding DataContext.RemoveSubConditionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                            CommandParameter="{Binding}"
                                                                            Style="{DynamicResource WarningButton}" Cursor="Hand"/>
                                                                </StackPanel>
                                                                <!-- Node trái + Key trái: 2 cột bằng nhau -->
                                                                <Grid Grid.Row="1" Margin="0,0,0,6">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                                        <TextBlock Text="Node (trái):" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" HorizontalAlignment="Stretch"
                                                                                  ItemsSource="{Binding AvailableSourceNodes}"
                                                                                  SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                                                  SelectedValue="{Binding LeftSourceNodeId, Mode=TwoWay}"/>
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                                        <TextBlock Text="Key (trái):" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" HorizontalAlignment="Stretch"
                                                                                  ItemsSource="{Binding AvailableLeftKeys}"
                                                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                                                  SelectedValue="{Binding LeftKey, Mode=TwoWay}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                                <!-- Toán tử -->
                                                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
                                                                    <TextBlock Text="Điều kiện:" Foreground="{DynamicResource TextBrush}" FontSize="12" Width="80" VerticalAlignment="Center"/>
                                                                    <ComboBox Height="32" MinWidth="220" Style="{DynamicResource BaseComboBox}"
                                                                              ItemsSource="{Binding DataContext.OperatorOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                                                              SelectedValue="{Binding Operator, Mode=TwoWay}"/>
                                                                </StackPanel>
                                                                <!-- Bên phải -->
                                                                <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,0"
                                                                            Visibility="{Binding IsRightSideVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <CheckBox Content="Dùng giá trị nhập (so sánh với text bên dưới)"
                                                                              IsChecked="{Binding RightUseLiteralValue, Mode=TwoWay}"
                                                                              Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,6"/>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6"
                                                                                Visibility="{Binding RightUseLiteralValue, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <TextBlock Text="Giá trị so sánh:" Foreground="{DynamicResource TextBrush}" FontSize="12" Width="100" VerticalAlignment="Center"/>
                                                                        <TextBox Height="32" MinWidth="200" Style="{DynamicResource BaseTextBoxV2}" Margin="8,0,0,0"
                                                                                 Text="{Binding RightLiteralValue, UpdateSourceTrigger=PropertyChanged}"
                                                                                 VerticalContentAlignment="Center" Padding="8,0,8,0"/>
                                                                    </StackPanel>
                                                                    <!-- Node phải + Key phải: 2 cột bằng nhau -->
                                                                    <Grid Visibility="{Binding RightUseLiteralValue, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <StackPanel Grid.Column="0" Margin="0,0,4,0">
                                                                            <TextBlock Text="Node (phải):" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                                                            <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" HorizontalAlignment="Stretch"
                                                                                      ItemsSource="{Binding AvailableSourceNodes}"
                                                                                      SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                                                      SelectedValue="{Binding RightSourceNodeId, Mode=TwoWay}"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                                                            <TextBlock Text="Key (phải):" Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,4"/>
                                                                            <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" HorizontalAlignment="Stretch"
                                                                                      ItemsSource="{Binding AvailableRightKeys}"
                                                                                      SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                                                      SelectedValue="{Binding RightKey, Mode=TwoWay}"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="+ Thêm điều kiện else if" Height="36" Margin="0,8,0,0"
                            Command="{Binding AddConditionCommand}"
                            Style="{DynamicResource PrimaryButton}" Cursor="Hand"/>

                    <!-- Inputs/Outputs (empty for conditional node) -->
                    <StackPanel x:Name="InputsPanel" Margin="0,16,0,0"/>
                    <StackPanel x:Name="OutputsPanel" Margin="0,0,0,0" Visibility="Collapsed"/>
                </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Tái sử dụng flow -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Vị trí cổng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Port IN (cổng vào)"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           Opacity="0.8"
                                           Margin="0,0,0,4"/>
                                <ComboBox Height="32"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding PortPositionOptions}"
                                          SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Port OUT (cổng ra các nhánh)"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="12"
                                           Opacity="0.8"
                                           Margin="0,0,0,4"/>
                                <ComboBox Height="32"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding PortPositionOptions}"
                                          SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                            </StackPanel>

                            <!-- ConditionalNode có nhiều port OUT (mỗi nhánh if/else if/else), không dùng ReuseRoutes -->
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
