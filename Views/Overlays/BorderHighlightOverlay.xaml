<Window x:Class="FlowMy.Views.Overlays.BorderHighlightOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Border Highlight"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="Manual"
        SizeToContent="Manual"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Focusable="False"
        ResizeMode="NoResize">

    <Grid x:Name="GlowBorder" IsHitTestVisible="False">
        
        <!-- Vạch cực mỏng ngoài cùng -->
        <Border x:Name="OuterBorder" BorderThickness="2" CornerRadius="0"/>

        <!-- Linear Gradient fade từ mép vào trong -->
        <Rectangle x:Name="TopGradient" Height="15" VerticalAlignment="Top" IsHitTestVisible="False"/>
        <Rectangle x:Name="BottomGradient" Height="15" VerticalAlignment="Bottom" IsHitTestVisible="False"/>
        <Rectangle x:Name="LeftGradient" Width="15" HorizontalAlignment="Left" IsHitTestVisible="False"/>
        <Rectangle x:Name="RightGradient" Width="15" HorizontalAlignment="Right" IsHitTestVisible="False"/>

    </Grid>
</Window>
