<Window x:Class="FlowMy.Views.Overlays.KeyCaptureDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KeyCaptureDialog"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowState="Maximized"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <!-- Overlay tối toàn màn hình -->
        <Rectangle Fill="#80000000"
                   IsHitTestVisible="False"/>
        
        <!-- Dialog content ở giữa màn hình -->
        <Border Style="{DynamicResource DialogOuterBorder}"
                Padding="20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MinWidth="300"
                MaxWidth="400">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="0"
                                  BlurRadius="20"
                                  Opacity="0.5"
                                  Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Nhấn một phím..."
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Dialog sẽ tự đóng sau khi nhận phím"
                           FontSize="12"
                           Foreground="{DynamicResource TextBrush}"
                           Opacity="0.85"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>

