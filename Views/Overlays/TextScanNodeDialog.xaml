<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.TextScanNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:converters="clr-namespace:FlowMy.Converters"
        Title="Text Scan (OCR)"
        WindowStyle="None" ResizeMode="CanResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        Width="540" MinWidth="440" MinHeight="480">

    <local:BaseNodeDialog.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </local:BaseNodeDialog.Resources>

    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TitleTextBox" Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16" Padding="0,4" VerticalContentAlignment="Center" Cursor="IBeam"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="24" Height="24" Content="▶" FontSize="12" Padding="0" Margin="8,0,0,0"
                                Style="{DynamicResource PrimaryButton}" Cursor="Hand" ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton" Width="24" Height="24" Padding="0" Content="✕" FontSize="12" 
                                FontWeight="Bold" Margin="8,0,0,0" Cursor="Hand"
                                Style="{DynamicResource DangerButton}" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <!-- TAB: LOGIC -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình hiển thị -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Cấu hình hiển thị" Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Hiển thị tiêu đề" Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>
                                    <TextBlock Text="Màu tiêu đề" Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Border x:Name="TitleColorPreview" Grid.Column="1"
                                                Width="32" Height="32" CornerRadius="6" Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- OCR Engine -->
                            <TextBlock Text="OCR Engine" Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" Margin="0,0,0,12"
                                      ItemsSource="{Binding OcrEngineModeOptions}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding OcrEngineMode, Mode=TwoWay}"/>

                            <!-- Tesseract Settings -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12"
                                    Visibility="{Binding IsTesseractMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="⚙️ Cấu hình Tesseract" Foreground="{DynamicResource TextBrush}"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Text="Thư mục tessdata" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="TessdataPathTextBox" Grid.Column="0" Height="32"
                                                 Text="{Binding TessdataPath, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource BaseTextBoxV2}" VerticalContentAlignment="Center"/>
                                        <Button Grid.Column="1" Content="📁" Height="32" Width="32" Padding="0" Margin="6,0,0,0"
                                                Style="{DynamicResource SecondaryButton}" ToolTip="Chọn thư mục" Cursor="Hand"
                                                Click="BrowseTessdataButton_Click"/>
                                    </Grid>
                                    <TextBlock Text="Page Seg Mode" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                                              ItemsSource="{Binding TesseractPageSegModeOptions}"
                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TesseractPageSegMode, Mode=TwoWay}"/>
                                    <TextBlock Text="Engine Mode" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding TesseractEngineModeOptions}"
                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TesseractEngineMode, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- Image Source Mode -->
                            <TextBlock Text="Nguồn ảnh" Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" Margin="0,0,0,12"
                                      ItemsSource="{Binding ImageSourceModeOptions}"
                                      SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding ImageSourceMode, Mode=TwoWay}"/>

                            <!-- MODE: Screen Capture -->
                            <StackPanel x:Name="ScreenCapturePanel"
                                        Visibility="{Binding IsScreenCaptureMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="📍 Input — Toạ độ vùng cắt" Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Node" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                                <controls:NodeSearchComboBoxUserControl x:Name="CoordSourceNodeId" Height="32"
                                                          ItemsSource="{Binding AvailableNodeOptions}"
                                                          SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                          SelectedValue="{Binding CoordSourceNodeId, Mode=TwoWay}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Key" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="CoordSourceOutputKey" Height="32" Style="{DynamicResource BaseComboBox}"
                                                          ItemsSource="{Binding CoordKeyOptions}"
                                                          SelectedValuePath="Key" DisplayMemberPath="Key"
                                                          SelectedValue="{Binding CoordSourceOutputKey, Mode=TwoWay}"
                                                          IsSynchronizedWithCurrentItem="False"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Ứng dụng cần chụp" Foreground="{DynamicResource TextBrush}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="SelectedTargetWindow" Grid.Column="0" Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding ActiveWindows}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"/>
                                    <Button Grid.Column="1" Content="↻" Height="32" Width="32" Padding="0" Margin="6,0,0,0"
                                            Style="{DynamicResource SecondaryButton}" ToolTip="Tải lại" Cursor="Hand"
                                            Command="{Binding LoadWindowsCommand}"/>
                                </Grid>

                                <!-- Background Mode Checkbox -->
                                <CheckBox IsChecked="{Binding UseBackgroundMode, Mode=TwoWay}" Cursor="Hand" Margin="0,0,0,12"
                                          Visibility="{Binding ShowBackgroundModeCheckbox, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="📸 Chụp không cần active app (chạy ngầm)"/>
                                    </TextBlock>
                                </CheckBox>
                            </StackPanel>

                            <!-- MODE: From Node -->
                            <StackPanel x:Name="FromNodePanel"
                                        Visibility="{Binding IsFromNodeMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="📍 Input — Ảnh từ node" Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Node" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                                <controls:NodeSearchComboBoxUserControl x:Name="ImageSourceNodeId" Height="32"
                                                          ItemsSource="{Binding AvailableNodeOptions}"
                                                          SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                          SelectedValue="{Binding ImageSourceNodeId, Mode=TwoWay}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Key" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="ImageSourceOutputKey" Height="32" Style="{DynamicResource BaseComboBox}"
                                                          ItemsSource="{Binding ImageKeyOptions}"
                                                          SelectedValuePath="Key" DisplayMemberPath="Key"
                                                          SelectedValue="{Binding ImageSourceOutputKey, Mode=TwoWay}"
                                                          IsSynchronizedWithCurrentItem="False"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- MODE: Path/URL -->
                            <StackPanel x:Name="PathUrlPanel"
                                        Visibility="{Binding IsPathUrlMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Path / URL" Foreground="{DynamicResource TextBrush}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Height="32"
                                             Text="{Binding ImagePath, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}" VerticalContentAlignment="Center"/>
                                    <Button x:Name="BrowseImageButton" Grid.Column="1" Content="📂" Height="32" Width="32" Padding="0"
                                            Style="{DynamicResource PrimaryButton}" Margin="6,0,0,0" Cursor="Hand"
                                            Click="BrowseImageButton_Click"/>
                                </Grid>
                            </StackPanel>

                            <!-- MODE: Base64 -->
                            <StackPanel x:Name="Base64Panel"
                                        Visibility="{Binding IsBase64Mode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Base64 string" Foreground="{DynamicResource TextBrush}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <TextBox Text="{Binding Base64Image, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource BaseTextBoxV2}" Height="80" TextWrapping="Wrap"
                                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12"/>
                            </StackPanel>

                            <!-- MODE: Manual Region -->
                            <StackPanel x:Name="ManualRegionPanel"
                                        Visibility="{Binding IsManualRegionMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Ứng dụng cần chụp" Foreground="{DynamicResource TextBrush}"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="ManualRegionTargetWindow" Grid.Column="0" Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding ActiveWindows}"
                                              DisplayMemberPath="DisplayName"
                                              SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"/>
                                    <Button Grid.Column="1" Content="↻" Height="32" Width="32" Padding="0" Margin="6,0,0,0"
                                            Style="{DynamicResource SecondaryButton}" ToolTip="Tải lại" Cursor="Hand"
                                            Command="{Binding LoadWindowsCommand}"/>
                                </Grid>

                                <!-- Background Mode Checkbox -->
                                <CheckBox IsChecked="{Binding UseBackgroundMode, Mode=TwoWay}" Cursor="Hand" Margin="0,0,0,10"
                                          Visibility="{Binding ShowBackgroundModeCheckbox, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="📸 Chụp không cần active app (chạy ngầm)"/>
                                    </TextBlock>
                                </CheckBox>

                                <Button x:Name="ManualCaptureButton" Content="📸 Chụp vùng thủ công" Height="36" Margin="0,0,0,10"
                                        Style="{DynamicResource PrimaryButton}" Cursor="Hand" Click="ManualCaptureButton_Click"/>
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Vùng đã chọn:" Foreground="{DynamicResource TextBrush}"
                                                   FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock x:Name="ManualRegionCoordinates" Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" FontFamily="Consolas" Text="Chưa chụp"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Language Settings -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding AutoDetectLanguage, Mode=TwoWay}" Cursor="Hand" Margin="0,0,0,10">
                                        <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center">
                                            <Run Text="Tự động phát hiện ngôn ngữ"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <StackPanel Visibility="{Binding AutoDetectLanguage, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <TextBlock Text="Ngôn ngữ OCR" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding OcrLanguageOptions}"
                                                  SelectedValuePath="Code" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding OcrLanguage, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Visibility="{Binding AutoDetectLanguage, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="Chọn ngôn ngữ để phát hiện" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                        <controls:MultiSelectComboBoxUserControl Height="36" Margin="0,4,0,0"
                                            ItemsSource="{Binding AvailableTesseractLanguages}"
                                            SelectedValues="{Binding SelectedLanguages, Mode=TwoWay}"
                                            DisplayMemberPath="DisplayName" SelectedValuePath="Code"
                                            PlaceholderText="Chọn ngôn ngữ..."/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Outputs -->
                            <TextBlock Text="Outputs" Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border Style="{DynamicResource DialogOuterBorder}" CornerRadius="8" Padding="10">
                                <StackPanel x:Name="OutputsPanel"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB: CẤU HÌNH -->
                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Vị trí cổng IN/OUT" Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Tái sử dụng flow" Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="ReuseRoutesItemsControl" ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,10" Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                        <ColumnDefinition Width="2*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}" FontSize="10" Opacity="0.7" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding IncomingNodeTitle}" Foreground="{DynamicResource TextBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}" FontSize="10" Opacity="0.7" Margin="0,0,0,4"/>
                                                        <controls:NodeSearchComboBoxUserControl Height="28"
                                                                  ItemsSource="{Binding OutgoingOptions}"
                                                                  SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                                  SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                        <TextBlock Text="Kiểu line OUT" Foreground="{DynamicResource TextBrush}" FontSize="10" Opacity="0.7" Margin="0,0,0,4"/>
                                                        <ComboBox Height="28" Style="{DynamicResource BaseComboBox}"
                                                                  ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                                  SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                </Grid>
                                                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                                    <TextBlock Text="Chức năng" Foreground="{DynamicResource TextBrush}" FontSize="10" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox x:Name="FunctionTypeComboBox" Height="28" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.FunctionTypeOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedFunctionType, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
