<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.DataFetcherNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        Title="Data Fetcher"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="430"
        Height="600"
        MinWidth="380"
        MinHeight="480">

    <local:BaseNodeDialog.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
    </local:BaseNodeDialog.Resources>

    <Border CornerRadius="12" Padding="0"
            Background="{DynamicResource WindowBodyBackground}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Fetch Now -->
                        <Button Width="24" Height="24"
                                Content="?"
                                FontSize="11"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="L?y gi� tr? ngay (preview)"
                                Command="{Binding FetchNowCommand}"/>
                        <!-- Play -->
                        <Button x:Name="PlayButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Content="?"
                                FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Ch?y logic node n�y"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <!-- Close -->
                        <Button x:Name="CloseButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="�"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="0,4,0,0">

                <!-- TAB LOGIC -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- TitleDisplayMode -->
                            <TextBlock Text="Hi?n th? ti�u d?:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <ComboBox Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,14"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <!-- Node ngu?n -->
                            <TextBlock Text="Node ngu?n (l?y output t? node n�o):"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <ComboBox Height="34"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,10"
                                      ItemsSource="{Binding AvailableNodeOptions}"
                                      SelectedValuePath="NodeId"
                                      DisplayMemberPath="Title"
                                      SelectedValue="{Binding SelectedSourceNodeId, Mode=TwoWay}"
                                      SelectionChanged="SourceNodeComboBox_SelectionChanged"/>

                            <!-- Output key (ch? hi?n khi kh�ng fetch t?t c?) -->
                            <TextBlock Text="Output key c? th? (d? tr?ng = l?y t?t c?):"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                       Margin="0,0,0,6"
                                       Visibility="{Binding HasSourceNode, Converter={StaticResource BoolToVisConverter}}"/>
                            <ComboBox Height="34"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,4"
                                      ItemsSource="{Binding AvailableOutputKeyOptions}"
                                      SelectedValuePath="Key"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding SelectedSourceOutputKey, Mode=TwoWay}"
                                      Visibility="{Binding HasSourceNode, Converter={StaticResource BoolToVisConverter}}"/>
                            <TextBlock Text="(N?u kh�ng ch?n key, DataFetcher s? copy TO�N B? outputs c?a node ngu?n)"
                                       Foreground="{DynamicResource TextMuted}" FontSize="10" TextWrapping="Wrap"
                                       Margin="0,0,0,10"
                                       Visibility="{Binding HasSourceNode, Converter={StaticResource BoolToVisConverter}}"/>

                            <!-- WebNode wait -->
                            <CheckBox Content="? Ch? trang WebNode load xong r?i m?i l?y"
                                      Foreground="{DynamicResource TextSecondary}" FontSize="12"
                                      IsChecked="{Binding WaitForWebNodeLoad, Mode=TwoWay}"
                                      Margin="0,0,0,14"
                                      Visibility="{Binding IsSourceWebNode, Converter={StaticResource BoolToVisConverter}}"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <!-- Preview -->
                            <TextBlock Text="Gi� tr? d� l?y (preview):"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource CardColor}" CornerRadius="6" Padding="10,8" Margin="0,0,0,14">
                                <TextBlock Text="{Binding FetchedValuePreview}"
                                           Foreground="{DynamicResource TextBrush}" FontSize="12"
                                           TextWrapping="Wrap" MaxHeight="80"/>
                            </Border>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <CheckBox Content="?? Ch?y l?i node ngu?n tru?c khi l?y d? li?u"
                                      Foreground="{DynamicResource PrimaryBrush}" FontSize="12"
                                      IsChecked="{Binding RunSourceNodeFirst, Mode=TwoWay}"
                                      Margin="16,0,0,4"
                                      ToolTip="Khi b?t: DataFetcher s? k�ch ho?t ch?y l?i node ngu?n (nhu nh?n ? c?a node d�) tru?c khi copy data. �?m b?o l?y du?c gi� tr? M?I NH?T d� node ngu?n chua ch?y."/>
                            <TextBlock Text="(B?t t�y ch?n n�y n?u node ngu?n chua ch?y ho?c c?n refresh tru?c khi l?y)"
                                       Foreground="{DynamicResource TextMuted}" FontSize="10" TextWrapping="Wrap"
                                       Margin="16,0,0,14"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>   
                            <!-- Timer -->
                            <TextBlock Text="? Timer t? d?ng:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <CheckBox Content="B?t Timer (t? d?ng l?y theo chu k?)"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12"
                                      IsChecked="{Binding EnableTimer, Mode=TwoWay}"
                                      Margin="0,0,0,8"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14"
                                        IsEnabled="{Binding EnableTimer}">
                                <TextBlock Text="Chu k?:" Foreground="{DynamicResource TextMuted}" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding TimerIntervalValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" Height="32"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         Margin="0,0,8,0"/>
                                <ComboBox Width="70" Height="32"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TimerUnitOptions}"
                                          SelectedItem="{Binding TimerUnit, Mode=TwoWay}"/>
                            </StackPanel>

                            <CheckBox Content="Ch? ch?y chu k? ch�nh khi output d� c� data (m?c d?nh: t?t)"
                                      Foreground="{DynamicResource PrimaryBrush}" FontSize="12"
                                      IsChecked="{Binding EnableDataReadyScan, Mode=TwoWay}"
                                      Margin="0,0,0,8"
                                      IsEnabled="{Binding EnableTimer}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding EnableTimer}" Value="True"/>
                                                    <Condition Binding="{Binding EnableDataReadyScan}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="Chu k? qu�t data:" Foreground="{DynamicResource TextMuted}" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding DataReadyScanIntervalValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         Width="70" Height="32"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         Margin="0,0,8,0"/>
                                <ComboBox Width="70" Height="32"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TimerUnitOptions}"
                                          SelectedItem="{Binding DataReadyScanUnit, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Text="Luu �: chu k? qu�t data kh�ng du?c l?n hon chu k? Timer ch�nh."
                                       Foreground="{DynamicResource TextMuted}" FontSize="10" TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <TextBlock Text="Key d�ng d? ki?m tra data-ready (ch?n 1 ho?c nhi?u):"
                                       Foreground="{DynamicResource TextMuted}" FontSize="12"
                                       Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource CardColor}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,0,0,6">
                                <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding DataReadyScanKeyOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <CheckBox Content="{Binding DisplayName}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Foreground="{DynamicResource TextSecondary}"
                                                          Margin="0,2,0,2"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>
                            <TextBlock Text="�? tr?ng danh s�ch n�y = d�ng logic cu (theo key c? th? ho?c b?t k? output c� data)."
                                       Foreground="{DynamicResource TextMuted}" FontSize="10" TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <!-- Realtime -->
                            <TextBlock Text="? Realtime:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <CheckBox Content="B?t Realtime (nh?n ngay khi node ngu?n x? l� xong)"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12"
                                      IsChecked="{Binding EnableRealtime, Mode=TwoWay}"
                                      Margin="0,0,0,8"/>
                            
                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <!-- Outputs Panel -->
                            <TextBlock x:Name="TextBlockOutputPanel"
                                       Text="Outputs (gi� tr? d� fetch):"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource WindowBodyBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,8"
                                    x:Name="BorderOutputPanel">
                                <StackPanel x:Name="OutputsPanel"/>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB C?U H�NH -->
                <TabItem Header="C?u h�nh" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- M�u ti�u d? -->
                            <TextBlock Text="M�u ti�u d?:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TitleColorComboBox"
                                          Grid.Column="0" Height="34"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                          SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                <Border Grid.Column="1" x:Name="TitleColorPreview"
                                        Width="34" Height="34" CornerRadius="6"
                                        Margin="8,0,0,0"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                            </Grid>

                            <!-- V? tr� Port IN/OUT -->
                            <TextBlock Text="V? tr� c?ng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Ki?u line OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Ghi ch�: DataFetcher ch?y theo flow khi c� port IN k?t n?i. Timer/Realtime l� ch? d? ph? th�m."
                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"
                                       Margin="0,0,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
