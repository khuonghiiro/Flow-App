<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.NotificationNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        Title="Notification Node"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        Height="620"
        MinWidth="420"
        MinHeight="420">
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             MinWidth="150"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Content="▶"
                                FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy node thông báo này"
                                Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="×"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- 🎨 Cấu hình hiển thị -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Cấu hình hiển thị" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Hiển thị tiêu đề" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 📝 Tiêu đề thông báo -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📝 Tiêu đề thông báo" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Source Node"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,0,0,4"/>
                                            <controls:NodeSearchComboBoxUserControl Height="32"
                                                                            x:Name="TitleSourceNodeComboBox"
                                                                            ItemsSource="{Binding TitleSourceNodes}"
                                                                            SelectedValue="{Binding TitleSelectedSourceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                            SelectedValuePath="NodeId"
                                                                            DisplayMemberPath="Title"
                                                                            PlaceholderText="Tìm node nguồn..."/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Source Key"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,0,0,4"/>
                                            <ComboBox Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding TitleOutputKeys}"
                                                      SelectedValue="{Binding TitleSelectedSourceOutputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 📄 Nội dung thông báo -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📄 Nội dung thông báo" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Source Node"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,0,0,4"/>
                                            <controls:NodeSearchComboBoxUserControl Height="32"
                                                      x:Name="ContentSourceNodeComboBox"
                                                      ItemsSource="{Binding ContentSourceNodes}"
                                                      SelectedValue="{Binding ContentSelectedSourceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="NodeId"
                                                      DisplayMemberPath="Title"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Source Key"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,0,0,4"/>
                                            <ComboBox Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding ContentOutputKeys}"
                                                      SelectedValue="{Binding ContentSelectedSourceOutputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 📝 Giá trị mặc định -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📝 Giá trị mặc định (khi không map từ node)" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Tiêu đề mặc định" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding StaticTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             Height="32"
                                             Margin="0,0,0,8"/>

                                    <TextBlock Text="Nội dung mặc định" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox Text="{Binding StaticContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             MinHeight="80"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Border>

                            <!-- ⏱️ Thời gian hiển thị -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⏱️ Thời gian hiển thị (giây)" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                            <TextBlock Text="Source Node / Key (optional)"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                                          x:Name="DurationSourceNodeComboBox"
                                                          Height="32"
                                                          ItemsSource="{Binding DurationSourceNodes}"
                                                          SelectedValue="{Binding DurationSelectedSourceNodeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="NodeId"
                                                          DisplayMemberPath="Title"
                                                          Margin="0,0,4,0"/>
                                                <ComboBox Grid.Column="1"
                                                          Height="32"
                                                          Style="{DynamicResource BaseComboBox}"
                                                          ItemsSource="{Binding DurationOutputKeys}"
                                                          SelectedValue="{Binding DurationSelectedSourceOutputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          SelectedValuePath="Key"
                                                          DisplayMemberPath="DisplayName"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Default (giây)"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       FontSize="10"
                                                       Margin="0,0,0,4"/>
                                            <TextBox Height="32"
                                                     Style="{DynamicResource BaseTextBoxV2}"
                                                     Text="{Binding DefaultDurationSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 🎨 Màu sắc popup thông báo -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Màu sắc popup thông báo" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Màu tiêu đề"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding TitleColorOptions}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValue="{Binding ToastTitleColorKey, Mode=TwoWay}"/>
                                            <Button Grid.Column="1"
                                                    Content="🎨"
                                                    Width="32"
                                                    Height="32"
                                                     Padding ="0"
                                                    Margin="8,0,0,0"
                                                    ToolTip="Chọn màu tuỳ ý"
                                                    Click="PickToastTitleColor_Click"/>
                                        </Grid>
                                        <Border x:Name="ToastTitleColorPreview"
                                                Height="18"
                                                Margin="0,4,0,0"
                                                CornerRadius="4"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Màu nội dung"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding TitleColorOptions}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValue="{Binding ToastContentColorKey, Mode=TwoWay}"/>
                                            <Button Grid.Column="1"
                                                    Content="🎨"
                                                    Width="32"
                                                    Height="32"
                                                     Padding ="0"
                                                    Margin="8,0,0,0"
                                                    ToolTip="Chọn màu tuỳ ý"
                                                    Click="PickToastContentColor_Click"/>
                                        </Grid>
                                        <Border x:Name="ToastContentColorPreview"
                                                Height="18"
                                                Margin="0,4,0,0"
                                                CornerRadius="4"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8">
                                        <TextBlock Text="Màu nền"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox Grid.Column="0"
                                                      Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding TitleColorOptions}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValue="{Binding ToastBackgroundColorKey, Mode=TwoWay}"/>
                                            <Button Grid.Column="1"
                                                    Content="🎨"
                                                    Width="32"
                                                    Height="32"
                                                     Padding ="0"
                                                    Margin="8,0,0,0"
                                                    ToolTip="Chọn màu tuỳ ý"
                                                    Click="PickToastBackgroundColor_Click"/>
                                        </Grid>
                                        <Border x:Name="ToastBackgroundColorPreview"
                                                Height="18"
                                                Margin="0,4,0,0"
                                                CornerRadius="4"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,0">
                                        <TextBlock Text="Độ trong suốt nền"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Slider Grid.Column="0"
                                                    Minimum="0"
                                                    Maximum="1"
                                                    SmallChange="0.05"
                                                    LargeChange="0.1"
                                                    TickFrequency="0.05"
                                                    IsSnapToTickEnabled="True"
                                                    Value="{Binding ToastBackgroundOpacity, Mode=TwoWay}"/>
                                            <TextBlock Grid.Column="1"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextBrush}"
                                                       FontSize="10"
                                                       Text="{Binding ToastBackgroundOpacity, StringFormat='{}{0:P0}'}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Port IN" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Port OUT" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32" ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>

