<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.GitSourceNodeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:FlowMy.Controls"
    xmlns:local="clr-namespace:FlowMy.Views.Overlays"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:conv="clr-namespace:FlowMy.Converters"
    Title="Git Source"
    WindowStyle="None" ResizeMode="CanResize"
    AllowsTransparency="True" Background="Transparent"
    ShowInTaskbar="False" Topmost="True"
    Width="520" MinWidth="420" MaxWidth="1200" MinHeight="420">

    <local:BaseNodeDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>
        <conv:InverseBooleanConverter x:Key="InverseBoolConverter"/>
    </local:BaseNodeDialog.Resources>

    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <controls:SvgViewboxEx Grid.Column="0" Width="18" Height="18" Margin="0,0,10,0"
                                           Fill="{DynamicResource TextBrush}" Opacity="0.9"
                                           Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}"/>

                    <TextBox x:Name="TitleTextBox" Grid.Column="1"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}" FontSize="16"
                             Padding="0,4,0,4" VerticalContentAlignment="Center" Cursor="IBeam"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- VSCodium button -->
                        <Button Width="70" Height="24" Margin="8,0,0,0"
                                Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                ToolTip="Mở VS Code với source code (cmd: code .)"
                                Command="{Binding OpenInVsCodeCommand}">
                            <TextBlock Text="VS Code" FontSize="10" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="CloseButton" Width="24" Height="24"
                                Style="{DynamicResource DangerButton}" Padding="0"
                                Content="×" FontSize="12" FontWeight="Bold" Cursor="Hand"
                                Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

                <!-- TAB 1: CÀI ĐẶT (command line) -->
                <TabItem Header="Cài đặt" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- 💻 Command Line -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="💻 Command Line"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Nhập lệnh để chạy (ví dụ: npm install, npm run build, dotnet run...)"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                    <TextBox x:Name="CommandTextBox"
                                             Text="{Binding CommandText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             MinHeight="80" MaxHeight="200"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             FontFamily="Consolas" FontSize="10"
                                             Margin="0,0,0,8"/>
                                    <Button Height="32" MinWidth="120" HorizontalAlignment="Left"
                                            Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                            Command="{Binding RunCommandCommand}"
                                            IsEnabled="{Binding IsRunningCommand, Converter={StaticResource InverseBoolConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="▶" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Áp dụng" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- 📄 Command output -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="📄 Output"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Border Background="{DynamicResource HeaderBackgroundBrush}" CornerRadius="6" Padding="8"
                                            MaxHeight="200">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                                            <TextBlock Text="{Binding CommandOutput}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       TextWrapping="Wrap"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Inputs/Outputs hidden -->
                            <StackPanel x:Name="InputsPanel" Visibility="Collapsed"/>
                            <StackPanel x:Name="OutputsPanel" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- TAB 2: HIỂN THỊ -->
                <TabItem Header="Hiển thị" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- 🎨 Icon -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Icon"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <controls:IconSelectorUserControl x:Name="IconSelector"
                                                              ButtonHeight="32"
                                                              SelectedIcon="{Binding IconKey, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎨 Màu icon -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Màu icon"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="IconColorComboBox" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding IconColorKey, Mode=TwoWay}"
                                                  SelectionChanged="IconColorComboBox_SelectionChanged"/>
                                        <Button Grid.Column="1" Content="🎨" Width="32" Height="32"
                                                Padding="0" Margin="8,0,0,0" Cursor="Hand"
                                                ToolTip="Chọn màu icon tuỳ ý" Click="PickIconColor_Click"/>
                                        <Border x:Name="IconColorPreview" Grid.Column="2"
                                                Width="32" Height="32" CornerRadius="6" Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 🎨 Màu node -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Màu node"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Button Grid.Column="1" Content="🎨" Width="32" Height="32"
                                                Padding="0" Margin="8,0,0,0" Cursor="Hand"
                                                ToolTip="Chọn màu tuỳ ý" Click="PickNodeColor_Click"/>
                                        <Border x:Name="TitleColorPreview" Grid.Column="2"
                                                Width="32" Height="32" CornerRadius="6" Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 💬 Tooltip -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="💬 Tooltip"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBox Text="{Binding TooltipText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}" Height="64"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             VerticalContentAlignment="Top"
                                             Padding="8,4"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
