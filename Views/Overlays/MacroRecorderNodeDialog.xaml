<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.MacroRecorderNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Macro Recorder"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MaxWidth="700"
        MinHeight="420">
    <local:BaseNodeDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </local:BaseNodeDialog.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             MinWidth="150"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton"
                                Padding="0,0,0,0"
                                Width="24"
                                Height="24"
                                Content="▶"
                                FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton"
                                Padding="0,0,0,0"
                                Width="24"
                                Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="×"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">

                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- 🎨 Hiển thị tiêu đề -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Hiển thị tiêu đề" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="TitleDisplayModeComboBox"
                                              Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎨 Màu tiêu đề -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Màu tiêu đề" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox x:Name="TitleColorComboBox"
                                                  Grid.Column="0"
                                                  Height="32"
                                                  MinWidth="150"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>

                                        <Border Grid.Column="1"
                                                x:Name="TitleColorPreview"
                                                Width="32"
                                                Height="32"
                                                CornerRadius="6"
                                                Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 🔑 Output Key -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🔑 Output Key" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBox x:Name="OutputKeyTextBox"
                                             Height="32"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding OutputKey, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>

                            <!-- 📄 Dữ liệu đã ghi (JSON) -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📄 Dữ liệu đã ghi (JSON)" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBox x:Name="MacroDataJsonTextBox"
                                             Height="80"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             FontSize="10"
                                             Padding="8,6,8,6"
                                             VerticalContentAlignment="Top"
                                             TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto"
                                             IsReadOnly="True"
                                             Text="{Binding MacroDataJson, Mode=OneWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Phạm vi hoạt động -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎯 Phạm vi hoạt động" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="ExecutionModeComboBox"
                                              Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding ExecutionModeOptions}"
                                              SelectedItem="{Binding SelectedExecutionMode, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Chọn ứng dụng đích -->
                            <StackPanel Visibility="{Binding IsTargetAppVisible, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,0,0,12">
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="🎯 Chọn ứng dụng đích" 
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="TargetAppComboBox"
                                                      Grid.Column="0"
                                                      Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding ActiveWindows}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"/>
                                            <Button Grid.Column="1"
                                                    Content="↻"
                                                    Height="32"
                                                    Width="32"
                                                    Padding = "0"
                                                    Margin="8,0,0,0"
                                                    Style="{DynamicResource SecondaryButton}"
                                                    Command="{Binding LoadWindowsCommand}"
                                                    ToolTip="Tải lại danh sách cửa sổ"
                                                    Cursor="Hand"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Button: Ghi lại thao tác -->
                            <Button x:Name="RecordButton"
                                    Content="🔴 Ghi lại thao tác"
                                    Height="36"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Style="{DynamicResource PrimaryButton}"
                                    Cursor="Hand"
                                    Margin="0,0,0,8"
                                    Click="RecordButton_Click"/>

                            <!-- Checkbox: hiển thị nét di chuyển chuột -->
                            <CheckBox x:Name="ShowMouseTrailCheckBox"
                                      Content="Hiển thị nét di chuyển chuột khi ghi"
                                      IsChecked="{Binding ShowMouseTrail, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextBrush}"
                                      FontSize="12"
                                      Opacity="0.85"
                                      Margin="0,0,0,8"
                                      Cursor="Hand"/>

                            <!-- Checkbox: ở lại màn hình thao tác sau khi chạy xong -->
                            <CheckBox x:Name="StayOnTargetCheckBox"
                                      Content="Ở lại màn hình thao tác sau khi chạy xong"
                                      IsChecked="{Binding StayOnTargetAfterExecution, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextBrush}"
                                      FontSize="12"
                                      Opacity="0.85"
                                      Margin="0,0,0,16"
                                      Cursor="Hand"/>

                            <!-- ⚙️ Chế độ phát lại -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⚙️ Chế độ phát lại" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="PlaybackModeComboBox"
                                              Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PlaybackModeOptions}"
                                              SelectedItem="{Binding SelectedPlaybackMode, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 👁️ Hiển thị khi chạy -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="👁️ Hiển thị khi chạy" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="VisualPlaybackModeComboBox"
                                              Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              Margin="0,0,0,8"
                                              ItemsSource="{Binding VisualPlaybackModeOptions}"
                                              SelectedItem="{Binding SelectedVisualPlaybackMode, Mode=TwoWay}"/>
                                    <TextBlock x:Name="VisualModeHint"
                                               FontSize="10"
                                               Opacity="0.65"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}"/>
                                </StackPanel>
                            </Border>

                            <!-- ⏱️ Đếm ngược trước khi phát lại -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⏱️ Đếm ngược trước khi phát lại (giây, 0 = không đếm)" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBox Height="32"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             VerticalContentAlignment="Center"
                                             Text="{Binding CountdownSeconds, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🔄 Thời gian giữa chu kỳ -->
                            <StackPanel Visibility="{Binding IsRepeatVisible, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,0,0,12">
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="🔄 Thời gian giữa chu kỳ (ms)" 
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBox x:Name="RepeatIntervalMsTextBox"
                                                 Height="32"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding RepeatIntervalMs, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- 🔢 Số lần lặp -->
                            <StackPanel Visibility="{Binding IsRepeatVisible, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,0,0,12">
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="🔢 Số lần lặp" 
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBox x:Name="RepeatCountTextBox"
                                                 Height="32"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Export / Import JSON buttons -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Button x:Name="ExportJsonButton"
                                        Content="📤 Export JSON"
                                        Height="34"
                                        FontSize="13"
                                        Style="{DynamicResource PrimaryButton}"
                                        Cursor="Hand"
                                        Margin="0,0,8,0"
                                        IsEnabled="{Binding CanExportJson}"
                                        Click="ExportJsonButton_Click"/>

                                <Button x:Name="ImportJsonButton"
                                        Content="📥 Import JSON"
                                        Height="34"
                                        FontSize="13"
                                        Style="{DynamicResource PrimaryButton}"
                                        Cursor="Hand"
                                        Click="ImportJsonButton_Click"/>
                            </StackPanel>

                            <!-- Inputs Panel -->
                            <StackPanel x:Name="InputsPanel"/>

                            <!-- Outputs Panel -->
                            <StackPanel x:Name="OutputsPanel"/>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Cấu hình -->
                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl
                                                              Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
