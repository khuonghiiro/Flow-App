<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.AsyncTaskDispatchCollectNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Collect AsyncTask Results"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="420"
        Height="480"
        MinWidth="320"
        MaxWidth="700"
        MinHeight="360">
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Content="?" FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Ch?y logic node n�y"
                                Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="�"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16" Grid.Row="1">
                <StackPanel>
                    <TextBlock Text="Ngu?n node (trong body AsyncTask):"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <ComboBox Height="36"
                              Style="{DynamicResource BaseComboBox}"
                              ItemsSource="{Binding AvailableBodyNodeOptions}"
                              DisplayMemberPath="Title"
                              SelectedValuePath="NodeId"
                              SelectedValue="{Binding SelectedSourceBodyNodeId, Mode=TwoWay}"
                              Margin="0,0,0,16"/>

                    <TextBlock Text="Output key c?n collect:"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <ComboBox Height="36"
                              Style="{DynamicResource BaseComboBox}"
                              ItemsSource="{Binding AvailableOutputKeys}"
                              DisplayMemberPath="DisplayName"
                              SelectedValuePath="Key"
                              SelectedValue="{Binding SelectedSourceOutputKey, Mode=TwoWay}"
                              Margin="0,0,0,16"/>

                    <Border Background="{DynamicResource BorderColor}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="12" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="K?t qu? sau khi collect s? du?c xu?t ra output key:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="results (JSON object string)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.9"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="G?i �:"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Sau khi node ch?y xong, c�c node ph�a sau node n�y c� th? d�ng OutputNode d? d?c {results[0]}, {results[1]}..."
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Opacity="0.95"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</local:BaseNodeDialog>

