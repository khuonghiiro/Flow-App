<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.AsyncTaskDispatchCollectNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Collect AsyncTask Results"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        Height="500"
        MinWidth="420"
        MaxWidth="700"
        MinHeight="420">
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Content="▶" FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="✕"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16" Grid.Row="1">
                <StackPanel>
                    <!-- 📍 Nguồn node -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📍 Nguồn node (trong body AsyncTask)"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Chọn node AsyncTask chứa dữ liệu cần collect"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <controls:NodeSearchComboBoxUserControl Height="32"
                                      ItemsSource="{Binding AvailableBodyNodeOptions}"
                                      DisplayMemberPath="Title"
                                      SelectedValuePath="NodeId"
                                      SelectedValue="{Binding SelectedSourceBodyNodeId, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- 🔑 Output key cần collect -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="🔑 Output key cần collect"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Chọn output key từ node nguồn"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="10" Margin="0,0,0,4"/>
                            <ComboBox Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      ItemsSource="{Binding AvailableOutputKeys}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedSourceOutputKey, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- 📊 Kết quả -->
                    <Border Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="📊 Kết quả sau khi collect"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                            <TextBlock Text="Kết quả sẽ được xuất ra output key: results (JSON object string)"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- 💡 Gợi ý -->
                    <Border Background="{DynamicResource CardColor}" CornerRadius="8" Padding="12">
                        <StackPanel>
                            <TextBlock Text="💡 Gợi ý"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <TextBlock Text="Sau khi node chạy xong, các node phía sau node này có thể dùng OutputNode để đọc {results[0]}, {results[1]}..."
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="10" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</local:BaseNodeDialog>

