<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.KeyPressEventNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Key Press Event Node"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MaxWidth="700"
        MinHeight="420">
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16" Padding="0,4,0,4"
                             VerticalContentAlignment="Center" Cursor="IBeam"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Width="24" Height="24" Content="▶" FontSize="12"
                                Padding="0" Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                Margin="8,0,0,0" ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton" Width="24" Height="24" Content="×"
                                Padding="0" Style="{DynamicResource DangerButton}"
                                FontSize="12" FontWeight="Bold" Cursor="Hand"
                                Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

                <!-- ═══ Tab 1: Logic ═══ -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- ⌨️ Phím kích hoạt -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⌨️ Phím kích hoạt" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Button x:Name="KeyButton"
                                            Content="{Binding KeyDisplayText}"
                                            Height="32" Style="{DynamicResource SecondaryButton}"
                                            Background="{DynamicResource CardBackgroundBrush}"
                                            BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                            Foreground="{DynamicResource TextBrush}" FontSize="11"
                                            Cursor="Hand"
                                            Click="KeyButton_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Ứng dụng đích -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎯 Ứng dụng cần nhấn phím" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10"
                                               TextWrapping="Wrap" Margin="0,0,0,8">
                                        <Run Text="Chọn app để tự động focus trước khi nhấn phím. Để trống = dùng cửa sổ hiện tại."/>
                                    </TextBlock>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="SelectedTargetWindow" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding ActiveWindows}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"/>
                                        <Button Grid.Column="1" Content="↻" Height="32" Width="32" Padding="0"
                                                Margin="8,0,0,0" Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding LoadWindowsCommand}"
                                                ToolTip="Tải lại danh sách cửa sổ" Cursor="Hand"/>
                                    </Grid>

                                    <CheckBox IsChecked="{Binding ReturnToOriginalScreen, Mode=TwoWay}" Cursor="Hand">
                                        <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center">
                                            <Run Text="↩️ Trở về màn hình ban đầu sau khi thực hiện xong"/>
                                        </TextBlock>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <!-- ⚙️ Background Mode -->
                            <Border Background="{DynamicResource WindowBackground}" Visibility="Collapsed"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding UseBackgroundMode, Mode=TwoWay}"
                                              Cursor="Hand" Margin="0,0,0,8">
                                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" VerticalAlignment="Center">
                                            <Run Text="Chạy ngầm (không cần app active)"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10"
                                               TextWrapping="Wrap">
                                        <Run Text="App đích không bị đưa lên foreground. Giống AnyDesk/TeamViewer."/>
                                    </TextBlock>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding UseBackgroundMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Chế độ gửi input"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,8,0,4"/>
                                        <ComboBox x:Name="BackgroundInputModeComboBox" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding BackgroundInputModeOptions}"
                                                  SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding BackgroundInputMode, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 📍 Toạ độ click trước khi nhấn -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📍 Toạ độ click trước khi nhấn" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Từ node khác"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="Node nguồn"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <controls:NodeSearchComboBoxUserControl x:Name="CoordSourceNodeId" Height="32"
                                              Margin="0,0,0,8"
                                              ItemsSource="{Binding AvailableNodeOptions}"
                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                              SelectedValue="{Binding CoordSourceNodeId, Mode=TwoWay}"/>
                                    <TextBlock Text="Output key (x / y / position)"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CoordSourceOutputKey" Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding AvailableOutputKeyOptions}"
                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding CoordSourceOutputKey, Mode=TwoWay}"/>

                                    <TextBlock Text="Hoặc chọn thủ công"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,12,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="PositionDisplayText"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Text="{Binding PositionText}"/>
                                        <Button x:Name="PickPositionButton" Grid.Column="1"
                                                Content="🎯 Chọn" Height="32"
                                                Style="{DynamicResource PrimaryButton}"
                                                Cursor="Hand" Click="PickPositionButton_Click"
                                                Padding="10,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Click tại toạ độ -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding ClickOnPosition, Mode=TwoWay}"
                                              Cursor="Hand" Margin="0,0,0,8">
                                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" VerticalAlignment="Center">
                                            <Run Text="Click vào toạ độ trước khi nhấn phím"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClickOnPosition}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Thời gian giữ chuột khi click (ms)"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ClickDurationTextBox" Height="32"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 Text="{Binding ClickDurationMs, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ⏱️ Thời gian delay -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⏱️ Delay giữa các lần nhấn (ms)" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBox x:Name="PressDelayTextBox" Height="32"
                                             Text="{Binding PressDelayMs, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 📥 Inputs -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📥 Số lần nhấn phím" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="InputsPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- 📤 Outputs -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📤 Giá trị trả về" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="OutputsPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎨 Tiêu đề node -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Tiêu đề node" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="TitleDisplayModeComboBox" Height="32"
                                              Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Border Grid.Column="1" x:Name="TitleColorPreview"
                                                Width="32" Height="32" CornerRadius="6" Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══ Tab 2: Tái sử dụng flow ═══ -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT" Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
