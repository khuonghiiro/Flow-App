<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.MouseEventNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:converters="clr-namespace:FlowMy.Converters"
        Title="Mouse Event Node Dialog"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MaxWidth="700"
        MinHeight="420">
    <Window.Resources>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
    </Window.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TitleTextBox" Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16" Padding="0,4,0,4"
                             VerticalContentAlignment="Center" Cursor="IBeam"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Width="24" Height="24" Content="▶" FontSize="12"
                                Padding="0" Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                Margin="8,0,0,0" ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton" Width="24" Height="24" Content="×"
                                Padding="0" Style="{DynamicResource DangerButton}"
                                FontSize="12" FontWeight="Bold" Cursor="Hand"
                                Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

                <!-- ═══ Tab 1: Logic ═══ -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <!-- 🖱️ Nút chuột -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🖱️ Nút chuột" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="MouseButtonComboBox" Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding MouseButtonOptions}"
                                              SelectedValue="{Binding MouseButton, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Ứng dụng đích -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎯 Ứng dụng cần click" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10"
                                               TextWrapping="Wrap" Margin="0,0,0,8">
                                        <Run Text="Chọn app để gửi thao tác chuột đến. "/>
                                        <Run FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}">
                                            <Run.Style>
                                                <Style TargetType="Run">
                                                    <Setter Property="Text" Value=""/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UseBackgroundMode}" Value="True">
                                                            <Setter Property="Text" Value="(BẮT BUỘC khi dùng chạy ngầm) "/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Run.Style>
                                        </Run>
                                        <Run Text="Để trống = dùng cửa sổ hiện tại."/>
                                    </TextBlock>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="SelectedTargetWindow" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding ActiveWindows}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedItem="{Binding SelectedTargetWindow, Mode=TwoWay}"/>
                                        <Button Grid.Column="1" Content="↻" Height="32" Width="32" Padding="0"
                                                Margin="8,0,0,0" Style="{DynamicResource SecondaryButton}"
                                                Command="{Binding LoadWindowsCommand}"
                                                ToolTip="Tải lại danh sách cửa sổ" Cursor="Hand"/>
                                    </Grid>

                                    <CheckBox IsChecked="{Binding ReturnToOriginalScreen, Mode=TwoWay}" Cursor="Hand">
                                        <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="11" VerticalAlignment="Center">
                                            <Run Text="↩️ Trở về màn hình ban đầu sau khi thực hiện xong"/>
                                        </TextBlock>
                                    </CheckBox>
                                </StackPanel>
                            </Border>

                            <!-- ⚙️ Background Mode -->
                            <Border Background="{DynamicResource WindowBackground}" Visibility="Collapsed"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding UseBackgroundMode, Mode=TwoWay}"
                                              Cursor="Hand" Margin="0,0,0,8">
                                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" VerticalAlignment="Center">
                                            <Run Text="Chạy ngầm (không cần app active)"/>
                                        </TextBlock>
                                    </CheckBox>
                                     
                                    <!-- Warning khi chưa chọn app -->
                                    <Border Background="#33FF6B00" BorderBrush="#FFFF6B00" BorderThickness="1"
                                            CornerRadius="4" Padding="8" Margin="0,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasBackgroundModeWarning}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding BackgroundModeWarning}"
                                                   Foreground="#FFFF6B00" FontSize="10" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                     
                                    <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10"
                                               TextWrapping="Wrap">
                                        <Run Text="App đích không bị đưa lên foreground. Giống AnyDesk/TeamViewer."/>
                                    </TextBlock>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding UseBackgroundMode}" Value="True"/>
                                                            <Condition Binding="{Binding ElementName=EmbedStatusText, Path=Tag}" Value="NotEmbedded"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Chế độ gửi input"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,8,0,4"/>
                                        <ComboBox x:Name="BackgroundInputModeComboBox" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding BackgroundInputModeOptions}"
                                                  SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding BackgroundInputMode, Mode=TwoWay}"/>
                                    </StackPanel>
                                     
                                    <!-- Message khi đã embed -->
                                    <Border Background="#E8F5E9"
                                            BorderBrush="#4CAF50"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="10"
                                            Margin="0,8,0,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ElementName=EmbedStatusText, Path=Tag}" Value="Embedded">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Foreground="#2E7D32" 
                                                       FontSize="10" 
                                                       FontWeight="SemiBold">
                                                <Run Text="✅ App đã embedded"/>
                                            </TextBlock>
                                            <TextBlock Foreground="#2E7D32" 
                                                       FontSize="10" 
                                                       TextWrapping="Wrap"
                                                       Margin="0,4,0,0">
                                                <Run Text="Input sẽ được gửi trực tiếp đến embedded window. Không cần cấu hình chế độ."/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- 📍 Toạ độ click / scroll -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📍 Toạ độ click / scroll" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <!-- Từ node khác -->
                                    <TextBlock Text="Từ node khác"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="Node nguồn"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <controls:NodeSearchComboBoxUserControl x:Name="CoordSourceNodeId"
                                              Height="32" Margin="0,0,0,8"
                                              ItemsSource="{Binding AvailableNodeOptions}"
                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                              SelectedValue="{Binding CoordSourceNodeId, Mode=TwoWay}"/>
                                    <TextBlock Text="Output key (x / y / position)"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CoordSourceOutputKey" Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding AvailableOutputKeyOptions}"
                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding CoordSourceOutputKey, Mode=TwoWay}"/>

                                    <!-- Thủ công -->
                                    <TextBlock Text="Hoặc chọn thủ công"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="11" FontWeight="SemiBold" Margin="0,12,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="PositionDisplayText"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Text="{Binding PositionText}"/>
                                        <Button x:Name="PickPositionButton" Grid.Column="1"
                                                Content="🎯 Chọn" Height="32"
                                                Style="{DynamicResource PrimaryButton}"
                                                Cursor="Hand" Click="PickPositionButton_Click"
                                                Padding="10,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Click tại toạ độ trước khi thực hiện -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding ClickOnPosition, Mode=TwoWay}"
                                              Cursor="Hand" Margin="0,0,0,8">
                                        <TextBlock Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11" VerticalAlignment="Center">
                                            <Run Text="Click vào toạ độ trước khi thực hiện"/>
                                        </TextBlock>
                                    </CheckBox>
                                    <StackPanel>
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ClickOnPosition}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="Thời gian giữ chuột khi click (ms)"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="ClickDurationTextBox" Height="32"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 Text="{Binding ClickDurationMs, UpdateSourceTrigger=PropertyChanged}"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- 🔢 Số lần / thời gian giữ / tốc độ scroll -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🔢 Số lần nhấn" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"
                                               Visibility="{Binding IsScrollMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                    <TextBox x:Name="RepeatCountTextBox" Height="32"
                                             Text="{Binding RepeatCount, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             VerticalContentAlignment="Center"
                                             IsEnabled="{Binding IsRepeatCountEnabled}"
                                             Visibility="{Binding IsScrollMode, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                    <TextBlock x:Name="ExtraLabel" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,12,0,10"/>
                                    <TextBox x:Name="ExtraTextBox" Height="32"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             VerticalContentAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- 📥 Inputs -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📥 Inputs" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="InputsPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- 📤 Outputs -->
                            <Border x:Name="BorderOutputPanel"
                                    Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock x:Name="TextBlockOutputPanel" Text="📤 Outputs" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="OutputsPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎨 Tiêu đề node -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Tiêu đề node" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <ComboBox x:Name="TitleDisplayModeComboBox" Height="32"
                                              Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Border Grid.Column="1" x:Name="TitleColorPreview"
                                                Width="32" Height="32" CornerRadius="6" Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- ═══ Tab 2: Preview (Embedded Window) ═══ -->
                <TabItem Header="Preview" Style="{StaticResource HttpTabItemStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header with Embed/Unembed controls -->
                        <Border Grid.Row="0" 
                                Background="{DynamicResource WindowBackground}"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="0,0,0,1" 
                                Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="App Preview" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="14" FontWeight="Bold"/>
                                    <TextBlock x:Name="EmbedStatusText"
                                               Text="Chọn app ở tab Logic để embed"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="11"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="EmbedButton"
                                            Content="📌 Embed App"
                                            Height="32"
                                            Padding="12,0"
                                            Style="{DynamicResource PrimaryButton}"
                                            Cursor="Hand"
                                            Click="EmbedButton_Click"
                                            IsEnabled="False"
                                            Margin="0,0,8,0"/>
                                    
                                    <Button x:Name="UnembedButton"
                                            Content="↩️ Unembed"
                                            Height="32"
                                            Padding="12,0"
                                            Style="{DynamicResource DangerButton}"
                                            Cursor="Hand"
                                            Click="UnembedButton_Click"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Embedded Window Host Container -->
                        <Border Grid.Row="1" 
                                Background="#F5F5F5"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="0">
                            <Grid>
                                <!-- Placeholder when no window embedded -->
                                <StackPanel x:Name="EmbedPlaceholder"
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            Visibility="Visible">
                                    <TextBlock Text="🖼️" 
                                               FontSize="48" 
                                               HorizontalAlignment="Center"
                                               Opacity="0.3"/>
                                    <TextBlock Text="No app embedded" 
                                               FontSize="14" 
                                               Foreground="#9E9E9E"
                                               HorizontalAlignment="Center"
                                               Margin="0,10,0,0"/>
                                    <TextBlock Text="Select app in Logic tab, then click Embed" 
                                               FontSize="11" 
                                               Foreground="#BDBDBD"
                                               HorizontalAlignment="Center"
                                               Margin="0,5,0,0"/>
                                </StackPanel>

                                <!-- Actual embedded window host -->
                                <controls:EmbeddedWindowHost x:Name="EmbeddedWindowHost"
                                                             RemoveDecoration="True"
                                                             Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- ═══ Tab 3: Tái sử dụng flow ═══ -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
