<Window x:Class="FlowMy.Views.Overlays.HtmlUiEditorPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        Title="HTML UI � So?n th?o m? r?ng"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="900"
        Height="620"
        MinWidth="600"
        MinHeight="400"
        Background="{DynamicResource CardColor}">
    <Border CornerRadius="8" Padding="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="12,10" CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="So?n th?o HTML UI � 4 tab (Html / Js / Css / Params)"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" VerticalAlignment="Center"/>
                    <Button x:Name="ClosePopupButton" Grid.Column="1" Content="��ng"
                            Width="80" Height="32" Padding="8,0"
                            Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Cursor="Hand" Click="ClosePopupButton_Click"/>
                </Grid>
            </Border>

            <!-- Body: TabControl v?i 4 editor, binding l?i c�ng ViewModel -->
            <TabControl Grid.Row="1" Margin="12">
                <TabItem Header="HTML" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding HtmlCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
                <TabItem Header="JS" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding JsCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
                <TabItem Header="CSS" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding CssCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
                <TabItem Header="Params (config)" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding ParamsCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
            </TabControl>

            <!-- Footer hint -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBackgroundBrush}" Padding="12,8" CornerRadius="0,0,8,8">
                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap">
                    <Run Text="V� d?: output key "/>
                    <Run Text="'result'" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=" s? nh?n gi� tr? t? � input "/>
                    <Run Text="#txtResult" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=" khi JS g?i "/>
                    <Run Text="window.chrome.webview.postMessage({ result: value });" FontWeight="SemiBold" Foreground="{DynamicResource WarningColor}"/>
                    <Run Text=" trong h�m "/>
                    <Run Text="submitResult()" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=". B?n c� th? s?a HTML/CSS/JS/Params ? d�y cho tho?i m�i hon."/>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>

