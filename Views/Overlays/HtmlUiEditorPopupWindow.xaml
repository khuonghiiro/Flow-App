<Window x:Class="FlowMy.Views.Overlays.HtmlUiEditorPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        Title="HTML UI – Soạn thảo mở rộng"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="900"
        Height="620"
        MinWidth="600"
        MinHeight="400"
        Background="{DynamicResource CardColor}">
    <Border CornerRadius="8" Padding="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="12,10" CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Soạn thảo HTML UI – 4 tab (Html / Js / Css / Params)"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" VerticalAlignment="Center"/>
                    <Button x:Name="ClosePopupButton" Grid.Column="1" Content="Đóng"
                            Width="80" Height="32" Padding="8,0"
                            Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Cursor="Hand" Click="ClosePopupButton_Click"/>
                </Grid>
            </Border>

            <!-- Body: TabControl với 4 editor, binding lại cùng ViewModel -->
            <TabControl Grid.Row="1" Margin="12">
                <TabItem Header="HTML" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding HtmlCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
                <TabItem Header="JS" Style="{StaticResource HttpTabItemStyle}">
                    <Grid Margin="0,4,0,4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,6">
                            <Button Content="↑"
                                    Width="28"
                                    Height="26"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="MoveJsTabUpButton_Click"
                                    Style="{DynamicResource SecondaryButton}"
                                    ToolTip="Đẩy tab JS đang chọn lên trên"/>
                            <Button Content="↓"
                                    Width="28"
                                    Height="26"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="MoveJsTabDownButton_Click"
                                    Style="{DynamicResource SecondaryButton}"
                                    ToolTip="Đẩy tab JS đang chọn xuống dưới"/>
                            <Button Content="Xóa tab"
                                    Width="74"
                                    Height="26"
                                    Margin="0,0,6,0"
                                    Cursor="Hand"
                                    Click="DeleteJsTabButton_Click"
                                    Style="{DynamicResource DangerButton}"
                                    ToolTip="Xóa tab JS đang chọn (giữ lại tối thiểu 1 tab)"/>
                            <Button Content="+ Thêm JS"
                                    Width="96"
                                    Height="26"
                                    Cursor="Hand"
                                    Click="AddJsTabButton_Click"
                                    Style="{DynamicResource PrimaryButton}"
                                    ToolTip="Tạo thêm tab JS con"/>
                        </StackPanel>
                        <TabControl x:Name="PopupJsSubTabsControl"
                                    Grid.Row="1"
                                    Background="Transparent"
                                    BorderThickness="0">
                            <TabItem x:Name="PopupJsPrimaryTabItem" Header="JS 1" Style="{StaticResource HttpTabItemStyle}">
                                <controls:SyntaxHighlightCodeEditor x:Name="PopupJsEditor"
                                    CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                                    Margin="0,4,0,4"
                                    MinHeight="260"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>
                <TabItem Header="CSS" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding CssCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
                <TabItem Header="Params (config)" Style="{StaticResource HttpTabItemStyle}">
                    <controls:SyntaxHighlightCodeEditor
                        Text="{Binding ParamsCode, UpdateSourceTrigger=PropertyChanged}"
                        CodeFontSize="{Binding CodeFontSize, Mode=TwoWay}"
                        Margin="0,4,0,4"
                        MinHeight="260"/>
                </TabItem>
            </TabControl>

            <!-- Footer hint -->
            <Border Grid.Row="2" Background="{DynamicResource HeaderBackgroundBrush}" Padding="12,8" CornerRadius="0,0,8,8">
                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap">
                    <Run Text="Ví dụ: output key "/>
                    <Run Text="'result'" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=" sẽ nhận giá trị từ ô input "/>
                    <Run Text="#txtResult" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=" khi JS gọi "/>
                    <Run Text="window.chrome.webview.postMessage({ result: value });" FontWeight="SemiBold" Foreground="{DynamicResource WarningColor}"/>
                    <Run Text=" trong hàm "/>
                    <Run Text="submitResult()" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=". Bạn có thể sửa HTML/CSS/JS/Params ở đây cho thoải mái hơn."/>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>

