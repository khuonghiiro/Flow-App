                                            <LineBreak/>
                                            <Run Text="__tab1_exec_par(" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text="`console.log('[Tab1] par1:', Date.now());`"/>
                                            <Run Text=");" Foreground="{DynamicResource WarningColor}"/>
                                            <LineBreak/>
                                            <Run Text="__tab1_exec_par(" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text="`document.title = 'Processing...';`"/>
                                            <Run Text=");" Foreground="{DynamicResource WarningColor}"/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="// par2 KHÔNG đợi par1 xong → cả 2 chạy song song"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- SEQ Example 2: Fetch trong Tab1 (Tab1 có session) -->
                                <Border Background="{DynamicResource WindowBackground}" CornerRadius="6" Padding="8" Margin="0,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="SEQ 2 — Fetch API trong Tab1 + navigate sau khi done:" Foreground="{DynamicResource PrimaryBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Button Content="📋 Copy" FontSize="10" Height="20" Padding="6,0" Margin="8,0,0,0"
                                                    Background="#1D4ED8" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                    Click="CopySnippet_Click"
                                                    Tag="// SEQ: dùng fetch trong Tab1 (có session/cookie đầy đủ)&#xA;// Bước 1: ensure Tab1 ở đúng origin&#xA;__tab1_exec_seq(`&#xA;    if (!window.location.href.includes('grok.com')) {&#xA;        window.location.href = 'https://grok.com';&#xA;    }&#xA;`);&#xA;&#xA;// Bước 2: dùng async fetch trong Tab1 (có cookie grok.com)&#xA;__tab1_exec_seq(`&#xA;    (async () => {&#xA;        const r = await fetch('/api/data', { credentials: 'include' });&#xA;        const data = await r.json();&#xA;        window.__tab1Data = data; // lưu cho bước sau&#xA;        console.log('[Tab1 fetch]', data);&#xA;    })();&#xA;`);&#xA;&#xA;// Bước 3: navigate Tab1 đến kết quả&#xA;__tab1_exec_seq(`window.location.href = '/result/' + (window.__tab1Data?.id ?? '');`);"/>
                                            <Button Content="🖊 Áp dụng" FontSize="10" Height="20" Padding="6,0" Margin="4,0,0,0"
                                                    Background="#059669" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                    Click="ApplyExample_Click" Tag="tab1_seq2"
                                                    ToolTip="Điền sẵn ví dụ fetch + navigate Tab1 vào editor"/>
                                        </StackPanel>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                            <Run Text="// Bước 1: navigate Tab1 đến grok.com (ensure cookie origin)"/>
                                            <LineBreak/>
                                            <Run Text="__tab1_exec_seq(`window.location.href = 'https://grok.com';`);" Foreground="{DynamicResource WarningColor}"/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="// Bước 2: async fetch bên trong Tab1 (có session đầy đủ)"/>
                                            <LineBreak/>
                                            <Run Text="__tab1_exec_seq(`" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text="(async () => {"/>
                                            <LineBreak/>
                                            <Run Text="    const r = await fetch('/api/data', { credentials: 'include' });"/>
                                            <LineBreak/>
                                            <Run Text="    window.__tab1Data = await r.json();"/>
                                            <LineBreak/>
                                            <Run Text="    console.log('[Tab1 fetch]', window.__tab1Data);"/>
                                            <LineBreak/>
                                            <Run Text="})();"/>
                                            <Run Text="`);" Foreground="{DynamicResource WarningColor}"/>
                                            <LineBreak/><LineBreak/>
                                            <Run Text="// Bước 3: navigate Tab1 đến kết quả sau khi fetch xong"/>
                                            <LineBreak/>
                                            <Run Text="__tab1_exec_seq(`window.location.href='/result/'+window.__tab1Data?.id;`);" Foreground="{DynamicResource WarningColor}"/>
