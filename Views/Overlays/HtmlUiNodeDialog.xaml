                                                    Background="#1D4ED8" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                    Click="CopySnippet_Click"
                                                    Tag="// PAR: cả 2 chạy ngay lập tức, không đợi nhau&#xA;__tab1_exec_par(`console.log('[Tab1] request1 started:', Date.now());`);&#xA;__tab1_exec_par(`document.title = 'Processing...';`);&#xA;&#xA;// Khác với SEQ: par2 KHÔNG đợi par1 xong"/>
                                            <Button Content="🖊 Áp dụng" FontSize="10" Height="20" Padding="6,0" Margin="4,0,0,0"
                                                    Background="#059669" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                    Click="ApplyExample_Click" Tag="tab1_par1"
