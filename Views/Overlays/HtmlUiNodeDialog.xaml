<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.HtmlUiNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        Title="HTML UI"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="800"
        MinWidth="500"
        MaxWidth="1200"
        MinHeight="560">
    <local:BaseNodeDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </local:BaseNodeDialog.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TitleTextBox" Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}" FontSize="16" Padding="0,4,0,4"
                             VerticalContentAlignment="Center" Cursor="IBeam"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton" Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="×"
                            FontSize="12"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body: 2 tab Logic + Tái sử dụng flow -->
            <TabControl x:Name="MainTabsControl"
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <!-- Title display mode -->
                    <TextBlock Text="Hiển thị tiêu đề:"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <ComboBox x:Name="TitleDisplayModeComboBox" Height="36"
                              Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                              ItemsSource="{Binding TitleDisplayModeOptions}"
                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                    <!-- Title color -->
                    <TextBlock Text="Màu tiêu đề:" Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="TitleColorComboBox" Grid.Column="0" Height="36"
                                  Style="{DynamicResource BaseComboBox}"
                                  ItemsSource="{Binding TitleColorOptions}"
                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                        <Border Grid.Column="1" x:Name="TitleColorPreview"
                                Width="36" Height="36" CornerRadius="6" Margin="8,0,0,0"
                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                    </Grid>

                    <!-- ===== UseWebTab: 2-Tab Mode ===== -->
                    <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <CheckBox x:Name="UseWebTabCheckBox"
                                      IsChecked="{Binding UseWebTab, Mode=TwoWay}"
                                      Content="Sử dụng 2 tab (Tab1: Trình duyệt Web, Tab2: HTML UI)"
                                      Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                      Margin="0,0,0,6"
                                      ToolTip="Khi bật: Tab1 = Web Browser đầy đủ (address bar, cookie), Tab2 = HTML UI hiện tại."/>
                            <!-- Cookie panel: chỉ hiển thị khi UseWebTab = true -->
                            <StackPanel x:Name="CookiePanel"
                                        Visibility="{Binding UseWebTab, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,4,0,0">

                                <!-- Node nguồn + Key (chọn node để lấy cookie text) -->
                                <TextBlock Text="Lấy cookie/data từ node:" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,6"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Node" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                        <ComboBox Height="30" Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding AvailableNodeOptions}"
                                                  SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                  SelectedValue="{Binding WebTabCookieSourceNodeId, Mode=TwoWay}"
                                                  ToolTip="Node nguồn cho cookie (thường là HttpRequest, DataFetcher...)"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Key (output của node)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                        <ComboBox Height="30" Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding WebTabCookieSourceKeyOptions}"
                                                  SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding WebTabCookieSourceOutputKey, Mode=TwoWay}"
                                                  ToolTip="Key trong output của node nguồn chứa cookie text"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Auto-refresh -->
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                                    <CheckBox IsChecked="{Binding WebTabAutoRefreshEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                              Content="Tự động lấy dữ liệu mỗi"
                                              ToolTip="Bật để tự động pull cookie/dữ liệu từ source node và load vào Tab1 theo khoảng thời gian"/>
                                    <TextBox Text="{Binding WebTabAutoRefreshInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Width="52" Height="26" Margin="6,0,4,0"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             IsEnabled="{Binding WebTabAutoRefreshEnabled}"
                                             ToolTip="Khoảng thời gian lấy dữ liệu mới"/>
                                    <ComboBox Height="26" Width="60"
                                              Style="{DynamicResource BaseComboBox}"
                                              IsEnabled="{Binding WebTabAutoRefreshEnabled}"
                                              ItemsSource="{Binding AutoRefreshUnitOptions}"
                                              SelectedItem="{Binding WebTabAutoRefreshUnit, Mode=TwoWay}"/>
                                    <TextBlock Text="→ re-load cookie vào Tab1" Foreground="{DynamicResource TextMuted}" FontSize="10"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>

                                <!-- Manual cookie input (fallback / ghi đè) -->
                                <TextBlock Text="Hoặc nhập thủ công (nếu để trống, dùng từ node bên trên):"
                                           Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CookieTextBox" Grid.Column="0"
                                             Text="{Binding CookieText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             AcceptsReturn="True" TextWrapping="Wrap"
                                             Height="70" VerticalScrollBarVisibility="Auto"
                                             Margin="0,0,8,0"
                                             FontFamily="Consolas" FontSize="11"
                                             ToolTip="Nhập cookie: raw (name=value), JSON object {url,cookies:[{name,value,domain,path,secure,httpOnly,session,expirationTime}]}, JSON array [{...}], Netscape. URL đầu tiên → navigate Tab1."/>
                                    <Button Grid.Column="1"
                                            Content="▶ Áp dụng" Width="80" Height="36"
                                            VerticalAlignment="Top"
                                            Style="{DynamicResource SuccessButton}"
                                            Command="{Binding ApplyCookieCommand}"
                                            Cursor="Hand"
                                            ToolTip="Parse cookie và set vào Tab1 WebView2 ngay lập tức. Nếu có URL thì mở luôn website đó."/>
                                </Grid>
                                <TextBlock Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,4,0,0"
                                           Text="→ Hỗ trợ: raw, JSON object {url, cookies:[{name,value,domain,path,secure,httpOnly,session,expirationTime}]}, JSON array, Netscape. URL → navigate Tab1. Sẽ xóa sau khi đóng dialog."/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Inputs -->
                    <TextBlock Text="Inputs (node nguồn + key → biến dùng trong Html/Js):"
                               Foreground="{DynamicResource TextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="160">
                            <ItemsControl x:Name="InputMappingsItemsControl" ItemsSource="{Binding InputMappingsList}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8" Background="{DynamicResource WindowBackground}" CornerRadius="6" Padding="6">
                                            <StackPanel>
                                                <!-- Row 1: Node / Key / Biến / Xóa -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Node" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                                  ItemsSource="{Binding DataContext.AvailableNodeOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                                  SelectedValue="{Binding SourceNodeId, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Key" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                                  ItemsSource="{Binding AvailableOutputKeyOptions}"
                                                                  SelectedValuePath="Key"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedValue="{Binding SourceOutputKey, Mode=TwoWay}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="4">
                                                        <TextBlock Text="Biến dùng trong Html/Js (trống = dùng key)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                        <TextBox Text="{Binding InputKeyOverride, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{DynamicResource BaseTextBoxV2}" Height="32"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="5" Content="−" Width="26" Height="26" Margin="8,0,0,0" VerticalAlignment="Bottom"
                                                            Command="{Binding DataContext.RemoveInputMappingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Foreground="{DynamicResource TextBrush}" Background="#FFEF4444" BorderThickness="0" Cursor="Hand"/>
                                                </Grid>
                                                <!-- Row 2: Auto-refresh controls -->
                                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                    <CheckBox IsChecked="{Binding AutoRefreshEnabled, Mode=TwoWay}"
                                                              VerticalAlignment="Center"
                                                              Foreground="{DynamicResource TextSecondary}" FontSize="11"
                                                              Content="Auto push JS mỗi"
                                                              ToolTip="Bật để tự động push giá trị mới nhất vào window.__ac theo khoảng thời gian"/>
                                                    <TextBox Text="{Binding AutoRefreshInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="52" Height="26" Margin="6,0,4,0"
                                                             Style="{DynamicResource BaseTextBoxV2}"
                                                             IsEnabled="{Binding AutoRefreshEnabled}"
                                                             ToolTip="Khoảng thời gian lấy dữ liệu mới"/>
                                                    <ComboBox Height="26" Width="60"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              IsEnabled="{Binding AutoRefreshEnabled}"
                                                              ItemsSource="{Binding DataContext.AutoRefreshUnitOptions, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              SelectedItem="{Binding AutoRefreshUnit, Mode=TwoWay}"/>
                                                    <TextBlock Text="→ window.__ac.live['{biến}']"
                                                               Foreground="{DynamicResource TextMuted}" FontSize="10"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                                               FontFamily="Consolas"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                    <Button Content="+ Thêm input" Height="32" Margin="0,0,0,12"
                            Command="{Binding AddInputMappingCommand}"
                            Width="140" Style="{DynamicResource PrimaryButton}" HorizontalAlignment="Left"/>

                    <!-- Ví dụ & Gợi ý -->
                    <Expander x:Name="ExampleHintsExpander" IsExpanded="False" Margin="0,0,0,12">
                        <Expander.Header>
                            <TextBlock Text="Hướng dẫn dùng {variableName} trong HTML/CSS/JS" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"/>
                        </Expander.Header>
                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="8" Padding="14" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Cách truyền value từ node vào HTML/CSS/JS:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10">
                                    <Run Text="1) Cấu hình Input: Chọn Node nguồn + Key (ví dụ node HttpRequest, key responseBody)."/>
                                    <LineBreak/>
                                    <Run Text="2) Đặt 'Biến dùng trong Html/Js' (ví dụ: apiResponse, hoặc để trống = dùng key)."/>
                                    <LineBreak/>
                                    <Run Text="3) Trong HTML/CSS/JS, dùng {variableName} để thay thế bằng giá trị từ node nguồn."/>
                                </TextBlock>
                                <TextBlock Text="Ví dụ trong HTML:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="#1E293B" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="• Hiển thị giá trị trực tiếp:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                            <Run Text="&lt;div&gt;Kết quả: {apiResponse}&lt;/div&gt;"/>
                                        </TextBlock>
                                        <TextBlock Text="• Dùng trong attribute:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                            <Run Text="&lt;input value=&quot;{userId}&quot; /&gt;"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Ví dụ trong JS:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="#1E293B" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="• Parse JSON từ input:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                            <Run Text="const data = JSON.parse('{apiResponse}');"/>
                                        </TextBlock>
                                        <TextBlock Text="• Dùng trong string:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                            <Run Text="const url = 'https://api.example.com/data?id={userId}';"/>
                                        </TextBlock>
                                        <TextBlock Text="• Biến hiện tại:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                            <Run Text="const input = '{"/>
                                            <Run Text="{Binding FirstInputVariableName, Mode=OneWay}" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text="}';"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Ví dụ trong CSS:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="#1E293B" Padding="10" CornerRadius="6" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="• Dùng cho màu sắc:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap" Margin="0,0,0,8">
                                            <Run Text=".button { background-color: {primaryColor}; }"/>
                                        </TextBlock>
                                        <TextBlock Text="• Dùng cho kích thước:" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,6"/>
                                        <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                            <Run Text="body { font-size: {fontSize}px; }"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="Lưu ý:" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,6"/>
                                <Border Background="#1E293B" Padding="10" CornerRadius="6" Margin="0,0,0,14">
                                    <StackPanel>
                                        <TextBlock Text="• {variableName} sẽ được replace bằng giá trị string từ node nguồn" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• Nếu giá trị là JSON, dùng JSON.parse('{variableName}') trong JS để parse" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• Nếu giá trị chứa ký tự đặc biệt HTML, cần escape hoặc dùng textContent thay vì innerHTML" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Text="• Nếu không tìm thấy variable, {variableName} sẽ giữ nguyên (không replace)" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                                        <TextBlock Margin="0,4,0,0">
                                            <Run Text="• Biến hiện tại: " Foreground="{DynamicResource TextSecondary}"/>
                                            <Run Text="{Binding EffectiveInputKeyDisplay, Mode=OneWay}" Foreground="{DynamicResource WarningColor}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                                <!-- === REAL-TIME window.__ac === -->
                                <Border Background="{DynamicResource WindowBackground}" BorderBrush="#2563EB" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,0">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="⚡ Real-time: " Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center">
                                                <Run Text="window.__ac.onUpdate(key, callback)"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,10">
                                            <Run Text="Khi input có checkbox "/>
                                            <Run Text="☑ Auto push JS" Foreground="{DynamicResource WarningColor}"/>
                                            <Run Text=" được bật, C# sẽ tự động push giá trị mới nhất vào JS theo khoảng thời gian. Dùng API dưới để nhận và xử lý."/>
                                        </TextBlock>

                                        <!-- Ví dụ 1 -->
                                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="Cách 1 — Nhận 1 param:" Foreground="{DynamicResource SuccessColor}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Button Content="📋 Copy" FontSize="10" Height="20" Padding="6,0" Margin="8,0,0,0"
                                                            Background="#1D4ED8" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                            Click="CopySnippet_Click"
                                                            Tag="window.__ac.onUpdate('price', function(price) {&amp;#xA;    document.getElementById('price').textContent = price;&amp;#xA;});"/>
                                                    <Button Content="🖊 Áp dụng" FontSize="10" Height="20" Padding="6,0" Margin="4,0,0,0"
                                                            Background="#059669" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                            Click="ApplyExample_Click" Tag="ex1"
                                                            ToolTip="Điền sẵn HTML/CSS/JS ví dụ này vào editor"/>
                                                </StackPanel>
                                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                                    <Run Text="window.__ac.onUpdate("/>
                                                    <Run Text="'price'" Foreground="{DynamicResource WarningColor}"/>
                                                    <Run Text=", function(price) {"/>
                                                    <LineBreak/>
                                                    <Run Text="    document.getElementById('price').textContent = price;"/>
                                                    <LineBreak/>
                                                    <Run Text="});"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Ví dụ 2 -->
                                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="Cách 2 — Nhận nhiều params cùng lúc:" Foreground="{DynamicResource SuccessColor}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Button Content="📋 Copy" FontSize="10" Height="20" Padding="6,0" Margin="8,0,0,0"
                                                            Background="#1D4ED8" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                            Click="CopySnippet_Click"
                                                            Tag="// Khi cả price lẫn quantity thay đổi đều gọi callback này&amp;#xA;window.__ac.onUpdate('price', 'quantity', function(price, quantity) {&amp;#xA;    var total = parseFloat(price || 0) * parseInt(quantity || 0);&amp;#xA;    document.getElementById('total').textContent = 'Tổng: ' + total;&amp;#xA;});"/>
                                                    <Button Content="🖊 Áp dụng" FontSize="10" Height="20" Padding="6,0" Margin="4,0,0,0"
                                                            Background="#059669" Foreground="{DynamicResource TextBrush}" BorderThickness="0" Cursor="Hand"
                                                            Click="ApplyExample_Click" Tag="ex2"
                                                            ToolTip="Điền sẵn HTML/CSS/JS ví dụ price × quantity vào editor"/>
                                                </StackPanel>
                                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="{DynamicResource PrimaryBrush}" TextWrapping="Wrap">
                                                    <Run Text="window.__ac.onUpdate("/>
                                                    <Run Text="'price', 'quantity'" Foreground="{DynamicResource WarningColor}"/>
                                                    <Run Text=", function(price, qty) {"/>
                                                    <LineBreak/>
                                                    <Run Text="    var total = parseFloat(price||0) * parseInt(qty||0);"/>
                                                    <LineBreak/>
                                                    <Run Text="    document.getElementById('total').textContent = total;"/>
                                                    <LineBreak/>
                                                    <Run Text="});"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Ví dụ 3: gọi nhiều func trong 1 callback -->
                                        <Border Background="{DynamicResource WindowBackground}" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
