                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                
                <!-- Tab 2: Thư viện offline JS/CSS -->
                <TabItem Header="📦 Thư viện offline" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Tiêu đề + hướng dẫn -->
                            <Border Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📦 Thư viện JS/CSS offline"
                                               Foreground="{DynamicResource InfoBrush}"
                                               FontSize="14" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12">
                                        <Run Text="• Tải thư viện JS/CSS về máy một lần rồi dùng offline (không cần Internet khi chạy node)."/>
                                        <LineBreak/>
                                        <Run Text="• Google Fonts (preset hoặc URL css2): khi tải, file .woff2 được gộp vào file CSS (data URI) vì HtmlUi dùng data: — không cần thẻ &lt;link&gt;. Trong CSS tab dùng font-family: 'Inter', 'JetBrains Mono', sans-serif;"/>
                                        <LineBreak/>
                                        <Run Text="• Thêm nhanh từ danh sách preset bên dưới, hoặc nhập URL / chọn file thủ công."/>
                                        <LineBreak/>
                                        <Run Text="• Preset chỉ dùng để thêm nhanh vào danh sách. Tải (hoặc tải lại) chủ động bằng nút ⬇ ở từng dòng bên dưới."/>
                                        <LineBreak/>
                                        <Run Text="• ☑ bật = tự động inject vào HTML khi node render. ☐ tắt = bỏ qua."/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- ===== Preset phổ biến ===== -->
                            <TextBlock Text="⚡ Thêm nhanh từ preset phổ biến:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource SurfaceColor}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1" CornerRadius="8"
                                    Padding="12,10" Margin="0,0,0,12">
                                <StackPanel>

                                    <!-- ── Hàng JS ── -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Background="{DynamicResource WarningBrush}"
                                                CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="JS" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="JavaScript libraries"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ItemsControl x:Name="JsPresetsItemsControl" Margin="0,0,0,2">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- JS Preset Card -->
                                                <Button Margin="0,0,6,6"
                                                        MinWidth="148" MaxWidth="200"
                                                        Padding="0"
                                                        Click="AddPresetButton_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="{Binding Description}"
                                                        Cursor="Hand">
                                                    <!-- 2-line card layout -->
                                                    <StackPanel Margin="10,7,10,7">
                                                        <!-- Dòng 1: Tên (không set Foreground — inherit từ Button để hover hoạt động đúng) -->
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,0,4"/>
                                                        <!-- Dòng 2: Status badges -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <!-- Badge: NEW (thêm thủ công) -->
                                                            <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                                    Background="{DynamicResource AccentColor}"
                                                                    Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="NEW" FontSize="8" FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextBrush}"/>
                                                            </Border>
                                                            <!-- Badge: Có file local -->
                                                            <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1"
                                                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="⬇ Có file" FontSize="9" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource SuccessBrush}"/>
                                                            </Border>
                                                            <!-- Badge: Đã thêm — JS dùng WarningBrush (amber) -->
                                                            <Border CornerRadius="3" Padding="5,2"
                                                                    Background="{DynamicResource WarningBrush}"
                                                                    Visibility="{Binding IsAdded, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="✓ Đã thêm" FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                                            </Border>
                                                            <!-- Badge: Chưa thêm -->
                                                            <Border CornerRadius="3" Padding="5,2">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsInstalled}" Value="False"/>
                                                                                    <Condition Binding="{Binding IsAdded}" Value="False"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="+ Thêm" FontSize="9"
                                                                           Foreground="{DynamicResource TextSecondary}"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource OfflineAssetPresetButton}">
                                                            <Setter Property="Background" Value="{DynamicResource CardColor}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1,1,1,2"/>
                                                            <Style.Triggers>
                                                                <!-- JS selected: nền amber -->
                                                                <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="1,1,1,2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Divider -->
                                    <Border Height="1" Background="{DynamicResource BorderColor}"
                                            Margin="0,6,0,10" Opacity="0.6"/>

                                    <!-- ── Hàng CSS ── -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <Border Background="{DynamicResource PrimaryBrush}"
                                                CornerRadius="4" Padding="8,3"
                                                VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="CSS" FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                        </Border>
                                        <TextBlock Text="Stylesheet libraries"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <ItemsControl x:Name="CssPresetsItemsControl">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- CSS Preset Card -->
                                                <Button Margin="0,0,6,6"
                                                        MinWidth="148" MaxWidth="200"
                                                        Padding="0"
                                                        Click="AddPresetButton_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="{Binding Description}"
                                                        Cursor="Hand">
                                                    <StackPanel Margin="10,7,10,7">
                                                        <!-- Dòng 1: Tên (inherit Foreground từ Button) -->
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Margin="0,0,0,4"/>
                                                        <!-- Dòng 2: Status badges -->
                                                        <StackPanel Orientation="Horizontal">
                                                            <!-- Badge: NEW (thêm thủ công) -->
                                                            <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                                    Background="{DynamicResource AccentColor}"
                                                                    Visibility="{Binding IsCustom, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="NEW" FontSize="8" FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextBrush}"/>
                                                            </Border>
                                                            <!-- Badge: Có file local -->
                                                            <Border CornerRadius="3" Padding="5,2" Margin="0,0,4,0"
                                                                    Background="Transparent"
                                                                    BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="1"
                                                                    Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="⬇ Có file" FontSize="9" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource SuccessBrush}"/>
                                                            </Border>
                                                            <!-- Badge: Đã thêm — CSS dùng PrimaryBrush (xanh) -->
                                                            <Border CornerRadius="3" Padding="5,2"
                                                                    Background="{DynamicResource PrimaryBrush}"
                                                                    Visibility="{Binding IsAdded, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="✓ Đã thêm" FontSize="9" FontWeight="Bold"
                                                                           Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                                                            </Border>
                                                            <!-- Badge: Chưa thêm -->
                                                            <Border CornerRadius="3" Padding="5,2">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <MultiDataTrigger>
                                                                                <MultiDataTrigger.Conditions>
                                                                                    <Condition Binding="{Binding IsInstalled}" Value="False"/>
                                                                                    <Condition Binding="{Binding IsAdded}" Value="False"/>
                                                                                </MultiDataTrigger.Conditions>
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </MultiDataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="+ Thêm" FontSize="9"
                                                                           Foreground="{DynamicResource TextSecondary}"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource OfflineAssetPresetButton}">
                                                            <Setter Property="Background" Value="{DynamicResource CardColor}"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1,1,1,2"/>
                                                            <Style.Triggers>
                                                                <!-- CSS selected: nền xanh PrimaryBrush -->
                                                                <DataTrigger Binding="{Binding IsAdded}" Value="True">
                                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextOnPrimaryBrush}"/>
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                                    <Setter Property="BorderThickness" Value="1,1,1,2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </Border>

                            <!-- ===== Thêm thủ công ===== -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="✏ Thêm thủ công:" Foreground="{DynamicResource TextBrush}"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button x:Name="ToggleManualAddButton"
                                            Height="28" Padding="10,0" Margin="0,0,8,0"
                                            Click="ToggleManualAddSection_Click"
                                            Cursor="Hand"
                                            Foreground="{DynamicResource TextBrush}"
                                            Content="Mở form"
                                            ToolTip="Hiện khối form thêm thủ công (URL / chọn file)">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bdT" CornerRadius="6"
                                                        Background="{DynamicResource SurfaceColor}" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bdT" Property="Opacity" Value="0.9"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="ManagePresetsButton"
                                            Height="28" Padding="10,0"
                                            Click="ManagePresets_Click"
                                            Cursor="Hand"
                                            ToolTip="Mở dialog quản lý tất cả preset tùy chỉnh (thêm / sửa / xóa)">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" CornerRadius="6"
                                                        Background="#1E40AF" Padding="{TemplateBinding Padding}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="📚" FontSize="12" Margin="0,0,5,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Quản lý preset" FontSize="11"
                                                                   FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"
                                                                   VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#2563EB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                            <Grid x:Name="ManualAddSectionGrid" Margin="0,0,0,12" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="80"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Tên hiển thị (Title)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                <TextBox x:Name="NewAssetTitleBox" Style="{DynamicResource BaseTextBoxV2}" Height="30" FontSize="12"
                                                         ToolTip="Ví dụ: Chart.js 4.x"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Loại" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="NewAssetTypeCombo" Height="30" Style="{DynamicResource BaseComboBox}"
                                                          SelectedIndex="0">
                                                    <ComboBoxItem Content="JS"/>
                                                    <ComboBoxItem Content="CSS"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Mô tả (Description)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="NewAssetDescBox" Style="{DynamicResource BaseTextBoxV2}" Height="30" FontSize="12" Margin="0,0,0,8"
                                                 ToolTip="Mô tả ngắn gọn — user đọc để biết thư viện này dùng để làm gì"/>
                                        <TextBlock Text="URL tải về (hoặc để trống nếu chọn file local)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                        <TextBox x:Name="NewAssetUrlBox" Style="{DynamicResource BaseTextBoxV2}" Height="30" FontSize="12"
                                                 ToolTip="JS/CSS trực tiếp, hoặc Google Fonts: https://fonts.googleapis.com/css2?family=... (app sẽ gộp font vào file .css offline)."/>
                                        <TextBlock Text="Tên file lưu local (để trống = tự đặt từ URL)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,8,0,4"/>
                                        <TextBox x:Name="NewAssetFileNameBox" Style="{DynamicResource BaseTextBoxV2}" Height="30" FontSize="12"
                                                 ToolTip="Ví dụ: chart.min.js — file sẽ được lưu vào thư mục HtmlUiAssets"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Button x:Name="AddAssetFromUrlButton" Content="⬇ Tải về" Height="36" Width="90" Margin="0,0,0,8"
                                            Style="{StaticResource OfflineAssetActionButton}"
                                            Background="#0EA5E9"
                                            Click="AddAssetFromUrl_Click"
                                            ToolTip="Tải file từ URL. Google Fonts css2: tạo một .css chứa @font-face + font base64 để dùng offline trong HtmlUi."/>
                                    <Button x:Name="AddAssetFromFileButton" Content="📁 Chọn file" Height="36" Width="90" Margin="0,0,0,8"
                                            Style="{StaticResource OfflineAssetActionButton}"
                                            Background="{DynamicResource ControlBorderBrush}"
                                            Click="AddAssetFromFile_Click"
                                            ToolTip="Chọn file JS/CSS local (sẽ được copy vào thư mục HtmlUiAssets)"/>
                                    <!-- Thêm thủ công vào preset nhanh -->
                                    <Button x:Name="AddToPresetButton" Height="36" Width="90"
                                            Style="{StaticResource OfflineAssetActionButton}"
                                            Background="{DynamicResource SuccessBrush}"
                                            Click="AddToPreset_Click"
                                            ToolTip="Thêm vào danh sách preset nhanh (hiển thị ở trên, có nhãn NEW)">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="+ Thêm" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <!-- ===== Danh sách assets ===== -->
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📋 Danh sách thư viện đã đăng ký:" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Foreground="{DynamicResource TextMuted}" FontSize="11" VerticalAlignment="Center"
                                           Text="☑ = inject vào HTML | ☐ = bỏ qua"/>
                            </Grid>

                            <Border Background="{DynamicResource WindowBackground}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="6" Margin="0,0,0,12">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                                    <ItemsControl x:Name="OfflineAssetsItemsControl" ItemsSource="{Binding OfflineAssetsList}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,6" Background="{DynamicResource WindowBackground}" CornerRadius="8" Padding="10"
                                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Checkbox enable/disable -->
                                                        <CheckBox Grid.Column="0"
                                                                  Style="{StaticResource ModernCheckBox}"
                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                  VerticalAlignment="Top"
                                                                  Margin="0,2,10,0"
                                                                  ToolTip="☑ bật = inject vào HTML | ☐ tắt = bỏ qua (và cũng không tự tải khi đóng dialog)"/>

                                                        <!-- Nội dung asset -->
                                                        <StackPanel Grid.Column="1">
                                                            <!-- Row 1: Badge + Title + Status -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <Border CornerRadius="4" Padding="5,2" Margin="0,0,6,0"
                                                                        Background="{DynamicResource WarningBrush}">
                                                                    <TextBlock Text="{Binding TypeBadge}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding AssetType}" Value="css">
                                                                                    <Setter Property="Background" Value="{DynamicResource InfoBrush}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding AssetType}" Value="js">
                                                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                </Border>
                                                                <TextBox Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{DynamicResource BaseTextBoxV2}"
                                                                         FontSize="13" FontWeight="SemiBold"
                                                                         Background="Transparent" BorderThickness="0"
                                                                         Padding="0" MinWidth="120" MaxWidth="240"
                                                                         VerticalContentAlignment="Center"
                                                                         ToolTip="Tên thư viện"/>
                                                                <Border Padding="5,2" CornerRadius="4" Margin="8,0,0,0" VerticalAlignment="Center"
                                                                        Background="{Binding LocalStatusBrush}">
                                                                    <TextBlock Text="{Binding LocalStatusText}" FontSize="9" FontWeight="Bold" Foreground="{DynamicResource TextBrush}"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <!-- Row 2: Description -->
                                                            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{DynamicResource BaseTextBoxV2}"
                                                                     FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                                                     Background="Transparent" BorderThickness="0"
                                                                     Padding="0" Margin="0,0,0,4"
                                                                     TextWrapping="Wrap" AcceptsReturn="False"
                                                                     ToolTip="Mô tả ngắn — giúp bạn nhớ thư viện này dùng để làm gì"/>

                                                            <!-- Row 3: URL source -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock Text="URL:" Foreground="{DynamicResource TextMuted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                <TextBox Text="{Binding SourceUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{DynamicResource BaseTextBoxV2}"
                                                                         FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource PrimaryBrush}"
                                                                         Background="Transparent" BorderThickness="0"
                                                                         Padding="0" MinWidth="200" Width="300"
                                                                         VerticalContentAlignment="Center"
                                                                         ToolTip="URL nguồn để tải lại nếu cần"/>
                                                            </StackPanel>

                                                            <!-- Row 4: Local file + status message -->
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="File:" Foreground="{DynamicResource TextMuted}" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                <TextBox Text="{Binding LocalFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                         Style="{DynamicResource BaseTextBoxV2}"
                                                                         FontSize="10" FontFamily="Consolas" Foreground="{DynamicResource WarningColor}"
                                                                         Background="Transparent" BorderThickness="0"
                                                                         Padding="0" Width="180"
                                                                         VerticalContentAlignment="Center"
                                                                         ToolTip="Tên file lưu trong thư mục HtmlUiAssets"/>
                                                                <TextBlock Text="|" Foreground="{DynamicResource TextSecondary}" FontSize="10" VerticalAlignment="Center" Margin="8,0,8,0"/>
                                                                <TextBlock Text="{Binding StatusMessage}" FontSize="10" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>

                                                                <!-- Downloading indicator -->
                                                                <TextBlock Text=" ⏳ Đang tải..." FontSize="10" Foreground="{DynamicResource WarningColor}" VerticalAlignment="Center"
                                                                           Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}"/>
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <!-- Buttons cột phải -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="8,0,0,0">
                                                            <Button Content="⬇" Width="28" Height="28" Margin="0,0,0,4"
                                                                    Style="{StaticResource OfflineAssetIconButton}"
                                                                    Background="#0EA5E9"
                                                                    Click="DownloadAsset_Click" Tag="{Binding}"
                                                                    FontSize="14" ToolTip="Tải về từ URL (ghi đè nếu đã có)"/>
                                                            <Button Content="🗑" Width="28" Height="28"
                                                                    Style="{StaticResource OfflineAssetIconButton}"
                                                                    Background="#EF4444"
                                                                    Command="{Binding DataContext.RemoveOfflineAssetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    FontSize="12" ToolTip="Xóa khỏi danh sách (không xóa file trên disk)"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <!-- Status message download -->
                            <TextBlock x:Name="AssetStatusText" Text="" Foreground="{DynamicResource WarningColor}" FontSize="12" Margin="0,0,0,8"
