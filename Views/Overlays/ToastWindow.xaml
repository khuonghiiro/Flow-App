<Window x:Class="FlowMy.Views.Overlays.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="320"
        Height="80"
        ResizeMode="NoResize">
    <Border CornerRadius="10"
            Background="#CC0F172A"
            BorderBrush="#33FFFFFF"
            BorderThickness="1"
            Padding="12">
        <StackPanel>
            <TextBlock x:Name="TitleText"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="MessageText"
                       Foreground="#E5E7EB"
                       FontSize="12"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis"
                       MaxHeight="40"/>
        </StackPanel>
    </Border>
</Window>

