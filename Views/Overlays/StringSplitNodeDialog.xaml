<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.StringSplitNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:converters="clr-namespace:FlowMy.Converters"
        Title="String Split Node"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="450"
        Height="650"
        MinWidth="350"
        MaxWidth="800"
        MinHeight="400">
    <Window.Resources>
        <!-- D�ng l?i converter gi?ng LoopNodeDialog d? show/hide error text -->
        <converters:InverseStringNullOrEmptyToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- ?? CRITICAL: Title TextBox v?i binding NodeTitle -->
                    <TextBox x:Name="TitleTextBox"
                          Grid.Column="0"
                          Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource BaseTextBoxV2}"
                          FontSize="16"
                          Padding="0,4,0,4"
                          VerticalContentAlignment="Center"
                          Cursor="IBeam"/>

                    <!-- ?? CRITICAL: Close button ph?i g?i SaveTitleCommand -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="?" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Ch?y logic node n�y"
                            Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="�" 
                            FontSize="12" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content: 2 tab Logic + T�i s? d?ng flow -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <!-- TitleDisplayMode Section -->
                    <TextBlock Text="Hi?n th? ti�u d?:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ComboBox x:Name="TitleDisplayModeComboBox"
                              Height="36"
                              Style="{DynamicResource BaseComboBox}"
                              Margin="0,0,0,16"
                              ItemsSource="{Binding TitleDisplayModeOptions}"
                              SelectedValuePath="Value"
                              DisplayMemberPath="DisplayName"
                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                    <!-- TitleColorMode Section -->
                    <TextBlock Text="M�u ti�u d?:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <ComboBox x:Name="TitleColorComboBox"
                                  Grid.Column="0"
                                  Height="36"
                                  Style="{DynamicResource BaseComboBox}"
                                  ItemsSource="{Binding TitleColorOptions}"
                                  SelectedValuePath="Key"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                        
                        <!-- Color Preview -->
                        <Border Grid.Column="1" 
                                x:Name="TitleColorPreview"
                                Width="36" Height="36" 
                                CornerRadius="6"
                                Margin="8,0,0,0"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1"/>
                    </Grid>

                    <!-- Regex Pattern Section -->
                    <TextBlock Text="Regex Pattern:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    
                    <TextBox Text="{Binding RegexPattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             Height="36"
                             Margin="0,0,0,4"
                             ToolTip="Regex pattern d? c?t chu?i (m?c d?nh: \r?\n d? c?t theo d�ng)"/>
                    
                    <TextBlock Text="M?c d?nh: \r?\n (c?t theo d�ng m?i)"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,0,0,16"/>

                    <!-- Output Key Section -->
                    <TextBlock Text="Output Key:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    
                    <TextBox Text="{Binding OutputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             Height="36"
                             Margin="0,0,0,4"
                             ToolTip="Key c?a output (d? tr?ng s? d�ng 'ListItems')"/>
                    
                    <TextBlock Text="�? tr?ng s? d�ng key m?c d?nh: 'ListItems'"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="11"
                               Margin="0,0,0,16"/>

                    <!-- Input Section -->
                    <TextBlock Text="Input:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>
                    
                    <Border Background="{DynamicResource WindowBodyBackground}" 
                            BorderBrush="{DynamicResource ControlBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="12" 
                            Margin="0,0,0,8">
                        <StackPanel x:Name="InputsPanel"/>
                    </Border>

                    <!-- Error message khi input type kh�ng ph?i String -->
                    <TextBlock Text="{Binding InputErrorMessage}"
                               Foreground="{DynamicResource DangerColor}"
                               FontSize="11"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16"
                               Visibility="{Binding InputErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Output Section -->
                    <TextBlock Text="Output:"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               x:Name="TextBlockOutputPanel"/>
                    
                    <Border Background="{DynamicResource WindowBodyBackground}" 
                            BorderBrush="{DynamicResource ControlBorderBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="12" 
                            Margin="0,0,0,16"
                            x:Name="BorderOutputPanel">
                        <StackPanel x:Name="OutputsPanel"/>
                    </Border>

                    <!-- Note Section -->
                    <Border Background="{DynamicResource HeaderBackgroundBrush}" 
                            BorderBrush="{DynamicResource PrimaryGlowBrush}" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="12" 
                            Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="?? Luu �:"
                                       Foreground="{DynamicResource PrimaryBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextMuted}"
                                       FontSize="12"
                                       LineHeight="18">
                                � Node s? t? d?ng b? qua c�c item r?ng, null, ho?c ch? c� kho?ng tr?ng<LineBreak/>
                                � Output l� m?ng string<LineBreak/>
                                � C� th? d?i key c?a output d? d? nh?n di?n
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: T�i s? d?ng flow -->
                <TabItem Header="T�i s? d?ng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- C?u h�nh v? tr� c?ng IN/OUT -->
                            <TextBlock Text="V? tr� c?ng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Port IN -->
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN (c?ng v�o)"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>

                                <!-- Port OUT -->
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT (c?ng ra)"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <!-- C?u h�nh t�i s? d?ng flow -->
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Node IN -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Node OUT -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <!-- Ki?u line OUT -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Ki?u line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
