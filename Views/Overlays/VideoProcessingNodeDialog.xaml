<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.VideoProcessingNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Video Processing"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MinHeight="420">
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton"
                                Width="24"
                                Height="24"
                                Content="▶"
                                FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Margin="8,0,0,0"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton"
                                Width="24"
                                Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="✕"
                                FontSize="12"
                                FontWeight="Bold"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Hiển thị tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <ComboBox Height="36"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,12"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <TextBlock Text="Màu tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <ComboBox Height="36"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,16"
                                      ItemsSource="{Binding TitleColorOptions}"
                                      SelectedValuePath="Key"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"/>

                            <TextBlock Text="Video Source"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                                                         Height="36"
                                                                         ItemsSource="{Binding AvailableNodeOptions}"
                                                                         SelectedValuePath="NodeId"
                                                                         DisplayMemberPath="Title"
                                                                         SelectedValue="{Binding VideoSourceNodeId, Mode=TwoWay}"
                                                                         SelectionChanged="VideoSourceNodeComboBox_SelectionChanged"/>
                                <ComboBox x:Name="VideoSourceKeyComboBox"
                                          Grid.Column="2"
                                          Height="36"
                                          Style="{DynamicResource BaseComboBox}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="Key"
                                          SelectedValue="{Binding VideoSourceOutputKey, Mode=TwoWay}"/>
                            </Grid>

                            <CheckBox Content="Output Base64"
                                      Foreground="{DynamicResource TextBrush}"
                                      IsChecked="{Binding OutputBase64, Mode=TwoWay}"
                                      Margin="0,0,0,10"/>

                            <StackPanel x:Name="OutputFolderPanel">
                                <TextBlock Text="Output Folder"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                                                             Height="36"
                                                                             ItemsSource="{Binding AvailableNodeOptions}"
                                                                             SelectedValuePath="NodeId"
                                                                             DisplayMemberPath="Title"
                                                                             SelectedValue="{Binding OutputFolderSourceNodeId, Mode=TwoWay}"
                                                                             SelectionChanged="OutputFolderNodeComboBox_SelectionChanged"/>
                                    <ComboBox x:Name="OutputFolderKeyComboBox"
                                              Grid.Column="2"
                                              Height="36"
                                              Style="{DynamicResource BaseComboBox}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Key"
                                              SelectedValue="{Binding OutputFolderSourceOutputKey, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>

                            <StackPanel x:Name="VideoOutputFolderPanel">
                                <TextBlock Text="Video Folder (node link)"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,16,0,8"/>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                                                             Height="36"
                                                                             ItemsSource="{Binding AvailableNodeOptions}"
                                                                             SelectedValuePath="NodeId"
                                                                             DisplayMemberPath="Title"
                                                                             SelectedValue="{Binding VideoOutputFolderSourceNodeId, Mode=TwoWay}"
                                                                             SelectionChanged="VideoOutputFolderNodeComboBox_SelectionChanged"/>
                                    <ComboBox x:Name="VideoOutputFolderKeyComboBox"
                                              Grid.Column="2"
                                              Height="36"
                                              Style="{DynamicResource BaseComboBox}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="Key"
                                              SelectedValue="{Binding VideoOutputFolderSourceOutputKey, Mode=TwoWay}"/>
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="Frame Output Folder (local)"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBox Height="36"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Margin="0,0,0,12"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding FrameOutputFolderPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Default Output Video Path"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <TextBox Height="36"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Margin="0,0,0,16"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding DefaultOutputVideoPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Outputs:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12">
                                <StackPanel x:Name="OutputsPanel"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Vị trí cổng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Đường dẫn FFmpeg"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Height="36"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding FfmpegPath, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2"
                                        MinWidth="92"
                                        Height="36"
                                        Content="Chọn thư mục"
                                        Style="{DynamicResource PrimaryButton}"
                                        Click="BrowseFfmpegFolderButton_Click"/>
                                <Button Grid.Column="4"
                                        MinWidth="92"
                                        Height="36"
                                        Content="Chọn file..."
                                        Style="{DynamicResource PrimaryButton}"
                                        Click="BrowseFfmpegPathButton_Click"/>
                            </Grid>
                            <TextBlock Foreground="{DynamicResource TextMuted}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,4">
                                Có thể nhập đường dẫn thư mục chứa <Run FontWeight="SemiBold">ffmpeg.exe</Run> hoặc nhập trực tiếp file <Run FontWeight="SemiBold">ffmpeg.exe</Run>.
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource TextMuted}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,16">
                                Nếu chưa có FFmpeg, tải bản full build tại
                                <Hyperlink NavigateUri="https://www.gyan.dev/ffmpeg/builds/"
                                           RequestNavigate="OpenFfmpegGuideLink_Click">gyan.dev/ffmpeg/builds</Hyperlink>,
                                giải nén và chọn file <Run FontWeight="SemiBold">bin\ffmpeg.exe</Run>.
                            </TextBlock>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
