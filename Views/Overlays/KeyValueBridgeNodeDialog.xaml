<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.KeyValueBridgeNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:converters="clr-namespace:FlowMy.Converters"
        Title="KeyValue Bridge"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        Height="720"
        MinWidth="420"
        MaxWidth="800"
        MinHeight="420">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                          Grid.Column="0"
                          Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource BaseTextBoxV2}"
                          FontSize="16"
                          Padding="0,4,0,4"
                          VerticalContentAlignment="Center"
                          Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="✕"
                            FontSize="12"
                            FontWeight="Bold"
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- 🎨 Cấu hình hiển thị -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Cấu hình hiển thị"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Hiển thị tiêu đề"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="TitleDisplayModeComboBox"
                                              Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>
                                    <TextBlock Text="Màu tiêu đề"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox"
                                                  Grid.Column="0"
                                                  Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Border Grid.Column="1"
                                                x:Name="TitleColorPreview"
                                                Width="32" Height="32"
                                                CornerRadius="6"
                                                Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ⚙️ Chế độ hoạt động -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⚙️ Chế độ hoạt động"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <CheckBox Content="Chế độ Pass (ghi KV từ luồng)"
                                              IsChecked="{Binding IsPassKeyMode, Mode=TwoWay}"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="11"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="10"
                                               LineHeight="16"
                                               Margin="22,4,0,10"
                                               Text="Bật: hiện cổng IN/OUT trên canvas — mỗi lần luồng chạy qua, giá trị được append vào kho key/value runtime (dùng chung trong một lần chạy workflow). Tắt: chuyển sang Get — đọc KV đã có theo interval, thường không cần nối cổng IN (trừ khi bật 'Xoá dữ liệu' bên dưới)."/>
                                    <CheckBox Content="Xoá dữ liệu (cleanup KV runtime)"
                                              IsChecked="{Binding EnableDataCleanup, Mode=TwoWay}"
                                              Foreground="{DynamicResource TextBrush}"
                                              FontSize="11"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="10"
                                               LineHeight="16"
                                               Margin="22,4,0,0"
                                               Text="Bật: node dùng để xóa KV theo cấu hình mục 'KV Data Cleanup'. Cổng IN trên canvas luôn hiện để bạn nối luồng kích hoạt cleanup — kể cả khi Pass đang tắt (Get)."/>
                                </StackPanel>
                            </Border>

                            <StackPanel Visibility="{Binding EnableDataCleanup, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                            <StackPanel Visibility="{Binding IsPassKeyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <!-- 🔑 Key Identifier -->
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="🔑 Key Identifier"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Khóa định danh KV"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding KvChannelKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 Height="32"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsPassKeyMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <!-- 🔗 Source node (Get mode) -->
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="🔗 Source node (Get mode)"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <TextBlock Text="Node nguồn (Pass Key bridge)"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <controls:NodeSearchComboBoxUserControl x:Name="SourceBridgeCombo"
                                                  Height="32"
                                                  Margin="0,0,0,8"
                                                  ItemsSource="{Binding PassBridgeSourceOptions}"
                                                  SelectedValuePath="NodeId"
                                                  DisplayMemberPath="Title"
                                                  SelectedValue="{Binding SelectedSourceBridgeNodeId, Mode=TwoWay}"/>

                                        <TextBlock Text="Key"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="KeyCombo"
                                                  Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  Margin="0,0,0,8"
                                                  IsEditable="False"
                                                  ItemsSource="{Binding KnownKeyOptions}"
                                                  SelectedItem="{Binding KvChannelKey, Mode=TwoWay}"/>

                                        <TextBlock Text="Fetch interval"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Margin="0,0,8,0"
                                                     Style="{DynamicResource BaseTextBoxV2}"
                                                     Height="32"
                                                     Text="{Binding PollIntervalValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <ComboBox Grid.Column="1"
                                                      Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ItemsSource="{Binding PollUnitOptions}"
                                                      SelectedValuePath="Unit"
                                                      DisplayMemberPath="Label"
                                                      SelectedValue="{Binding PollIntervalUnit, Mode=TwoWay}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsPassKeyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                                <!-- 📥 Input mapping (Pass mode) -->
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="📥 Input mapping (Pass mode)"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <Border Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1" CornerRadius="6" Padding="12">
                                            <StackPanel x:Name="InputsPanel"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ➕ Value append sources -->
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="➕ Value append sources (multiple)"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                        <ItemsControl ItemsSource="{Binding AdditionalAppendSources}" Margin="0,0,0,8">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                                                      Height="32"
                                                                      Margin="0,0,8,0"
                                                                      ItemsSource="{Binding AvailableSources}"
                                                                      SelectedValuePath="NodeId"
                                                                      DisplayMemberPath="Title"
                                                                      SelectedValue="{Binding SelectedSourceNodeId, Mode=TwoWay}"/>
                                                            <ComboBox Grid.Column="1"
                                                                      Height="32"
                                                                      Margin="0,0,8,0"
                                                                      Style="{DynamicResource BaseComboBox}"
                                                                      ItemsSource="{Binding AvailableOutputKeyOptions}"
                                                                      SelectedValuePath="Key"
                                                                      DisplayMemberPath="Key"
                                                                      SelectedValue="{Binding SelectedSourceOutputKey, Mode=TwoWay}"/>
                                                            <Button Grid.Column="2"
                                                                    Content="X"
                                                                    Width="28"
                                                                    Height="28"
                                                                    Style="{DynamicResource DangerButton}"
                                                                    Click="RemoveAdditionalAppendSource_Click"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="+ Thêm nguồn append"
                                                Style="{DynamicResource PrimaryButton}"
                                                Height="32"
                                                Click="AddAdditionalAppendSource_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </StackPanel>

                            <!-- 📤 Outputs -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📤 Outputs"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="OutputsPanel"/>
                                </StackPanel>
                            </Border>

                            <!-- 💡 Runtime -->
                            <Border Background="{DynamicResource CardColor}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="💡 Runtime"
                                               Foreground="{DynamicResource PrimaryBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10"
                                               LineHeight="16"
                                               Text="• Kho kv dùng chung trong một lần chạy (ExecutionId). Trong Code node: kv['myKey'] đọc; gán kv['myKey']=x để ghi (append nếu trùng key).&#x0a;• Pass: cổng IN/OUT trên flow để ghi KV. Get: không cần IN; đọc store theo interval.&#x0a;• Cleanup: bật 'Xoá dữ liệu' thì luôn có cổng IN để nối luồng kích hoạt xóa."/>
                                </StackPanel>
                            </Border>

                            <!-- 🧹 KV Data Cleanup -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🧹 KV Data Cleanup"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,10"/>
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextMuted}"
                                               FontSize="10"
                                               LineHeight="16"
                                               Margin="0,0,0,8"
                                               Text="Cấu hình xóa dữ liệu runtime của một node KeyValueBridge (Pass) khác. Luồng phải chạy qua cổng IN của node này (khi đã bật 'Xoá dữ liệu') thì cleanup mới chạy theo workflow."/>

                                    <StackPanel Visibility="{Binding EnableDataCleanup, Converter={StaticResource BoolToVisibilityConverter}}">
                                <!-- 🎯 Điều kiện trigger -->
                                <Border Background="{DynamicResource CardColor}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="🎯 1) Điều kiện trigger (bắt buộc)"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock TextWrapping="Wrap"
                                                   Text="Chọn node có output động, rồi chọn output key. Cột phải: chọn giá trị kỳ vọng."
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   LineHeight="14"
                                                   Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                                      Height="32"
                                                      Margin="0,0,6,0"
                                                      ToolTip="Node nguồn: phải có ít nhất một output động (dynamic output)."
                                                      ItemsSource="{Binding CleanupTriggerSourceOptions}"
                                                      SelectedValuePath="NodeId"
                                                      DisplayMemberPath="Title"
                                                      SelectedValue="{Binding CleanupTriggerSourceNodeId, Mode=TwoWay}"/>
                                            <ComboBox Grid.Column="1"
                                                      Height="32"
                                                      Margin="0,0,6,0"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ToolTip="Output key trên node trigger — giá trị sẽ được so với ô bên phải."
                                                      ItemsSource="{Binding CleanupTriggerOutputKeyOptions}"
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValue="{Binding CleanupTriggerSourceOutputKey, Mode=TwoWay}"/>
                                            <ComboBox Grid.Column="2"
                                                      Height="32"
                                                      Style="{DynamicResource BaseComboBox}"
                                                      ToolTip="Giá trị kỳ vọng (so khớp kiểu boolean/số)."
                                                      ItemsSource="{Binding CleanupTriggerExpectedValueOptions}"
                                                      SelectedItem="{Binding CleanupTriggerExpectedValue, Mode=TwoWay}"/>
                                        </Grid>
                                        <TextBlock Text="Cột trái → giữa → phải: node trigger — output đọc giá trị — giá trị kỳ vọng."
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="9"
                                                   Margin="0,0,0,0"/>

                                        <CheckBox Content="Xóa toàn bộ KV runtime của node đích"
                                                  Foreground="{DynamicResource DangerColor}"
                                                  FontSize="10"
                                                  IsChecked="{Binding ClearAllDataForSelectedNode, Mode=TwoWay}"
                                                  Margin="0,8,0,0"/>
                                        <TextBlock TextWrapping="Wrap"
                                                   Text="Tick: xóa hết key của node KeyValueBridge đích. Bỏ tick: xóa theo key / lọc mảng ở các bước dưới."
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="9"
                                                   LineHeight="14"
                                                   Margin="22,0,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 🎯 Node KV đích -->
                                <Border Background="{DynamicResource CardColor}"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="🎯 2) Node KV đích (Pass) bị xóa data"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock TextWrapping="Wrap"
                                                   Text="Liệt kê các KeyValueBridge Pass hoặc Get (không bật 'Xoá dữ liệu' trên chính node đó)."
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="10"
                                                   LineHeight="14"
                                                   Margin="0,0,0,6"/>
                                        <controls:NodeSearchComboBoxUserControl Height="32"
                                                  ToolTip="Node KVB Pass hoặc Get (không phải node cleanup). Pass = xóa kho kv gốc; Get = xóa kv Get + kv Pass nguồn nếu có."
                                                  ItemsSource="{Binding DeleteBridgeNodeOptions}"
                                                  SelectedValuePath="NodeId"
                                                  DisplayMemberPath="Title"
                                                  SelectedValue="{Binding SelectedDeleteBridgeNodeId, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Visibility="{Binding ClearAllDataForSelectedNode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock Text="3) Key cần xóa (hoặc xóa cả node)"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap"
                                           Text="Chỉ hiện khi không bật 'xóa toàn bộ' ở trên: nhập hoặc chọn một key trong ô combobox (danh sách từ snapshot runtime). Hai combobox map động là tùy chọn."
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           LineHeight="16"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Map động tên key (tùy chọn):"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                              Height="36"
                                              Margin="0,0,4,0"
                                              ToolTip="Node có output string — thường là tên key cần xóa do luồng trước tính ra."
                                              ItemsSource="{Binding CleanupKeySourceOptions}"
                                              SelectedValuePath="NodeId"
                                              DisplayMemberPath="Title"
                                              SelectedValue="{Binding CleanupKeySourceNodeId, Mode=TwoWay}"/>
                                    <ComboBox Grid.Column="1"
                                              Height="36"
                                              Margin="4,0,0,0"
                                              Style="{DynamicResource BaseComboBox}"
                                              ToolTip="Output key chứa chuỗi tên key."
                                              ItemsSource="{Binding CleanupKeySourceOutputKeyOptions}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding CleanupKeySourceOutputKey, Mode=TwoWay}"/>
                                </Grid>
                                <ComboBox Height="36"
                                          Style="{DynamicResource BaseComboBox}"
                                          Margin="0,0,0,8"
                                          IsEditable="True"
                                          ToolTip="Key tĩnh (gõ) hoặc chọn từ danh sách key đang có trên node đích. Nếu đã map động ở trên thì map được ưu tiên khi chạy."
                                          ItemsSource="{Binding DeleteKeyOptions}"
                                          Text="{Binding DeleteTargetKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <TextBlock Text="4) Xóa theo phần tử trong mảng JSON (tùy chọn)"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,4"/>
                                <TextBlock TextWrapping="Wrap"
                                           Text="Dùng khi value của key là mảng object và bạn chỉ muốn bỏ các phần tử có field = value. Có thể gõ tĩnh ở hai ô text, hoặc map thêm từ output node (ưu tiên khi chạy nếu đã bind)."
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           LineHeight="16"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Tên field JSON (map động tùy chọn):"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                              Height="36"
                                              Margin="0,0,4,0"
                                              ToolTip="Node cung cấp tên field (string), ví dụ tên cột trong object mảng."
                                              ItemsSource="{Binding CleanupFilterFieldSourceOptions}"
                                              SelectedValuePath="NodeId"
                                              DisplayMemberPath="Title"
                                              SelectedValue="{Binding CleanupFilterFieldSourceNodeId, Mode=TwoWay}"/>
                                    <ComboBox Grid.Column="1"
                                              Height="36"
                                              Margin="4,0,0,0"
                                              Style="{DynamicResource BaseComboBox}"
                                              ToolTip="Output key → chuỗi tên field."
                                              ItemsSource="{Binding CleanupFilterFieldSourceOutputKeyOptions}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding CleanupFilterFieldSourceOutputKey, Mode=TwoWay}"/>
                                </Grid>
                                <TextBlock Text="Giá trị tĩnh: tên field (trái) — giá trị cần khớp (phải)"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Height="36"
                                             Margin="0,0,4,0"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             ToolTip="Ví dụ: cardId — trường trong mỗi object của mảng."
                                             Text="{Binding ArrayFilterField, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="1"
                                             Height="36"
                                             Margin="4,0,0,0"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             ToolTip="Ví dụ: UUID hoặc chuỗi id — object nào có field bằng giá trị này thì bị loại khỏi mảng."
                                             Text="{Binding ArrayFilterValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </Grid>
                                <TextBlock Text="Ví dụ: field = cardId, value = db90733a-aed0-440a-ba1d-6773271268b9"
                                           Foreground="{DynamicResource TextMuted}"
                                           FontSize="10"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Giá trị filter — map động (tùy chọn, thay cho ô text phải):"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11"
                                           Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:NodeSearchComboBoxUserControl Grid.Column="0"
                                              Height="36"
                                              Margin="0,0,4,0"
                                              ToolTip="Node nguồn giá trị cần so khớp (cùng nghĩa với ô text phải)."
                                              ItemsSource="{Binding CleanupFilterValueSourceOptions}"
                                              SelectedValuePath="NodeId"
                                              DisplayMemberPath="Title"
                                              SelectedValue="{Binding CleanupFilterValueSourceNodeId, Mode=TwoWay}"/>
                                    <ComboBox Grid.Column="1"
                                              Height="36"
                                              Margin="4,0,0,0"
                                              Style="{DynamicResource BaseComboBox}"
                                              ToolTip="Output key → giá trị so khớp với field đã chọn."
                                              ItemsSource="{Binding CleanupFilterValueSourceOutputKeyOptions}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding CleanupFilterValueSourceOutputKey, Mode=TwoWay}"/>
                                </Grid>
                                <CheckBox Content="Xóa tất cả item khớp điều kiện (tắt = chỉ xóa 1 item)"
                                          Foreground="{DynamicResource TextSecondary}"
                                          FontSize="12"
                                          IsChecked="{Binding RemoveAllMatchedArrayItems, Mode=TwoWay}"
                                          Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource CardColor}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Effective key / filter (debug):"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   FontSize="11"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding EffectiveDeleteKeyPreview}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding EffectiveFilterValuePreview}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Button Content="Thực hiện xóa KV data"
                                        Height="32"
                                        Style="{DynamicResource DangerButton}"
                                        Cursor="Hand"
                                        Margin="0,0,0,8"
                                        Command="{Binding DeleteKvDataCommand}"/>

                                <Border Background="{DynamicResource CardColor}"
                                        CornerRadius="6"
                                        Padding="10,8"
                                        Margin="0,0,0,8">
                                    <TextBlock Text="{Binding DeleteResultMessage}"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               TextWrapping="Wrap"/>
                                </Border>
                                </StackPanel>

                                <TextBlock Text="Preview dữ liệu hiện tại trước khi xóa:"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           Margin="0,0,0,6"/>
                                <Button Content="Refresh Preview"
                                        Height="28"
                                        Width="130"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,6"
                                        Style="{DynamicResource PrimaryButton}"
                                        Cursor="Hand"
                                        Command="{Binding RefreshDeletePreviewNowCommand}"/>
                                <Border Background="{DynamicResource WindowBackground}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="8"
                                        Margin="0,0,0,0">
                                    <ScrollViewer MaxHeight="180" VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding DeletePreviewJson}"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   FontSize="11"
                                                   FontFamily="Consolas"
                                                   TextWrapping="Wrap"/>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Vị trí cổng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                    <ColumnDefinition Width="2*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
