<Window x:Class="FlowMy.Views.Overlays.MacroPlaybackOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Playback"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Focusable="False">

    <Grid>
        <!-- Viền sáng primary khi đang phát lại thao tác -->
        <Border x:Name="GlowBorder"
                IsHitTestVisible="False"
                BorderBrush="#FF2299FF"
                BorderThickness="6"
                CornerRadius="8"
                Margin="8"
                Opacity="0.85">
            <Border.Effect>
                <DropShadowEffect Color="#2299FF" BlurRadius="25" ShadowDepth="0" Opacity="0.9"/>
            </Border.Effect>
            <!-- Hiệu ứng sáng viền (pulse) -->
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.2" To="1.0" Duration="0:0:1.0" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- Drawing canvas for replay visuals -->
        <Canvas x:Name="DrawingCanvas" IsHitTestVisible="False"/>

        <!-- Chuột ảo: theo dõi vị trí thực thi thao tác (không ảnh hưởng input) -->
        <Canvas x:Name="CursorCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False">
            <!-- Mũi tên chuột ảo màu xanh lam, luôn hiển thị khi overlay mở -->
            <Path x:Name="VirtualCursor"
                  Visibility="Collapsed"
                  IsHitTestVisible="False"
                  Fill="#FF2299FF"
                  Stroke="#FFFFFFFF"
                  StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0" IsClosed="True">
                            <LineSegment Point="0,14"/>
                            <LineSegment Point="4,10"/>
                            <LineSegment Point="7,16"/>
                            <LineSegment Point="9,15"/>
                            <LineSegment Point="6,9"/>
                            <LineSegment Point="11,9"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
                <Path.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/>
                </Path.Effect>
            </Path>

            <!-- Floating action tooltip — follows cursor, auto-repositions near edges -->
            <Border x:Name="ActionHintBorder"
                    Visibility="Collapsed"
                    Background="#E0101828"
                    BorderBrush="#CC2299FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,7"
                    Canvas.Left="20"
                    Canvas.Top="20">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Dòng 1: phím / tổ hợp phím -->
                    <TextBlock x:Name="ActionHintKeyText"
                               FontSize="13"
                               FontWeight="Bold"
                               Foreground="#FF2299FF"
                               TextAlignment="Center"
                               Visibility="Collapsed"/>
                    <!-- Dòng 2: mô tả hành động -->
                    <TextBlock x:Name="ActionHintText"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFFFF"
                               TextAlignment="Center"
                               MaxWidth="180"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Status bar — top center -->
        <Border x:Name="StatusPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,24,0,0"
                Background="#E0111111"
                CornerRadius="8"
                Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="16"
                           Foreground="#44FF88"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Text="▶"/>
                <TextBlock x:Name="StatusText"
                           FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Text="Đang phát lại thao tác..."/>
            </StackPanel>
        </Border>

        <!-- Progress: cycle / action count — top right -->
        <Border x:Name="ProgressPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,24,24,0"
                Background="#E0003366"
                CornerRadius="8"
                Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Text="▶"/>
                <TextBlock x:Name="ProgressText"
                           FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Text="0 / 0"/>
            </StackPanel>
        </Border>

        <!-- Action counter — top left -->
        <Border x:Name="ActionPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="24,24,0,0"
                Background="#E0111111"
                CornerRadius="8"
                Padding="14,8">
            <TextBlock x:Name="ActionText"
                       FontSize="13"
                       Foreground="#FFFFFF"
                       FontWeight="Medium"
                       Text="Thao tác 0 / 0"/>
        </Border>

        <!-- ESC hint — bottom center -->
        <Border IsHitTestVisible="False"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,24"
                Background="#CC111111"
                CornerRadius="6"
                Padding="14,6"
                Visibility="Collapsed">  <!-- Ẩn bớt đi cho gọn, giữ panel held keys -->
            <TextBlock FontSize="12"
                       Foreground="#AAFFFFFF"
                       Text="Nhấn ESC × 3 liên tiếp để dừng workflow"/>
        </Border>

        <!-- Hiển thị các phím Modifier đang giữ (Góc dưới phải) -->
        <Border x:Name="HeldKeysPanel"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,24,24"
                Background="#D00A0A0A"
                CornerRadius="8"
                Padding="16,10"
                Visibility="Collapsed"
                IsHitTestVisible="False">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="ĐANG GIỮ PHÍM" FontSize="11" Foreground="#AAFFFFFF" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Center"/>
                <StackPanel x:Name="HeldKeysStack" Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Sẽ được thêm bằng code-behind -->
                </StackPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
