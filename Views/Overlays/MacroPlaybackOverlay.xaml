<Window x:Class="FlowMy.Views.Overlays.MacroPlaybackOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Playback"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        IsHitTestVisible="False"
        Focusable="False">

    <Grid>
        <!-- Drawing canvas for replay visuals -->
        <Canvas x:Name="DrawingCanvas" IsHitTestVisible="False"/>

        <!-- Chuột ảo: theo dõi vị trí thực thi thao tác (không ảnh hưởng input) -->
        <Canvas x:Name="CursorCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                IsHitTestVisible="False">
            <!-- Mũi tên chuột ảo màu xanh lam, luôn hiển thị khi overlay mở -->
            <Path x:Name="VirtualCursor"
                  Visibility="Collapsed"
                  IsHitTestVisible="False"
                  Fill="#FF2299FF"
                  Stroke="#FFFFFFFF"
                  StrokeThickness="1">
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0" IsClosed="True">
                            <LineSegment Point="0,14"/>
                            <LineSegment Point="4,10"/>
                            <LineSegment Point="7,16"/>
                            <LineSegment Point="9,15"/>
                            <LineSegment Point="6,9"/>
                            <LineSegment Point="11,9"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
                <Path.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.6"/>
                </Path.Effect>
            </Path>

            <!-- Hint hành động: hiện khi đang nhấn / giữ chuột -->
            <Border x:Name="ActionHintBorder"
                    Visibility="Collapsed"
                    Background="#DD1A1A2E"
                    BorderBrush="#882299FF"
                    BorderThickness="1"
                    CornerRadius="5"
                    Padding="8,4"
                    Canvas.Left="16"
                    Canvas.Top="16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🖱 "
                               FontSize="11"
                               Foreground="#FF2299FF"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActionHintText"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#FFFFFFFF"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Status bar — top center -->
        <Border x:Name="StatusPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,24,0,0"
                Background="#E0111111"
                CornerRadius="8"
                Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="16"
                           Foreground="#44FF88"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Text="▶"/>
                <TextBlock x:Name="StatusText"
                           FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Text="Đang phát lại thao tác..."/>
            </StackPanel>
        </Border>

        <!-- Progress: cycle / action count — top right -->
        <Border x:Name="ProgressPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,24,24,0"
                Background="#E0003366"
                CornerRadius="8"
                Padding="16,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Text="▶"/>
                <TextBlock x:Name="ProgressText"
                           FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Text="0 / 0"/>
            </StackPanel>
        </Border>

        <!-- Action counter — top left -->
        <Border x:Name="ActionPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="24,24,0,0"
                Background="#E0111111"
                CornerRadius="8"
                Padding="14,8">
            <TextBlock x:Name="ActionText"
                       FontSize="13"
                       Foreground="#FFFFFF"
                       FontWeight="Medium"
                       Text="Thao tác 0 / 0"/>
        </Border>

        <!-- ESC hint — bottom center -->
        <Border IsHitTestVisible="False"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,24"
                Background="#CC111111"
                CornerRadius="6"
                Padding="14,6">
            <TextBlock FontSize="12"
                       Foreground="#AAFFFFFF"
                       Text="Nhấn ESC × 3 liên tiếp để dừng workflow"/>
        </Border>

        <!-- Right-side action info panel -->
        <Border x:Name="RightActionPanel"
                IsHitTestVisible="False"
                VerticalAlignment="Center"
                HorizontalAlignment="Right"
                Margin="0,0,24,0"
                Background="#E0111111"
                CornerRadius="12"
                Padding="20,16"
                Visibility="Collapsed">
            <StackPanel>
                <!-- Phím/Tổ hợp phím -->
                <TextBlock x:Name="RightActionKeyText"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FF2299FF"
                           TextAlignment="Center"
                           Margin="0,0,0,8"
                           Text="Ctrl+L"/>
                <!-- Mô tả đang xử lý gì -->
                <TextBlock x:Name="RightActionDescText"
                           FontSize="14"
                           Foreground="#CCFFFFFF"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="200"
                           Text="Đang nhấn chuột trái"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
