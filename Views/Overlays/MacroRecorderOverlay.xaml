<Window x:Class="FlowMy.Views.Overlays.MacroRecorderOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Macro Recorder"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowState="Maximized"
        ShowInTaskbar="False"
        Focusable="True">

    <Grid>
        <!-- Viền xanh khi đang ghi — hiển thị để biết overlay đang active -->
        <Border x:Name="RecordingBorder"
                IsHitTestVisible="False"
                BorderBrush="#FF0077FF"
                BorderThickness="1"
                CornerRadius="0"
                Margin="0"
                Background="Transparent"
                Panel.ZIndex="100"
                Visibility="Collapsed">
            
            <!-- Hiệu ứng đậm đến nhạt từ viền ngoài vào trong -->
            <Border BorderBrush="#AA0077FF" BorderThickness="8" CornerRadius="0" Background="Transparent">
                <Border BorderBrush="#550077FF" BorderThickness="16" CornerRadius="0" Background="Transparent">
                </Border>
            </Border>

            <!-- Hiệu ứng sáng viền (pulse) -->
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Visibility, RelativeSource={RelativeSource Self}}" Value="Visible">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.1" To="1.0" Duration="0:0:1.0" AutoReverse="True"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
        </Border>

        <!-- Lớp phủ trong suốt — rất nhẹ, chỉ để overlay có nền -->
        <!-- Ẩn khi ở chế độ thao tác thực để click đi qua -->
        <Rectangle x:Name="HitTestRect" Fill="#01000000" IsHitTestVisible="True"/>

        <!-- Canvas để vẽ trail và visual feedback -->
        <Canvas x:Name="DrawingCanvas" IsHitTestVisible="False"/>

        <!-- Chuột ảo: hiển thị vị trí chuột thật khi đang ghi (không ảnh hưởng input) -->
        <Canvas x:Name="CursorCanvas" IsHitTestVisible="False">
            <!-- VirtualCursor: hình mũi tên nhỏ màu đỏ, ẩn khi chưa ghi -->
            <Path x:Name="VirtualCursor"
                  Visibility="Collapsed"
                  IsHitTestVisible="False"
                  Fill="#FFEE0000"
                  Stroke="#FFFFFFFF"
                  StrokeThickness="1">
                <!-- Mũi tên chuột chuẩn (12×18 px) -->
                <Path.Data>
                    <PathGeometry>
                        <PathFigure StartPoint="0,0" IsClosed="True">
                            <LineSegment Point="0,14"/>
                            <LineSegment Point="4,10"/>
                            <LineSegment Point="7,16"/>
                            <LineSegment Point="9,15"/>
                            <LineSegment Point="6,9"/>
                            <LineSegment Point="11,9"/>
                        </PathFigure>
                    </PathGeometry>
                </Path.Data>
            </Path>
        </Canvas>

        <!-- Panel hướng dẫn / trạng thái (góc trên giữa) -->
        <Border x:Name="InstructionPanel"
                VerticalAlignment="Top"
                HorizontalAlignment="Center"
                Margin="0,24,0,0"
                Background="#E0111111"
                CornerRadius="8"
                Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="StatusIcon"
                           FontSize="16"
                           Foreground="#FFFFFF"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Text="⏺"/>
                <TextBlock x:Name="InstructionText"
                           FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Medium"
                           VerticalAlignment="Center"
                           Text="Nhấn giữ tổ hợp phím Ctrl+Alt+Shift để bắt đầu ghi lại thao tác"/>
            </StackPanel>
        </Border>

        <!-- Đồng hồ đếm giây (chỉ hiện khi đang ghi) -->
        <Border x:Name="TimerPanel"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,24,24,0"
                Background="#E0CC0000"
                CornerRadius="8"
                Padding="16,8"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontSize="14"
                           Foreground="#FFFFFF"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Text="🔴"/>
                <TextBlock x:Name="TimerText"
                           FontSize="18"
                           Foreground="#FFFFFF"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Text="00:00"/>
            </StackPanel>
        </Border>

        <!-- Số action đã ghi (góc trên trái) -->
        <Border x:Name="ActionCountPanel"
                VerticalAlignment="Top"
                HorizontalAlignment="Left"
                Margin="24,24,0,0"
                Background="#E0111111"
                CornerRadius="8"
                Padding="14,8"
                Visibility="Collapsed">
            <TextBlock x:Name="ActionCountText"
                       FontSize="13"
                       Foreground="#FFFFFF"
                       FontWeight="Medium"
                       Text="0 thao tác"/>
        </Border>

        <!-- Gợi ý ESC (góc dưới giữa) -->
        <Border VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Margin="0,0,0,24"
                Background="#CC111111"
                CornerRadius="6"
                Padding="14,6">
            <TextBlock x:Name="EscHintText"
                       FontSize="12"
                       Foreground="#AAFFFFFF"
                       Text="ESC để hủy"/>
        </Border>

        <!-- Hiển thị các phím Modifier đang giữ (Góc dưới phải) -->
        <Border x:Name="HeldKeysPanel"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Right"
                Margin="0,0,24,24"
                Background="#D00A0A0A"
                CornerRadius="8"
                Padding="16,10"
                Visibility="Collapsed">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="ĐANG GIỮ PHÍM" FontSize="11" Foreground="#AAFFFFFF" FontWeight="Bold" Margin="0,0,0,6" TextAlignment="Center"/>
                <StackPanel x:Name="HeldKeysStack" Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Sẽ được thêm bằng code-behind -->
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
