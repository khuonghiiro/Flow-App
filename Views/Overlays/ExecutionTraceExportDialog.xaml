<Window x:Class="FlowMy.Views.Overlays.ExecutionTraceExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        mc:Ignorable="d"
        Title="Cấu hình xuất Execution Log"
        Width="520"
        Height="460"
        MinWidth="480"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="SectionCardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Opacity" Value="0.65"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Xuất Execution Log"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextBrush}"/>
            <TextBlock Text="Chọn dữ liệu cần đi kèm và giới hạn kích thước để tránh file log nặng."
                       Style="{StaticResource HintText}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <Border Style="{StaticResource SectionCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Trường dữ liệu" Style="{StaticResource SectionTitle}"/>
                        <CheckBox IsChecked="{Binding ExportIncludeInput, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Content="Kèm IN (input data)"
                                  Margin="0,0,0,6"/>
                        <CheckBox IsChecked="{Binding ExportIncludeOutput, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Content="Kèm OUT (output data)"
                                  Margin="0,0,0,6"/>
                        <CheckBox IsChecked="{Binding ExportIncludeError, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Content="Kèm ERR (error message)"/>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Bỏ chọn để không xuất trường đó (giảm nhiều kích thước file nếu data nặng)."/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Cắt độ dài IN/OUT/ERR" Style="{StaticResource SectionTitle}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tối đa"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBox x:Name="MaxLengthTextBox"
                                     Width="110"
                                     Height="28"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Text="{Binding ExportMaxFieldLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PreviewTextInput="MaxLengthTextBox_PreviewTextInput"/>
                            <TextBlock Text="ký tự (0 = không cắt)"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}"
                                       Opacity="0.75"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Style="{StaticResource HintText}"
                                   Text="Ví dụ: 100 → giữ 100 ký tự đầu và thêm '...' cuối."/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SectionCardBorder}">
                    <StackPanel>
                        <TextBlock Text="Cấu trúc &amp; phạm vi" Style="{StaticResource SectionTitle}"/>
                        <CheckBox IsChecked="{Binding ExportIncludeTree, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Content="Kèm cấu trúc cây Run (tree) ngoài danh sách rows"
                                  Margin="0,0,0,6"/>
                        <CheckBox IsChecked="{Binding ExportOnlyCurrentFilter, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Content="Chỉ xuất các rows đang thoả filter/search hiện tại"
                                  Margin="0,0,0,6"/>
                        <CheckBox IsChecked="{Binding ExportPrettyPrint, Mode=TwoWay}"
                                  Foreground="{DynamicResource TextBrush}"
                                  Content="JSON pretty-print (thụt lề cho dễ đọc)"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,6,0,0">
            <Button Content="Huỷ"
                    MinWidth="90"
                    Margin="0,0,8,0"
                    Style="{DynamicResource SecondaryButton}"
                    Click="CancelButton_Click"/>
            <Button Content="Tiếp tục xuất"
                    MinWidth="120"
                    Style="{DynamicResource PrimaryButton}"
                    IsDefault="True"
                    Click="ContinueButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
