<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.DelayNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Delay"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MaxWidth="700"
        MinHeight="420">
    <local:BaseNodeDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </local:BaseNodeDialog.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             MinWidth="150"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="×"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- 🎨 Cấu hình hiển thị -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Cấu hình hiển thị" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Hiển thị tiêu đề" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="TitleDisplayModeComboBox"
                                              Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                                    <TextBlock Text="Màu tiêu đề" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox"
                                                  Grid.Column="0"
                                                  Height="32"
                                                  MinWidth="150"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Border Grid.Column="1"
                                                x:Name="TitleColorPreview"
                                                Width="32" Height="32"
                                                CornerRadius="6"
                                                Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- ⏱️ Cấu hình thời gian -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="⏱️ Cấu hình thời gian" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Chế độ đặc biệt" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              Margin="0,0,0,8"
                                              ItemsSource="{Binding TimingModeOptions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TimingMode, Mode=TwoWay}"/>

                                    <TextBlock Text="Đơn vị thời gian (áp dụng cho các chế độ)" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Margin="0,0,0,0"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding DelayUnitOptions}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding DelayUnit, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Chế độ delay -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <!-- Chế độ Không có: delay cố định -->
                                    <StackPanel Visibility="{Binding IsNoneMode, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="Thời gian chờ cố định" 
                                                   Foreground="{DynamicResource TextMuted}" 
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <TextBox x:Name="DelayValueTextBox"
                                                 Height="32"
                                                 MinWidth="100"
                                                 Text="{Binding DelayValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 FontSize="13"
                                                 Padding="8,0,8,0"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Chế độ ngẫu nhiên -->
                                    <StackPanel Visibility="{Binding IsRandomMode, Converter={StaticResource BoolToVisibility}}" Margin="0,8,0,0">
                                        <TextBlock Text="Khoảng ngẫu nhiên (min → max, cùng đơn vị ở trên)" 
                                                   Foreground="{DynamicResource TextMuted}" 
                                                   FontSize="10" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Min" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                                <TextBox Height="32"
                                                         Text="{Binding RandomMinValue, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{DynamicResource BaseTextBoxV2}"
                                                         Padding="8,0,8,0"
                                                         VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Max" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                                <TextBox Height="32"
                                                         Text="{Binding RandomMaxValue, UpdateSourceTrigger=PropertyChanged}"
                                                         Style="{DynamicResource BaseTextBoxV2}"
                                                         Padding="8,0,8,0"
                                                         VerticalContentAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Chế độ lấy từ node key -->
                                    <StackPanel Visibility="{Binding IsNodeKeyMode, Converter={StaticResource BoolToVisibility}}" Margin="0,8,0,0">
                                        <TextBlock Text="Lấy số thời gian chờ từ output (áp dụng đơn vị ở trên; rỗng/sai định dạng → 1)" 
                                                   Foreground="{DynamicResource TextMuted}" 
                                                   FontSize="10" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                        <TextBlock Text="Node nguồn" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                        <controls:NodeSearchComboBoxUserControl Height="32"
                                                  Margin="0,0,0,8"
                                                  ItemsSource="{Binding AvailableNodeOptions}"
                                                  SelectedValuePath="NodeId"
                                                  DisplayMemberPath="Title"
                                                  SelectedValue="{Binding DelaySourceNodeId, Mode=TwoWay}"/>
                                        <TextBlock Text="Output key" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding AvailableOutputKeyOptions}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding DelaySourceOutputKey, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource CardColor}" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                <TextBlock Foreground="{DynamicResource TextMuted}" 
                                           FontSize="10" TextWrapping="Wrap">
                                    <Run Text="💡 Gợi ý: trên canvas, node hiển thị tóm tắt theo chế độ (cố định / random / key)."/>
                                </TextBlock>
                            </Border>

                            <!-- Không dùng combobox input/output cho Delay -->
                            <StackPanel x:Name="InputsPanel" Visibility="Collapsed"/>
                            <StackPanel x:Name="OutputsPanel" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Cấu hình -->
                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                        <ColumnDefinition Width="*" MinWidth="120"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Port IN"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Port OUT"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32" ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>

