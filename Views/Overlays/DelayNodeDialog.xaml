<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.DelayNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Delay"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="400"
        MinWidth="350"
        MaxWidth="700"
        MinHeight="400">
    <local:BaseNodeDialog.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </local:BaseNodeDialog.Resources>
    <Border CornerRadius="12"
            Padding="0"
            Background="{DynamicResource WindowBodyBackground}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="12,12,0,0"
                    Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             MinWidth="150"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Width="24" Height="24" Content="▶" FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy logic node này"
                                Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="×"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0">
                <!-- Tab 1: Logic -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Title Display Mode -->
                            <TextBlock Text="Hiển thị tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <ComboBox x:Name="TitleDisplayModeComboBox"
                                      Height="36"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,16"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <!-- Title Color -->
                            <TextBlock Text="Màu tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="TitleColorComboBox"
                                          Grid.Column="0"
                                          Height="36"
                                          MinWidth="150"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                          SelectionChanged="TitleColorComboBox_SelectionChanged"/>

                                <Border Grid.Column="1"
                                        x:Name="TitleColorPreview"
                                        Width="36" Height="36"
                                        CornerRadius="6"
                                        Margin="8,0,0,0"
                                        BorderBrush="{DynamicResource ControlBorderBrush}"
                                        BorderThickness="1"/>
                            </Grid>

                            <TextBlock Text="Chế độ đặc biệt:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <ComboBox Height="36"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,12"
                                      ItemsSource="{Binding TimingModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TimingMode, Mode=TwoWay}"/>

                            <TextBlock Text="Đơn vị thời gian (áp dụng cho các chế độ):"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>
                            <ComboBox Height="36"
                                      Margin="0,0,0,16"
                                      Style="{DynamicResource BaseComboBox}"
                                      ItemsSource="{Binding DelayUnitOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding DelayUnit, Mode=TwoWay}"/>

                            <!-- Chế độ Không có: delay cố định -->
                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding IsNoneMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Thời gian chờ cố định:"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBox x:Name="DelayValueTextBox"
                                         Height="36"
                                         MinWidth="100"
                                         Text="{Binding DelayValue, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         FontSize="13"
                                         Padding="8,0,8,0"
                                         VerticalContentAlignment="Center"/>
                            </StackPanel>

                            <!-- Chế độ ngẫu nhiên -->
                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding IsRandomMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Khoảng ngẫu nhiên (min → max, cùng đơn vị ở trên):"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Min" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBox Height="36"
                                                 Text="{Binding RandomMinValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 Padding="8,0,8,0"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Max" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                        <TextBox Height="36"
                                                 Text="{Binding RandomMaxValue, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{DynamicResource BaseTextBoxV2}"
                                                 Padding="8,0,8,0"
                                                 VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <!-- Chế độ lấy từ node key -->
                            <StackPanel Margin="0,0,0,16"
                                        Visibility="{Binding IsNodeKeyMode, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Lấy số thời gian chờ từ output (áp dụng đơn vị ở trên; rỗng/sai định dạng → 1):"
                                           Foreground="{DynamicResource TextBrush}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Node nguồn" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                <ComboBox Height="36"
                                          Margin="0,0,0,10"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding AvailableNodeOptions}"
                                          SelectedValuePath="NodeId"
                                          DisplayMemberPath="Title"
                                          SelectedValue="{Binding DelaySourceNodeId, Mode=TwoWay}"/>
                                <TextBlock Text="Output key" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                <ComboBox Height="36"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding AvailableOutputKeyOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding DelaySourceOutputKey, Mode=TwoWay}"/>
                            </StackPanel>

                            <TextBlock Text="Gợi ý: trên canvas, node hiển thị tóm tắt theo chế độ (cố định / random / key)."
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>

                            <!-- Không dùng combobox input/output cho Delay -->
                            <StackPanel x:Name="InputsPanel" Visibility="Collapsed"/>
                            <StackPanel x:Name="OutputsPanel" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Cấu hình -->
                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Vị trí cổng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                    <ColumnDefinition Width="*" MinWidth="120"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Port IN"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Port OUT"
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12"
                                               Opacity="0.8"
                                               Margin="0,0,0,4"/>
                                    <ComboBox Height="32"
                                              Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>

