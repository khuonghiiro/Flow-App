<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.InputNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:enums="clr-namespace:FlowMy.Models.Enums;assembly=FlowMy"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        Title="Input Node Dialog"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        MinWidth="420"
        MaxWidth="800"
        MinHeight="420">
    <local:BaseNodeDialog.Resources>
        <!-- Converter cho visibility theo kiểu dữ liệu -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </local:BaseNodeDialog.Resources>
    <Border CornerRadius="12" Padding="0" Style="{DynamicResource DialogOuterBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                          Grid.Column="0"
                          Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                          Style="{DynamicResource BaseTextBoxV2}"
                          FontSize="16"
                          Padding="0,4,0,4"
                          VerticalContentAlignment="Center"
                          MinWidth="150"
                          Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PlayButton" Padding="0,0,0,0"  Width="24" Height="24" Content="▶" FontSize="12"
                            Style="{DynamicResource PrimaryButton}"
                            Cursor="Hand"
                            Margin="8,0,0,0" ToolTip="Chạy logic node này"
                            Command="{Binding RunSingleNodeCommand}"/>

                        <Button x:Name="CloseButton" Padding="0,0,0,0"  Width="24" Height="24"
                            Style="{DynamicResource DangerButton}"
                            Content="×" 
                            FontSize="12" 
                            FontWeight="Bold" 
                            Cursor="Hand"
                            Margin="8,0,0,0" Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <TabControl Grid.Row="1"
                        Margin="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                <!-- Tab 1: Logic (giữ nguyên nội dung cũ) -->
                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình hiển thị -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎨 Cấu hình hiển thị" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Title Display" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="TitleDisplayModeComboBox" Height="32" Style="{DynamicResource BaseComboBox}" Margin="0,0,0,8"
                                              ItemsSource="{Binding TitleDisplayModeOptions}"
                                              SelectedValuePath="Value" DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                                    <TextBlock Text="Màu tiêu đề" 
                                               Foreground="{DynamicResource TextMuted}" 
                                               FontSize="10" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="150"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TitleColorComboBox"
                                                  Grid.Column="0"
                                                  Height="32"
                                                  MinWidth="150"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding TitleColorOptions}"
                                                  SelectedValuePath="Key"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                                  SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                        <Border Grid.Column="1" 
                                                x:Name="TitleColorPreview"
                                                Width="32" Height="32" 
                                                CornerRadius="6"
                                                Margin="8,0,0,0"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 🎯 Input Configuration -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="🎯 Input Configuration" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <TextBlock Text="Key" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <TextBox x:Name="KeyTextBox" Height="32" Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource BaseTextBoxV2}" FontSize="13" Padding="8,0,8,0"
                                             VerticalContentAlignment="Center" Margin="0,0,0,8"/>

                                    <TextBlock Text="Data Type" Foreground="{DynamicResource TextMuted}" FontSize="10" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="DataTypeComboBox" Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding DataTypeOptions}" SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName" SelectedValue="{Binding DataType, Mode=TwoWay}"/>
                                </StackPanel>
                            </Border>

                            <!-- 💾 Value -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="💾 Value" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Value"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="1"
                                                Margin="8,0,0,0"
                                                Height="32"
                                                Width="80"
                                                FontSize="12"
                                                Click="ToggleValueModeButton_Click"
                                                Visibility="{Binding IsStringType, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource InfoButton}">
                                                    <Setter Property="Content" Value="1 Dòng" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMultilineString}" Value="True">
                                                            <Setter Property="Content" Value="Nhiều Dòng" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </Grid>
                                    <Border Style="{DynamicResource DialogOuterBorder}" CornerRadius="6" Padding="10">
                                        <StackPanel x:Name="ValuePanel">
                                            <!-- Value controls sẽ được thêm động ở đây -->
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="ErrorTextBlock" Text="" Foreground="{DynamicResource DangerColor}" FontSize="10"
                                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- 📊 Outputs -->
                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="📊 Outputs" 
                                               Foreground="{DynamicResource TextBrush}"
                                               FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10"/>
                                    <StackPanel x:Name="OutputsPanel"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Tab 2: Tái sử dụng flow -->
                <TabItem Header="Tái sử dụng flow" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <!-- Cấu hình vị trí cổng IN/OUT -->
                            <TextBlock Text="Vị trí cổng IN/OUT"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8"/>

                            <Border Background="{DynamicResource WindowBackground}"
                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                        <ColumnDefinition Width="*" MinWidth="120" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Port IN -->
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0" Visibility="Collapsed" >
                                        <TextBlock Text="Port IN"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>

                                    <!-- Port OUT -->
                                    <StackPanel Grid.Column="0" Margin="8,0,0,0">
                                        <TextBlock Text="Port OUT"
                                                   Foreground="{DynamicResource TextMuted}"
                                                   FontSize="10"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox Height="32"
                                                  Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding PortPositionOptions}"
                                                  SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Cấu hình tái sử dụng flow -->
                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12"
                                                Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*" MinWidth="100" />
                                                    <ColumnDefinition Width="2*" MinWidth="100" />
                                                    <ColumnDefinition Width="2*" MinWidth="100" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Cột 1: Node IN (readonly) -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <!-- Cột 2: Node OUT -->
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <controls:NodeSearchComboBoxUserControl Height="32"
                                                              ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId"
                                                              DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <!-- Cột 3: Kiểu line -->
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="12"
                                                               Opacity="0.7"
                                                               Margin="0,0,0,4"/>
                                                    <ComboBox Height="32"
                                                              Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
