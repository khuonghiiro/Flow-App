<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.FileDownloadNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="Tải file"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="520"
        Height="760"
        MinWidth="460"
        MinHeight="620">

    <Border CornerRadius="12" Padding="0"
            Background="{DynamicResource WindowBodyBackground}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1">
        <Border.Resources>
            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        </Border.Resources>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="24" Height="24"
                                Content="▶"
                                FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy tải (node này)"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="×"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="0,4,0,0">

                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>

                            <TextBlock Text="Hiển thị tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <ComboBox Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,14"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <TextBlock Text="Tên file (mẫu)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Placeholder: {filename}, {date}, {time}, {datetime}, {index}. Ví dụ: {filename}_{date}. Nếu có {index} và bật tự tăng, lần đầu rỗng rồi _1, _2…"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding FileNameTemplate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Height="34" Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Node → key (tên file từ output)" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="FileNameSourceNodeComboBox"
                                              Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding AvailableNodeOptions}"
                                              SelectedValuePath="NodeId"
                                              DisplayMemberPath="Title"
                                              SelectedValue="{Binding FileNameSourceNodeId, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="Key" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="FileNameSourceKeyComboBox"
                                              Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding FileNameOutputKeyOptions}"
                                              SelectedValuePath="Key"
                                              DisplayMemberPath="DisplayName"
                                              SelectedValue="{Binding FileNameSourceOutputKey, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Giới hạn độ dài tên (base, không gồm đuôi):" Foreground="{DynamicResource TextMuted}" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox Text="{Binding MaxFileNameLength, UpdateSourceTrigger=PropertyChanged}"
                                         Width="72" Height="32" Style="{DynamicResource BaseTextBoxV2}"/>
                            </StackPanel>

                            <CheckBox Content="Tự tăng tên khi trùng (file, file_1, file_2… hoặc {index})"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12"
                                      IsChecked="{Binding AutoIncrementIfExists, Mode=TwoWay}"
                                      Margin="0,0,0,14"/>
                            <CheckBox Content="Chuẩn hóa tên file: bỏ dấu tiếng Việt và ký tự đặc biệt"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12"
                                      IsChecked="{Binding RemoveDiacriticsFromFileName, Mode=TwoWay}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Lưu thêm nhiều file từ output node (nội dung text vào thư mục lưu)"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12"
                                      IsChecked="{Binding SaveAdditionalOutputFiles, Mode=TwoWay}"
                                      Margin="0,0,0,8"/>

                            <StackPanel Visibility="{Binding SaveAdditionalOutputFiles, Converter={StaticResource BoolToVisibility}}"
                                        Margin="0,0,0,14">
                                <TextBlock Text="Từng dòng: hàng trên là mẫu tên file; hàng dưới là Node → Key và định dạng lưu"
                                           Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                <ItemsControl ItemsSource="{Binding AdditionalSaveRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8" Background="{DynamicResource CardColor}" CornerRadius="6" Padding="8">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                                        <TextBlock Text="Mẫu tên file (trống = dùng “Tên file (mẫu)” phía trên)" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                        <TextBox Text="{Binding NameTemplate, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{DynamicResource BaseTextBoxV2}" Height="32"
                                                                 ToolTip="Trống = dùng “Tên file (mẫu)” phía trên. Có thể dùng {filename}, {date}, {time}, {datetime}, {index}."/>
                                                    </StackPanel>
                                                    <Grid Grid.Row="1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="100"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="Node" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                            <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                                      ItemsSource="{Binding DataContext.AvailableNodeOptions, RelativeSource={RelativeSource AncestorType=local:FileDownloadNodeDialog}}"
                                                                      SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                                      SelectedValue="{Binding SourceNodeId, Mode=TwoWay}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2">
                                                            <TextBlock Text="Key" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                            <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                                      ItemsSource="{Binding AvailableOutputKeyOptions}"
                                                                      SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                                      SelectedValue="{Binding SourceOutputKey, Mode=TwoWay}"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="4">
                                                            <TextBlock Text="Định dạng" Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,0,0,4"/>
                                                            <TextBox Text="{Binding SaveFormat, UpdateSourceTrigger=PropertyChanged}"
                                                                     Style="{DynamicResource BaseTextBoxV2}" Height="32"
                                                                     ToolTip="txt, .csv, json… Trống = .txt"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="5" Content="−" Width="28" Height="28" Margin="8,0,0,0"
                                                                VerticalAlignment="Bottom"
                                                                Command="{Binding DataContext.RemoveAdditionalSaveRowCommand, RelativeSource={RelativeSource AncestorType=local:FileDownloadNodeDialog}}"
                                                                CommandParameter="{Binding}"
                                                                Foreground="{DynamicResource TextBrush}" Background="{DynamicResource DangerBrush}" BorderThickness="0" Cursor="Hand"/>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button Content="+ Thêm dòng lưu" Height="32" Margin="0,4,0,0"
                                        Command="{Binding AddAdditionalSaveRowCommand}"
                                        HorizontalAlignment="Left" MinWidth="120"
                                        Style="{DynamicResource PrimaryButton}"/>
                            </StackPanel>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <TextBlock Text="URL tải (GET/POST theo curl nếu dùng curl)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding DownloadUrl, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Height="34" Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="32" Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding AvailableNodeOptions}"
                                          SelectedValuePath="NodeId"
                                          DisplayMemberPath="Title"
                                          SelectedValue="{Binding UrlSourceNodeId, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="1" Height="32" Style="{DynamicResource BaseComboBox}"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding UrlOutputKeyOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding UrlSourceOutputKey, Mode=TwoWay}"/>
                            </Grid>

                            <TextBlock Text="cURL (ưu tiên hơn URL nếu có và hợp lệ)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding CurlCommand, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     MinHeight="72"
                                     VerticalScrollBarVisibility="Auto"
                                     Margin="0,0,0,8"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="32" Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding AvailableNodeOptions}"
                                          SelectedValuePath="NodeId"
                                          DisplayMemberPath="Title"
                                          SelectedValue="{Binding CurlSourceNodeId, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="1" Height="32" Style="{DynamicResource BaseComboBox}"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding CurlOutputKeyOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding CurlSourceOutputKey, Mode=TwoWay}"/>
                            </Grid>

                            <TextBlock Text="Thư mục lưu (tự tạo nếu chưa có)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding DownloadFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         Height="34" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="Chọn…" Height="34" MinWidth="72"
                                        Style="{DynamicResource PrimaryButton}"
                                        Click="BrowseFolder_Click"/>
                            </Grid>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="32" Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding AvailableNodeOptions}"
                                          SelectedValuePath="NodeId"
                                          DisplayMemberPath="Title"
                                          SelectedValue="{Binding FolderSourceNodeId, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="1" Height="32" Style="{DynamicResource BaseComboBox}"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding FolderOutputKeyOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding FolderSourceOutputKey, Mode=TwoWay}"/>
                            </Grid>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <TextBlock Text="Kết quả lần chạy gần nhất"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource CardColor}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <TextBlock Text="{Binding LastRunSummary}"
                                           Foreground="{DynamicResource TextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <TextBlock Text="Output: filePath (đường dẫn đầy đủ), completed (True/False), errorMessage"
                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>

                            <Border Style="{DynamicResource DialogOuterBorder}"
                                    CornerRadius="8" Padding="12" Margin="0,12,0,8"
                                    x:Name="BorderOutputPanel">
                                <StackPanel x:Name="OutputsPanel"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Màu tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TitleColorComboBox"
                                          Grid.Column="0" Height="34"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                          SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                <Border Grid.Column="1" x:Name="TitleColorPreview"
                                        Width="34" Height="34" CornerRadius="6"
                                        Margin="8,0,0,0"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                            </Grid>

                            <TextBlock Text="Vị trí cổng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Hướng dẫn" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="13" LineHeight="22"
                                       Text="• Ưu tiên: nếu ô cURL có lệnh hợp lệ (copy từ trình duyệt), node sẽ parse URL + header + body và tải. Nếu không, dùng URL tĩnh hoặc URL lấy từ node/key."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="13" LineHeight="22" Margin="0,10,0,0"
                                       Text="• Thư mục lưu: đường dẫn đầy đủ trên máy; app sẽ tạo thư mục nếu chưa tồn tại. Có thể bind từ output của node Folder (fullPath) hoặc nhập tay."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="13" LineHeight="22" Margin="0,10,0,0"
                                       Text="• Tên file: {date}=yyyy-MM-dd, {time}=HHmmss, {datetime}=yyyyMMdd_HHmmss. {index}: để trống lần đầu, sau đó _1, _2 nếu bật “Tự tăng”. Giới hạn độ dài áp dụng cho phần tên (không tính đuôi mở rộng)."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="13" LineHeight="22" Margin="0,10,0,0"
                                       Text="• Output filePath: đường dẫn file đã lưu; completed=True khi tải thành công; errorMessage mô tả lỗi nếu có. Khi chạy workflow song song, giá trị được cô lập theo từng lần chạy (scoped outputs)."/>
                            <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontSize="13" LineHeight="22" Margin="0,10,0,0"
                                       Text="• Lưu thêm nhiều file: ghi chuỗi output (text) ra file trong cùng thư mục lưu; có thể bỏ URL nếu chỉ cần xuất file. Định dạng: nhập txt, .csv, json… (trống = .txt). Trùng tên sẽ tự tăng nếu bật “Tự tăng tên khi trùng”."/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
