<Window x:Class="FlowMy.Views.Overlays.NodeGeneratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FlowMy.ViewModels"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        Title="🧱 Tạo Base Node — FlowMy"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        Width="960" MinWidth="820"
        Height="780" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- Section header style -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- Label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card border style -->
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WindowBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Small icon button -->
        <Style x:Key="SmallIconBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="6"
                                Background="Transparent"
                                BorderBrush="{DynamicResource ControlBorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Add button -->
        <Style x:Key="AddBtn" TargetType="Button" BasedOn="{StaticResource SmallIconBtn}">
            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource SuccessBrush}"/>
        </Style>

        <!-- Remove button -->
        <Style x:Key="RemoveBtn" TargetType="Button" BasedOn="{StaticResource SmallIconBtn}">
            <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
        </Style>
    </Window.Resources>

    <!-- Outer rounded border -->
    <Border CornerRadius="14" Style="{DynamicResource DialogOuterBorder}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="Auto"/> <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" CornerRadius="14,14,0,0" Style="{DynamicResource DialogHeaderBorder}" Padding="20,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🧱" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Tạo Base Node" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                        <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Node Generator" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                        </Border>
                    </StackPanel>

                    <TextBlock Grid.Column="1" Text="Điền thông tin → ✨ Tạo Node để sinh tất cả base files tự động"
                               Foreground="{DynamicResource TextMuted}" FontSize="11"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <Button Grid.Column="2" x:Name="CloseBtn" Width="32" Height="32" Content="✕"
                            FontSize="14" FontWeight="Bold" Cursor="Hand"
                            Style="{DynamicResource DangerButton}" Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT (2 columns) ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>          <!-- Left: Form -->
                    <ColumnDefinition Width="8"/>           <!-- Splitter -->
                    <ColumnDefinition Width="320"/>         <!-- Right: Preview -->
                </Grid.ColumnDefinitions>

                <!-- ─── LEFT: FORM ─── -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="20,16,12,16">
                    <StackPanel>

                        <!-- ■ BASIC INFO -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="📌 Thông tin cơ bản" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="NodeName (PascalCase) *" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Height="32" Style="{DynamicResource BaseTextBoxV2}"
                                                 Text="{Binding NodeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Tên class. VD: HelloWorld → sẽ tạo HelloWorldNode, HelloWorldNodeDialog..."
                                                 x:Name="NodeNameBox"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Title (hiển thị trên canvas)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Height="32" Style="{DynamicResource BaseTextBoxV2}"
                                                 Text="{Binding Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="NodeTitle mặc định hiển thị trên canvas"/>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="IconKey" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Height="32" Style="{DynamicResource BaseTextBoxV2}"
                                                 Text="{Binding IconKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="VD: star duotone-regular / circle-nodes duotone-light"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="ColorKey" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                  ItemsSource="{Binding ColorKeyOptions}"
                                                  Text="{Binding ColorKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  IsEditable="True"
                                                  ToolTip="Chọn ColorKey từ Common.xaml. VD: SunsetOrange, ForestPine, Info, CoralVivid, RoyalPurple..."/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ■ NODE TYPE -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="🏷️ NodeType Enum" Style="{StaticResource SectionHeader}"/>
                                <CheckBox Content="Thêm NodeType mới vào NodeType.cs"
                                          IsChecked="{Binding AddNewNodeType, Mode=TwoWay}"
                                          Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                                <Grid Visibility="{Binding AddNewNodeType, Converter={StaticResource BoolToVis}}">
                                    <StackPanel>
                                        <TextBlock Text="NodeType name (để trống = dùng NodeName)" Style="{StaticResource FieldLabel}"/>
                                        <TextBox Height="32" Style="{DynamicResource BaseTextBoxV2}"
                                                 Text="{Binding NodeTypeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="VD: HelloWorld → NodeType.HelloWorld"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Visibility="{Binding AddNewNodeType, Converter={StaticResource InverseBoolToVis}}"
                                           Text="Dùng NodeType.Generic (không thêm entry mới vào enum)"
                                           Foreground="{DynamicResource TextMuted}" FontSize="10"/>
                            </StackPanel>
                        </Border>

                        <!-- ■ PORTS -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="🔌 Ports" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Input ports -->
                                    <StackPanel Grid.Column="0">
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Port IN" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                                            <Button Style="{StaticResource AddBtn}" Content="+" HorizontalAlignment="Right"
                                                    Command="{Binding AddInputPortCommand}" ToolTip="Thêm input port"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding InputPorts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="4"/>
                                                            <ColumnDefinition Width="26"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding ColorKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="ColorKey của port (VD: Info, SunsetOrange)"/>
                                                        <Button Grid.Column="2" Style="{StaticResource RemoveBtn}" Content="✕"
                                                                Command="{Binding DataContext.RemoveInputPortCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <!-- Output ports -->
                                    <StackPanel Grid.Column="2">
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="Port OUT" Style="{StaticResource FieldLabel}" VerticalAlignment="Center"/>
                                            <Button Style="{StaticResource AddBtn}" Content="+" HorizontalAlignment="Right"
                                                    Command="{Binding AddOutputPortCommand}" ToolTip="Thêm output port"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding OutputPorts}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="4"/>
                                                            <ColumnDefinition Width="26"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding ColorKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="ColorKey của port (VD: SunsetOrange, Info)"/>
                                                        <Button Grid.Column="2" Style="{StaticResource RemoveBtn}" Content="✕"
                                                                Command="{Binding DataContext.RemoveOutputPortCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- ■ OUTPUT KEYS -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="📊 Output Keys (DynamicOutputs)" Style="{StaticResource SectionHeader}"/>
                                <TextBlock Text="Danh sách key output node produce (phân cách bằng dấu phẩy)"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox Height="32" Style="{DynamicResource BaseTextBoxV2}"
                                         Text="{Binding OutputKeysRaw, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="VD: result,error,status"/>
                            </StackPanel>
                        </Border>

                        <!-- ■ DIALOG OPTIONS -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="🪟 Tùy chọn Dialog" Style="{StaticResource SectionHeader}"/>

                                <!-- HasInputSection -->
                                <Border Background="{DynamicResource WindowBackground}" CornerRadius="6"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding HasInputSection, Mode=TwoWay}"
                                                  Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3">
                                            <CheckBox.Content>
                                                <StackPanel>
                                                    <TextBlock Text="📥 Input từ node khác" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="Sinh NodeSearchComboBox để chọn output của node trước làm đầu vào."
                                                               FontSize="10" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>

                                <!-- HasDynamicInputs -->
                                <Border Background="{DynamicResource WindowBackground}" CornerRadius="6"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                        Padding="10,8" Margin="0,0,0,6">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding HasDynamicInputs, Mode=TwoWay}"
                                                  Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3">
                                            <CheckBox.Content>
                                                <StackPanel>
                                                    <TextBlock Text="➕ Dynamic Inputs panel" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="Sinh panel thêm/xóa input keys động — dùng cho node có số lượng đầu vào biến đổi (VD: Merge, Condition)."
                                                               FontSize="10" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>

                                <!-- HasOutputsPanel -->
                                <Border Background="{DynamicResource WindowBackground}" CornerRadius="6"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                        Padding="10,8">
                                    <StackPanel>
                                        <CheckBox IsChecked="{Binding HasOutputsPanel, Mode=TwoWay}"
                                                  Foreground="{DynamicResource TextBrush}" Margin="0,0,0,3">
                                            <CheckBox.Content>
                                                <StackPanel>
                                                    <TextBlock Text="📤 Outputs panel" FontWeight="SemiBold" FontSize="11"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <TextBlock Text="Sinh panel hiển thị danh sách output keys node tạo ra — dùng để map kết quả với các node tiếp theo."
                                                               FontSize="10" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </CheckBox.Content>
                                        </CheckBox>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ■ CUSTOM TEXTBOXES -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="📝 Custom TextBox fields" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource AddBtn}" Content="+ Thêm" HorizontalAlignment="Right"
                                            Padding="8,0" Command="{Binding AddTextBoxCommand}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding CustomTextBoxes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackground}"
                                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="26"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Label" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="BindingPath (VM property)" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding BindingPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="Tên property trong ViewModel (VD: TargetUrl)"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="4" Style="{StaticResource RemoveBtn}" Content="✕"
                                                            VerticalAlignment="Bottom" Margin="0,0,0,0"
                                                            Command="{Binding DataContext.RemoveTextBoxCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ■ CUSTOM COMBOBOXES -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="🔽 Custom ComboBox fields" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource AddBtn}" Content="+ Thêm" HorizontalAlignment="Right"
                                            Padding="8,0" Command="{Binding AddComboBoxCommand}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding CustomComboBoxes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackground}"
                                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="26"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Label" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="BindingPath" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding BindingPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="4" Style="{StaticResource RemoveBtn}" Content="✕"
                                                            VerticalAlignment="Bottom"
                                                            Command="{Binding DataContext.RemoveComboBoxCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ■ CHECKBOXES -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="✅ Custom CheckBox options" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource AddBtn}" Content="+ Thêm" HorizontalAlignment="Right"
                                            Padding="8,0" Command="{Binding AddCheckBoxCommand}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding CustomCheckBoxes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="6"/>
                                                    <ColumnDefinition Width="26"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0" Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                         Text="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="Label hiển thị"/>
                                                <TextBox Grid.Column="2" Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                         Text="{Binding BindingPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         ToolTip="BindingPath trong VM (bool property)"/>
                                                <Button Grid.Column="4" Style="{StaticResource RemoveBtn}" Content="✕"
                                                        Command="{Binding DataContext.RemoveCheckBoxCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ■ RADIO GROUPS -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="🔘 Radio Groups" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                    <Button Style="{StaticResource AddBtn}" Content="+ Thêm group" HorizontalAlignment="Right"
                                            Padding="8,0" Command="{Binding AddRadioGroupCommand}"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding RadioGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource WindowBackground}"
                                                    BorderBrush="{DynamicResource ControlBorderBrush}"
                                                    BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="6"/>
                                                        <ColumnDefinition Width="26"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Group Label" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding GroupLabel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Options (phân cách bằng dấu phẩy)" Style="{StaticResource FieldLabel}"/>
                                                        <TextBox Height="28" Style="{DynamicResource BaseTextBoxV2}"
                                                                 Text="{Binding OptionsRaw, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 ToolTip="VD: Option A,Option B,Option C"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="4" Style="{StaticResource RemoveBtn}" Content="✕"
                                                            VerticalAlignment="Bottom"
                                                            Command="{Binding DataContext.RemoveRadioGroupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- ■ PROJECT ROOT -->
                        <Border Style="{StaticResource CardBorder}">
                            <StackPanel>
                                <TextBlock Text="📂 Project Root" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Height="32" Style="{DynamicResource BaseTextBoxV2}"
                                             Text="{Binding ProjectRoot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Thư mục gốc chứa FlowMy.csproj"/>
                                    <Button Grid.Column="2" Height="32" Padding="12,0" Content="📂 Chọn..."
                                            Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                            Command="{Binding BrowseProjectRootCommand}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ─── SPLITTER ─── -->
                <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="{DynamicResource ControlBorderBrush}"/>

                <!-- ─── RIGHT: PREVIEW ─── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Preview panel -->
                    <Border Grid.Row="0" Margin="0,16,20,8"
                            Background="{DynamicResource WindowBackground}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1" CornerRadius="10">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" CornerRadius="10,10,0,0" Padding="14,10"
                                    Style="{DynamicResource DialogHeaderBorder}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="👁️" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Preview &amp; File List" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Node visual mock-up -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="14">
                                <StackPanel>
                                    <!-- Node mock -->
                                    <TextBlock Text="Node trên Canvas:" Foreground="{DynamicResource TextMuted}"
                                               FontSize="10" Margin="0,0,0,8"/>
                                    <Border x:Name="NodeMockBorder"
                                            HorizontalAlignment="Center" Margin="0,0,0,16"
                                            Width="72" Height="72" CornerRadius="12"
                                            Background="{DynamicResource InfoBrush}"
                                            BorderBrush="White" BorderThickness="2">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" ShadowDepth="4" BlurRadius="10" Opacity="0.4" Direction="270"/>
                                        </Border.Effect>
                                        <Grid>
                                            <TextBlock x:Name="PreviewIcon" Text="◆"
                                                       FontSize="28" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" Foreground="White"/>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="PreviewNodeTitle" Text="Node Name"
                                               FontSize="11" FontWeight="SemiBold" TextAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                                    <!-- File list preview -->
                                    <Border Height="1" Background="{DynamicResource ControlBorderBrush}" Margin="0,0,0,12"/>
                                    <TextBox x:Name="PreviewTextBox"
                                             Style="{DynamicResource BaseTextBoxV2}"
                                             IsReadOnly="True" TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             FontSize="10" FontFamily="Consolas"
                                             Foreground="{DynamicResource TextMuted}"
                                             MinHeight="200"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Registration log panel (sau khi đăng ký) -->
                    <Border Grid.Row="2" Margin="0,0,20,4" CornerRadius="8" Padding="12"
                            Visibility="{Binding HasRegistrationResult, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter Property="Opacity" Value="0.15"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasRegistrationError}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextBrush}">
                                <Run Text="🚀 Kết quả Đăng ký:"/>
                            </TextBlock>
                            <TextBox Text="{Binding RegistrationLog, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                     Background="Transparent" BorderThickness="0"
                                     FontSize="10" FontFamily="Consolas"
                                     MaxHeight="120"
                                     Foreground="{DynamicResource TextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Result panel (sau khi generate) -->
                    <Border Grid.Row="1" Margin="0,0,20,16" CornerRadius="8" Padding="12"
                            Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                <Setter Property="Opacity" Value="0.15"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasError}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBox Text="{Binding ResultText, Mode=OneWay}"
                                 IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                 Background="Transparent" BorderThickness="0"
                                 FontSize="10" FontFamily="Consolas"
                                 MaxHeight="180"
                                 Foreground="{DynamicResource TextBrush}"/>
                    </Border>
                </Grid>
            </Grid>

            <!-- ═══ FOOTER ═══ -->
            <Border Grid.Row="2" CornerRadius="0,0,14,14" Padding="20,14"
                    Style="{DynamicResource DialogHeaderBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="✅ Nhấn '✨ Tạo Node' để sinh files → sau đó nhấn '🚀 Đăng ký' để thêm vào palette &amp; hệ thống"
                                   Foreground="{DynamicResource TextMuted}" FontSize="10"
                                   VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="460"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="📋 Copy JSON" Margin="0,0,8,0" Height="36" Padding="14,0"
                                Style="{DynamicResource PrimaryButton}" Cursor="Hand"
                                Command="{Binding CopyJsonConfigCommand}"
                                ToolTip="Copy JSON config để dùng với NodeGeneratorService.ParseFromJson()"/>
                        <!-- 🚀 Đăng ký vào Hệ thống -->
                        <Button Height="36" Padding="16,0" Margin="0,0,8,0"
                                Cursor="Hand"
                                Command="{Binding RegisterToSystemCommand}"
                                x:Name="RegisterBtn">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#10B981" Offset="0"/>
                                                <GradientStop Color="#059669" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="🚀 Đăng ký vào Hệ thống" Foreground="White"
                                                   FontWeight="Bold" FontSize="12"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Height="36" Padding="20,0"
                                Cursor="Hand"
                                Command="{Binding GenerateNodeCommand}"
                                x:Name="GenerateBtn">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#8B5CF6" Offset="0.5"/>
                                                <GradientStop Color="#EC4899" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="✨ Tạo Node" Foreground="White"
                                                   FontWeight="Bold" FontSize="13"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
