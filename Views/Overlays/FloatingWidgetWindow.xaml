<Window x:Class="FlowMy.Views.Overlays.FloatingWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        Title="Widget">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>

        <!-- Context menu dùng cho cả idle shape và title bar -->
        <ContextMenu x:Key="WidgetContextMenu"
                     Background="{DynamicResource CardColor}"
                     Foreground="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource ControlBorderBrush}"
                     BorderThickness="1">
            <MenuItem Tag="expand"
                      Header="▸ Mở rộng widget"
                      Click="ContextExpand_Click"/>
            <MenuItem Tag="collapse"
                      Header="▾ Thu nhỏ widget"
                      Click="ContextCollapse_Click"/>
            <Separator/>
            <MenuItem Header="↻ Tải lại nội dung" Click="ContextReload_Click"/>
            <MenuItem Tag="topmost"
                      Header="📍 Luôn trên cùng"
                      IsCheckable="True"
                      Click="ContextTopmost_Click"/>
            <Separator/>
            <MenuItem Header="🚪 Đóng widget"
                      Foreground="{DynamicResource DangerBrush}"
                      Click="ContextClose_Click"/>
        </ContextMenu>

        <!-- Thu nhỏ widget — viền theme, chevron rõ nét -->
        <Style x:Key="WidgetCollapseButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Thu nhỏ"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <Path Data="M 3.5 6 L 8 10.5 L 12.5 6"
                                  Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="1.35"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WidgetTitleActionButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SecondaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WidgetTitleRevealButton" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Content" Value="≡"/>
            <Setter Property="ToolTip" Value="Hiện thanh tiêu đề widget"/>
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextOnDangerBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TextOnDangerBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DangerPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True"
          RenderOptions.BitmapScalingMode="HighQuality">
        <!-- ═══ STATE 1: Collapsed / Idle Shape ═══ -->
        <Grid x:Name="IdleContainer" Visibility="Visible"
              ContextMenu="{StaticResource WidgetContextMenu}"
              ContextMenuOpening="ContextMenu_Opening"
              MouseLeftButtonDown="Idle_MouseLeftButtonDown"
              MouseMove="Idle_MouseMove"
              MouseLeftButtonUp="Idle_MouseLeftButtonUp"
              MouseEnter="Idle_MouseEnter"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">

            <!-- Circle shape (default) -->
            <Border x:Name="IdleCircle"
                    Width="48" Height="48"
                    CornerRadius="24"
                    Cursor="Hand"
                    Background="{DynamicResource PrimaryBrush}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="IdleScaleTransform" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <Grid IsHitTestVisible="False">
                    <controls:SvgViewboxEx x:Name="IdleCircleSvg"
                                           Width="20" Height="20"
                                           Fill="{DynamicResource TextOnPrimaryBrush}"
                                           Visibility="Collapsed"/>
                    <TextBlock x:Name="IdleIcon" Text="⚡"
                               FontSize="20"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Diamond shape (rotated square) -->
            <Border x:Name="IdleDiamond"
                    Width="40" Height="40"
                    CornerRadius="4"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Background="{DynamicResource PrimaryBrush}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <RotateTransform Angle="45"/>
                        <ScaleTransform x:Name="IdleDiamondScale" ScaleX="1" ScaleY="1"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Grid IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <RotateTransform Angle="-45"/>
                    </Grid.RenderTransform>
                    <controls:SvgViewboxEx x:Name="IdleDiamondSvg"
                                           Width="16" Height="16"
                                           Fill="{DynamicResource TextOnPrimaryBrush}"
                                           Visibility="Collapsed"/>
                    <TextBlock x:Name="IdleDiamondIcon" Text="⚡" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Square shape -->
            <Border x:Name="IdleSquare"
                    Width="48" Height="48"
                    CornerRadius="0"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Background="{DynamicResource PrimaryBrush}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    RenderTransformOrigin="0.5,0.5">
                <Grid IsHitTestVisible="False">
                    <controls:SvgViewboxEx x:Name="IdleSquareSvg"
                                           Width="20" Height="20"
                                           Fill="{DynamicResource TextOnPrimaryBrush}"
                                           Visibility="Collapsed"/>
                    <TextBlock x:Name="IdleSquareIcon" Text="⚡" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- RoundedSquare shape -->
            <Border x:Name="IdleRoundedSquare"
                    Width="48" Height="48"
                    CornerRadius="10"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Background="{DynamicResource PrimaryBrush}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True"
                    RenderTransformOrigin="0.5,0.5">
                <Grid IsHitTestVisible="False">
                    <controls:SvgViewboxEx x:Name="IdleRoundedSvg"
                                           Width="20" Height="20"
                                           Fill="{DynamicResource TextOnPrimaryBrush}"
                                           Visibility="Collapsed"/>
                    <TextBlock x:Name="IdleRoundedIcon" Text="⚡" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Edge-dock square: hiển thị khi SlideToEdgeWhenIdle=true và EdgeDockAsSquare=true.
                 Có thể bị ẩn 1 phần vào cạnh theo cấu hình; hover vào chỉ lộ full shape. -->
            <Border x:Name="EdgeDockSquare"
                    Width="28" Height="28"
                    CornerRadius="6"
                    Cursor="Hand"
                    Visibility="Collapsed"
                    Background="{DynamicResource PrimaryBrush}"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid IsHitTestVisible="False">
                    <controls:SvgViewboxEx x:Name="EdgeDockSvg"
                                           Width="14" Height="14"
                                           Fill="{DynamicResource TextOnPrimaryBrush}"
                                           Visibility="Collapsed"/>
                    <TextBlock x:Name="EdgeDockIcon" Text="⚡" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextOnPrimaryBrush}"/>
                </Grid>
            </Border>

            <!-- Ripple layers (ẩn mặc định), animate theo chế độ Sóng nước -->
            <Border x:Name="RippleLayer1"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Width="48" Height="48"
                    BorderThickness="2"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    Background="Transparent"
                    Opacity="0.0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="RippleScale1" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
            </Border>
            <Border x:Name="RippleLayer2"
                    Visibility="Collapsed"
                    IsHitTestVisible="False"
                    Width="48" Height="48"
                    BorderThickness="2"
                    BorderBrush="{DynamicResource PrimaryBrush}"
                    Background="Transparent"
                    Opacity="0.0"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="RippleScale2" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
            </Border>
        </Grid>

        <!-- ═══ STATE 2: Expanded / Active ═══ -->
        <Grid x:Name="ExpandedContainer" Visibility="Collapsed">
            <Border x:Name="ExpandedBorder"
                    CornerRadius="0"
                    BorderThickness="1"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderColor}"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Title bar -->
                        <RowDefinition Height="*"/>     <!-- Content (WebView2) -->
                    </Grid.RowDefinitions>

                    <!-- ── Title Bar ── -->
                    <Border x:Name="TitleBar" Grid.Row="0"
                            Height="32"
                            Cursor="SizeAll"
                            Background="{DynamicResource WindowBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            ContextMenu="{StaticResource WidgetContextMenu}"
                            ContextMenuOpening="ContextMenu_Opening"
                            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                            MouseMove="TitleBar_MouseMove"
                            MouseLeftButtonUp="TitleBar_MouseLeftButtonUp"
                            MouseEnter="TitleBar_MouseEnter">
                        <Grid Margin="10,0,8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- Drag handle -->
                                <ColumnDefinition Width="*"/>     <!-- Title -->
                                <ColumnDefinition Width="Auto"/>  <!-- Run buttons -->
                                <ColumnDefinition Width="Auto"/>  <!-- Collapse -->
                            </Grid.ColumnDefinitions>

                            <!-- Drag handle -->
                            <TextBlock Grid.Column="0" Text="⋮⋮"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Opacity="0.9"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" Margin="0,0,8,0"
                                       IsHitTestVisible="False"/>

                            <!-- Title -->
                            <TextBlock x:Name="TitleText" Grid.Column="1"
                                       Text="Widget"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       IsHitTestVisible="False"/>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Margin="0,0,8,0">
                                <Button x:Name="StartWorkflowBtn"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,4,0"
                                        Padding="0"
                                        Cursor="Hand"
                                        ToolTip="Chạy workflow"
                                        Style="{StaticResource WidgetTitleActionButton}"
                                        Click="StartWorkflowBtn_Click">
                                    <Grid>
                                        <controls:SvgViewboxEx Width="13"
                                                               Height="13"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='play duotone-regular'}"
                                                               Fill="{DynamicResource TextOnSkyAzureBrush}"/>
                                        <Border x:Name="StartRunCountBadge"
                                                Width="13"
                                                Height="13"
                                                CornerRadius="6.5"
                                                Background="{DynamicResource DangerBrush}"
                                                BorderBrush="{DynamicResource TextOnDangerBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,-6,-6,0"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="StartRunCountText"
                                                       Text="0"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextOnDangerBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button x:Name="StopWorkflowBtn"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,4,0"
                                        Padding="0"
                                        Cursor="Hand"
                                        ToolTip="Dừng workflow đang chạy"
                                        Style="{StaticResource WidgetTitleActionButton}"
                                        Click="StopWorkflowBtn_Click"
                                        MouseEnter="StopWorkflowBtn_MouseEnter"
                                        MouseLeave="StopWorkflowBtn_MouseLeave">
                                    <Grid>
                                        <controls:SvgViewboxEx Width="13"
                                                               Height="13"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='flag-checkered sharp-duotone-solid'}"
                                                               Fill="{DynamicResource TextBrush}"/>
                                        <Border x:Name="StopRunCountBadge"
                                                Width="13"
                                                Height="13"
                                                CornerRadius="6.5"
                                                Background="{DynamicResource DangerBrush}"
                                                BorderBrush="{DynamicResource TextOnDangerBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Margin="0,-6,-6,0"
                                                Visibility="Collapsed">
                                            <TextBlock x:Name="StopRunCountText"
                                                       Text="0"
                                                       FontSize="8"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource TextOnDangerBrush}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Button>

                                <Button x:Name="TitleOutsideCollapseToggleBtn"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,4,0"
                                        Padding="0"
                                        Cursor="Hand"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource WidgetTitleActionButton}"
                                        Click="OutsideCollapseToggleButton_Click"
                                        ToolTip="Bật/tắt: click ra ngoài thì tự thu nhỏ">
                                    <TextBlock Text="◌"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </Button>

                                <Button x:Name="TitlePinToggleBtn"
                                        Width="24"
                                        Height="24"
                                        Margin="0,0,4,0"
                                        Padding="0"
                                        Cursor="Hand"
                                        FontSize="11"
                                        Style="{StaticResource WidgetTitleActionButton}"
                                        Click="PinToggleButton_Click"
                                        ToolTip="Bật/tắt ghim widget">
                                    <TextBlock Text="📌"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </Button>
                            </StackPanel>

                            <!-- Thu nhỏ (đóng: chuột phải → Đóng widget) -->
                            <Button x:Name="CollapseBtn" Grid.Column="3"
                                    Style="{StaticResource WidgetCollapseButton}"
                                    Click="CollapseBtn_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="StopSessionsPopup"
                           PlacementTarget="{Binding ElementName=StopWorkflowBtn}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           StaysOpen="False"
                           PopupAnimation="Fade"
                           MouseEnter="StopSessionsPopup_MouseEnter"
                           MouseLeave="StopSessionsPopup_MouseLeave">
                        <Border Background="{DynamicResource CardColor}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6"
                                MinWidth="64">
                            <StackPanel x:Name="StopSessionsButtonsPanel"
                                        Orientation="Horizontal"/>
                        </Border>
                    </Popup>

                    <!-- ── Content Area ── -->
                    <Border Grid.Row="1" x:Name="ContentArea" ClipToBounds="True"
                            Background="{DynamicResource CardColor}"
                            CornerRadius="0">
                        <!-- WebView2 hoặc content sẽ được thêm programmatically -->
                    </Border>

                    <!-- ── Resize Grip (bottom-right) ── -->
                    <Thumb x:Name="ResizeGrip" Grid.Row="1"
                           Width="16" Height="16"
                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                           Cursor="SizeNWSE" Opacity="0.5"
                           DragDelta="ResizeGrip_DragDelta">
                        <Thumb.Template>
                            <ControlTemplate>
                                <Canvas Width="16" Height="16">
                                    <Line X1="12" Y1="16" X2="16" Y2="12" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"/>
                                    <Line X1="8" Y1="16" X2="16" Y2="8" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"/>
                                    <Line X1="4" Y1="16" X2="16" Y2="4" Stroke="{DynamicResource TextBrush}" StrokeThickness="1.5"/>
                                </Canvas>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
