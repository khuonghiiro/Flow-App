<Window x:Class="FlowMy.Views.Overlays.CodeEditorPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        Title="Code � So?n th?o m? r?ng"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Width="800"
        Height="560"
        MinWidth="500"
        MinHeight="400"
        Background="{DynamicResource CardColor}">
    <Border CornerRadius="8" Padding="0" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" Padding="12,10" CornerRadius="8,8,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="So?n th?o code JavaScript � return { key: value }; d? tr? output"
                              Foreground="{DynamicResource TextBrush}" FontSize="14" VerticalAlignment="Center"/>
                    <Button x:Name="ClosePopupButton" Grid.Column="1" Content="��ng"
                            Width="80" Height="32" Padding="8,0"
                            Foreground="{DynamicResource TextBrush}" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                            Cursor="Hand" Click="ClosePopupButton_Click"/>
                </Grid>
            </Border>

            <controls:SyntaxHighlightCodeEditor x:Name="PopupCodeEditor" Grid.Row="1"
                     Text="{Binding ScriptCode, UpdateSourceTrigger=PropertyChanged}"
                     CodeFontSize="14"
                     Margin="12"/>

            <Border Grid.Row="2" Background="{DynamicResource HeaderBackgroundBrush}" Padding="12,8" CornerRadius="0,0,8,8">
                <TextBlock Foreground="{DynamicResource TextSecondary}" FontSize="12" TextWrapping="Wrap">
                    <Run Text="Bi?n t? input: "/>
                    <Run x:Name="PopupVarNameRun" Text="" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                    <Run Text=" � Ch?y workflow d? th?c thi code (node Code s? l?y data t? node ngu?n d� ch?n)."/>
                </TextBlock>
            </Border>
        </Grid>
    </Border>
</Window>
