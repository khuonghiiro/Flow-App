<local:BaseNodeDialog x:Class="FlowMy.Views.Overlays.FolderFilePathsNodeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FlowMy.Views.Overlays"
        Title="File trong thư mục"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Width="540"
        Height="720"
        MinWidth="480"
        MinHeight="580">

    <Border CornerRadius="12" Padding="0"
            Background="{DynamicResource WindowBodyBackground}"
            BorderBrush="{DynamicResource ControlBorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{DynamicResource DialogHeaderBorder}" Padding="16,12,12,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="TitleTextBox"
                             Grid.Column="0"
                             Text="{Binding NodeTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource BaseTextBoxV2}"
                             FontSize="16"
                             Padding="0,4,0,4"
                             VerticalContentAlignment="Center"
                             Cursor="IBeam"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="24" Height="24"
                                Content="▶"
                                FontSize="12"
                                Style="{DynamicResource PrimaryButton}"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                ToolTip="Chạy node này"
                                Command="{Binding RunSingleNodeCommand}"/>
                        <Button x:Name="CloseButton" Padding="0,0,0,0" 
                                Width="24" Height="24"
                                Style="{DynamicResource DangerButton}"
                                Content="×"
                                FontSize="12"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="0,4,0,0">

                <TabItem Header="Logic" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <StackPanel.Resources>
                                <!-- QuickExtTagChipStyle is now in Themes/Controls/DialogStyles.xaml -->
                            </StackPanel.Resources>

                            <TextBlock Text="Hiển thị tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <ComboBox Height="32"
                                      Style="{DynamicResource BaseComboBox}"
                                      Margin="0,0,0,14"
                                      ItemsSource="{Binding TitleDisplayModeOptions}"
                                      SelectedValuePath="Value"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValue="{Binding TitleDisplayMode, Mode=TwoWay}"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <TextBlock Text="Thư mục"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         Height="34" Margin="0,0,8,0"/>
                                <Button Grid.Column="1" Content="…" Width="40" Height="34"
                                        Style="{DynamicResource PrimaryButton}"
                                        Click="BrowseFolder_Click"
                                        ToolTip="Chọn thư mục"/>
                            </Grid>
                            <TextBlock Text="Hoặc lấy đường dẫn từ node / key:" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox Grid.Column="0" Height="32" Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding AvailableNodeOptions}"
                                          SelectedValuePath="NodeId"
                                          DisplayMemberPath="Title"
                                          SelectedValue="{Binding FolderSourceNodeId, Mode=TwoWay}"/>
                                <ComboBox Grid.Column="1" Height="32" Style="{DynamicResource BaseComboBox}"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding FolderOutputKeyOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding FolderSourceOutputKey, Mode=TwoWay}"/>
                            </Grid>
                            <CheckBox IsChecked="{Binding RefreshFolderSourceNodeBeforeUse, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextBrush}" FontSize="12" Margin="0,0,0,12">
                                <TextBlock Text="Khi chạy flow: chạy lại node nguồn (▶) trước khi lấy đường dẫn"
                                           TextWrapping="Wrap"/>
                            </CheckBox>

                            <CheckBox Content="Gồm cả file trong thư mục con (recursive)"
                                      IsChecked="{Binding IncludeSubfolders, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,12"/>

                            <TextBlock Text="Lọc đuôi file (Notepad++ style)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Ví dụ: .png,.jpg,.mp4 hoặc *.png;*.jpg — để trống = mọi loại file. Cộng thêm tag bên dưới."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ExtensionFilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Height="34" Margin="0,0,0,10"/>

                            <TextBlock Text="Tag đuôi nhanh" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="Chạm để thêm đuôi vào danh sách lọc (cộng với ô phía trên)."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource CardColor}" CornerRadius="10" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                    Padding="10,10" Margin="0,0,0,10">
                                <WrapPanel>
                                    <Button Style="{DynamicResource QuickExtTagChipStyle}" Content=".png"
                                            Command="{Binding AddPresetTagCommand}" CommandParameter=".png"/>
                                    <Button Style="{DynamicResource QuickExtTagChipStyle}" Content=".jpg"
                                            Command="{Binding AddPresetTagCommand}" CommandParameter=".jpg"/>
                                    <Button Style="{DynamicResource QuickExtTagChipStyle}" Content=".mp4"
                                            Command="{Binding AddPresetTagCommand}" CommandParameter=".mp4"/>
                                    <Button Style="{DynamicResource QuickExtTagChipStyle}" Content=".txt"
                                            Command="{Binding AddPresetTagCommand}" CommandParameter=".txt"/>
                                    <Button Style="{DynamicResource QuickExtTagChipStyle}" Content=".json"
                                            Command="{Binding AddPresetTagCommand}" CommandParameter=".json"/>
                                </WrapPanel>
                            </Border>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         Text="{Binding ExtensionTagDraft, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource BaseTextBoxV2}"
                                         Height="34" Margin="0,0,8,0"
                                         ToolTip="Nhập đuôi (vd .webp) rồi Thêm"/>
                                <Button Grid.Column="1" Content="Thêm tag" Height="34" MinWidth="88"
                                        Style="{DynamicResource PrimaryButton}"
                                        Command="{Binding AddExtensionTagCommand}" Cursor="Hand"/>
                            </Grid>

                            <TextBlock Text="Đuôi đã chọn" Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding ExtensionTags}" Margin="0,0,0,12">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,8,8" CornerRadius="10" Background="{DynamicResource ControlBorderBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                Padding="2,2,2,2" SnapsToDevicePixels="True">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding}" Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center" Margin="10,4,2,4"/>
                                                <Button Content="×" FontSize="13" FontWeight="SemiBold" Width="26" Height="26"
                                                        Foreground="{DynamicResource TextSecondary}" Background="{DynamicResource CardColor}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                        Cursor="Hand" FocusVisualStyle="{x:Null}" Padding="0"
                                                        ToolTip="Xóa tag"
                                                        Command="{Binding DataContext.RemoveExtensionTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="XBg"
                                                                    CornerRadius="7"
                                                                    Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="XBg" Property="Background" Value="#475569"/>
                                                                    <Setter TargetName="XBg" Property="BorderBrush" Value="#F87171"/>
                                                                    <Setter Property="Foreground" Value="#FECACA"/>
                                                                </Trigger>
                                                                <Trigger Property="IsPressed" Value="True">
                                                                    <Setter TargetName="XBg" Property="Background" Value="#7F1D1D"/>
                                                                    <Setter TargetName="XBg" Property="BorderBrush" Value="#EF4444"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <CheckBox Content="Đọc nội dung file (mục khớp đuôi bên dưới = text/base64; còn lại = đường dẫn)"
                                      IsChecked="{Binding ReadFileContents, Mode=TwoWay}"
                                      Foreground="{DynamicResource TextBrush}" FontSize="13" Margin="0,0,0,8"/>

                            <TextBlock Text="Đuôi được phép đọc (khi bật đọc file)"
                                       Foreground="{DynamicResource TextBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock Text="Mặc định .txt — ảnh (.png, .jpg, …) trả về Base64; file text UTF-8; nhị phân khác thử UTF-8 rồi Base64."
                                       Foreground="{DynamicResource TextSecondary}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding ReadContentExtensionsText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{DynamicResource BaseTextBoxV2}"
                                     Height="34" Margin="0,0,0,12"/>

                            <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,14"/>

                            <TextBlock Text="Kết quả lần chạy gần nhất"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Border Background="{DynamicResource CardColor}" CornerRadius="6" Padding="10,8" Margin="0,0,0,8">
                                <TextBlock Text="{Binding LastRunSummary}"
                                           Foreground="{DynamicResource TextBrush}" FontSize="12" TextWrapping="Wrap"/>
                            </Border>

                            <TextBlock Text="Output: paths (JSON string[] — đường dẫn hoặc nội dung), count, errorMessage"
                                       Foreground="{DynamicResource TextMuted}" FontSize="11" TextWrapping="Wrap"/>

                            <Border Style="{DynamicResource DialogOuterBorder}"
                                    CornerRadius="8" Padding="12" Margin="0,12,0,8"
                                    x:Name="BorderOutputPanel">
                                <StackPanel x:Name="OutputsPanel"/>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Cấu hình" Style="{StaticResource HttpTabItemStyle}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <StackPanel>
                            <TextBlock Text="Màu tiêu đề:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="TitleColorComboBox"
                                          Grid.Column="0" Height="34"
                                          Style="{DynamicResource BaseComboBox}"
                                          ItemsSource="{Binding TitleColorOptions}"
                                          SelectedValuePath="Key"
                                          DisplayMemberPath="DisplayName"
                                          SelectedValue="{Binding TitleColorKey, Mode=TwoWay}"
                                          SelectionChanged="TitleColorComboBox_SelectionChanged"/>
                                <Border Grid.Column="1" x:Name="TitleColorPreview"
                                        Width="34" Height="34" CornerRadius="6"
                                        Margin="8,0,0,0"
                                        BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"/>
                            </Grid>

                            <TextBlock Text="Vị trí cổng IN/OUT:"
                                       Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold"
                                       Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                    <TextBlock Text="Port IN" Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding InputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                    <TextBlock Text="Port OUT" Foreground="{DynamicResource TextBrush}" FontSize="11" Opacity="0.8" Margin="0,0,0,4"/>
                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                              ItemsSource="{Binding PortPositionOptions}"
                                              SelectedItem="{Binding OutputPortPosition, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding ReuseRoutes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,12" Background="{DynamicResource WindowBackground}"
                                                BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1"
                                                CornerRadius="8" Padding="10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Node IN" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <TextBlock Text="{Binding IncomingNodeTitle}" Foreground="{DynamicResource TextBrush}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Node OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}" ItemsSource="{Binding OutgoingOptions}"
                                                              SelectedValuePath="NodeId" DisplayMemberPath="Title"
                                                              SelectedValue="{Binding SelectedOutgoingNodeId, Mode=TwoWay}"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Kiểu line OUT" Foreground="{DynamicResource TextBrush}" FontSize="12" Opacity="0.7" Margin="0,0,0,4"/>
                                                    <ComboBox Height="32" Style="{DynamicResource BaseComboBox}"
                                                              ItemsSource="{Binding DataContext.ConnectionLineStyleOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              SelectedValuePath="Key" DisplayMemberPath="DisplayName"
                                                              SelectedValue="{Binding SelectedLineStyleKey, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</local:BaseNodeDialog>
