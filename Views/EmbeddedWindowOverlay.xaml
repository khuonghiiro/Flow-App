<Window x:Class="FlowMy.Views.EmbeddedWindowOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        Title="Flow-App Control"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">
    
    <Border Background="#F0FFFFFF" 
            BorderBrush="#2196F3" 
            BorderThickness="2"
            CornerRadius="8"
            Effect="{StaticResource CardShadow}">
        <Border.Resources>
            <DropShadowEffect x:Key="CardShadow" 
                              Color="#000000" 
                              BlurRadius="20" 
                              ShadowDepth="4" 
                              Opacity="0.3"/>
        </Border.Resources>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header Bar (thin) -->
            <Border Grid.Row="0" 
                    Background="#2196F3"
                    CornerRadius="6,6,0,0"
                    Height="28"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid Margin="8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="🎯"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    
                    <TextBlock Grid.Column="1"
                               x:Name="TitleText"
                               Text="Flow-App Control"
                               Foreground="White"
                               FontSize="11"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" 
                                Orientation="Horizontal">
                        <Button x:Name="MinimizeButton"
                                Content="−"
                                Width="20" Height="20"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="MinimizeButton_Click"
                                Margin="0,0,4,0"/>
                        
                        <Button x:Name="CloseButton"
                                Content="×"
                                Width="20" Height="20"
                                Background="#F44336"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Embedded Window Container -->
            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="0,0,6,6"
                    ClipToBounds="True">
                <controls:EmbeddedWindowHost x:Name="WindowHost"
                                             RemoveDecoration="True"/>
            </Border>
        </Grid>
    </Border>
</Window>
