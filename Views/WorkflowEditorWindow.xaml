            <!-- Canvas area: thiết kế kiểu DevTools cho panel log
                 - Columns: [LeftLog | LeftSplitter | Canvas(*) | RightSplitter | RightLog]
                 - Rows:    [Canvas(*) | BottomSplitter | BottomLog]
                 Log panel di chuyển giữa các ô dựa trên IsTraceDock{Bottom,Left,Right} qua DataTrigger. -->
            <Grid Grid.Column="2" x:Name="CanvasHostGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ScrollViewer x:Name="ScrollViewer"
                        Grid.Row="0"
                        Grid.Column="2"
                        Visibility="{Binding IsExecutionLogMaximizedOverCanvas, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden"
                        Background="{DynamicResource CanvasBackgroundBrush}"
                        PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                    <Grid>
                        <!-- Grid background layer -->
                        <Canvas x:Name="GridCanvas"
                                Background="Transparent"
                                ClipToBounds="False">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="GridScaleTransform"/>
                                    <TranslateTransform x:Name="GridTranslateTransform"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                        
                        <!-- Workflow content layer -->
                        <Canvas x:Name="WorkflowCanvas"
                                Background="Transparent"
                                MouseMove="WorkflowCanvas_MouseMove"
                                MouseUp="WorkflowCanvas_MouseUp"
                                MouseDown="WorkflowCanvas_MouseDown"
                                ClipToBounds="False">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ScaleTransform"/>
                                    <TranslateTransform x:Name="TranslateTransform"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                            <!-- Canvas sẽ được populate từ code-behind -->
                        </Canvas>
                    </Grid>
                </ScrollViewer>

                <!-- Nút nổi mở lại Execution Log panel khi user đã ẩn panel nhưng còn bật EnableExecutionTraceLog.
                     Đặt Grid.Row=0, Grid.Column=2 (chung ô với canvas) + align bottom-right để luôn nhìn thấy khi panel log collapsed. -->
                <Button Grid.Row="0"
                        Grid.Column="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Bottom"
                        Margin="0,0,20,16"
                        Panel.ZIndex="50"
                        Cursor="Hand"
                        Command="{Binding ToggleExecutionTracePanelCommand}"
                        ToolTip="Mở lại Execution Log panel"
                        Visibility="{Binding IsExecutionTraceReopenerVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="18"
                                    Padding="12,8"
                                    SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.35"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal">
                                    <controls:SvgViewboxEx Width="14" Height="14"
                                                           Fill="{DynamicResource TextOnPrimaryBrush}"
                                                           VerticalAlignment="Center"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='timeline-arrow duotone-light'}"/>
                                    <TextBlock Text="Mở Execution Log"
                                               Margin="8,0,0,0"
                                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                                               FontWeight="SemiBold"
                                               FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Resize handles (Thumb) – mỗi dock mode có một thanh kéo riêng, chỉ hiện khi mode đang active.
                     Dùng Thumb + DragDelta (xử lý trong code-behind) thay GridSplitter để có toàn quyền clamp min/max. -->
                <Thumb x:Name="TraceDockBottomResizer"
                       Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="5"
                       Height="5"
                       Background="{DynamicResource BorderColor}"
                       Cursor="SizeNS"
                       DragDelta="TraceDockBottomResizer_DragDelta"
                       ToolTip="Kéo để thay đổi chiều cao panel log">
                    <Thumb.Style>
                        <Style TargetType="Thumb">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExecutionTracePanelInMainGrid}" Value="True"/>
                                        <Condition Binding="{Binding IsTraceDockBottom}" Value="True"/>
                                        <Condition Binding="{Binding IsExecutionLogMaximizedOverCanvas}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Thumb.Style>
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <Thumb x:Name="TraceDockLeftResizer"
                       Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                       Width="5"
                       Background="{DynamicResource BorderColor}"
                       Cursor="SizeWE"
                       DragDelta="TraceDockLeftResizer_DragDelta"
                       ToolTip="Kéo để thay đổi chiều rộng panel log">
                    <Thumb.Style>
                        <Style TargetType="Thumb">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExecutionTracePanelInMainGrid}" Value="True"/>
                                        <Condition Binding="{Binding IsTraceDockLeft}" Value="True"/>
                                        <Condition Binding="{Binding IsExecutionLogMaximizedOverCanvas}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Thumb.Style>
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>
                <Thumb x:Name="TraceDockRightResizer"
                       Grid.Row="0" Grid.RowSpan="3" Grid.Column="3"
                       Width="5"
                       Background="{DynamicResource BorderColor}"
                       Cursor="SizeWE"
                       DragDelta="TraceDockRightResizer_DragDelta"
                       ToolTip="Kéo để thay đổi chiều rộng panel log">
                    <Thumb.Style>
                        <Style TargetType="Thumb">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExecutionTracePanelInMainGrid}" Value="True"/>
                                        <Condition Binding="{Binding IsTraceDockRight}" Value="True"/>
                                        <Condition Binding="{Binding IsExecutionLogMaximizedOverCanvas}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Thumb.Style>
                    <Thumb.Template>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="{TemplateBinding Background}"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

                <Border x:Name="ExecutionTracePanelHostBorder"
                        Background="{DynamicResource CardColor}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1,1,0,0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <!-- Default = Bottom dock -->
                            <Setter Property="Grid.Row" Value="2"/>
                            <Setter Property="Grid.RowSpan" Value="1"/>
                            <Setter Property="Grid.Column" Value="0"/>
                            <Setter Property="Grid.ColumnSpan" Value="5"/>
                            <Setter Property="Panel.ZIndex" Value="0"/>
                            <Setter Property="Height" Value="{Binding ExecutionTracePanelHeight}"/>
                            <Setter Property="Width" Value="{x:Static sys:Double.NaN}"/>
                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                            <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <!-- Chỉ hiện trong main grid khi KHÔNG detached và panel expanded. -->
                                <DataTrigger Binding="{Binding IsExecutionTracePanelInMainGrid}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- Dock Left: spans all rows, column 0.
                                     ZIndex=150 để nằm trên NodePaletteExpandButton (ZIndex=120) ở góc trái,
                                     nếu không nút toggle ẩn/hiện palette sẽ đè lên panel log. -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExecutionTracePanelInMainGrid}" Value="True"/>
                                        <Condition Binding="{Binding IsTraceDockLeft}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Grid.Row" Value="0"/>
                                    <Setter Property="Grid.RowSpan" Value="3"/>
                                    <Setter Property="Grid.Column" Value="0"/>
                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                    <Setter Property="Panel.ZIndex" Value="150"/>
                                    <Setter Property="Height" Value="{x:Static sys:Double.NaN}"/>
                                    <Setter Property="Width" Value="{Binding ExecutionTracePanelDockWidth}"/>
                                </MultiDataTrigger>
                                <!-- Dock Right: spans all rows, column 4. -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExecutionTracePanelInMainGrid}" Value="True"/>
                                        <Condition Binding="{Binding IsTraceDockRight}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Grid.Row" Value="0"/>
                                    <Setter Property="Grid.RowSpan" Value="3"/>
                                    <Setter Property="Grid.Column" Value="4"/>
                                    <Setter Property="Grid.ColumnSpan" Value="1"/>
                                    <Setter Property="Height" Value="{x:Static sys:Double.NaN}"/>
                                    <Setter Property="Width" Value="{Binding ExecutionTracePanelDockWidth}"/>
                                </MultiDataTrigger>
                                <!-- Maximize over canvas: full grid (chỉ áp dụng khi dock Bottom). -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsExecutionLogMaximizedOverCanvas}" Value="True"/>
                                        <Condition Binding="{Binding IsTraceDockBottom}" Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Grid.Row" Value="0"/>
                                    <Setter Property="Grid.RowSpan" Value="3"/>
                                    <Setter Property="Grid.Column" Value="0"/>
                                    <Setter Property="Grid.ColumnSpan" Value="5"/>
                                    <Setter Property="Panel.ZIndex" Value="100"/>
                                    <Setter Property="Height" Value="{x:Static sys:Double.NaN}"/>
                                    <Setter Property="Width" Value="{x:Static sys:Double.NaN}"/>
                                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource HeaderBackgroundMainBrush}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <Border.Resources>
                                <!-- Toolbar icon button: uniform size, hover/press background feedback. -->
                                <Style x:Key="TraceToolbarIconButton" TargetType="Button">
                                    <Setter Property="Width" Value="28"/>
                                    <Setter Property="Height" Value="24"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="2,0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                    <Setter Property="ToolTipService.InitialShowDelay" Value="400"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        SnapsToDevicePixels="True">
                                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                      Margin="{TemplateBinding Padding}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Opacity" Value="0.45"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                                <!-- Same feedback, wider to fit text+icon like "Tải log". -->
                                <Style x:Key="TraceToolbarTextIconButton" TargetType="Button" BasedOn="{StaticResource TraceToolbarIconButton}">
                                    <Setter Property="Width" Value="NaN"/>
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="Margin" Value="0,0,6,0"/>
                                </Style>
                                <!-- Thin separator between logical groups in the toolbar. -->
                                <Style x:Key="TraceToolbarSeparator" TargetType="Rectangle">
                                    <Setter Property="Width" Value="1"/>
                                    <Setter Property="Height" Value="16"/>
                                    <Setter Property="Fill" Value="#55FFFFFF"/>
                                    <Setter Property="Margin" Value="6,0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </Border.Resources>
                            <!-- Responsive: khi dock Left/Right hoặc panel narrow, toolbar wrap xuống dòng thay vì cuộn ngang.
                                 Mỗi "nhóm logic" (title / filter / search / action) đóng gói trong 1 StackPanel con
                                 để các item liên quan (label + combobox) không tách đôi ở biên wrap. -->
                            <WrapPanel Orientation="Horizontal" ItemHeight="28">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <controls:SvgViewboxEx Width="14"
                                                           Height="14"
                                                           Margin="0,0,6,0"
                                                           Fill="White"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='timeline-arrow duotone-light'}"/>
                                    <TextBlock Text="Execution Log"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="11"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Status" Foreground="White" Opacity="0.8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="100"
                                              Height="24"
                                              ItemsSource="{Binding ExecutionTraceStatusOptions}"
                                              SelectedItem="{Binding ExecutionTraceStatusFilter, Mode=TwoWay}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Type" Foreground="White" Opacity="0.8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="130"
                                              Height="24"
                                              ItemsSource="{Binding ExecutionTraceNodeTypeOptions}"
                                              SelectedItem="{Binding ExecutionTraceNodeTypeFilter, Mode=TwoWay}"
                                              VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- Search box với placeholder overlay; TextBlock ẩn khi TextBox có text/focus. -->
                                <Grid Width="240"
                                      Height="24"
                                      Margin="0,0,12,0"
                                      VerticalAlignment="Center">
                                    <TextBox x:Name="ExecutionTraceSearchTextBox"
                                             Height="24"
                                             VerticalAlignment="Center"
                                             Style="{StaticResource BaseTextBox}"
                                             Padding="10,0,8,0"
                                             Text="{Binding ExecutionTraceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="Tìm theo node name/id/key/output/error"/>
                                    <!-- Kính lúp gợi ý đây là search input. -->
                                    <controls:SvgViewboxEx Width="12" Height="12"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"
                                                           Margin="8,0,0,0"
                                                           IsHitTestVisible="False"
                                                           Fill="{DynamicResource PlaceholderBrush}"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='magnifying-glass duotone-regular'}"/>
                                    <TextBlock Text="Tìm node / key / output / error..."
                                               Foreground="{DynamicResource PlaceholderBrush}"
                                               FontStyle="Italic"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Margin="28,0,0,0"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding Text, ElementName=ExecutionTraceSearchTextBox}" Value=""/>
                                                            <Condition Binding="{Binding IsKeyboardFocused, ElementName=ExecutionTraceSearchTextBox}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Display style selector: Full / Relative / Compact.
                                     Mặc định = Full → UI log hiện tại. Các mode khác dùng DataTrigger
                                     để ẩn/compact các phần detail của từng card. -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Hiển thị" Foreground="White" Opacity="0.8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="110"
                                              Height="24"
                                              ItemsSource="{Binding ExecutionTraceDisplayStyleOptions}"
                                              SelectedValuePath="Id"
                                              DisplayMemberPath="Label"
                                              SelectedValue="{Binding ExecutionTraceDisplayStyle, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              ToolTip="Kiểu hiển thị log: Đầy đủ / Tương đối / Thu gọn"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Button Style="{StaticResource TraceToolbarTextIconButton}"
                                            Command="{Binding ExportExecutionTraceLogsCommand}"
                                            ToolTip="Xuất log run ra JSON">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                                   VerticalAlignment="Center"
                                                                   Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='file-export duotone-light'}"/>
                                            <TextBlock Margin="6,0,0,0"
                                                       Foreground="White"
                                                       FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Text="Tải log"/>
                                        </StackPanel>
                                    </Button>

                                    <Rectangle Style="{StaticResource TraceToolbarSeparator}"/>

                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding ExpandAllExecutionTraceTreeCommand}"
                                            ToolTip="Mở tất cả nhánh">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='rectangle-plus solid'}"/>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding CollapseAllExecutionTraceTreeCommand}"
                                            ToolTip="Đóng tất cả nhánh">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='rectangle-minus duotone-light'}"/>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding ClearExecutionTraceLogsCommand}"
                                            ToolTip="Xóa log hiện tại">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='trash-can duotone-regular'}"/>
                                    </Button>

                                    <Rectangle Style="{StaticResource TraceToolbarSeparator}"/>

                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding ZoomOutExecutionTraceCommand}"
                                            ToolTip="Thu nhỏ log tree">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='magnifying-glass-minus duotone-regular'}"/>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding ZoomInExecutionTraceCommand}"
                                            ToolTip="Phóng to log tree">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='magnifying-glass-plus duotone-regular'}"/>
                                    </Button>

                                    <Rectangle Style="{StaticResource TraceToolbarSeparator}"/>

                                    <!-- DevTools-like dock buttons: Bottom | Left | Right | Detach -->
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding SetExecutionTracePanelDockModeCommand}"
                                            CommandParameter="Bottom"
                                            ToolTip="Dock dưới">
                                        <Button.Content>
                                            <Grid Width="14" Height="14">
                                                <Rectangle Stroke="White" StrokeThickness="1.2" RadiusX="1" RadiusY="1" Fill="Transparent"/>
                                                <Rectangle Fill="White" Height="4" VerticalAlignment="Bottom" Margin="1,0,1,1"/>
                                            </Grid>
                                        </Button.Content>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding SetExecutionTracePanelDockModeCommand}"
                                            CommandParameter="Left"
                                            ToolTip="Dock trái">
                                        <Button.Content>
                                            <Grid Width="14" Height="14">
                                                <Rectangle Stroke="White" StrokeThickness="1.2" RadiusX="1" RadiusY="1" Fill="Transparent"/>
                                                <Rectangle Fill="White" Width="4" HorizontalAlignment="Left" Margin="1,1,0,1"/>
                                            </Grid>
                                        </Button.Content>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding SetExecutionTracePanelDockModeCommand}"
                                            CommandParameter="Right"
                                            ToolTip="Dock phải">
                                        <Button.Content>
                                            <Grid Width="14" Height="14">
                                                <Rectangle Stroke="White" StrokeThickness="1.2" RadiusX="1" RadiusY="1" Fill="Transparent"/>
                                                <Rectangle Fill="White" Width="4" HorizontalAlignment="Right" Margin="0,1,1,1"/>
                                            </Grid>
                                        </Button.Content>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding SetExecutionTracePanelDockModeCommand}"
                                            CommandParameter="Detached"
                                            ToolTip="Mở panel log ra cửa sổ riêng">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='arrow-up-right-from-square sharp-solid'}"/>
                                    </Button>

                                    <Rectangle Style="{StaticResource TraceToolbarSeparator}"/>

                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding ToggleExecutionTracePanelMaximizeCommand}"
                                            ToolTip="Phóng to/thu nhỏ panel log">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='window-maximize duotone-regular'}"/>
                                    </Button>
                                    <Button Style="{StaticResource TraceToolbarIconButton}"
                                            Command="{Binding ToggleExecutionTracePanelCommand}"
                                            ToolTip="Ẩn/hiện panel log">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='chevron-down duotone-regular'}"/>
                                    </Button>
                                </StackPanel>
                            </WrapPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Padding="10,6,14,10"
                                          ClipToBounds="False">
                                <Grid x:Name="ExecutionTraceTreeOuterGrid"
                                      Margin="0"
                                      HorizontalAlignment="Left"
                                      ClipToBounds="False">
                                    <Grid.LayoutTransform>
                                        <ScaleTransform ScaleX="{Binding ExecutionTraceZoom}"
                                                        ScaleY="{Binding ExecutionTraceZoom}"/>
                                    </Grid.LayoutTransform>
                                    <ItemsControl x:Name="ExecutionTraceTreeItemsControl"
                                                  ItemsSource="{Binding ExecutionTraceRunRoots}"
                                                  HorizontalAlignment="Left">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <!-- Collapse ngay ở ContentPresenter khi run-root bị filter ẩn toàn bộ children. -->
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.Resources>
                                            <BooleanToVisibilityConverter x:Key="LocalBoolToVis"/>
                                            <!-- Alpha-blended brushes cho IN/OUT/ERR.
                                                 Alpha thấp (0x33 = 20%) → nổi trên cả nền sáng (Light) lẫn nền tối (Dark)
                                                 mà không bị chói; text dùng DynamicResource TextBrush để luôn tương phản đủ.
                                                 Chip labels (IN/OUT/ERR) giữ alpha cao hơn để đọc được rõ. -->
                                            <SolidColorBrush x:Key="TraceInBackgroundBrush" Color="#332DBE6C"/>
                                            <SolidColorBrush x:Key="TraceInBorderBrush"     Color="#802DBE6C"/>
                                            <SolidColorBrush x:Key="TraceInAccentBrush"     Color="#FF2DBE6C"/>

                                            <SolidColorBrush x:Key="TraceOutBackgroundBrush" Color="#33228BE6"/>
                                            <SolidColorBrush x:Key="TraceOutBorderBrush"     Color="#80228BE6"/>
                                            <SolidColorBrush x:Key="TraceOutAccentBrush"     Color="#FF228BE6"/>

                                            <SolidColorBrush x:Key="TraceErrBackgroundBrush" Color="#33FA5252"/>
                                            <SolidColorBrush x:Key="TraceErrBorderBrush"     Color="#80FA5252"/>
                                            <SolidColorBrush x:Key="TraceErrAccentBrush"     Color="#FFFA5252"/>

                                            <!-- ==== Display-style helper styles ====
                                                 Các style dưới bind DataContext.IsTraceDisplay* trên Window (chứa VM)
                                                 để ẩn/hiện element theo chế độ Full/Relative/Compact mà không phải
                                                 viết lặp DataTrigger ở từng element. -->
                                            <Style x:Key="TraceCompactHiddenTextBlock" TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                            <Style x:Key="TraceCompactHiddenToggle" TargetType="ToggleButton">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                            <!-- Hide element khi ở chế độ Compact HOẶC Relative (dùng cho "from node:" line). -->
                                            <Style x:Key="TraceRelativeOrCompactHiddenTextBlock" TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding DataContext.IsTraceDisplayRelative, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        <Style x:Key="TraceDetailsToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource QaToggleButton}">
                                            <Setter Property="Height" Value="20"/>
                                            <Setter Property="FontSize" Value="10"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        </Style>
                                        <Style x:Key="TraceStatusBadgeStyle" TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource CardColor}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                            <Setter Property="CornerRadius" Value="10"/>
                                            <Setter Property="Padding" Value="7,1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="completed">
                                                    <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="running">
                                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter Property="Opacity" Value="0.85"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="failed">
                                                    <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </DataTrigger>
                                                <!-- Compact mode: badge → chấm tròn nhỏ (10x10), không padding, chỉ thể hiện màu status. -->
                                                <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                    <Setter Property="Width" Value="10"/>
                                                    <Setter Property="Height" Value="10"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>

                                        <DataTemplate DataType="{x:Type viewModels:ExecutionTraceTreeNodeViewModel}">
                                            <StackPanel Visibility="{Binding IsVisible, Converter={StaticResource LocalBoolToVis}}"
                                                        HorizontalAlignment="Left"
                                                        ClipToBounds="False">
                                                <Grid Margin="{Binding ItemMargin}"
                                                      HorizontalAlignment="Left"
                                                      ClipToBounds="False">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Solid L-connector only (indent = ItemMargin; no extra guide columns) -->
                                                    <Grid Grid.Column="0"
                                                          x:Name="TraceConnectorHost"
                                                          Width="60"
                                                          Height="{Binding ElementName=TraceNodeCard, Path=ActualHeight, FallbackValue=36}"
                                                          VerticalAlignment="Top"
                                                          Margin="0,0,4,0"
                                                          Visibility="{Binding ShowConnector, Converter={StaticResource LocalBoolToVis}}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>
                                                        <Rectangle Grid.Row="0"
                                                                   Width="1"
                                                                   Fill="{DynamicResource BorderColor}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Stretch"
                                                                   Visibility="{Binding ShowTopStem, Converter={StaticResource LocalBoolToVis}}"/>
                                                        <Rectangle Grid.Row="1"
                                                                   Width="1"
                                                                   Fill="{DynamicResource BorderColor}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Stretch"
                                                                   Visibility="{Binding ShowBottomStem, Converter={StaticResource LocalBoolToVis}}"/>
                                                        <Rectangle Grid.RowSpan="2"
                                                                   Height="1"
                                                                   Fill="{DynamicResource BorderColor}"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Stretch"
                                                                   Margin="30,0,0,0"
                                                                   Visibility="{Binding ShowHorizontalConnector, Converter={StaticResource LocalBoolToVis}}"/>
                                                    </Grid>

                                                    <Border Grid.Column="1"
                                                            x:Name="TraceNodeCard"
                                                            Padding="6,5"
                                                            CornerRadius="4"
                                                            BorderThickness="1"
                                                            BorderBrush="{Binding TraceCardBorderBrush}"
                                                            Background="{Binding TraceCardBackgroundBrush}"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Top"
                                                            MinWidth="220"
                                                            MaxWidth="{Binding DataContext.ExecutionTraceCardMaxWidth, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                            Cursor="Hand"
                                                            ToolTip="Click để di chuyển canvas tới node này"
                                                            MouseLeftButtonUp="ExecutionLogNodeIcon_MouseLeftButtonUp">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="18"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <!-- Tam giác ngay sát tiêu đề (trong card), ảnh mẫu -->
                                                            <Grid Grid.Column="0" Width="18" VerticalAlignment="Top" Margin="0,4,0,0">
                                                                <ToggleButton Width="16"
                                                                              Height="16"
                                                                              HorizontalAlignment="Left"
                                                                              VerticalAlignment="Top"
                                                                              Background="Transparent"
                                                                              BorderThickness="0"
                                                                              Padding="0"
                                                                              IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                                              Visibility="{Binding HasChildren, Converter={StaticResource LocalBoolToVis}}">
                                                                    <Path Data="M 4 3 L 9 8 L 4 13"
                                                                          Stroke="{DynamicResource TextBrush}"
                                                                          StrokeThickness="1.15"
                                                                          Fill="Transparent"
                                                                          RenderTransformOrigin="0.5,0.5">
                                                                        <Path.Style>
                                                                            <Style TargetType="Path">
                                                                                <Setter Property="RenderTransform">
                                                                                    <Setter.Value><RotateTransform Angle="0"/></Setter.Value>
                                                                                </Setter>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                        <Setter Property="RenderTransform">
                                                                                            <Setter.Value><RotateTransform Angle="90"/></Setter.Value>
                                                                                        </Setter>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Path.Style>
                                                                    </Path>
                                                                </ToggleButton>
                                                            </Grid>
                                                            <StackPanel Grid.Column="1">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                        <Border Width="20"
                                                                                Height="20"
                                                                                CornerRadius="10"
                                                                                Margin="0,0,6,0"
                                                                                Cursor="Hand"
                                                                                MouseLeftButtonUp="ExecutionLogNodeIcon_MouseLeftButtonUp"
                                                                                ToolTip="Di chuyển tới node"
                                                                                Background="{Binding NodeBrush}">
                                                                            <controls:SvgViewboxEx Width="11"
                                                                                                   Height="11"
                                                                                                   Fill="{Binding IconBrush}"
                                                                                                   Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding NodeTitle}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="11"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding NodeTitle}"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{Binding ElapsedText}"
                                                                               Margin="8,0,8,0"
                                                                               FontSize="10"
                                                                               Opacity="0.65"
                                                                               Foreground="{DynamicResource TextBrush}"
                                                                               VerticalAlignment="Center"
                                                                               Style="{StaticResource TraceCompactHiddenTextBlock}"/>
                                                                    <Border Grid.Column="2" Style="{StaticResource TraceStatusBadgeStyle}">
                                                                        <!-- Full/Relative: hiển thị text status (running/completed/failed);
                                                                             Compact: ẩn text, giữ Border làm dot màu thể hiện status. -->
                                                                        <TextBlock Text="{Binding Status}"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   Style="{StaticResource TraceCompactHiddenTextBlock}"/>
                                                                    </Border>
                                                                    <!-- Per-card toggle: collapsed = trim ellipsis, expanded = wrap full.
                                                                         Compact mode: ẩn nút để dòng card gọn nhất (user xem chi tiết ở mode Đầy đủ).
                                                                         Lưu ý: Visibility được đặt trong Style (setter + trigger) thay vì inline
                                                                         để Compact-mode trigger có hiệu lực cao hơn (inline value sẽ beat trigger). -->
                                                                    <ToggleButton Grid.Column="3"
                                                                                  Width="22" Height="20"
                                                                                  Margin="6,0,0,0"
                                                                                  Padding="0"
                                                                                  Cursor="Hand"
                                                                                  Background="Transparent"
                                                                                  BorderThickness="1"
                                                                                  BorderBrush="{DynamicResource BorderColor}"
                                                                                  IsChecked="{Binding IsDetailsExpanded, Mode=TwoWay}">
                                                                        <ToggleButton.Style>
                                                                            <Style TargetType="ToggleButton">
                                                                                <Setter Property="Visibility" Value="{Binding ShowDetailsToggle, Converter={StaticResource LocalBoolToVis}}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ToggleButton.Style>
                                                                        <ToggleButton.ToolTip>
                                                                            <TextBlock>
                                                                                <Run Text="Mở rộng / thu gọn IN/OUT/ERR"/>
                                                                            </TextBlock>
                                                                        </ToggleButton.ToolTip>
                                                                        <ToggleButton.Template>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border x:Name="Bd"
                                                                                        Background="{TemplateBinding Background}"
                                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                                        CornerRadius="3"
                                                                                        SnapsToDevicePixels="True">
                                                                                    <Path x:Name="Arrow"
                                                                                          Data="M 3 5 L 8 10 L 13 5"
                                                                                          Stroke="{DynamicResource TextBrush}"
                                                                                          StrokeThickness="1.4"
                                                                                          Fill="Transparent"
                                                                                          HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center"
                                                                                          RenderTransformOrigin="0.5,0.5">
                                                                                        <Path.RenderTransform>
                                                                                            <RotateTransform Angle="0"/>
                                                                                        </Path.RenderTransform>
                                                                                    </Path>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource MenuItemHoverBackgroundBrush}"/>
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                                                            <Setter.Value>
                                                                                                <RotateTransform Angle="180"/>
                                                                                            </Setter.Value>
                                                                                        </Setter>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </ToggleButton.Template>
                                                                    </ToggleButton>
                                                                </Grid>

                                                                <!-- "from node: xyz" chỉ hiện ở mode Đầy đủ; Tương đối/Thu gọn ẩn để dòng card gọn hơn. -->
                                                                <TextBlock Margin="0,4,0,0"
                                                                           FontSize="9"
                                                                           Opacity="0.55"
                                                                           Foreground="{DynamicResource TextBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           Text="{Binding ParentNodeId, StringFormat=from node: {0}}"
                                                                           Style="{StaticResource TraceRelativeOrCompactHiddenTextBlock}"/>

                                                                <!--
                                                                    Khối IN/OUT/ERR:
                                                                    - Khi đóng (IsDetailsExpanded=false): chỉ hiện 1 dòng tóm tắt, ellipsis, chiều cao tối thiểu.
                                                                    - Khi mở: hiện danh sách chip key/value wrap text + nút Copy riêng cho từng dòng IN/OUT/ERR.
                                                                    - Dùng Visibility để LOẠI phần mở rộng khỏi visual tree khi đóng, đảm bảo re-measure đúng
                                                                    để height tự co (trước đây wrapped content giữ height cũ khi toggle back).
                                                                -->

                                                                <!-- IN -->
                                                                <StackPanel Margin="0,4,0,0"
                                                                            Visibility="{Binding HasInput, Converter={StaticResource LocalBoolToVis}}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0"
                                                                                Background="{DynamicResource TraceInBackgroundBrush}"
                                                                                BorderBrush="{DynamicResource TraceInBorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="3"
                                                                                Padding="4,0"
                                                                                Margin="0,0,6,0"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="IN"
                                                                                       FontSize="9"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="{DynamicResource TraceInAccentBrush}"/>
                                                                        </Border>
                                                                        <!-- Collapsed: single-line summary ellipsis. Compact mode: ẩn để card gọn. -->
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding InputSummary}"
                                                                                   FontSize="9"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="NoWrap"
                                                                                   VerticalAlignment="Center"
                                                                                   ToolTip="{Binding InputSummary}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <Button Grid.Column="2"
                                                                                Width="20" Height="18"
                                                                                Padding="0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent"
                                                                                BorderBrush="{DynamicResource TraceInBorderBrush}"
                                                                                BorderThickness="1"
                                                                                ToolTip="Copy toàn bộ IN (bản đầy đủ)"
                                                                                Command="{Binding DataContext.CopyTraceTextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                                CommandParameter="{Binding InputSummaryExpanded}">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <TextBlock Text="⧉" FontSize="10" Foreground="{DynamicResource TraceInAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Button>
                                                                    </Grid>
                                                                    <!-- Expanded: list of parsed key/value chips (FULL - không bị cắt ngắn ...) -->
                                                                    <ItemsControl Margin="0,3,0,0"
                                                                                  ItemsSource="{Binding FullInputItems}">
                                                                        <ItemsControl.Style>
                                                                            <Style TargetType="ItemsControl">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="True"/>
                                                                                            <Condition Binding="{Binding HasFullInputItems}" Value="True"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ItemsControl.Style>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type viewModels:TraceKeyValueItem}">
                                                                                <Border Background="{DynamicResource TraceInBackgroundBrush}"
                                                                                        BorderBrush="{DynamicResource TraceInBorderBrush}"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="3"
                                                                                        Padding="5,3"
                                                                                        Margin="0,0,0,2">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <StackPanel Grid.Column="0">
                                                                                            <TextBlock Text="{Binding Key}"
                                                                                                       FontSize="9"
                                                                                                       FontWeight="SemiBold"
                                                                                                       Foreground="{DynamicResource TraceInAccentBrush}"
                                                                                                       TextWrapping="Wrap"
                                                                                                       Visibility="{Binding HasKey, Converter={StaticResource LocalBoolToVis}}"/>
                                                                                            <TextBlock Text="{Binding Value}"
                                                                                                       FontSize="9"
                                                                                                       Foreground="{DynamicResource TextBrush}"
                                                                                                       TextWrapping="Wrap"
                                                                                                       Margin="0,1,0,0"/>
                                                                                        </StackPanel>
                                                                                        <Button Grid.Column="1"
                                                                                                Width="18" Height="16"
                                                                                                Margin="4,0,0,0"
                                                                                                Padding="0"
                                                                                                Cursor="Hand"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                ToolTip="Copy dòng này"
                                                                                                VerticalAlignment="Top"
                                                                                                Command="{Binding DataContext.CopyTraceTextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                                                CommandParameter="{Binding CopyText}">
                                                                                            <TextBlock Text="⧉" FontSize="10" Foreground="{DynamicResource TraceInAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Button>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <!-- Expanded fallback: không parse được key/value → show wrap text thô (FULL không cắt) -->
                                                                    <TextBlock Text="{Binding InputSummaryExpanded}"
                                                                               Margin="0,3,0,0"
                                                                               FontSize="9"
                                                                               Foreground="{DynamicResource TextBrush}"
                                                                               TextWrapping="Wrap">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="True"/>
                                                                                            <Condition Binding="{Binding HasFullInputItems}" Value="False"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <!-- OUT -->
                                                                <StackPanel Margin="0,3,0,0"
                                                                            Visibility="{Binding HasOutput, Converter={StaticResource LocalBoolToVis}}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0"
                                                                                Background="{DynamicResource TraceOutBackgroundBrush}"
                                                                                BorderBrush="{DynamicResource TraceOutBorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="3"
                                                                                Padding="4,0"
                                                                                Margin="0,0,6,0"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="OUT"
                                                                                       FontSize="9"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="{DynamicResource TraceOutAccentBrush}"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding OutputSummary}"
                                                                                   FontSize="9"
                                                                                   Foreground="{DynamicResource TextBrush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="NoWrap"
                                                                                   VerticalAlignment="Center"
                                                                                   ToolTip="{Binding OutputSummary}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <Button Grid.Column="2"
                                                                                Width="20" Height="18"
                                                                                Padding="0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent"
                                                                                BorderBrush="{DynamicResource TraceOutBorderBrush}"
                                                                                BorderThickness="1"
                                                                                ToolTip="Copy toàn bộ OUT (bản đầy đủ)"
                                                                                Command="{Binding DataContext.CopyTraceTextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                                CommandParameter="{Binding OutputSummaryExpanded}">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <TextBlock Text="⧉" FontSize="10" Foreground="{DynamicResource TraceOutAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Button>
                                                                    </Grid>
                                                                    <ItemsControl Margin="0,3,0,0"
                                                                                  ItemsSource="{Binding FullOutputItems}">
                                                                        <ItemsControl.Style>
                                                                            <Style TargetType="ItemsControl">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="True"/>
                                                                                            <Condition Binding="{Binding HasFullOutputItems}" Value="True"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </ItemsControl.Style>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type viewModels:TraceKeyValueItem}">
                                                                                <Border Background="{DynamicResource TraceOutBackgroundBrush}"
                                                                                        BorderBrush="{DynamicResource TraceOutBorderBrush}"
                                                                                        BorderThickness="1"
                                                                                        CornerRadius="3"
                                                                                        Padding="5,3"
                                                                                        Margin="0,0,0,2">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <StackPanel Grid.Column="0">
                                                                                            <TextBlock Text="{Binding Key}"
                                                                                                       FontSize="9"
                                                                                                       FontWeight="SemiBold"
                                                                                                       Foreground="{DynamicResource TraceOutAccentBrush}"
                                                                                                       TextWrapping="Wrap"
                                                                                                       Visibility="{Binding HasKey, Converter={StaticResource LocalBoolToVis}}"/>
                                                                                            <TextBlock Text="{Binding Value}"
                                                                                                       FontSize="9"
                                                                                                       Foreground="{DynamicResource TextBrush}"
                                                                                                       TextWrapping="Wrap"
                                                                                                       Margin="0,1,0,0"/>
                                                                                        </StackPanel>
                                                                                        <Button Grid.Column="1"
                                                                                                Width="18" Height="16"
                                                                                                Margin="4,0,0,0"
                                                                                                Padding="0"
                                                                                                Cursor="Hand"
                                                                                                Background="Transparent"
                                                                                                BorderThickness="0"
                                                                                                ToolTip="Copy dòng này"
                                                                                                VerticalAlignment="Top"
                                                                                                Command="{Binding DataContext.CopyTraceTextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                                                CommandParameter="{Binding CopyText}">
                                                                                            <TextBlock Text="⧉" FontSize="10" Foreground="{DynamicResource TraceOutAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                        </Button>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Text="{Binding OutputSummaryExpanded}"
                                                                               Margin="0,3,0,0"
                                                                               FontSize="9"
                                                                               Foreground="{DynamicResource TextBrush}"
                                                                               TextWrapping="Wrap">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <MultiDataTrigger>
                                                                                        <MultiDataTrigger.Conditions>
                                                                                            <Condition Binding="{Binding IsDetailsExpanded}" Value="True"/>
                                                                                            <Condition Binding="{Binding HasFullOutputItems}" Value="False"/>
                                                                                        </MultiDataTrigger.Conditions>
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </MultiDataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>

                                                                <!-- ERR -->
                                                                <StackPanel Margin="0,3,0,0"
                                                                            Visibility="{Binding HasError, Converter={StaticResource LocalBoolToVis}}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Border Grid.Column="0"
                                                                                Background="{DynamicResource TraceErrBackgroundBrush}"
                                                                                BorderBrush="{DynamicResource TraceErrBorderBrush}"
                                                                                BorderThickness="1"
                                                                                CornerRadius="3"
                                                                                Padding="4,0"
                                                                                Margin="0,0,6,0"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="ERR"
                                                                                       FontSize="9"
                                                                                       FontWeight="Bold"
                                                                                       Foreground="{DynamicResource TraceErrAccentBrush}"/>
                                                                        </Border>
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding ErrorMessage}"
                                                                                   FontSize="9"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource TraceErrAccentBrush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   TextWrapping="NoWrap"
                                                                                   VerticalAlignment="Center"
                                                                                   ToolTip="{Binding ErrorMessage}">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <Button Grid.Column="2"
                                                                                Width="20" Height="18"
                                                                                Padding="0"
                                                                                Cursor="Hand"
                                                                                Background="Transparent"
                                                                                BorderBrush="{DynamicResource TraceErrBorderBrush}"
                                                                                BorderThickness="1"
                                                                                ToolTip="Copy toàn bộ ERR (bản đầy đủ)"
                                                                                Command="{Binding DataContext.CopyTraceTextCommand, RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                                                                CommandParameter="{Binding ErrorMessageExpanded}">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding DataContext.IsTraceDisplayCompact, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="True">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <TextBlock Text="⧉" FontSize="10" Foreground="{DynamicResource TraceErrAccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Button>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding ErrorMessageExpanded}"
                                                                               Margin="0,3,0,0"
                                                                               FontSize="9"
                                                                               FontWeight="SemiBold"
                                                                               Foreground="{DynamicResource TraceErrAccentBrush}"
                                                                               TextWrapping="Wrap">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>

                                                <!-- Dashed vertical line continuing through children when expanded.
                                                     Toàn bộ Grid chỉ visible khi có ít nhất 1 child chưa bị filter ẩn,
                                                     tránh để lại dải trống phía dưới card cha khi user filter. -->
                                                <Grid x:Name="TraceChildrenBranchGrid">
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasVisibleChildren}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Line X1="0" Y1="0" X2="0"
                                                          Stroke="{DynamicResource ExecutionTraceGuideBrush}"
                                                          StrokeThickness="1.25"
                                                          StrokeDashArray="5,4"
                                                          StrokeDashCap="Round"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Top"
                                                          SnapsToDevicePixels="True"
                                                          IsHitTestVisible="False"
                                                          Margin="{Binding ChildrenDashedLineMargin}">
                                                        <Line.Y2>
                                                            <MultiBinding Converter="{StaticResource SubtractMinZeroMultiConverter}">
                                                                <Binding Path="ActualHeight" ElementName="TraceChildrenBranchGrid"/>
                                                                <Binding Path="ChildrenDashedLineHeightTrim"/>
                                                            </MultiBinding>
                                                        </Line.Y2>
                                                        <Line.Style>
                                                            <Style TargetType="Line">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsExpanded}" Value="True"/>
                                                                            <Condition Binding="{Binding HasChildren}" Value="True"/>
                                                                            <Condition Binding="{Binding IsLastSibling}" Value="False"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Line.Style>
                                                    </Line>
                                                    <ItemsControl Margin="0,0,0,0"
                                                                  ItemsSource="{Binding Children}">
                                                        <ItemsControl.Style>
                                                            <Style TargetType="ItemsControl">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ItemsControl.Style>
                                                        <!-- Ẩn item container (ContentPresenter) theo IsVisible của child. Mục đích:
                                                             tránh trường hợp WPF vẫn reserve khoảng trống khi chỉ có DataTemplate.root
                                                             bên trong bị Collapsed mà CP vẫn tham gia measure. Bỏ qua luôn ở mức
                                                             ItemContainer → không còn khoảng trống thừa khi filter. -->
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource LocalBoolToVis}}"/>
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                    </ItemsControl>
                                                </Grid>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.Resources>
                                    </ItemsControl>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Grid>
                </Border>

