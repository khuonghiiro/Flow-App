                                </Border.ContextMenu>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='inbox-out duotone-light'}"
                                                          Fill="{DynamicResource TextOnMintChocolateBrush}"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource SeaFoamBrush}"
                                    Tag="KeyValueBridge">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="240">
                                            <TextBlock Text="KeyValue Bridge" FontWeight="Bold"/>
                                            <TextBlock Text="Kênh key/value runtime chung cho một lần chạy: Pass Key (truyền key trong flow) hoặc Get Value (đọc store sau interval). Code node: biến kv[...]." TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.95"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='list-check solid'}"
                                                          Fill="{DynamicResource TextOnSeaFoamBrush}"/>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource KiwiGreenBrush}"
                                    Tag="FlowOverwrite">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="240">
                                            <TextBlock Text="Flow Overwrite" FontWeight="Bold"/>
                                            <TextBlock Text="Ghi đè hoặc gom mảng giá trị theo node chạy vào cuối cùng. Chỉ map node nối trực tiếp vào cổng IN." TextWrapping="Wrap" Margin="0,2,0,0" Opacity="0.95"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='merge sharp-regular'}"
                                                          Fill="{DynamicResource TextOnKiwiGreenBrush}"/>
                                </Grid>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="Screen" Style="{StaticResource PaletteGroupHeaderStyle}"/>
                        <WrapPanel Orientation="Horizontal" x:Name="ScreenWrapPanel">
                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource AmethystBrush}"
                                    Tag="ScreenPosition">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="220">
                                            <TextBlock Text="Screen Position" FontWeight="Bold"/>
                                            <TextBlock Text="Chọn 1 điểm trên màn hình để lấy (x,y)." TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="Outputs: x, y, position" Opacity="0.85" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Border.ContextMenu>
                                    <ContextMenu Placement="MousePoint" StaysOpen="False">
                                        <MenuItem IsHitTestVisible="False">
                                            <MenuItem.Header>
                                                <Border Background="{DynamicResource AmethystBrush}" CornerRadius="10" Padding="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="Screen Position" Foreground="{DynamicResource TextOnAmethystBrush}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="Chọn vị trí màn hình và xuất ra x/y." Foreground="{DynamicResource TextOnAmethystBrush}" Opacity="0.9" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='crosshairs sharp-duotone-solid'}"
                                                          Fill="{DynamicResource TextOnAmethystBrush}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource SuccessBrush}"
                                    Tag="ScreenCapture">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="220">
                                            <TextBlock Text="Screen Capture" FontWeight="Bold"/>
                                            <TextBlock Text="Chụp màn hình/vùng chọn và xuất ảnh + thông tin." TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Border.ContextMenu>
                                    <ContextMenu Placement="MousePoint" StaysOpen="False">
                                        <MenuItem IsHitTestVisible="False">
                                            <MenuItem.Header>
                                                <Border Background="{DynamicResource SuccessBrush}" CornerRadius="10" Padding="10" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                                                    <StackPanel>
                                                        <TextBlock Text="Screen Capture" Foreground="{DynamicResource TextOnSuccessBrush}" FontWeight="Bold" FontSize="13"/>
                                                        <TextBlock Text="Chụp màn hình và xuất metadata (width/height/base64...)." Foreground="{DynamicResource TextOnSuccessBrush}" Opacity="0.9" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </MenuItem.Header>
                                        </MenuItem>
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='camera-viewfinder duotone-light'}"
                                                          Fill="{DynamicResource TextOnSuccessBrush}"/>
                                </Grid>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>

                    <Border VerticalAlignment="Bottom"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,10,8"
                            Panel.ZIndex="2"
                            Visibility="{Binding HasManualRunSessions, Converter={StaticResource BooleanToVisibilityConverter}}"
                            CornerRadius="8"
                            Padding="8,6"
                            Background="{DynamicResource CardColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            MaxHeight="240">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Phiên đang chạy"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       Margin="0,0,0,6"/>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          MaxHeight="180"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding ManualRunSessions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding LineText}"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1"
                                                        Content="Dừng"
                                                        Command="{Binding StopThisSessionCommand}"
                                                        Style="{StaticResource DangerButton}"
                                                        Padding="6,2"
                                                        Margin="6,0,0,0"
                                                        FontSize="10"
                                                        Cursor="Hand"
                                                        MinWidth="56"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Canvas area -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ScrollViewer x:Name="ScrollViewer"
                        Grid.Row="0"
                        HorizontalScrollBarVisibility="Hidden"
                        VerticalScrollBarVisibility="Hidden"
                        Background="{DynamicResource CanvasBackgroundBrush}"
                        PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
                    <Grid>
                        <!-- Grid background layer -->
                        <Canvas x:Name="GridCanvas"
                                Background="Transparent"
                                ClipToBounds="False">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="GridScaleTransform"/>
                                    <TranslateTransform x:Name="GridTranslateTransform"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                        </Canvas>
                        
                        <!-- Workflow content layer -->
                        <Canvas x:Name="WorkflowCanvas"
                                Background="Transparent"
                                MouseMove="WorkflowCanvas_MouseMove"
                                MouseUp="WorkflowCanvas_MouseUp"
                                MouseDown="WorkflowCanvas_MouseDown"
                                ClipToBounds="False">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ScaleTransform"/>
                                    <TranslateTransform x:Name="TranslateTransform"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                            <!-- Canvas sẽ được populate từ code-behind -->
                        </Canvas>
                    </Grid>
                </ScrollViewer>

                <Border Grid.Row="1"
                        Visibility="{Binding IsExecutionTracePanelVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="{DynamicResource CardColor}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1,1,0,0"
                        MaxHeight="320">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource HeaderBackgroundMainBrush}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="0,0,0,1"
                                Padding="10,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <controls:SvgViewboxEx Width="14"
                                                           Height="14"
                                                           Margin="0,0,6,0"
                                                           Fill="White"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='timeline-arrow duotone-light'}"/>
                                    <TextBlock Text="Execution Log"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="11"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1" Text="Status" Foreground="White" Opacity="0.8" VerticalAlignment="Center" Margin="12,0,6,0"/>
                                <ComboBox Grid.Column="2"
                                          Width="100"
                                          Height="24"
                                          ItemsSource="{Binding ExecutionTraceStatusOptions}"
                                          SelectedItem="{Binding ExecutionTraceStatusFilter, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="3" Text="Type" Foreground="White" Opacity="0.8" VerticalAlignment="Center" Margin="12,0,6,0"/>
                                <ComboBox Grid.Column="4"
                                          Width="130"
                                          Height="24"
                                          ItemsSource="{Binding ExecutionTraceNodeTypeOptions}"
                                          SelectedItem="{Binding ExecutionTraceNodeTypeFilter, Mode=TwoWay}"
                                          VerticalAlignment="Center"/>

                                <TextBox Grid.Column="5"
                                         Width="240"
                                         Height="24"
                                         Margin="12,0,8,0"
                                         VerticalAlignment="Center"
                                         Text="{Binding ExecutionTraceSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Tìm theo node name/id/key/output/error"/>

                                <Button Grid.Column="7"
                                        Margin="0,0,8,0"
                                        Padding="8,2"
                                        Command="{Binding ExportExecutionTraceLogsCommand}"
                                        Style="{DynamicResource TransparentButtonStyle}"
                                        ToolTip="Xuất log run ra JSON">
                                    <StackPanel Orientation="Horizontal">
                                        <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                               Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='file-export duotone-light'}"/>
                                        <TextBlock Margin="5,0,0,0" Foreground="White" VerticalAlignment="Center" Text="Tải log"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="8"
                                        Margin="8,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding ExpandAllExecutionTraceTreeCommand}"
                                        Style="{DynamicResource TransparentButtonStyle}"
                                        ToolTip="Mở tất cả nhánh">
                                    <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='rectangle-plus duotone-lightr'}"/>
                                </Button>
                                <Button Grid.Column="8"
                                        Margin="38,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding CollapseAllExecutionTraceTreeCommand}"
                                        Style="{DynamicResource TransparentButtonStyle}"
                                        ToolTip="Đóng tất cả nhánh">
                                    <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='rectangle-minus duotone-light'}"/>
                                </Button>
                                <Button Grid.Column="8"
                                        Margin="68,0,0,0"
                                        Padding="8,2"
                                        Command="{Binding ClearExecutionTraceLogsCommand}"
                                        Style="{DynamicResource TransparentButtonStyle}"
                                        ToolTip="Xóa log hiện tại">
                                    <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='trash-can duotone-regular'}"/>
                                </Button>
                                <Button Grid.Column="9"
                                        Padding="8,2"
                                        Command="{Binding ToggleExecutionTracePanelCommand}"
                                        Style="{DynamicResource TransparentButtonStyle}"
                                        ToolTip="Ẩn/hiện panel log">
                                    <controls:SvgViewboxEx Width="12" Height="12" Fill="White"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='chevron-down duotone-regular'}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                        <TreeView ItemsSource="{Binding ExecutionTraceRunRoots}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,2"/>
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunRoot}" Value="False">
                                                <Setter Property="Padding" Value="4,0,0,0"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.Resources>
                                    <BooleanToVisibilityConverter x:Key="LocalBoolToVis"/>
                                    <Style x:Key="TraceDetailsToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource QaToggleButton}">
                                        <Setter Property="Height" Value="20"/>
                                        <Setter Property="FontSize" Value="10"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                    </Style>
                                    <Style x:Key="TraceStatusBadgeStyle" TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource CardColor}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="10"/>
                                        <Setter Property="Padding" Value="7,1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="completed">
                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="running">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="failed">
                                                <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                <Setter Property="Opacity" Value="0.9"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    <DataTemplate DataType="{x:Type viewModels:ExecutionTraceConnectorGuideViewModel}">
                                        <Grid Width="10" Height="16">
                                            <Rectangle Width="1"
                                                       Height="16"
                                                       Fill="{DynamicResource BorderColor}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding ShowVertical, Converter={StaticResource LocalBoolToVis}}"/>
                                        </Grid>
                                    </DataTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type viewModels:ExecutionTraceTreeNodeViewModel}"
                                                              ItemsSource="{Binding Children}">
                                        <Border Margin="{Binding ItemMargin}"
                                                Padding="5"
                                                CornerRadius="6"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource BorderColor}"
                                                Background="{DynamicResource CardColor}"
                                                Visibility="{Binding IsVisible, Converter={StaticResource LocalBoolToVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                                        <Setter Property="Background" Value="{DynamicResource CardColor}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                                <Setter Property="Background" Value="{DynamicResource PrimaryGlowBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <Border Width="20"
                                                            Height="20"
                                                            CornerRadius="10"
                                                            Margin="0,0,4,0"
                                                            Cursor="Hand"
                                                            MouseLeftButtonUp="ExecutionLogNodeIcon_MouseLeftButtonUp"
                                                            ToolTip="Di chuyển tới node">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{Binding NodeBrush}"/>
                                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Setter Property="Opacity" Value="1"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding NodeBrush}" Value="{x:Null}">
                                                                        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Opacity" Value="0.88"/>
                                                                        <Setter Property="BorderThickness" Value="1"/>
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource TextOnPrimaryBrush}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <controls:SvgViewboxEx Width="11"
                                                                               Height="11"
                                                                               Fill="{DynamicResource TextOnPrimaryBrush}"
                                                                               Source="{Binding IconKey, Converter={StaticResource IconKeyToPathConverter}}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding NodeTitle}"
                                                               FontWeight="SemiBold"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding ElapsedText}"
                                                           Margin="8,0,8,0"
                                                               FontSize="10"
                                                           Opacity="0.8"
                                                           Foreground="{DynamicResource TextBrush}"
                                                               VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Style="{StaticResource TraceStatusBadgeStyle}">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                </Grid>
                                                <TextBlock Margin="32,3,0,0"
                                                           FontSize="9"
                                                           Opacity="0.6"
                                                           Foreground="{DynamicResource TextBrush}"
                                                           Text="{Binding ParentNodeId, StringFormat=from node: {0}}"/>
                                                <Grid Margin="32,2,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding InputSummary, StringFormat=IN: {0}}"
                                                                   Foreground="{DynamicResource TextBrush}"
                                                                   FontSize="9"
                                                                   MaxWidth="560"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding InputSummary}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding OutputSummary, StringFormat=OUT: {0}}"
                                                                   Margin="0,1,0,0"
                                                                   Foreground="{DynamicResource SuccessBrush}"
                                                                   FontSize="9"
                                                                   MaxWidth="560"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding OutputSummary}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding ErrorMessage, StringFormat=ERR: {0}}"
                                                                   Margin="0,1,0,0"
                                                                   Foreground="{DynamicResource DangerBrush}"
                                                                   FontSize="9"
                                                                   MaxWidth="560"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <ToggleButton x:Name="TraceDetailsToggle"
                                                                  Grid.Column="1"
                                                                  Margin="8,0,0,0"
                                                                  Padding="6,1"
                                                                  VerticalAlignment="Top"
                                                                  Style="{StaticResource TraceDetailsToggleStyle}"
                                                                  IsChecked="{Binding IsDetailsExpanded, Mode=TwoWay}"
                                                                  Visibility="{Binding ShowDetailsToggle, Converter={StaticResource LocalBoolToVis}}"
                                                                  Content="chi tiết"/>
                                                </Grid>
                                                <StackPanel Margin="32,2,0,0">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding ShowDetailsToggle}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsDetailsExpanded}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="{Binding InputSummary, StringFormat=IN full: {0}}"
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="9"
                                                               MaxWidth="560"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding InputSummary}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding OutputSummary, StringFormat=OUT full: {0}}"
                                                               Margin="0,1,0,0"
                                                               Foreground="{DynamicResource SuccessBrush}"
                                                               FontSize="9"
                                                               MaxWidth="560"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding OutputSummary}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding ErrorMessage, StringFormat=ERR full: {0}}"
                                                               Margin="0,1,0,0"
                                                               Foreground="{DynamicResource DangerBrush}"
                                                               FontSize="9"
                                                               MaxWidth="560"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Minimap và Fit to View button -->
                <Grid x:Name="MinimapPanel"
                      Grid.Row="0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Bottom"
                      Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Buttons Panel - có thể wrap -->
                    <WrapPanel Grid.Column="0"
