                            Click="CanvasSettingsPopupButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,10,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Mở cấu hình canvas nâng cao">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='sliders duotone-light'}"
                                      Width="18" Height="18" Fill="{DynamicResource SkyAzureBrush}"/>
                    </Button>

                        <!-- Grid Type Selector Button -->
                        <Button x:Name="GridTypeButton"
                            Visibility="Collapsed"
                            Height="25"
                            Width="25"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Kiểu lưới nền">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Không có lưới" Click="GridType_None_Click" Tag="None"/>
                                <MenuItem Header="Kẻ chấm (Dots)" Click="GridType_Dots_Click" Tag="Dots"/>
                                <MenuItem Header="Kẻ liền (Lines)" Click="GridType_Lines_Click" Tag="Lines"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='chart-tree-map duotone'}"
                                      Width="18" Height="18" Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- Connection Color Mode Button -->
                        <Button x:Name="ConnectionColorButton"
                            Visibility="Collapsed"
                            Click="ConnectionColorButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,10,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Chọn màu kết nối">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Màu theo node" Click="ConnectionColorMode_NodeColor_Click"/>
                                <MenuItem Header="Màu tùy chọn" Click="ConnectionColorMode_CustomColor_Click">
                                    <MenuItem.Items>
                                        <MenuItem Header="Lime Green" Click="CustomColor_Click" Tag="LimeGreen"/>
                                        <MenuItem Header="Primary Blue" Click="CustomColor_Click" Tag="PrimaryBrush"/>
                                        <MenuItem Header="Success Green" Click="CustomColor_Click" Tag="SuccessBrush"/>
                                        <MenuItem Header="Danger Red" Click="CustomColor_Click" Tag="DangerBrush"/>
                                        <MenuItem Header="Warning Orange" Click="CustomColor_Click" Tag="WarningBrush"/>
                                        <MenuItem Header="Info Cyan" Click="CustomColor_Click" Tag="InfoBrush"/>
                                        <MenuItem Header="Indigo" Click="CustomColor_Click" Tag="IndigoBrush"/>
                                        <MenuItem Header="Coral" Click="CustomColor_Click" Tag="CoralBrush"/>
                                        <MenuItem Header="Ocean" Click="CustomColor_Click" Tag="OceanBrush"/>
                                        <MenuItem Header="Lavender" Click="CustomColor_Click" Tag="LavenderBrush"/>
                                    </MenuItem.Items>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='palette chisel-regular'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- Canvas Display Mode Button -->
                        <Button x:Name="CanvasDisplayModeButton"
                            Visibility="Collapsed"
                            Click="CanvasDisplayModeButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,10,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Chế độ hiển thị node trên canvas">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="CanvasDisplayModeContextMenu">
                                <MenuItem Header="Hiển thị toàn bộ"
                                          x:Name="CanvasDisplayAllMenuItem"
                                          Click="CanvasDisplayMode_All_Click"/>
                                <MenuItem Header="Hiển thị theo màn"
                                          x:Name="CanvasDisplayViewportMenuItem"
                                          Click="CanvasDisplayMode_Viewport_Click"/>
                                <Separator/>
                                <MenuItem StaysOpenOnClick="True">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Hiệu năng:"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <ComboBox x:Name="CanvasPerformanceProfileComboBox"
                                                      Width="150"
                                                      Height="25"
                                                      Loaded="CanvasPerformanceProfileComboBox_Loaded"
                                                      SelectionChanged="CanvasPerformanceProfileComboBox_SelectionChanged"
                                                      ToolTip="Chọn mức tối ưu culling theo cấu hình máy">
                                                <ComboBoxItem Content="Máy yếu" Tag="Low"/>
                                                <ComboBoxItem Content="Máy bình thường" Tag="Normal"/>
                                                <ComboBoxItem Content="Máy mạnh" Tag="High"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem IsEnabled="False">
                                    <MenuItem.Header>
                                        <TextBlock x:Name="CanvasViewportStatsText"
                                                   Text="Visible: 0 / 0"
                                                   Opacity="0.85"/>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                             Converter={StaticResource IconKeyToPathConverter}, 
                                             ConverterParameter='display-medical sharp-duotone-light'}"
                                          Width="18"
                                          Height="18"
                                          Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- GPU Settings Button -->
                        <Button x:Name="GpuSettingsButton"
                            Visibility="Collapsed"
                            Height="25"
                            Width="25"
                            Margin="0, 0,10,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Cấu hình GPU Rendering">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu x:Name="GpuSettingsContextMenu">
                                <MenuItem Header="Cấu hình GPU Rendering" IsEnabled="False" FontWeight="Bold"/>
                                <Separator/>
                                <MenuItem StaysOpenOnClick="True" IsHitTestVisible="False">
                                    <MenuItem.Header>
                                        <StackPanel Margin="4,2,4,2">
                                            <TextBlock x:Name="GpuStatusLineText"
                                                       Text="GPU: Đang kiểm tra..."
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="GpuStatusRenderModeText"
                                                       Text="WPF Render: Unknown"
                                                       FontWeight="SemiBold"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock x:Name="GpuStatusTierText"
                                                       Text="Render Tier: ?"
                                                       Opacity="0.85"
                                                       Margin="0,2,0,0"/>
                                            <TextBlock x:Name="GpuStatusNameText"
                                                       Text="Device: Unknown"
                                                       TextWrapping="Wrap"
                                                       MaxWidth="320"
                                                       Opacity="0.85"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Header="Copy GPU diagnostics"
                                          Click="CopyGpuDiagnostics_Click"/>
                                <Separator/>
                                <MenuItem>
                                    <MenuItem.Header>
                                        <CheckBox x:Name="GpuEnabledCheckBox"
                                                  Content="Bật GPU Rendering"
                                                  Checked="GpuEnabledCheckBox_Checked"
                                                  Unchecked="GpuEnabledCheckBox_Unchecked"/>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="GpuQualityMenuItem">
                                    <MenuItem.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Chất lượng hiển thị:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <ComboBox x:Name="GpuQualityComboBox"
                                                      Width="200"
                                                      SelectionChanged="GpuQualityComboBox_SelectionChanged">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                             Converter={StaticResource IconKeyToPathConverter}, 
                                             ConverterParameter='microchip sharp-duotone-light'}"
                                          Width="18"
                                          Height="18"
                                          Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- Bulk Title Color Button - Thay đổi màu tiêu đề cho tất cả nodes -->
                        <Button x:Name="BulkTitleColorButton"
                            Visibility="Collapsed"
                            Click="BulkTitleColorButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,10,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Đổi màu tiêu đề tất cả nodes">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Màu theo node" Click="BulkTitleColor_NodeColor_Click"/>
                                <MenuItem Header="Lime Green" Click="BulkTitleColor_Click" Tag="LimeGreen"/>
                                <MenuItem Header="Primary Blue" Click="BulkTitleColor_Click" Tag="PrimaryBrush"/>
                                <MenuItem Header="Success Green" Click="BulkTitleColor_Click" Tag="SuccessBrush"/>
                                <MenuItem Header="Danger Red" Click="BulkTitleColor_Click" Tag="DangerBrush"/>
                                <MenuItem Header="Warning Orange" Click="BulkTitleColor_Click" Tag="WarningBrush"/>
                                <MenuItem Header="Info Cyan" Click="BulkTitleColor_Click" Tag="InfoBrush"/>
                                <MenuItem Header="Indigo" Click="BulkTitleColor_Click" Tag="IndigoBrush"/>
                                <MenuItem Header="Coral" Click="BulkTitleColor_Click" Tag="CoralBrush"/>
                                <MenuItem Header="Ocean" Click="BulkTitleColor_Click" Tag="OceanBrush"/>
                                <MenuItem Header="Lavender" Click="BulkTitleColor_Click" Tag="LavenderBrush"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='paintbrush duotone-regular'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- Execution Energy Color Button -->
                        <Button x:Name="EnergyColorButton"
                            Visibility="Collapsed"
                            Click="EnergyColorButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Chọn màu năng lượng (line đang chạy)">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Năng lượng theo màu line" Click="EnergyColorMode_FollowLineColor_Click"/>
                                <MenuItem Header="Năng lượng tùy chọn" Click="EnergyColorMode_CustomColor_Click">
                                    <MenuItem.Items>
                                        <MenuItem Header="Gold" Click="CustomEnergyColor_Click" Tag="Gold"/>
                                        <MenuItem Header="Lime Green" Click="CustomEnergyColor_Click" Tag="LimeGreen"/>
                                        <MenuItem Header="Primary Blue" Click="CustomEnergyColor_Click" Tag="PrimaryBrush"/>
                                        <MenuItem Header="Success Green" Click="CustomEnergyColor_Click" Tag="SuccessBrush"/>
                                        <MenuItem Header="Danger Red" Click="CustomEnergyColor_Click" Tag="DangerBrush"/>
                                        <MenuItem Header="Warning Orange" Click="CustomEnergyColor_Click" Tag="WarningBrush"/>
                                        <MenuItem Header="Info Cyan" Click="CustomEnergyColor_Click" Tag="InfoBrush"/>
                                        <MenuItem Header="Indigo" Click="CustomEnergyColor_Click" Tag="IndigoBrush"/>
                                        <MenuItem Header="Coral" Click="CustomEnergyColor_Click" Tag="CoralBrush"/>
                                        <MenuItem Header="Ocean" Click="CustomEnergyColor_Click" Tag="OceanBrush"/>
                                        <MenuItem Header="Lavender" Click="CustomEnergyColor_Click" Tag="LavenderBrush"/>
                                    </MenuItem.Items>
                                </MenuItem>

                                <Separator/>

                                <MenuItem StaysOpenOnClick="True">
                                    <MenuItem.Header>
                                        <StackPanel Margin="6,4,6,4">
                                            <TextBlock Text="Cài đặt hiệu ứng (chấm/text)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                            <TextBlock Text="Gap (khoảng cách chấm)" Opacity="0.85" Margin="0,0,0,2"/>
                                            <TextBox x:Name="EnergyDotGapTextBox"
                                                     Width="140"
                                                     Text="5"
                                                     Loaded="EnergyDotGapTextBox_Loaded"
                                                     TextChanged="EnergyDotGapTextBox_TextChanged"/>

                                            <TextBlock Text="Thickness (+ thêm so với line)" Opacity="0.85" Margin="0,8,0,2"/>
                                            <TextBox x:Name="EnergyDotThicknessTextBox"
                                                     Width="140"
                                                     Text="2"
                                                     Loaded="EnergyDotThicknessTextBox_Loaded"
                                                     TextChanged="EnergyDotThicknessTextBox_TextChanged"/>

                                            <TextBlock Text="Text thay cho chấm (để trống = chỉ chấm)" Opacity="0.85" Margin="0,8,0,2" Visibility="Collapsed" />
                                            <TextBox x:Name="EnergyDotTextTextBox" Visibility="Collapsed" 
                                                     Width="180"
                                                     Text=""
                                                     Loaded="EnergyDotTextTextBox_Loaded"
                                                     TextChanged="EnergyDotTextTextBox_TextChanged"/>

                                            <CheckBox x:Name="EnergyDotRotateCheckBox" Visibility="Collapsed" 
                                                      Content="Text xoay 360° liên tục"
                                                      IsChecked="True"
                                                      Margin="0,8,0,0"
                                                      Loaded="EnergyDotRotateCheckBox_Loaded"
                                                      Checked="EnergyDotRotateCheckBox_Changed"
                                                      Unchecked="EnergyDotRotateCheckBox_Changed"/>

                                            <TextBlock Text="Tốc độ chạy (x) — lớn hơn = nhanh hơn" Opacity="0.85" Margin="0,8,0,2"/>
                                            <TextBox x:Name="EnergyRunSpeedTextBox"
                                                     Width="140"
                                                     Text="2"
                                                     Loaded="EnergyRunSpeedTextBox_Loaded"
                                                     TextChanged="EnergyRunSpeedTextBox_TextChanged"/>

                                            <CheckBox x:Name="EnergyMeteorModeCheckBox"
                                                      Content="Hiệu ứng thiên thạch (nét đứt + đầu sáng)"
                                                      Margin="0,8,0,0"
                                                      Loaded="EnergyMeteorModeCheckBox_Loaded"
                                                      Checked="EnergyMeteorModeCheckBox_Changed"
                                                      Unchecked="EnergyMeteorModeCheckBox_Changed"/>

                                            <TextBlock Text="Tốc độ xoay (giây/vòng 360°)" Opacity="0.85" Margin="0,8,0,2" Visibility="Collapsed" />
                                            <TextBox x:Name="EnergySpinSpeedTextBox" Visibility="Collapsed" 
                                                     Width="140"
                                                     Text="0.7"
                                                     Loaded="EnergySpinSpeedTextBox_Loaded"
                                                     TextChanged="EnergySpinSpeedTextBox_TextChanged"/>
                                        </StackPanel>
                                    </MenuItem.Header>
                                </MenuItem>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='plug-circle-bolt sharp-duotone-regular'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>
                    
                        <!-- Connection Line Style Button -->
                        <Button x:Name="ConnectionLineStyleButton"
                            Visibility="Collapsed"
                            Click="ConnectionLineStyleButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Chọn kiểu đường kết nối">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Bezier (Cong mượt)" Click="LineStyle_Bezier_Click"/>
                                <MenuItem Header="Vuông góc (Orthogonal)" Click="LineStyle_Orthogonal_Click"/>
                                <!-- <MenuItem Header="Vuông góc thông minh (Orthogonal V2)" Click="LineStyle_OrthogonalV2_Click"/> -->
                                <MenuItem Header="Thẳng (Straight)" Click="LineStyle_Straight_Click"/>
                                <Separator/>
                                <MenuItem Header="Vuông góc bo tròn (Smooth-Orthogonal)" Click="LineStyle_SmoothOrthogonal_Click"/>
                                <!-- <MenuItem Header="Cung tròn (Arc)" Click="LineStyle_Arc_Click"/> -->
                                <!-- <MenuItem Header="Tỏa quạt (Radial / Fan-out)" Click="LineStyle_RadialFanout_Click"/> -->
                                <!-- <MenuItem Header="Gió thổi (Windy)" Click="LineStyle_Windy_Click"/> -->
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='timeline-arrow duotone-light'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- Animation Mode Button -->
                        <Button x:Name="AnimationToggleButton"
                            Visibility="Collapsed"
                            Click="AnimationToggleButton_Click"
                            Height="25"
                            Width="25"
                            Cursor="Hand"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Chế độ hiển thị animation line">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <Button.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="AnimationModeAnimatedMenuItem"
                                          Header="Bật Animation"
                                          IsCheckable="True"
                                          Click="AnimationMode_Animated_Click"/>
                                <MenuItem x:Name="AnimationModeOffMenuItem"
                                          Header="Tắt Animation"
                                          IsCheckable="True"
                                          Click="AnimationMode_Off_Click"/>
                                <MenuItem x:Name="AnimationModeDashedMenuItem"
                                          Header="Hiển thị nét đứt"
                                          IsCheckable="True"
                                          Click="AnimationMode_Dashed_Click"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                      Converter={StaticResource IconKeyToPathConverter}, 
                      ConverterParameter='anchor-lock duotone-regular'}"
                   Width="18" Height="18" 
                   Fill="{DynamicResource SecondaryBrush}"/>
                    </Button>

                        <!-- Clear All Nodes Button -->
                        <Button x:Name="ClearAllNodesButton"
                            Click="ClearAllNodesButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Xóa tất cả node (giữ lại Start và End)">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='trash-can-list sharp-regular'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource RubyRedBrush}"/>
                    </Button>
                    
                        <!-- Auto Layout Button -->
                        <Button x:Name="AutoLayoutButton" Visibility="Collapsed"
                            Click="AutoLayoutButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Tự động sắp xếp nodes">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='sitemap sharp-thin'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource PrimaryBrush}"/>
                    </Button>
                    
                        <!-- Fit to View Button -->
                        <Button x:Name="FitToViewButton"
                            Click="FitToViewButton_Click"
                            Height="25"
                            Width="25"
                            Margin="0, 0,15,0"
                            VerticalAlignment="Bottom"
                            Style="{DynamicResource TransparentButtonStyle}"
                            ToolTip="Zoom và pan để hiển thị tất cả nodes trong khung hình">
                        <Button.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Button.Effect>
                        <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                         Converter={StaticResource IconKeyToPathConverter}, 
                                         ConverterParameter='expand utility-fill-semibold'}"
                      Width="20"
                      Height="20"
                      Margin="0,0,0,0"
                      Fill="{DynamicResource ChocolateBrownBrush}"/>
                        </Button>
                    </WrapPanel>
                    
                    <!-- Minimap -->
                    <Border Grid.Column="1"
                            x:Name="MinimapBorder"
                            MinWidth="150"
                            MaxWidth="250"
                            Width="200"
                            MinHeight="100"
                            MaxHeight="200"
                            Height="150"
                            Background="{DynamicResource CardColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            Padding="4"
                            BorderThickness="1"
                            CornerRadius="5"
                            Opacity="0.9"
                            Margin="15,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="3" Opacity="0.5"/>
                        </Border.Effect>
                        <Canvas x:Name="MinimapCanvas"
                                Background="Transparent"
                                MouseDown="MinimapCanvas_MouseDown"/>
                    </Border>
                </Grid>

                <!-- Floating panel: hiển thị các node đang chạy -->
                <!-- Canvas overlay chỉ bắt hit-test tại vùng con (panel), không che canvas bên dưới -->
                <Canvas x:Name="ExecutionOverlayCanvas"
                        Grid.Row="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">
                    <Border x:Name="ExecutionFloatingPanel"
                            Canvas.Left="0"
                            Canvas.Top="0"
                            Width="260"
                            MinHeight="80"
                            MaxHeight="360"
                            Background="{DynamicResource CardColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="8"
                            Opacity="0.96"
                            IsHitTestVisible="True"
                            MouseLeftButtonDown="ExecutionFloatingPanel_MouseLeftButtonDown"
                            MouseMove="ExecutionFloatingPanel_MouseMove"
                            MouseLeftButtonUp="ExecutionFloatingPanel_MouseLeftButtonUp"
                            Loaded="ExecutionFloatingPanel_Loaded"
                            Visibility="{Binding HasRunningNodes, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <controls:SvgViewboxEx Width="14"
                                                       Height="14"
                                                       Margin="0,0,6,0"
                                                       Fill="{DynamicResource SecondaryBrush}"
                                                       Opacity="0.9"
                                                       Source="{Binding Source={x:Static sys:String.Empty},
                                                                        Converter={StaticResource IconKeyToPathConverter},
                                                                        ConverterParameter='bolt-lightning sharp-duotone-regular'}"/>
                                <TextBlock Text="Node đang chạy"
                                           FontWeight="Bold"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextBrush}"/>
                            </StackPanel>

                            <Separator Margin="0,6,0,6" Opacity="0.5"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="280">
                                <ItemsControl ItemsSource="{Binding RunningNodes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:WorkflowNode}">
                                            <Border Margin="0,2,0,2"
                                                    Padding="6"
                                                    CornerRadius="6"
                                                    Background="{Binding NodeBrush}"
                                                    Opacity="0.92"
                                                    Cursor="Hand"
                                                    ToolTip="Click để di chuyển đến node này"
                                                    MouseLeftButtonUp="RunningNodeItem_MouseLeftButtonUp">
                                                <StackPanel Orientation="Vertical">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="210"/>
                                                    <TextBlock Text="{Binding Id}"
                                                               FontSize="9"
                                                               Foreground="{DynamicResource TextOnPrimaryBrush}"
                                                               Opacity="0.8"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="210"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Canvas>
            </Grid>

            <!-- Nút mở lại palette khi đã thu gọn: bám cạnh trái, giữa chiều cao vùng editor -->
            <Button x:Name="NodePaletteExpandButton"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="-6,0,0,0"
                    MinWidth="40"
                    Panel.ZIndex="120"
                    Visibility="Collapsed"
                    Click="NodePaletteExpandButton_Click"
                    Cursor="Hand"
                    ToolTip="Mở bảng node"
                    Style="{DynamicResource TransparentButtonStyle}"
                    Padding="6,0,0,0"
                    BorderThickness="0"
                    Background="Transparent">
                <Button.RenderTransform>
                    <TranslateTransform x:Name="NodePaletteExpandButtonSlide"/>
                </Button.RenderTransform>
                <Border CornerRadius="0,14,14,0"
                        Padding="11,26"
                        Background="{DynamicResource CardColor}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1,1,1,1"
                        SnapsToDevicePixels="True">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.35" Direction="270"/>
                    </Border.Effect>
                    <controls:SvgViewboxEx x:Name="NodePaletteExpandIcon"
                                           Width="16" Height="16"
                                           Fill="{DynamicResource SecondaryBrush}"
                                           Opacity="0.95"
                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='angles-right duotone'}"/>
                </Border>
            </Button>
        </Grid>
    </Grid>
</Window>

