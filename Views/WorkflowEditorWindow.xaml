<Window x:Class="FlowMy.Views.WorkflowEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowMy.Views"
        xmlns:controls="clr-namespace:FlowMy.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:conv="clr-namespace:FlowMy.Converters"
        xmlns:models="clr-namespace:FlowMy.Models"
        xmlns:viewModels="clr-namespace:FlowMy.ViewModels"
        mc:Ignorable="d"
        Title="Workflow Editor"
        Height="700"
        Width="1000"
        MinHeight="500"
        MinWidth="800"
        WindowState="Maximized"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <conv:IconKeyToPathConverter x:Key="IconKeyToPathConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <conv:BooleanToBrushConverter x:Key="BooleanToBrushConverter"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                x:Name="TopToolbarBorder"
                Background="{DynamicResource HeaderBackgroundMainBrush}"
                Padding="16,8"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1"
                MinHeight="50">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="200"/> <!-- Workflow Management -->
                    <ColumnDefinition Width="*" MinWidth="100"/>    <!-- Center area -->
                    <ColumnDefinition Width="Auto" MinWidth="150"/> <!-- Test Execution -->
                    <ColumnDefinition Width="*" MinWidth="50"/>    <!-- Spacer -->
                    <ColumnDefinition Width="Auto" MinWidth="250"/> <!-- Persistence -->
                </Grid.ColumnDefinitions>

                <!-- Left Section: Workflow Management -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" x:Name="WorkflowManagementPanel">
                    <Button x:Name="ResetButton" Visibility="Collapsed"
                            Command="{Binding ResetWorkflowCommand}"
                            ToolTip="Reset về trạng thái ban đầu"
                            Style="{DynamicResource TransparentButtonStyle}"
                            Margin="0,0,12,0"
                            Padding="8,5"
                            MinWidth="60">
                        <StackPanel Orientation="Horizontal">
                            <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                              Converter={StaticResource IconKeyToPathConverter}, 
                                              ConverterParameter='sync-alt'}"
                                           Width="16" Height="16" Fill="White" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ResetText" Text="Reset" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Rectangle x:Name="ResetSeparator" Width="1" Height="24" Fill="White" Opacity="0.2" Margin="0,0,16,0" VerticalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="WorkflowLabel" Text="Workflow:" VerticalAlignment="Center" Margin="0,0,10,0" 
                                   Foreground="White" Opacity="0.6" FontSize="11" FontWeight="SemiBold"/>
                        <ComboBox x:Name="WorkflowSelector"
                                  ItemsSource="{Binding SavedWorkflows}"
                                  SelectedItem="{Binding CurrentWorkflowName}"
                                  Style="{DynamicResource BaseComboBox}"
                                  MinWidth="150"
                                  MaxWidth="300"
                                  Width="220"
                                  Height="32"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"/>
                        <Button x:Name="NewWorkflowButton"
                                Click="NewWorkflowButton_Click"
                                Style="{DynamicResource TransparentButtonStyle}"
                                Padding="6,4"
                                ToolTip="Tạo workflow mới"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                Margin="10,0,10,0"
                                MinWidth="32">
                            <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                             Converter={StaticResource IconKeyToPathConverter}, 
                                             ConverterParameter='clone-plus duotone'}"
                                          Width="20" Height="20" Fill="White" Opacity="0.8"/>
                        </Button>
                        <Button x:Name="ManageWorkflowsButton"
                                Click="ManageWorkflowsButton_Click"
                                Style="{DynamicResource TransparentButtonStyle}"
                                Padding="6,4"
                                ToolTip="Quản lý workflows"
                                Cursor="Hand"
                                VerticalAlignment="Center"
                                MinWidth="32">
                            <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                             Converter={StaticResource IconKeyToPathConverter}, 
                                             ConverterParameter='gear chisel-regular'}"
                                          Width="16" Height="16" Fill="White" Opacity="0.8"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- Middle Section: Execution -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" x:Name="ExecutionPanel" VerticalAlignment="Center">
                        <Button x:Name="StartExecutionButton"
                                Command="{Binding StartTestCommand}"
                                ToolTip="Mỗi lần bấm mở một phiên chạy mới (song song). Danh sách phiên ở góc dưới menu trái."
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="80"
                                MaxWidth="150"
                                Width="100"
                                Cursor="Hand"
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                                 Converter={StaticResource IconKeyToPathConverter}, 
                                                 ConverterParameter='play duotone-regular'}"
                                              Width="14" Height="14"  Fill="White" Margin="0,0,10,0"/>
                                <TextBlock x:Name="StartTestText" Text="Bắt đầu" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="StopExecutionButton"
                                Command="{Binding EndTestCommand}"
                                ToolTip="Hủy tất cả phiên chạy thủ công đang mở"
                                Visibility="{Binding IsExecuting, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Style="{StaticResource DangerButton}"
                                MinWidth="80"
                                MaxWidth="150"
                                Width="100"
                                Margin="8,0,0,0"
                                Cursor="Hand"
                                Background="#EF4444"
                                Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                                 Converter={StaticResource IconKeyToPathConverter}, 
                                                 ConverterParameter='circle-stop duotone'}"
                                              Width="18" Height="18" Fill="White" Margin="0,0,10,0"/>
                                <TextBlock x:Name="StopTestText" Text="Kết thúc" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <CheckBox Margin="12,0,0,0"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding EnableExecutionTraceLog, Mode=TwoWay}"
                                  ToolTip="Bật log runtime theo node (tắt để giảm tải)"
                                  Foreground="White"
                                  FontWeight="SemiBold"
                                  Content="Hiện log chạy"/>
                </StackPanel>

                <!-- Right Section: Persistence -->
                <StackPanel Orientation="Horizontal" Grid.Column="4" x:Name="PersistencePanel">
                    <Button x:Name="SaveButton"
                            Command="{Binding SaveWorkflowCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,12,0"
                            MinWidth="80"
                            MaxWidth="120"
                            Width="100"
                            ToolTip="Lưu workflow hiện tại"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <controls:SvgViewboxEx Source="{Binding Source={x:Static sys:String.Empty}, 
                                             Converter={StaticResource IconKeyToPathConverter}, 
                                             ConverterParameter='floppy-disk-circle-arrow-right light'}"
                                          Width="20" Height="20" Fill="White" Margin="0,0,8,0"/>
                            <TextBlock x:Name="SaveText" Text="Save" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>

                    <!-- Import Button — icon only, xanh lá -->
                    <Button x:Name="ImportButton"
                            Click="ImportWorkflow_Click"
                             Style="{StaticResource SecondaryButton}"
                             Width="40" 
                            Padding="8,4"
                            Margin = "6,0"
                            Cursor="Hand"
                            ToolTip="📥 Import — chọn .json hoặc 1 file nén .webpkg.zip/.zip (bên trong có workflow.json + web bundle). Với JSON legacy: tự giải nén .webpkg.zip nếu có PortableWebBundleFileName, hoặc _webcache cạnh file.">
                        <controls:SvgViewboxEx Width="16" Height="16" Fill="White"
                            Source="{Binding Source={x:Static sys:String.Empty},
                                     Converter={StaticResource IconKeyToPathConverter},
                                     ConverterParameter='file-import regular'}"/>
                    </Button>

                    <!-- Export Button — icon only, xanh dương -->
                    <Button x:Name="ExportButton"
                            Click="ExportWorkflow_Click"
                            Margin = "6,0"
                             Style="{StaticResource SecondaryButton}"
 Width="40" 
Padding="8,4"
Cursor="Hand"
                            ToolTip="📤 Export JSON — chỉ logic workflow, không cookie/WebView2">
                        <controls:SvgViewboxEx Width="16" Height="16" Fill="White"
    Source="{Binding Source={x:Static sys:String.Empty},
             Converter={StaticResource IconKeyToPathConverter},
             ConverterParameter='file-brackets-curly duotone-light'}"/>
                    </Button>

                    <!-- Export Compressed Button — icon only -->
                    <Button x:Name="ExportCompressedButton"
                            Click="ExportCompressedWorkflow_Click"
                            Margin = "6,0"
                            Style="{StaticResource SecondaryButton}"
                            Width="40"
                            Padding="8,4"
                            Cursor="Hand"
                            ToolTip="🗜 Export JSON nén (.flowz) — nhẹ hơn, dùng để gửi/dán sang canvas khác">
                        <controls:SvgViewboxEx Width="16" Height="16" Fill="White"
                            Source="{Binding Source={x:Static sys:String.Empty},
                                     Converter={StaticResource IconKeyToPathConverter},
                                     ConverterParameter='file-zip duotone-light'}"/>
                    </Button>

                    <!-- ExportWebBundle Button — icon only, vàng amber -->
                    <Button x:Name="ExportWebBundleButton"
                            Click="ExportWorkflowWithWebBundle_Click"
                            Margin = "6,0"
                                                         Style="{StaticResource SecondaryButton}"
 Width="40" 
Padding="8,4"
Cursor="Hand"
                            ToolTip="🌐 Export+Web Bundle — 1 file nén .webpkg.zip (chứa workflow.json + cookies + offline HTML). Không copy WebView2 profile (~500MB).">
                        <controls:SvgViewboxEx Width="16" Height="16" Fill="White"
     Source="{Binding Source={x:Static sys:String.Empty},
              Converter={StaticResource IconKeyToPathConverter},
              ConverterParameter='file-code duotone-light'}"/>
                    </Button>






                    <Rectangle Width="1" Height="24" Fill="White" Opacity="0.2" Margin="12,0,12,0" VerticalAlignment="Center"/>

                    <!-- Theme Selector ComboBox -->
                    <ComboBox x:Name="ThemeSelector"
                              SelectionChanged="ThemeSelector_SelectionChanged"
                              Style="{DynamicResource BaseComboBox}"
                              Width="100"
                              Height="28"
                              VerticalAlignment="Center"
                              Margin="0,0,4,0"
                              ToolTip="Chọn giao diện (Light / Dark / SoftLight / SoftDark / Dracula / Monokai / Night / Modern)">
                        <ComboBoxItem Tag="Light">☀️ Light</ComboBoxItem>
                        <ComboBoxItem Tag="Dark">🌙 Dark</ComboBoxItem>
                        <ComboBoxItem Tag="SoftLight">🌿 Soft Light</ComboBoxItem>
                        <ComboBoxItem Tag="SoftDark">🌑 Soft Dark</ComboBoxItem>
                        <ComboBoxItem Tag="Dracula">🧛 Dracula</ComboBoxItem>
                        <ComboBoxItem Tag="Monokai">🎨 Monokai</ComboBoxItem>
                        <ComboBoxItem Tag="Night">🌌 Night</ComboBoxItem>
                        <ComboBoxItem Tag="Modern">✨ Modern</ComboBoxItem>
                    </ComboBox>
                    <!-- Quick toggle icon -->
                    <!-- <Button x:Name="ThemeToggleButton"
                            Click="ThemeToggleButton_Click"
                            Style="{DynamicResource TransparentButtonStyle}"
                            Foreground="White"
                            Padding="6,5"
                            MinWidth="30"
                            ToolTip="Toggle Dark / Light">
                        <controls:SvgViewboxEx x:Name="ThemeToggleIcon"
                                          Width="16" Height="16" Fill="White" Opacity="0.9"
                                          Source="/Assets/Icons/circle2.svg"/>
                    </Button> -->
                </StackPanel>
            </Grid>
        </Border>

        <!-- Canvas cho workflow với zoom và pan -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftMenuColumn" Width="200" MinWidth="150" MaxWidth="400"/>
                <ColumnDefinition x:Name="LeftSplitterColumn" Width="5" MinWidth="5" MaxWidth="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- GridSplitter để resize menu trái -->
            <GridSplitter x:Name="LeftPaletteGridSplitter"
                         Grid.Column="1"
                         HorizontalAlignment="Stretch"
                         VerticalAlignment="Stretch"
                         Background="{DynamicResource BorderColor}"
                         Width="2"
                         ResizeDirection="Columns"
                         ShowsPreview="True"
                         Cursor="SizeWE"/>

            <!-- Menu bên trái chứa các node templates -->
            <Border Grid.Column="0"
                    x:Name="LeftMenuBorder"
                    Background="{DynamicResource WindowBodyBackground}"
                    BorderBrush="{DynamicResource ControlBorderBrush}"
                    BorderThickness="0,0,0,0"
                    Padding="10,8, 0, 8"
                    SnapsToDevicePixels="True"
                    MinWidth="150">
                <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2,0,2,8" x:Name="NodeTemplatesPanel">
                        <StackPanel.Resources>
                            <!-- Icon-only palette item (drag from templates) -->
                            <Style x:Key="PaletteIconNodeStyle" TargetType="Border">
                                <Setter Property="Width" Value="48"/>
                                <Setter Property="MinWidth" Value="40"/>
                                <Setter Property="MaxWidth" Value="60"/>
                                <Setter Property="Height" Value="48"/>
                                <Setter Property="MinHeight" Value="40"/>
                                <Setter Property="MaxHeight" Value="60"/>
                                <Setter Property="CornerRadius" Value="8"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="BorderBrush" Value="White"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                <Setter Property="VerticalAlignment" Value="Top"/>
                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter Property="ToolTipService.InitialShowDelay" Value="250"/>
                                <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
                                <!-- RenderTransform mặc định QUAN TRỌNG -->
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                    </Setter.Value>
                                </Setter>
                                <!-- Effect mặc định QUAN TRỌNG -->
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/>
                                    </Setter.Value>
                                </Setter>
                                <EventSetter Event="MouseDown" Handler="NodeTemplate_MouseDown"/>
                                <EventSetter Event="MouseMove" Handler="NodeTemplate_MouseMove"/>
                                <EventSetter Event="MouseUp" Handler="NodeTemplate_MouseUp"/>
                                <EventSetter Event="MouseEnter" Handler="NodeTemplate_MouseEnter"/>
                                <EventSetter Event="MouseLeave" Handler="NodeTemplate_MouseLeave"/>
                                <Style.Triggers>
                                    <!-- Hover effect: giữ viền trắng và shadow khi hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="White"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.05" ScaleY="1.05"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" BlurRadius="10" Opacity="0.35"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                    <!-- Trigger khi KHÔNG hover - đảm bảo quay về trạng thái ban đầu -->
                                    <Trigger Property="IsMouseOver" Value="False">
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.25"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="BorderBrush" Value="White"/>
                                        <Setter Property="BorderThickness" Value="1.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>

                            <Style x:Key="PaletteGroupHeaderStyle" TargetType="TextBlock">
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                <Setter Property="Margin" Value="0,10,0,6"/>
                                <Setter Property="Opacity" Value="0.85"/>
                            </Style>

                            <Style x:Key="PaletteSvgIconStyle" TargetType="controls:SvgViewboxEx">
                                <Setter Property="Width" Value="20"/>
                                <Setter Property="Height" Value="20"/>
                                <Setter Property="Opacity" Value="0.95"/>
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>

                        </StackPanel.Resources>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="Node Templates"
                                       FontWeight="Bold"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextBrush}"/>
                            <Button x:Name="NodePaletteCollapseButton"
                                    Grid.Column="1"
                                    Click="NodePaletteCollapseButton_Click"
                                    Style="{DynamicResource TransparentButtonStyle}"
                                    Padding="6,4"
                                    MinWidth="32"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Margin="4,0,0,0"
                                    ToolTip="Thu gọn bảng node (kéo ra sau)">
                                <Border x:Name="NodePaletteCollapseButtonFace"
                                        CornerRadius="10"
                                        Padding="6,4"
                                        Background="{DynamicResource CardColor}"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1">
                                    <controls:SvgViewboxEx Width="14" Height="14"
                                                           Fill="{DynamicResource SecondaryBrush}"
                                                           Opacity="0.95"
                                                           Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='angles-left duotone'}"/>
                                </Border>
                            </Button>
                        </Grid>
                        
                        <!-- Search Box -->
                        <Border Background="{DynamicResource CardColor}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6,4"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NodeSearchBox"
                                         TextChanged="NodeSearchBox_TextChanged"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="4,2"
                                         FontSize="11"
                                         Foreground="{DynamicResource TextBrush}"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="{DynamicResource TextBrush}"
                                         ToolTip="Tìm kiếm node...">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="TextBox">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="4">
                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                          Margin="{TemplateBinding Padding}"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                                <controls:SvgViewboxEx Grid.Column="1"
                                                      Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='box-arrow-down-magnifying-glass solid'}"
                                                      Width="14"
                                                      Height="14"
                                                     Fill="White"
                                                      Opacity="0.6"
                                                      VerticalAlignment="Center"
                                                      Margin="4,0,0,0"
                                                      IsHitTestVisible="False"/>
                            </Grid>
                        </Border>
                        
                        <!-- Start Node --><!--
                        <Border x:Name="StartNodeTemplate"
                                Background="{DynamicResource SkyAzureBrush}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="8"
                                Margin="0,0,0,8"
                                Cursor="Hand"
                                MouseDown="NodeTemplate_MouseDown"
                                MouseMove="NodeTemplate_MouseMove"
                                MouseUp="NodeTemplate_MouseUp"
                                Tag="Start"
                                MouseEnter="NodeTemplate_MouseEnter"
                                MouseLeave="NodeTemplate_MouseLeave">
                            <StackPanel>
                                <TextBlock Text="Start"
                                           Foreground="{DynamicResource TextOnSkyAzureBrush}"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Bắt đầu"
                                           Foreground="{DynamicResource TextOnSkyAzureBrush}"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Opacity="0.9"/>
                            </StackPanel>
                        </Border>

                        --><!-- End Node --><!--
                        <Border x:Name="EndNodeTemplate"
                                Background="{DynamicResource DangerBrush}"
                                BorderBrush="{DynamicResource BorderColor}"
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="8"
                                Margin="0,0,0,8"
                                Cursor="Hand"
                                MouseDown="NodeTemplate_MouseDown"
                                MouseMove="NodeTemplate_MouseMove"
                                MouseUp="NodeTemplate_MouseUp"
                                Tag="End"
                                MouseEnter="NodeTemplate_MouseEnter"
                                MouseLeave="NodeTemplate_MouseLeave">
                            <StackPanel>
                                <TextBlock Text="End"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Kết thúc"
                                           Foreground="White"
                                           FontSize="9"
                                           HorizontalAlignment="Center"
                                           Margin="0,2,0,0"
                                           Opacity="0.9"/>
                            </StackPanel>
                        </Border>-->

                        <!-- ===== Icon-only palette (3 columns) ===== -->

                        <TextBlock Text="Flow" Style="{StaticResource PaletteGroupHeaderStyle}"/>
                        <WrapPanel Orientation="Horizontal">
                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource SkyAzureBrush}"
                                    Tag="Start">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="220">
                                            <TextBlock Text="Start" FontWeight="Bold"/>
                                            <TextBlock Text="Điểm bắt đầu workflow và cấu hình FlowScope/RunMode." TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='play duotone-regular'}"
                                                          Fill="{DynamicResource TextOnSkyAzureBrush}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource DangerBrush}"
                                    Tag="End">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="220">
                                            <TextBlock Text="End" FontWeight="Bold"/>
                                            <TextBlock Text="Điểm kết thúc workflow và cấu hình EndBehavior." TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Border.ToolTip>
                                <Grid>
                                    <controls:SvgViewboxEx Style="{StaticResource PaletteSvgIconStyle}"
                                                          Source="{Binding Source={x:Static sys:String.Empty}, Converter={StaticResource IconKeyToPathConverter}, ConverterParameter='flag-checkered sharp-duotone-solid'}"
                                                          Fill="White"/>
                                </Grid>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="Events" Style="{StaticResource PaletteGroupHeaderStyle}"/>
                        <WrapPanel Orientation="Horizontal" x:Name="EventsWrapPanel">
                            <!-- KeyPressEvent -->
                            <Border Style="{StaticResource PaletteIconNodeStyle}"
                                    Background="{DynamicResource ChocolateBrownBrush}"
                                    Tag="KeyPressEvent">
                                <Border.ToolTip>
                                    <ToolTip>
                                        <StackPanel MaxWidth="220">
                                            <TextBlock Text="Key Press (Event)" FontWeight="Bold"/>
                                            <TextBlock Text="Chờ đến khi nhấn đúng phím (global) thì workflow mới đi tiếp." TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            <TextBlock Text="Output: key" Opacity="0.85" Margin="0,4,0,0"/>
                                        </StackPanel>
