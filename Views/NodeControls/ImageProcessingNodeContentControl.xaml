<UserControl x:Class="FlowMy.Views.NodeControls.ImageProcessingNodeContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:FlowMy.Models.Nodes"
             xmlns:local="clr-namespace:FlowMy.Views.NodeControls"
             mc:Ignorable="d"
             d:DesignWidth="900"
             d:DesignHeight="640"
             Background="Transparent"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <local:IntToHashLabelConverter x:Key="IntToHashLabelConverter"/>

        <!-- Một dòng trong danh sách crop -->
        <DataTemplate DataType="{x:Type models:ImageCropRegion}">
            <StackPanel Margin="1,0,1,4" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <TextBlock Margin="0,0,4,0"
                           VerticalAlignment="Center" Opacity="0.7"
                           FontSize="10" FontWeight="Bold" Foreground="White"
                           Text="{Binding Order}"/>
                <Border Width="64" Margin="0,0,0,1"
                        Cursor="Hand" ToolTip="Click để mở Image Processor"
                        BorderThickness="2" CornerRadius="3"
                        Background="#1E000000"
                        BorderBrush="{Binding StrokeBrush}"
                        MouseLeftButtonDown="CropThumbBorder_MouseLeftButtonDown">
                    <Image MaxHeight="64" Stretch="Uniform" HorizontalAlignment="Left"
                           Source="{Binding Thumbnail}"/>
                </Border>
                <StackPanel Margin="4,0,0,0" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Left">
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"
                              FontSize="8" Foreground="Gold" ToolTip="Bật/tắt hiển thị vùng crop"
                              IsChecked="{Binding IsVisible, Mode=TwoWay}"/>
                    <CheckBox Margin="0,0,3,0" VerticalAlignment="Center"
                              FontSize="8" Foreground="{DynamicResource PrimaryBrush}"
                              ToolTip="Ẩn nền polygon, đổi viền sang nét đứt"
                              IsChecked="{Binding IsOutlineOnly, Mode=TwoWay}"/>
                    <Button Content="X" Style="{DynamicResource DangerButton}"
                            Width="18" Height="18" FontSize="9" Padding="0" Margin="0"
                            VerticalAlignment="Center" ToolTip="Xoá vùng crop này"
                            PreviewMouseLeftButtonUp="DeleteCropButton_PreviewMouseLeftButtonUp"
                            Click="DeleteCropButton_Click"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <!-- Nhóm ảnh render theo crop -->
        <DataTemplate x:Key="RenderGroupTemplate">
            <StackPanel Margin="0,0,0,6" Orientation="Vertical">
                <TextBlock Margin="0,0,0,2" FontSize="9" FontWeight="Bold" Foreground="White"
                           Text="{Binding Order, Converter={StaticResource IntToHashLabelConverter}}"/>
                <ItemsControl ItemsSource="{Binding RenderedImages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="55" Margin="0,2,4,2"
                                    BorderBrush="#789CA3B8" BorderThickness="1" CornerRadius="3">
                                <Image MaxHeight="55" Stretch="Uniform" Source="{Binding}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootLayout">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition Width="6*"/>
            <ColumnDefinition Width="3.2*"/>
            <ColumnDefinition x:Name="IpColumnDefinition" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- Top bar -->
        <Border x:Name="TopMenuBorder" Grid.Row="0" Grid.ColumnSpan="3"
                Background="#2DFFFFFF" Padding="8,4,8,4">
            <Border Background="Transparent" IsHitTestVisible="True">
                <DockPanel LastChildFill="True">
                    <Button x:Name="IpToggleButton" DockPanel.Dock="Right"
                            Content="📐" ToolTip="Ẩn/hiện Image Processor"
                            Width="28" Height="22" FontSize="12" Padding="0"
                            Cursor="Hand" VerticalAlignment="Center"
                            Style="{DynamicResource DangerButton}"
                            PreviewMouseLeftButtonDown="IpToggleButton_PreviewMouseLeftButtonDown"
                            Click="IpToggleButton_Click"/>
                    <TextBlock x:Name="ImageTitleTextBlock"
                               Text="Chưa có ảnh"
                               Foreground="{DynamicResource WhiteBrush}"
                               d:Foreground="White"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               VerticalAlignment="Center" HorizontalAlignment="Left"/>
                </DockPanel>
            </Border>
        </Border>

        <!-- Left toolbar -->
        <Border x:Name="LeftMenuBorder" Grid.Row="1" Grid.Column="0"
                Background="#28FFFFFF" Padding="4,0,4,6">
            <Viewbox Stretch="Uniform" StretchDirection="Both"
                     HorizontalAlignment="Stretch" VerticalAlignment="Top">
                <StackPanel Width="48" Orientation="Vertical"
                            HorizontalAlignment="Center" VerticalAlignment="Top">
                    <Button x:Name="BtnOpenImage" Content="📁" ToolTip="Mở ảnh"
                            Width="30" Height="30" Style="{DynamicResource PrimaryButton}"
                            FontSize="16" Padding="0" Margin="0,0,0,10"
                            PreviewMouseLeftButtonDown="CommonButton_StopBubbling_MouseLeftButtonDown"
                            Click="BtnOpenImage_Click"/>
                    <Border BorderBrush="#78FFFFFF" BorderThickness="1" CornerRadius="4"
                            Padding="2" Margin="4,0,4,6">
                        <StackPanel Orientation="Vertical"
                                    HorizontalAlignment="Center" VerticalAlignment="Top">
                            <Button x:Name="ColorCropButton" Width="30" Height="30"
                                    Margin="0,0,0,10" BorderThickness="0" Cursor="Hand"
                                    Padding="0" ToolTip="Chọn màu viền/background vùng crop"
                                    Click="ColorCropButton_Click"/>
                            <Button x:Name="CropToolButton" Content="✂"
                                    ToolTip="Crop ảnh (Alt + click trái trên ảnh để tạo điểm)"
                                    Style="{DynamicResource WarningButton}"
                                    Width="30" Height="30" FontSize="16" Padding="0"
                                    PreviewMouseLeftButtonDown="CommonButton_StopBubbling_MouseLeftButtonDown"
                                    Click="CropToolButton_Click"/>
                        </StackPanel>
                    </Border>
                    <Border Background="Transparent" Width="22" Height="30" Margin="0,0,0,6"/>
                </StackPanel>
            </Viewbox>
        </Border>

        <!-- Center: image -->
        <ScrollViewer x:Name="MainScrollViewer" Grid.Row="1" Grid.Column="1"
                      HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Padding="0" Focusable="True">
            <Grid x:Name="ScrollContentGrid"
                  MinWidth="{Binding ElementName=MainScrollViewer, Path=ViewportWidth}"
                  MinHeight="{Binding ElementName=MainScrollViewer, Path=ViewportHeight}">
                <Grid x:Name="ImageAreaGrid"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="ImageZoomScale" ScaleX="1" ScaleY="1"/>
                    </Grid.LayoutTransform>
                    <Image x:Name="MainImage" Stretch="Uniform"
                           HorizontalAlignment="Left" VerticalAlignment="Top"/>
                    <TextBlock x:Name="PlaceholderTextBlock"
                               Text="Chưa có ảnh. Mở dialog (chuột phải hoặc nút Mở) để dán link/base64."
                               Foreground="#B0BEC5" FontSize="16" TextWrapping="Wrap"
                               Margin="10" VerticalAlignment="Center" HorizontalAlignment="Center"
                               Opacity="0.85"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Right: crops + renders -->
        <Border x:Name="RightMenuBorder" Grid.Row="1" Grid.Column="2"
                Background="#28000000" Padding="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Viewbox Stretch="Uniform" StretchDirection="Both"
                             HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <StackPanel Width="200" Orientation="Vertical" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="CropsLabelText" Text="Danh sách ảnh cắt"
                                       Foreground="White" FontSize="11" Opacity="0.7"
                                       Margin="0,0,0,4" HorizontalAlignment="Left"/>
                            <ItemsControl x:Name="CropsListControl"
                                          HorizontalAlignment="Stretch">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Viewbox Stretch="Uniform" StretchDirection="Both"
                             HorizontalAlignment="Stretch" VerticalAlignment="Top">
                        <StackPanel Width="200" Orientation="Vertical" HorizontalAlignment="Stretch">
                            <TextBlock x:Name="RenderLabelText" Text="Ảnh render"
                                       Foreground="White" FontSize="11" Opacity="0.7"
                                       Margin="0,4,0,4" HorizontalAlignment="Left"/>
                            <ItemsControl x:Name="RenderGroupsControl"
                                          ItemTemplate="{StaticResource RenderGroupTemplate}"/>
                        </StackPanel>
                    </Viewbox>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Magnifier (Alt), same cell as image -->
        <Grid x:Name="MagOverlayPanel" Grid.Row="1" Grid.Column="1"
              Width="124" HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Margin="0,0,8,8" Panel.ZIndex="100"
              Visibility="Collapsed" IsHitTestVisible="False">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Width="124" Height="124"
                    BorderBrush="#FFFFD700" BorderThickness="2"
                    Background="#CC1E1E2E" CornerRadius="4"
                    HorizontalAlignment="Center" VerticalAlignment="Top">
                <Grid Width="120" Height="120" ClipToBounds="True" IsHitTestVisible="False">
                    <Image x:Name="MagZoomImage" Width="120" Height="120"
                           Stretch="Uniform" IsHitTestVisible="False"/>
                    <Line X1="0" Y1="60" X2="120" Y2="60" StrokeThickness="0.8"
                          IsHitTestVisible="False" Stroke="#78FF0000"/>
                    <Line X1="60" Y1="0" X2="60" Y2="120" StrokeThickness="0.8"
                          IsHitTestVisible="False" Stroke="#78FF0000"/>
                    <Ellipse Width="10" Height="10" Stroke="Red" StrokeThickness="1.5"
                             Fill="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center"
                             IsHitTestVisible="False"/>
                </Grid>
            </Border>
            <TextBlock x:Name="MagCoordTextBlock" Grid.Row="1"
                       Foreground="White" FontSize="9"
                       HorizontalAlignment="Center" VerticalAlignment="Bottom"
                       Margin="0,0,0,2" IsHitTestVisible="False"/>
        </Grid>

        <!-- Image Processor (code gán Content từ BuildImageProcessorColumn) -->
        <ContentControl x:Name="IpProcessorHost" Grid.Row="0" Grid.Column="3"
                        Grid.RowSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    </Grid>
</UserControl>
