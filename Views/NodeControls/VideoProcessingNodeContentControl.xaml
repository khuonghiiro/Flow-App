<UserControl x:Class="FlowMy.Views.NodeControls.VideoProcessingNodeContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             Background="Transparent">
    <UserControl.Resources>
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,4,0,6"/>
        </Style>
        <Style x:Key="MetricTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Opacity" Value="0.9"/>
        </Style>
        <Style x:Key="ValueLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Opacity" Value="0.92"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="10,8"
                Margin="0,0,0,8"
                Background="#12000000"
                BorderBrush="#2FFFFFFF">
            <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <controls:SvgViewboxEx x:Name="IconView"
                                   Width="24"
                                   Height="24"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Vertical">
                <TextBlock Text="Video Processing"
                           x:Name="TitleText"
                           FontSize="13"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="VideoPathText"
                           Margin="0,4,0,0"
                           FontSize="10.5"
                           Opacity="0.82"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <Button Grid.Column="2"
                    x:Name="OpenVideoButton"
                    Content="Mở video..."
                    Height="28"
                    MinWidth="94"
                    Padding="12,0"
                    Style="{DynamicResource PrimaryButton}"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Height="220"
                Padding="0"
                Margin="0,0,0,8"
                Background="#23FFFFFF"
                BorderBrush="#46FFFFFF"
                CornerRadius="10">
            <Grid>
                <MediaElement x:Name="PreviewMedia"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="Uniform"
                              Volume="0"
                              ScrubbingEnabled="True"
                              Visibility="Collapsed"/>
                <TextBlock x:Name="PreviewText"
                           Text="Chưa chọn video"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Opacity="0.85"/>
                <Border HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8"
                        Padding="8,3"
                        CornerRadius="8"
                        Background="#7A000000"
                        BorderBrush="#4DFFFFFF"
                        BorderThickness="1">
                    <TextBlock Text="Preview"
                               FontSize="10"
                               Foreground="#F0FFFFFF"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Style="{StaticResource CardBorderStyle}"
                Background="#14FFFFFF"
                BorderBrush="#37FFFFFF"
                Padding="10,8,10,10">
            <TabControl Background="Transparent"
                        BorderThickness="0">
                <TabItem Header="General">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,6,0,0">
                            <Border Background="#18000000"
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,6"
                                    Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock x:Name="MetaLineText"
                                               Style="{StaticResource MetricTextStyle}"
                                               Margin="0,0,0,3"/>
                                    <TextBlock x:Name="AudioSummaryText"
                                               Style="{StaticResource MetricTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Frame Extract FPS"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                            <Slider x:Name="FpsSlider"
                                    Margin="0,0,0,8"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="False"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox x:Name="OutputBase64CheckBox"
                                          Content="Output Base64"
                                          Grid.Column="0"
                                          VerticalAlignment="Center"/>
                                <CheckBox x:Name="PreferGpuCheckBox"
                                          Content="Prefer GPU"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Grading">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Text="Color Grading"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <WrapPanel Grid.Column="0"
                                           x:Name="PresetPanel"
                                           VerticalAlignment="Center">
                                    <Button x:Name="PresetNeutralButton"
                                            Content="Neutral"
                                            Margin="0,0,6,0"
                                            Padding="8,2"/>
                                    <Button x:Name="PresetVividButton"
                                            Content="Vivid"
                                            Margin="0,0,6,0"
                                            Padding="8,2"/>
                                    <Button x:Name="PresetCinematicButton"
                                            Content="Cinematic"
                                            Margin="0,0,6,0"
                                            Padding="8,2"/>
                                    <Button x:Name="PresetBwButton"
                                            Content="B&amp;W"
                                            Padding="8,2"/>
                                </WrapPanel>
                                <Button Grid.Column="1"
                                        x:Name="ResetGradingButton"
                                        Content="Reset"
                                        Padding="10,2"/>
                            </Grid>

                            <StackPanel Margin="0,0,0,5">
                                <TextBlock x:Name="BrightnessLabel" Style="{StaticResource ValueLabelStyle}"/>
                                <Slider x:Name="BrightnessSlider" Minimum="-1" Maximum="1" TickFrequency="0.1"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,5">
                                <TextBlock x:Name="ContrastLabel" Style="{StaticResource ValueLabelStyle}"/>
                                <Slider x:Name="ContrastSlider" Minimum="0.1" Maximum="3" TickFrequency="0.1"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,5">
                                <TextBlock x:Name="SaturationLabel" Style="{StaticResource ValueLabelStyle}"/>
                                <Slider x:Name="SaturationSlider" Minimum="0" Maximum="3" TickFrequency="0.1"/>
                            </StackPanel>
                            <StackPanel Margin="0,0,0,5">
                                <TextBlock x:Name="HueLabel" Style="{StaticResource ValueLabelStyle}"/>
                                <Slider x:Name="HueSlider" Minimum="-180" Maximum="180" TickFrequency="1"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Timeline">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,6,0,0">
                            <TextBlock Text="Timeline Preview"
                                       Style="{StaticResource SectionTitleTextStyle}"/>
                            <Border Background="#18000000"
                                    BorderBrush="#33FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8">
                                <UniformGrid Columns="8">
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#302A3B5A"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#304A4A6E"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#305B3A46"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#304A365D"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#303A4F5E"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#305A4A3F"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#30453358"/>
                                    <Border Height="34" Margin="2" CornerRadius="3" Background="#302C4A62"/>
                                </UniformGrid>
                            </Border>
                            <TextBlock Margin="0,8,0,0"
                                       FontSize="10.5"
                                       Opacity="0.78"
                                       Text="Tab này dành cho xử lý timeline/frame theo cụm logic riêng."/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
