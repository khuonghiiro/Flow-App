<UserControl x:Class="FlowMy.Views.NodeControls.VideoProcessingNodeContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             xmlns:models="clr-namespace:FlowMy.Models.Nodes"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Background="#0E0E14"
             Foreground="#ECECF4">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#ECECF4"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#9CA3B8"/>
        <SolidColorBrush x:Key="ThemeCardBackgroundBrush" Color="#18181F"/>
        <SolidColorBrush x:Key="ThemeCardBorderBrush" Color="#2E2E3D"/>
        <SolidColorBrush x:Key="ThemeInnerCardBackgroundBrush" Color="#14141A"/>
        <SolidColorBrush x:Key="ThemeInnerCardBorderBrush" Color="#2A2A36"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#22222C"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#3A3A4A"/>
        <SolidColorBrush x:Key="ThemeInputForegroundBrush" Color="#F1F5FF"/>
        <SolidColorBrush x:Key="ThemeOverlayBackgroundBrush" Color="#CC0E0E14"/>
        <SolidColorBrush x:Key="ThemeOverlayBorderBrush" Color="#404050"/>
        <SolidColorBrush x:Key="ThemeTimelinePanelBrush" Color="#12121A"/>
        <SolidColorBrush x:Key="ThemeTrackBackgroundBrush" Color="#353545"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="ThemeTabNavBackgroundBrush" Color="#16161E"/>
        <SolidColorBrush x:Key="ThemeLogContainerBackgroundBrush" Color="#12121A"/>
        <SolidColorBrush x:Key="ThemeActionBarBackgroundBrush" Color="#16161E"/>
        <SolidColorBrush x:Key="ThemeActionBarBorderBrush" Color="#5AF59E0B"/>
        <SolidColorBrush x:Key="ThemeWarmAccentBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="ThemeWarmAccentBrushSoft" Color="#66F59E0B"/>
        <SolidColorBrush x:Key="ThemeBottomBarGroupInactiveBorderBrush" Color="#66909AA8"/>
        <SolidColorBrush x:Key="ThemeBottomBarActiveGroupBackgroundBrush" Color="#28F59E0B"/>
        <SolidColorBrush x:Key="ThemeVideoChromePrimaryBgBrush" Color="#303240"/>
        <SolidColorBrush x:Key="ThemeVideoChromePrimaryHoverBgBrush" Color="#3A3D50"/>
        <SolidColorBrush x:Key="ThemeVideoChromePrimaryFgBrush" Color="#F1F5FF"/>
        <SolidColorBrush x:Key="ThemeVideoChromePrimaryBorderBrush" Color="#45FFFFFF"/>
        <SolidColorBrush x:Key="ThemeVideoChromeSecondaryBgBrush" Color="#282A36"/>
        <SolidColorBrush x:Key="ThemeVideoChromeSecondaryHoverBgBrush" Color="#343644"/>
        <SolidColorBrush x:Key="ThemeVideoChromeSecondaryFgBrush" Color="#E8ECF8"/>
        <SolidColorBrush x:Key="ThemeVideoChromeSecondaryBorderBrush" Color="#38FFFFFF"/>
        <SolidColorBrush x:Key="ThemeVideoOpenButtonFgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeValueBadgeBackgroundBrush" Color="#2A2B38"/>
        <SolidColorBrush x:Key="ThemeTransportPlayBgBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="ThemeTransportPlayHoverBgBrush" Color="#4F52DD"/>
        <SolidColorBrush x:Key="ThemeTransportPlayFgBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTransportIconHoverBgBrush" Color="#303240"/>
        <SolidColorBrush x:Key="ThemeQuickOverlayHoverBgBrush" Color="#343644"/>
        <SolidColorBrush x:Key="ThemePresetChipBgBrush" Color="#242530"/>
        <SolidColorBrush x:Key="ThemePresetChipBorderBrush" Color="#3A3C4C"/>
        <SolidColorBrush x:Key="ThemePresetChipHoverBgBrush" Color="#303242"/>
        <SolidColorBrush x:Key="ThemePresetChipPressedBgBrush" Color="#2C2E3C"/>
        <SolidColorBrush x:Key="ThemePresetChipResetBgBrush" Color="#282C38"/>
        <SolidColorBrush x:Key="ThemePresetChipResetBorderBrush" Color="#464A5A"/>
        <SolidColorBrush x:Key="ThemeOnAccentTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeSliderThumbBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeComboPopupBackgroundBrush" Color="#1E1E2A"/>
        <SolidColorBrush x:Key="ThemeComboItemHoverBrush" Color="#343448"/>
        <SolidColorBrush x:Key="ThemeTabHoverBrush" Color="#2A2A38"/>
        <SolidColorBrush x:Key="ThemeActionExtractBrush" Color="#262E8FF9"/>
        <SolidColorBrush x:Key="ThemeActionSubtitleBrush" Color="#266366F1"/>
        <SolidColorBrush x:Key="ThemeActionWatermarkBrush" Color="#2614B8A6"/>
        <SolidColorBrush x:Key="ThemeActionConvertBrush" Color="#26A78BFA"/>
        <SolidColorBrush x:Key="ThemeActionTrimBrush" Color="#26EF4444"/>
        <SolidColorBrush x:Key="ThemeActionSnapshotBrush" Color="#26F59E0B"/>
        <SolidColorBrush x:Key="ThemeActionFolderVideoBrush" Color="#264ADE80"/>
        <SolidColorBrush x:Key="ThemeActionFolderFramesBrush" Color="#26F59E0B"/>
        <SolidColorBrush x:Key="ThemeOpenVideoBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="ThemeOpenVideoHoverBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="ThemeOpenVideoPressedBrush" Color="#B91C1C"/>
        <SolidColorBrush x:Key="ThemeTimelineTrackBrush" Color="#3A3A48"/>
        <SolidColorBrush x:Key="ThemeTimelineProgressBrush" Color="#6366F1"/>
        <SolidColorBrush x:Key="ThemeTimelineThumbStrokeBrush" Color="#E2E6EF"/>
        <SolidColorBrush x:Key="ThemeFrameLabelPreviewBg" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="ThemeFrameLabelPreviewFg" Color="#151922"/>

        <Style x:Key="VideoOpenPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="{DynamicResource ThemeOpenVideoBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeVideoOpenButtonFgBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeOpenVideoHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrush}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ThemeOpenVideoPressedBrush}"/>
                                <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><TranslateTransform Y="1"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VideoChromePrimaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeVideoChromePrimaryFgBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeVideoChromePrimaryBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeVideoChromePrimaryBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="FillBd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="WarmRing"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource ThemeWarmAccentBrush}"
                                    BorderThickness="1"
                                    Opacity="0"
                                    Margin="-1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FillBd" Property="Background" Value="{DynamicResource ThemeVideoChromePrimaryHoverBgBrush}"/>
                                <Setter TargetName="FillBd" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrushSoft}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WarmRing" Storyboard.TargetProperty="Opacity"
                                                             To="0.92" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WarmRing" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FillBd" Property="Background" Value="{DynamicResource ThemeVideoChromeSecondaryHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FillBd" Property="Opacity" Value="0.5"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="VideoChromeSecondaryButtonStyle" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeVideoChromeSecondaryFgBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeVideoChromeSecondaryBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeVideoChromeSecondaryBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="FillBd2"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="WarmRing2"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource ThemeWarmAccentBrush}"
                                    BorderThickness="1"
                                    Opacity="0"
                                    Margin="-1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FillBd2" Property="Background" Value="{DynamicResource ThemeVideoChromeSecondaryHoverBgBrush}"/>
                                <Setter TargetName="FillBd2" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrushSoft}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WarmRing2" Storyboard.TargetProperty="Opacity"
                                                             To="0.85" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WarmRing2" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FillBd2" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FillBd2" Property="Opacity" Value="0.48"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style x:Key="InnerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeInnerCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInnerCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
        </Style>
        <Style x:Key="ValueBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeValueBadgeBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="8,5"/>
        </Style>
        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,3,0,3"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#88EAF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"/>
                            <TextBlock Text="▾"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       FontSize="10"/>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource ThemeComboPopupBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MaxHeight="200"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeComboItemHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeInputForegroundBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource ThemeComboPopupBackgroundBrush}"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeComboItemHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}"/>
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeInputForegroundBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}"/>
        <Style TargetType="Slider" x:Key="ModernSliderStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" CornerRadius="2" Background="{DynamicResource ThemeTrackBackgroundBrush}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{DynamicResource ThemeAccentBrush}" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="{DynamicResource ThemeSliderThumbBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="IbFill"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="0"/>
                            <Border x:Name="IbRing"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource ThemeWarmAccentBrush}"
                                    BorderThickness="1"
                                    Opacity="0"
                                    Margin="-1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                                <Setter TargetName="IbFill" Property="Background" Value="{DynamicResource ThemeTransportIconHoverBgBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IbRing" Storyboard.TargetProperty="Opacity"
                                                             To="0.9" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IbRing" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="IbFill" Property="Background" Value="{DynamicResource ThemeVideoChromeSecondaryHoverBgBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="QuickOverlayIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeOverlayBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ThemeQuickOverlayHoverBgBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource ThemeVideoChromeSecondaryHoverBgBrush}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PlayButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemeTransportPlayBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTransportPlayFgBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeVideoChromePrimaryBorderBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="PlayBd"
                                    CornerRadius="18"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <Border x:Name="PlayRing"
                                    CornerRadius="18"
                                    BorderBrush="{DynamicResource ThemeWarmAccentBrush}"
                                    BorderThickness="1"
                                    Opacity="0"
                                    Margin="-1"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PlayBd" Property="Background" Value="{DynamicResource ThemeTransportPlayHoverBgBrush}"/>
                                <Setter TargetName="PlayBd" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrushSoft}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PlayRing" Storyboard.TargetProperty="Opacity"
                                                             To="0.92" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PlayRing" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PlayBd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PlayBd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetChipStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ThemePresetChipBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemePresetChipBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="ChipBd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="20"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="ChipWarm"
                                    CornerRadius="20"
                                    BorderBrush="{DynamicResource ThemeWarmAccentBrush}"
                                    BorderThickness="1"
                                    Opacity="0"
                                    Margin="-1"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBd" Property="Background" Value="{DynamicResource ThemePresetChipHoverBgBrush}"/>
                                <Setter TargetName="ChipBd" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrushSoft}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChipWarm" Storyboard.TargetProperty="Opacity"
                                                             To="0.82" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ChipWarm" Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ChipBd" Property="Background" Value="{DynamicResource ThemePresetChipPressedBgBrush}"/>
                                <Setter TargetName="ChipBd" Property="BorderBrush" Value="{DynamicResource ThemeWarmAccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                                <Setter TargetName="ChipBd" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetChipResetStyle" TargetType="Button" BasedOn="{StaticResource PresetChipStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemePresetChipResetBgBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemePresetChipResetBorderBrush}"/>
        </Style>
        <Style x:Key="PillTabNavStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0,6"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontFamily" Value="Segoe UI"/>
                        <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="12,8" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                            <Setter TargetName="Bd" Property="Padding" Value="12,8"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsSelected" Value="False"/>
                                                <Condition Property="IsMouseOver" Value="True"/>
                                            </MultiTrigger.Conditions>
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="11" Background="{DynamicResource ThemeTrackBackgroundBrush}" BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1"/>
                            <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="{DynamicResource ThemeSliderThumbBrush}" Margin="3" HorizontalAlignment="Left"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AspectRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootContentGrid" Margin="12,10,12,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="HeaderCardBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,10" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions> 
                <controls:SvgViewboxEx Grid.Column="0" x:Name="IconView" Width="24" Height="24" Margin="0,0,14,0" VerticalAlignment="Center" Fill="White" />
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" FontFamily="Segoe UI" Foreground="White" />
                    <TextBlock x:Name="VideoPathText" FontSize="11" Opacity="0.72" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" FontFamily="Segoe UI"/>
                </StackPanel>
                <Button Grid.Column="2" x:Name="ThemeModeButton" Height="32" MinWidth="44" Padding="12,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" ToolTip="Đổi sáng/tối">
                    <TextBlock Text="☀"/>
                </Button>
                <Button Grid.Column="4" x:Name="ToggleNodeSizeButton" Height="32" MinWidth="44" Padding="12,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" ToolTip="Phóng to/thu nhỏ node video">
                    <TextBlock Text="⤢" FontSize="13"/>
                </Button>
                <Button Grid.Column="6" x:Name="RunProcessingButton" Height="32" MinWidth="92" Padding="18,0" Style="{StaticResource VideoChromePrimaryButtonStyle}" ToolTip="Chạy xử lý video qua FFmpeg">
                    <TextBlock Text="Chạy" FontWeight="SemiBold"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="260"/>
                <ColumnDefinition Width="3*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" x:Name="PreviewContainerBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,10,0" Padding="0" ClipToBounds="True" VerticalAlignment="Stretch">
                <Grid x:Name="VideoContainerGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="12,12,12,8" Padding="10,8" Background="{DynamicResource ThemeTabNavBackgroundBrush}" CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="OpenVideoButton"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Height="30"
                                Padding="12,0"
                                Style="{StaticResource VideoOpenPrimaryButtonStyle}"
                                Click="OpenVideoButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="10" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Mở video" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Center">
                            <RadioButton x:Name="Aspect169" Content="16:9" GroupName="AspectRatio" IsChecked="True" Style="{StaticResource AspectRadioStyle}" ToolTip="Ngang chuẩn 16:9"/>
                            <RadioButton x:Name="Aspect916" Content="9:16" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Dọc 9:16"/>
                            <RadioButton x:Name="Aspect11" Content="1:1" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Vuông 1:1"/>
                            <RadioButton x:Name="Aspect32" Content="3:2" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Ngang 3:2"/>
                            <RadioButton x:Name="Aspect23" Content="2:3" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Dọc 2:3"/>
                            <RadioButton x:Name="AspectAuto" Content="Auto" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Dùng kích thước video thật"/>
                        </WrapPanel>
                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Margin="8,0,0,0">
                            <Border x:Name="HwBadge"
                                    Background="{DynamicResource ThemeAccentBrush}" BorderBrush="{DynamicResource ThemeOverlayBorderBrush}"
                                    BorderThickness="1" CornerRadius="10"
                                    Padding="7,3" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock x:Name="HwBadgeText" FontSize="9" FontWeight="Medium" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Border>
                            <Border Padding="7,8" CornerRadius="8"
                                    Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#4ADE80" Margin="0,0,5,0"  VerticalAlignment="Center" x:Name="LiveDot" Visibility="Collapsed"/>
                                    <TextBlock Text="Preview" FontSize="9.5" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="ToggleBeforeAfterButton"
                                    Margin="6,0,0,0"
                                    Height="24"
                                    Padding="8,0"
                                    FontSize="9.5"
                                    Style="{StaticResource VideoChromeSecondaryButtonStyle}"
                                    Content="Before/After"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="1"
                        x:Name="VideoViewportClipBorder"
                        Margin="12,0,12,0"
                        CornerRadius="10"
                        Background="Transparent">
                    <Grid>
                <Viewbox x:Name="VideoViewbox" Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <MediaElement x:Name="PreviewMedia"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  Stretch="Uniform"
                                  Width="1280"
                                  Height="720"
                                  Volume="0.7"
                                  ScrubbingEnabled="False"
                                  Visibility="Collapsed"
                                  Cursor="Hand"/>
                </Viewbox>
                <Grid x:Name="VideoAreaGrid">
                    <Grid x:Name="PreviewPlaceholder"
                          Panel.ZIndex="10"
                          Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Chưa chọn video"
                                   FontSize="12"
                                   Foreground="{DynamicResource ThemeTextPrimaryBrush}"
                                   Opacity="0.55"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Nhấn 'Mở video' để bắt đầu"
                                   FontSize="11"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,6,0,0"/>
                        <!--<Button x:Name="OpenVideoInPlaceholderButton"
                                Height="34"
                                Margin="0,14,0,0"
                                Padding="18,0"
                                IsHitTestVisible="True"
                                Click="OpenVideoInPlaceholderButton_Click"
                                Style="{StaticResource VideoOpenPrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Chọn video" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>-->
                        </StackPanel>
                    </Grid>
                </Grid>
                <Border x:Name="GradingOverlay"
                        Panel.ZIndex="2"
                        Background="Transparent"
                        IsHitTestVisible="False"/>
                <Image x:Name="WatermarkPreviewImage"
                       Panel.ZIndex="2"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"
                       Visibility="Collapsed"
                       IsHitTestVisible="False"/>
                <controls:OverlayCanvas x:Name="OverlayCanvasControl"
                                        Panel.ZIndex="3"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"/>
                <Border x:Name="QuickGradingPanel"
                        Panel.ZIndex="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,8"
                        Padding="8,6"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Quick Grade" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Sáng" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickBrightnessSlider" Grid.Column="1" Minimum="-1" Maximum="1" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickBrightnessLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Tương phản" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickContrastSlider" Grid.Column="1" Minimum="0.1" Maximum="3" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickContrastLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Bão hòa" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickSaturationSlider" Grid.Column="1" Minimum="0" Maximum="3" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickSaturationLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border x:Name="QuickPreviewQualityPanel"
                        Panel.ZIndex="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,8"
                        Padding="8,6"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Preview"
                                   Margin="0,0,6,0"
                                   FontSize="9.5"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ComboBox x:Name="PreviewQualityCombo"
                                  Width="132"
                                  Height="24"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  ToolTip="Chất lượng hiển thị preview tại khung video">
                            <ComboBoxItem Content="Auto" Tag="auto"/>
                            <ComboBoxItem Content="144p" Tag="144"/>
                            <ComboBoxItem Content="240p" Tag="240"/>
                            <ComboBoxItem Content="480p" Tag="480"/>
                            <ComboBoxItem Content="720p" Tag="720"/>
                            <ComboBoxItem Content="1080p" Tag="1080"/>
                            <ComboBoxItem Content="2K" Tag="1440"/>
                            <ComboBoxItem Content="4K" Tag="2160"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
                <StackPanel x:Name="QuickOverlayButtonsPanel"
                            Panel.ZIndex="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Orientation="Vertical"
                            Margin="0,0,8,8">
                    <Button x:Name="ToggleQuickGradeButton" Width="30" Height="30" Style="{StaticResource QuickOverlayIconButtonStyle}" Background="{DynamicResource ThemeOverlayBackgroundBrush}" Margin="0,0,0,4">
                        <TextBlock Text="🎨" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="QuickSnapshotButton" Width="30" Height="30" Style="{StaticResource QuickOverlayIconButtonStyle}" Background="{DynamicResource ThemeOverlayBackgroundBrush}" Margin="0,0,0,4">
                        <TextBlock Text="📷" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="QuickSetTrimButton" Width="30" Height="30" Style="{StaticResource QuickOverlayIconButtonStyle}" Background="{DynamicResource ThemeOverlayBackgroundBrush}">
                        <TextBlock Text="✂" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
                <Border x:Name="FrameInfoOverlay"
                        Panel.ZIndex="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,8,0,0"
                        Padding="10,4"
                        CornerRadius="8"
                        Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="FrameInfoText" FontSize="9.5" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                </Border>
                <Border x:Name="FrameLabelPreviewOverlay"
                        Panel.ZIndex="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="12"
                        Padding="10,6"
                        CornerRadius="4"
                        Background="{DynamicResource ThemeFrameLabelPreviewBg}"
                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="FrameLabelPreviewText"
                               Text="Frame 0 - 00:00:00"
                               FontFamily="Segoe UI Semibold"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               Foreground="{DynamicResource ThemeFrameLabelPreviewFg}"/>
                </Border>
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="{DynamicResource ThemeTimelinePanelBrush}" Padding="12,10,12,10" CornerRadius="0,0,10,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TimeCurrentText" Text="00:00" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <Grid Grid.Column="1" MinHeight="28" Cursor="Hand" x:Name="ProgressBarHitArea"
                                  VerticalAlignment="Center" Background="Transparent"
                                  PreviewMouseLeftButtonDown="ProgressBarHitArea_MouseDown"
                                  PreviewMouseMove="ProgressBarHitArea_MouseMove"
                                  PreviewMouseLeftButtonUp="ProgressBarHitArea_MouseUp"
                                  MouseEnter="ProgressBarHitArea_MouseEnter"
                                  MouseLeave="ProgressBarHitArea_MouseLeave">
                                <Border Background="{DynamicResource ThemeTimelineTrackBrush}" CornerRadius="4" Height="8" VerticalAlignment="Center"/>
                                <Border x:Name="ProgressBarFill" Background="{DynamicResource ThemeTimelineProgressBrush}" CornerRadius="4" Height="8" VerticalAlignment="Center" HorizontalAlignment="Left" Width="0"/>
                                <Canvas VerticalAlignment="Center" Height="28">
                                    <Ellipse x:Name="ProgressThumb" Width="22" Height="22" Canvas.Top="3" Visibility="Collapsed"
                                             Fill="{DynamicResource ThemeTimelineProgressBrush}"
                                             Stroke="{DynamicResource ThemeTimelineThumbStrokeBrush}" StrokeThickness="2">
                                        <Ellipse.RenderTransformOrigin>0.5,0.5</Ellipse.RenderTransformOrigin>
                                        <Ellipse.RenderTransform>
                                            <ScaleTransform x:Name="ProgressThumbScale" ScaleX="1" ScaleY="1"/>
                                        </Ellipse.RenderTransform>
                                    </Ellipse>
                                </Canvas>
                            </Grid>
                            <TextBlock x:Name="TimeTotalText" Grid.Column="2" Text="00:00" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" FontFamily="Consolas" VerticalAlignment="Center" Margin="7,0,0,0"/>
                        </Grid>
                        <TextBlock x:Name="SeekPerfText"
                                   Margin="0,0,0,6"
                                   FontSize="9"
                                   FontFamily="Consolas"
                                   Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                   Text="Preview: NORMAL | Seek: -- ms"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SkipBackButton" Grid.Column="0" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏮" FontSize="12" ToolTip="Lùi 5 giây"/>
                            <Button x:Name="PlayPauseButton" Grid.Column="2" Width="34" Height="34" Style="{StaticResource PlayButtonStyle}"/>
                            <Button x:Name="SkipForwardButton" Grid.Column="4" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏭" FontSize="12" ToolTip="Tiến 5 giây"/>
                            <Button x:Name="StopButton" Grid.Column="6" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏹" FontSize="12" ToolTip="Dừng"/>
                            <Button x:Name="MuteButton" Grid.Column="8" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" FontSize="11" ToolTip="Bật/Tắt âm"/>
                            <Slider x:Name="VolumeSlider" Grid.Column="9" Minimum="0" Maximum="1" Value="0.7" VerticalAlignment="Center" Margin="4,0" Style="{StaticResource ModernSliderStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Row="3" Margin="0,8,0,12" Background="{DynamicResource ThemeLogContainerBackgroundBrush}" BorderBrush="{DynamicResource ThemeCardBorderBrush}" BorderThickness="1" CornerRadius="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="{DynamicResource ThemeActionBarBackgroundBrush}" CornerRadius="10,10,0,0" Padding="10,5">
                            <Grid>
