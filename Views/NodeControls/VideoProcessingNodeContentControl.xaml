                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Thư mục chứa ffmpeg.exe, ffprobe.exe" FontSize="10" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="FfmpegFolderText" Height="28" FontSize="10.5"/>
                                        <Button x:Name="BrowseFfmpegFolderButton" Grid.Column="1" Content="..." Width="32" Height="28" Style="{DynamicResource SecondaryButton}" Margin="4,0,0,0"/>
                                    </Grid>
                                    <Border x:Name="FfmpegVerifyBadge" Margin="0,8,0,0" Padding="8,5" CornerRadius="7" Background="#1A4ADE80">
                                        <TextBlock x:Name="FfmpegVerifyText" FontSize="10" Text="Chưa xác minh" Foreground="#4ADE80"/>
                                    </Border>
                                    <Button x:Name="VerifyFfmpegButton" Content="Xác minh FFmpeg" Height="30" Margin="0,8,0,0" Style="{DynamicResource SecondaryButton}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Thư mục xuất ảnh frame" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Để trống = lưu cạnh video nguồn" FontSize="10" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="FrameOutputFolderText" Height="28" FontSize="10.5"/>
                                        <Button x:Name="BrowseFrameOutputFolderButton" Grid.Column="1" Content="..." Width="32" Height="28" Style="{DynamicResource SecondaryButton}" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Đường dẫn video đầu ra mặc định" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Để trống = tự sinh tên trong /Temp" FontSize="10" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="DefaultOutputVideoPathText" Height="28" FontSize="10.5"/>
                                        <Button x:Name="BrowseDefaultOutputVideoButton" Grid.Column="1" Content="..." Width="32" Height="28" Style="{DynamicResource SecondaryButton}" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                             <CheckBox x:Name="UseDialogVideoConfigCheckBox"
                                      Content="Sử dụng cấu hình dialog video (real-time)"
                                      Style="{StaticResource ReadableCheckBoxStyle}"
                                      Margin="0,0,0,14"
                                      IsChecked="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Border Grid.Row="2" x:Name="ActionButtonsBorder" Margin="0,6,0,0" Padding="8,6"
                Background="{DynamicResource ThemeActionBarBackgroundBrush}" CornerRadius="0,0,12,12"
                BorderBrush="{DynamicResource ThemeActionBarBorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel x:Name="GeneralActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Visible">
                    <Button x:Name="ExtractFramesButton" Height="30" Padding="12,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionExtractBrush}">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="🖼" Margin="0,0,4,0"/><TextBlock Text="Tách Frame" FontSize="11"/></StackPanel>
                    </Button>
                    <Button x:Name="RunAllButton" Height="30" Padding="14,0" Margin="8,0,0,0" Style="{DynamicResource PrimaryButton}">
                        <StackPanel Orientation="Horizontal"><TextBlock Text="▶" Margin="0,0,6,0" FontSize="11"/><TextBlock Text="Chạy tất cả" FontSize="11" FontWeight="SemiBold"/></StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel x:Name="GradingActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button x:Name="ApplyGradingButton" Height="30" Padding="14,0" Style="{DynamicResource PrimaryButton}"><TextBlock Text="Áp dụng màu" FontSize="11" FontWeight="SemiBold"/></Button>
                    <Button x:Name="ResetGradingButton2" Height="30" Padding="12,0" Margin="6,0,0,0" Style="{DynamicResource SecondaryButton}"><TextBlock Text="Đặt lại" FontSize="11"/></Button>
                </StackPanel>
                <StackPanel x:Name="FiltersActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button x:Name="BurnSubtitleButton" Height="30" Padding="12,0" Margin="0,0,6,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionSubtitleBrush}"><TextBlock Text="Gắn phụ đề" FontSize="11"/></Button>
                    <Button x:Name="QuickWatermarkButton" Height="30" Padding="12,0" Margin="0,0,6,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionWatermarkBrush}"><TextBlock Text="Watermark" FontSize="11"/></Button>
                    <Button x:Name="ApplyOverlayToVideoActionButton" Height="30" Padding="12,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionWatermarkBrush}"><TextBlock Text="Áp dụng Overlay" FontSize="11"/></Button>
                </StackPanel>
                <StackPanel x:Name="AudioActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button x:Name="MixAudioButton" Height="30" Padding="14,0" Style="{DynamicResource PrimaryButton}"><TextBlock Text="Ghép Audio" FontSize="11" FontWeight="SemiBold"/></Button>
                </StackPanel>
                <StackPanel x:Name="ExportActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button x:Name="RunExportButton" Height="30" Padding="14,0" Style="{DynamicResource PrimaryButton}"><TextBlock Text="Xuất video" FontSize="11" FontWeight="SemiBold"/></Button>
                    <Button x:Name="SnapshotButton" Height="30" Padding="12,0" Margin="6,0,0,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionSnapshotBrush}"><TextBlock Text="Chụp ảnh" FontSize="11"/></Button>
                    <Button x:Name="ConvertFormatButton" Visibility="Collapsed"/>
                    <Button x:Name="QuickTrimButton" Visibility="Collapsed"/>
                </StackPanel>
                <StackPanel x:Name="OutputsActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button x:Name="OpenOutputVideoActionButton" Height="30" Padding="12,0" Margin="0,0,6,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionFolderVideoBrush}"><TextBlock Text="Mở Video" FontSize="11"/></Button>
                    <Button x:Name="OpenFramesFolderActionButton" Height="30" Padding="12,0" Style="{DynamicResource SecondaryButton}" Background="{DynamicResource ThemeActionFolderFramesBrush}"><TextBlock Text="Mở Folder Frame" FontSize="11"/></Button>
                    <Button x:Name="OpenOutputVideoFolderQuickButton" Visibility="Collapsed"/>
                    <Button x:Name="OpenFramesFolderQuickButton" Visibility="Collapsed"/>
                </StackPanel>
                    <StackPanel x:Name="SettingsActionBar" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                        <Button x:Name="SaveSettingsButton" Height="30" Padding="14,0" Style="{DynamicResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="💾" Margin="0,0,6,0"/><TextBlock Text="Lưu cài đặt" FontSize="11" FontWeight="SemiBold"/></StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
