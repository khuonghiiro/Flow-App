                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="OutputVideoPathText"
                                                   Text="Chưa có đường dẫn video đầu ra"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="OpenOutputVideoButton"
                                                Grid.Column="1"
                                                Content="Mở"
                                                Margin="8,0,0,0"
                                                Height="26"
                                                Padding="10,0"
                                                Style="{DynamicResource SecondaryButton}"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="OutputFramesFolderText"
                                                   Text="Chưa có thư mục frame"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="OpenFramesFolderButton"
                                                Grid.Column="1"
                                                Content="Mở"
                                                Margin="8,0,0,0"
                                                Height="26"
                                                Padding="10,0"
                                                Style="{DynamicResource SecondaryButton}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InnerCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Kiểm tra cấu hình" FontSize="11.5" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ConfigMissingSummaryText" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ConfigCheckVideoText" Margin="0,8,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckOutputText" Margin="0,4,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckSubtitleText" Margin="0,4,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckWatermarkText" Margin="0,4,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckTextOverlayText" Margin="0,4,0,0" Text=""/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="LogTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8" Padding="10,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6"><TextBlock x:Name="ProgressStatusText" FontSize="11" FontWeight="Medium" Text="Chưa chạy"/><TextBlock x:Name="ProgressPercentText" HorizontalAlignment="Right" FontSize="11" FontFamily="Consolas" Opacity="0.8"/></Grid>
                                    <Grid><Border Background="#15FFFFFF" CornerRadius="4" Height="6"/><Border x:Name="ProgressFill" HorizontalAlignment="Left" Background="#7C6BF8" CornerRadius="4" Height="6" Width="0"/></Grid>
                                    <Grid Margin="0,6,0,0"><TextBlock x:Name="ElapsedTimeText" FontSize="10" Opacity="0.5" Text="Đã chạy: --"/><TextBlock x:Name="EstimatedTimeText" HorizontalAlignment="Right" FontSize="10" Opacity="0.5" Text="Còn lại: --"/></Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="#0C000000" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#12FFFFFF" CornerRadius="8,8,0,0" Padding="10,6">
                                        <Grid><TextBlock Text="Kết quả FFmpeg" FontSize="10.5" FontWeight="Medium" Opacity="0.8"/><Button x:Name="ClearLogButton" Content="Xóa" HorizontalAlignment="Right" Height="22" Padding="8,0" FontSize="10" Style="{DynamicResource SecondaryButton}"/></Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <TextBox x:Name="LogTextBox" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="10" Foreground="#CCFFFFFF" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" x:Name="ActionButtonsBorder" Margin="0,6,0,0" Padding="8,6"
                Background="#12FFFFFF" CornerRadius="0,0,12,12"
                BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0">
            <UniformGrid x:Name="ActionButtonsGrid" Rows="1">
                <Button x:Name="ExtractFramesButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource SecondaryButton}" ToolTip="Xuất frame thành ảnh PNG/JPEG từ video nguồn">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="🖼" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Tách ảnh" VerticalAlignment="Center" FontSize="11"/></StackPanel>
                </Button>
                <Button x:Name="BurnSubtitleButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource SecondaryButton}" ToolTip="Gắn file subtitle (.srt/.ass) vào video">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="💬" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Phụ đề" VerticalAlignment="Center" FontSize="11"/></StackPanel>
                </Button>
                <Button x:Name="QuickWatermarkButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource SecondaryButton}" ToolTip="Mở tab Filters để chỉnh watermark/logo">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="🔖" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Watermark" VerticalAlignment="Center" FontSize="11"/></StackPanel>
                </Button>
                <Button x:Name="ConvertFormatButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource SecondaryButton}" ToolTip="Mở tab Export để chọn định dạng đầu ra">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="🔄" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Chuyển đổi" VerticalAlignment="Center" FontSize="11"/></StackPanel>
                </Button>
                <Button x:Name="QuickTrimButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource SecondaryButton}" ToolTip="Đặt Trim Start tại vị trí hiện tại của timeline">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="✂" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Cắt" VerticalAlignment="Center" FontSize="11"/></StackPanel>
                </Button>
                <Button x:Name="SnapshotButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource SecondaryButton}" ToolTip="Chụp frame hiện tại thành file PNG">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="📷" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Chụp ảnh" VerticalAlignment="Center" FontSize="11"/></StackPanel>
                </Button>
                <Button x:Name="RunAllButton" Height="30" Margin="2,0" Padding="8,0" Style="{DynamicResource PrimaryButton}" ToolTip="Chạy toàn bộ pipeline xử lý video">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><TextBlock Text="▶" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="11"/><TextBlock Text="Chạy tất cả" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/></StackPanel>
                </Button>
            </UniformGrid>
        </Border>
    </Grid>
</UserControl>
