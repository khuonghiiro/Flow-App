                                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinHeight="220"
                                        Padding="8">
                                    <StackPanel>
                                        <TextBlock Text="Frame Start" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <Image x:Name="TrimStartFrameImage"
                                               MinHeight="40"
                                               MaxHeight="220"
                                               Stretch="Uniform"
                                               Visibility="Collapsed"/>
                                        <TextBlock x:Name="TrimStartFrameHintText" Text="Thả chuột để load..." FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Opacity="0.7" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8"
                                        MinHeight="220"
                                        Margin="8,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Frame End" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,6"/>
                                        <Image x:Name="TrimEndFrameImage"
                                               MinHeight="40"
                                               MaxHeight="220"
                                               Stretch="Uniform"
                                               Visibility="Collapsed"/>
                                        <TextBlock x:Name="TrimEndFrameHintText" Text="Thả chuột để load..." FontSize="10" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Opacity="0.7" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                                </StackPanel>
                            </Border>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="OutputPathText" Height="28" FontSize="10.5" Padding="6,4" Background="{DynamicResource ThemeInputBackgroundBrush}" BorderBrush="{DynamicResource ThemeInputBorderBrush}" Foreground="{DynamicResource ThemeInputForegroundBrush}"/><Button x:Name="BrowseOutputButton" Grid.Column="1" Height="28" Margin="6,0,0,0" Content="..." Padding="8,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}"/></Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="OutputsTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Liên kết đầu ra" FontSize="11.5" FontWeight="SemiBold"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Chế độ xuất:" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                        <TextBlock x:Name="OutputModeSummaryText" Grid.Column="1" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Định dạng video:" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                        <TextBlock x:Name="OutputFormatSummaryText" Grid.Column="1" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Âm thanh:" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                        <TextBlock x:Name="OutputAudioSummaryText" Grid.Column="1"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Ước tính frame:" Foreground="{DynamicResource ThemeTextSecondaryBrush}"/>
                                        <TextBlock x:Name="OutputEstimatedFramesText" Grid.Column="1"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="OutputVideoPathText"
                                                   Text="Chưa có đường dẫn video đầu ra"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="OpenOutputVideoButton"
                                                Grid.Column="1"
                                                Content="Mở"
                                                Margin="8,0,0,0"
                                                Height="26"
                                                Padding="10,0"
                                                Style="{StaticResource VideoChromeSecondaryButtonStyle}"/>
                                    </Grid>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="OutputFramesFolderText"
                                                   Text="Chưa có thư mục frame"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="OpenFramesFolderButton"
                                                Grid.Column="1"
                                                Content="Mở"
                                                Margin="8,0,0,0"
                                                Height="26"
                                                Padding="10,0"
                                                Style="{StaticResource VideoChromeSecondaryButtonStyle}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource InnerCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Kiểm tra cấu hình" FontSize="11.5" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ConfigMissingSummaryText" Margin="0,6,0,0" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ConfigCheckVideoText" Margin="0,8,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckOutputText" Margin="0,4,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckSubtitleText" Margin="0,4,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckWatermarkText" Margin="0,4,0,0" Text=""/>
                                    <TextBlock x:Name="ConfigCheckTextOverlayText" Margin="0,4,0,0" Text=""/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="SettingsTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <TextBlock Text="Đường dẫn FFmpeg" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Thư mục chứa ffmpeg.exe, ffprobe.exe" FontSize="10" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="FfmpegFolderText" Height="28" FontSize="10.5"/>
                                        <Button x:Name="BrowseFfmpegFolderButton" Grid.Column="1" Content="..." Width="32" Height="28" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Margin="4,0,0,0"/>
                                    </Grid>
                                    <Border x:Name="FfmpegVerifyBadge" Margin="0,8,0,0" Padding="8,5" CornerRadius="7" Background="#1A4ADE80">
                                        <TextBlock x:Name="FfmpegVerifyText" FontSize="10" Text="Chưa xác minh" Foreground="#4ADE80"/>
                                    </Border>
                                    <Button x:Name="VerifyFfmpegButton" Content="Xác minh FFmpeg" Height="30" Margin="0,8,0,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Thư mục xuất ảnh frame" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Để trống = lưu cạnh video nguồn" FontSize="10" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="FrameOutputFolderText" Height="28" FontSize="10.5"/>
                                        <Button x:Name="BrowseFrameOutputFolderButton" Grid.Column="1" Content="..." Width="32" Height="28" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Đường dẫn video đầu ra mặc định" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Để trống = tự sinh tên trong /Temp" FontSize="10" Opacity="0.6" Margin="0,0,0,6"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="DefaultOutputVideoPathText" Height="28" FontSize="10.5"/>
                                        <Button x:Name="BrowseDefaultOutputVideoButton" Grid.Column="1" Content="..." Width="32" Height="28" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Margin="4,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                             <CheckBox x:Name="UseDialogVideoConfigCheckBox"
                                      Content="Sử dụng cấu hình dialog video (real-time)"
                                      Style="{StaticResource ReadableCheckBoxStyle}"
                                      Margin="0,0,0,14"
                                      IsChecked="True"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            <Border x:Name="ActionButtonsBorder" Grid.Row="2" Margin="0,10,0,0" Padding="10,12"
                HorizontalAlignment="Stretch"
                Background="{DynamicResource ThemeActionBarBackgroundBrush}" CornerRadius="8"
                BorderBrush="{DynamicResource ThemeActionBarBorderBrush}" BorderThickness="1">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="BottomBarGroupGeneral" CornerRadius="8" Padding="8,6" Margin="0,0,8,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="GeneralActionBar" Orientation="Horizontal">
                                <Button x:Name="ExtractFramesButton" Height="32" MinWidth="120" Padding="12,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionExtractBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🖼" Margin="0,0,4,0"/><TextBlock x:Name="ExtractFramesButtonLabel" Text="Tách Frame" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="RunAllButton" Height="32" MinWidth="120" Padding="14,0" Margin="8,0,0,0" Style="{StaticResource VideoChromePrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="▶" Margin="0,0,6,0" FontSize="11"/><TextBlock x:Name="RunAllButtonLabel" Text="Chạy tất cả" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomBarGroupGrading" CornerRadius="8" Padding="8,6" Margin="0,0,8,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="GradingActionBar" Orientation="Horizontal">
                                <Button x:Name="ApplyGradingButton" Height="32" MinWidth="120" Padding="14,0" Style="{StaticResource VideoChromePrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🎨" Margin="0,0,6,0"/><TextBlock x:Name="ApplyGradingButtonLabel" Text="Áp dụng màu" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="ResetGradingButton2" Height="32" MinWidth="88" Padding="12,0" Margin="8,0,0,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="↺" Margin="0,0,6,0"/><TextBlock x:Name="ResetGradingButton2Label" Text="Đặt lại" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomBarGroupFilters" CornerRadius="8" Padding="8,6" Margin="0,0,8,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="FiltersActionBar" Orientation="Horizontal">
                                <Button x:Name="BurnSubtitleButton" Height="32" MinWidth="108" Padding="12,0" Margin="0,0,6,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionSubtitleBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="💬" Margin="0,0,6,0"/><TextBlock x:Name="BurnSubtitleButtonLabel" Text="Gắn phụ đề" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="QuickWatermarkButton" Height="32" MinWidth="108" Padding="12,0" Margin="0,0,6,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionWatermarkBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="💧" Margin="0,0,6,0"/><TextBlock x:Name="QuickWatermarkButtonLabel" Text="Watermark" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="ApplyOverlayToVideoActionButton" Height="32" MinWidth="120" Padding="12,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionWatermarkBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🧩" Margin="0,0,6,0"/><TextBlock x:Name="ApplyOverlayToVideoActionButtonLabel" Text="Áp dụng Overlay" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomBarGroupAudio" CornerRadius="8" Padding="8,6" Margin="0,0,8,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="AudioActionBar" Orientation="Horizontal">
                                <Button x:Name="MixAudioButton" Height="32" MinWidth="112" Padding="14,0" Style="{StaticResource VideoChromePrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔊" Margin="0,0,6,0"/><TextBlock x:Name="MixAudioButtonLabel" Text="Ghép Audio" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomBarGroupExport" CornerRadius="8" Padding="8,6" Margin="0,0,8,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="ExportActionBar" Orientation="Horizontal">
                                <Button x:Name="RunExportButton" Height="32" MinWidth="108" Padding="14,0" Style="{StaticResource VideoChromePrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="📤" Margin="0,0,6,0"/><TextBlock x:Name="RunExportButtonLabel" Text="Xuất video" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="SnapshotButton" Height="32" MinWidth="100" Padding="12,0" Margin="8,0,0,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionSnapshotBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="📷" Margin="0,0,6,0"/><TextBlock x:Name="SnapshotButtonLabel" Text="Chụp ảnh" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="ConvertFormatButton" Visibility="Collapsed"/>
                                <Button x:Name="QuickTrimButton" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomBarGroupOutputs" CornerRadius="8" Padding="8,6" Margin="0,0,8,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="OutputsActionBar" Orientation="Horizontal">
                                <Button x:Name="OpenOutputVideoActionButton" Height="32" MinWidth="100" Padding="12,0" Margin="0,0,6,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionFolderVideoBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="🎬" Margin="0,0,6,0"/><TextBlock x:Name="OpenOutputVideoActionButtonLabel" Text="Mở Video" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="OpenFramesFolderActionButton" Height="32" MinWidth="124" Padding="12,0" Style="{StaticResource VideoChromeSecondaryButtonStyle}" Background="{DynamicResource ThemeActionFolderFramesBrush}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="📁" Margin="0,0,6,0"/><TextBlock x:Name="OpenFramesFolderActionButtonLabel" Text="Mở Folder Frame" FontSize="11" Visibility="Collapsed"/></StackPanel>
                                </Button>
                                <Button x:Name="OpenOutputVideoFolderQuickButton" Visibility="Collapsed"/>
                                <Button x:Name="OpenFramesFolderQuickButton" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="BottomBarGroupSettings" CornerRadius="8" Padding="8,6" Margin="0,0,0,8"
                                BorderThickness="1" BorderBrush="{DynamicResource ThemeBottomBarGroupInactiveBorderBrush}" Background="Transparent">
                            <StackPanel x:Name="SettingsActionBar" Orientation="Horizontal">
                                <Button x:Name="SaveSettingsButton" Height="32" MinWidth="120" Padding="14,0" Style="{StaticResource VideoChromePrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="💾" Margin="0,0,6,0"/><TextBlock x:Name="SaveSettingsButtonLabel" Text="Lưu cài đặt" FontSize="11" FontWeight="SemiBold" Visibility="Collapsed"/></StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </WrapPanel>
            </Border>
            </Grid>
        </Grid>
    </Grid>
    </Grid>
</UserControl>
