                            <TextBlock x:Name="EstimatedTimeText" HorizontalAlignment="Right" FontSize="10.5" Opacity="0.7" Text="ETA: --"/>
                        </Grid>
                    </Grid>
                </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="4,8,8,8">
