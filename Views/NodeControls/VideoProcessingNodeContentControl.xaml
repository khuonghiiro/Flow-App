<UserControl x:Class="FlowMy.Views.NodeControls.VideoProcessingNodeContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             xmlns:models="clr-namespace:FlowMy.Models.Nodes"
             Background="#0F0F17"
             Foreground="#E8E8F0">
    <UserControl.Resources>
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#35FFFFFF"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
           
        </Style>
        <Style x:Key="InnerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#18000000"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="TextElement.Foreground" Value="#F0F4FF"/>
        </Style>
        <Style x:Key="ValueBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#88EAF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1AFFFFFF"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"/>
                            <TextBlock Text="▾"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="#88FFFFFF"
                                       FontSize="10"/>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="#1E1E30"
                                        BorderBrush="#40FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MaxHeight="200"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C6BF8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#E8F0FF"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#28FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#7C6BF8"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}"/>
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="BorderBrush" Value="#35FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#E8F0FF"/>
            <Setter Property="SelectionBrush" Value="#7C6BF8"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}"/>
        <Style TargetType="Slider" x:Key="ModernSliderStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" CornerRadius="2" Background="#33FFFFFF" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="#7C6BF8" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="White"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="#7C6BF8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="18" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetChipStyle" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7C6BF8"/>
                    <Setter Property="BorderBrush" Value="#7C6BF8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PresetChipResetStyle" TargetType="Button" BasedOn="{StaticResource PresetChipStyle}">
            <Setter Property="Background" Value="#284B5563"/>
        </Style>
        <Style x:Key="PillTabNavStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="0,7"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="#AAFFFFFF"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="2,7">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#7C6BF8"/>
                                            <Setter TargetName="Bd" Property="Padding" Value="4,7"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                            <Setter Property="Foreground" Value="#EEFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="11" Background="#28FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1"/>
                            <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White" Margin="3" HorizontalAlignment="Left"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#7C6BF8"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="280"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" x:Name="HeaderCardBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,8" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:SvgViewboxEx x:Name="IconView" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display"/>
                    <TextBlock x:Name="VideoPathText" FontSize="10" Opacity="0.65" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" x:Name="RunProcessingButton" Height="30" MinWidth="84" Padding="14,0" Style="{DynamicResource PrimaryButton}" ToolTip="Chạy xử lý video qua FFmpeg">
                    <TextBlock Text="Chạy"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" x:Name="PreviewContainerBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,6" Padding="0" ClipToBounds="True" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Viewbox Grid.Row="0" Stretch="Uniform" StretchDirection="Both">
                    <MediaElement x:Name="PreviewMedia"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  Stretch="Uniform"
                                  Width="1280"
                                  Height="720"
                                  Volume="0.7"
                                  ScrubbingEnabled="True"
                                  Visibility="Collapsed"
                                  MouseLeftButtonUp="PreviewMedia_MouseLeftButtonUp"
                                  Cursor="Hand"/>
                </Viewbox>
                <Grid Grid.Row="0" x:Name="VideoAreaGrid">
                    <Grid x:Name="PreviewPlaceholder"
                          Panel.ZIndex="1"
                          Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Chưa chọn video"
                                   FontSize="11.5"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Nhấn 'Mở video' để bắt đầu"
                                   FontSize="10"
                                   Opacity="0.35"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <Button x:Name="OpenVideoInPlaceholderButton"
                                Height="32"
                                Margin="0,10,0,0"
                                Padding="16,0"
                                Style="{DynamicResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" Margin="0,0,6,0"/>
                                <TextBlock Text="Chọn video" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
                <Button x:Name="OpenVideoButton"
                        Grid.Row="0"
                        Panel.ZIndex="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Margin="8,8,0,0"
                        Height="28"
                        Padding="10,0"
                        Style="{DynamicResource SecondaryButton}"
                        Opacity="0.84">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📁" FontSize="10" Margin="0,0,4,0"/>
                        <TextBlock Text="Mở video" FontSize="10.5"/>
                    </StackPanel>
                </Button>
                <StackPanel Grid.Row="0"
                            Panel.ZIndex="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Orientation="Horizontal"
                            Margin="0,8,8,0">
                    <Border x:Name="HwBadge"
                            Background="#2A7C6BF8" BorderBrush="#557C6BF8"
                            BorderThickness="1" CornerRadius="10"
                            Padding="7,3" Margin="0,0,6,0" VerticalAlignment="Center">
                        <TextBlock x:Name="HwBadgeText" FontSize="9" FontWeight="Medium" Foreground="#D0C8FF"/>
                    </Border>
                    <Border Padding="7,3" CornerRadius="8"
                            Background="#88000000"
                            BorderBrush="#30FFFFFF" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="6" Height="6" Fill="#4ADE80" Margin="0,0,5,0" VerticalAlignment="Center" x:Name="LiveDot" Visibility="Collapsed"/>
                            <TextBlock Text="Preview" FontSize="9.5" Foreground="#DDFFFFFF"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Border x:Name="GradingOverlay"
                        Grid.Row="0"
                        Panel.ZIndex="2"
                        Background="Transparent"
                        IsHitTestVisible="False"/>
                <Border x:Name="QuickGradingPanel"
                        Grid.Row="0"
                        Panel.ZIndex="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,8"
                        Padding="8,6"
                        CornerRadius="10"
                        Background="#CC0A0A1E"
                        BorderBrush="#30FFFFFF" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Quick Grade" FontSize="9" Foreground="#88FFFFFF" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Sáng" FontSize="9.5" Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickBrightnessSlider" Grid.Column="1" Minimum="-1" Maximum="1" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickBrightnessLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="#AAFFFFFF" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Tương phản" FontSize="9.5" Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickContrastSlider" Grid.Column="1" Minimum="0.1" Maximum="3" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickContrastLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="#AAFFFFFF" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Bão hòa" FontSize="9.5" Foreground="#99FFFFFF" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickSaturationSlider" Grid.Column="1" Minimum="0" Maximum="3" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickSaturationLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="#AAFFFFFF" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="0"
                            Panel.ZIndex="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Orientation="Vertical"
                            Margin="0,0,8,8">
                    <Button x:Name="ToggleQuickGradeButton" Width="30" Height="30" Style="{StaticResource IconButtonStyle}" Background="#AA0A0A1E" Margin="0,0,0,4">
                        <TextBlock Text="🎨" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="QuickSnapshotButton" Width="30" Height="30" Style="{StaticResource IconButtonStyle}" Background="#AA0A0A1E" Margin="0,0,0,4">
                        <TextBlock Text="📷" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="QuickSetTrimButton" Width="30" Height="30" Style="{StaticResource IconButtonStyle}" Background="#AA0A0A1E">
                        <TextBlock Text="✂" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
                <Border x:Name="FrameInfoOverlay"
                        Grid.Row="0"
                        Panel.ZIndex="4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,8,0,0"
                        Padding="10,4"
                        CornerRadius="8"
                        Background="#AA000000"
                        BorderBrush="#20FFFFFF"
                        BorderThickness="1"
                        Visibility="Collapsed"
                        IsHitTestVisible="False">
                    <TextBlock x:Name="FrameInfoText" FontSize="9.5" FontFamily="Consolas" Foreground="#DDFFFFFF"/>
                </Border>
                <Border Grid.Row="1" Background="#EE0A0A18" Padding="10,6,10,8" CornerRadius="0,0,12,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TimeCurrentText" Text="00:00" FontSize="9.5" Foreground="#99FFFFFF" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <Grid Grid.Column="1" Height="14" Cursor="Hand" x:Name="ProgressBarHitArea"
                                  VerticalAlignment="Center"
                                  MouseDown="ProgressBarHitArea_MouseDown"
                                  MouseMove="ProgressBarHitArea_MouseMove"
                                  MouseEnter="ProgressBarHitArea_MouseEnter"
                                  MouseLeave="ProgressBarHitArea_MouseLeave">
                                <Border Background="#2AFFFFFF" CornerRadius="2" Height="3" VerticalAlignment="Center"/>
                                <Border x:Name="ProgressBarFill" Background="#7C6BF8" CornerRadius="2" Height="3" VerticalAlignment="Center" HorizontalAlignment="Left" Width="0"/>
                                <Canvas>
                                    <Ellipse x:Name="ProgressThumb" Width="12" Height="12" Fill="White" Visibility="Collapsed"/>
                                </Canvas>
                            </Grid>
                            <TextBlock x:Name="TimeTotalText" Grid.Column="2" Text="00:00" FontSize="9.5" Foreground="#99FFFFFF" FontFamily="Consolas" VerticalAlignment="Center" Margin="7,0,0,0"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SkipBackButton" Grid.Column="0" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏮" FontSize="12" ToolTip="Lùi 5 giây"/>
                            <Button x:Name="PlayPauseButton" Grid.Column="2" Width="34" Height="34" Style="{StaticResource PlayButtonStyle}"/>
                            <Button x:Name="StopButton" Grid.Column="4" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏹" FontSize="12" ToolTip="Dừng"/>
                            <Button x:Name="SkipForwardButton" Grid.Column="6" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏭" FontSize="12" ToolTip="Tiến 5 giây"/>
                            <Button x:Name="MuteButton" Grid.Column="8" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" FontSize="11" ToolTip="Bật/Tắt âm"/>
                            <Slider x:Name="VolumeSlider" Grid.Column="9" Minimum="0" Maximum="1" Value="0.7" VerticalAlignment="Center" Margin="4,0" Style="{StaticResource ModernSliderStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" x:Name="TabNavBorder" Margin="0,0,0,6" Padding="4" Background="#0AFFFFFF" CornerRadius="12">
                <ListBox x:Name="TabNavList" Style="{StaticResource PillTabNavStyle}" SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBoxItem Content="Tổng quan" Tag="General"/>
                    <ListBoxItem Content="Màu sắc" Tag="Grading"/>
                    <ListBoxItem Content="Bộ lọc" Tag="Filters"/>
                    <ListBoxItem Content="Audio" Tag="Audio"/>
                    <ListBoxItem Content="Xuất file" Tag="Export"/>
                    <ListBoxItem Content="Đầu ra" Tag="Outputs"/>
                    <ListBoxItem Content="Nhật ký" Tag="Log"/>
                </ListBox>
            </Border>
            <Border Grid.Row="1" x:Name="TabContentBorder" Style="{StaticResource GlassCardStyle}" Padding="12,10">
                <Grid>
                    <ScrollViewer x:Name="GeneralTabContent" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Text="RESOLUTION" FontSize="9" Foreground="#99AABBCC"/><TextBlock x:Name="StatResolutionText" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEFF"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="FPS NGUỒN" FontSize="9" Foreground="#99AABBCC"/><TextBlock x:Name="StatFpsText" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEFF"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="THỜI LƯỢNG" FontSize="9" Foreground="#99AABBCC"/><TextBlock x:Name="StatDurationText" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEFF"/></StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10" Padding="10,8">
                                <StackPanel>
                                    <TextBlock x:Name="CodecInfoText" FontSize="10.5" Foreground="#AAC4D4E8"/>
