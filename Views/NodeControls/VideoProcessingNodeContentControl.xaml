<UserControl x:Class="FlowMy.Views.NodeControls.VideoProcessingNodeContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             xmlns:models="clr-namespace:FlowMy.Models.Nodes"
             Background="#0F0F17"
             Foreground="#E8E8F0">
    <UserControl.Resources>
        <SolidColorBrush x:Key="ThemeTextPrimaryBrush" Color="#E8E8F0"/>
        <SolidColorBrush x:Key="ThemeTextSecondaryBrush" Color="#C9D3E2"/>
        <SolidColorBrush x:Key="ThemeCardBackgroundBrush" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="ThemeCardBorderBrush" Color="#35FFFFFF"/>
        <SolidColorBrush x:Key="ThemeInnerCardBackgroundBrush" Color="#18000000"/>
        <SolidColorBrush x:Key="ThemeInnerCardBorderBrush" Color="#30FFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputBackgroundBrush" Color="#15FFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputBorderBrush" Color="#35FFFFFF"/>
        <SolidColorBrush x:Key="ThemeInputForegroundBrush" Color="#E8F0FF"/>
        <SolidColorBrush x:Key="ThemeOverlayBackgroundBrush" Color="#AA000000"/>
        <SolidColorBrush x:Key="ThemeOverlayBorderBrush" Color="#30FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTimelinePanelBrush" Color="#EE0A0A18"/>
        <SolidColorBrush x:Key="ThemeTrackBackgroundBrush" Color="#2AFFFFFF"/>
        <SolidColorBrush x:Key="ThemeAccentBrush" Color="#7C6BF8"/>
        <SolidColorBrush x:Key="ThemeTabNavBackgroundBrush" Color="#0AFFFFFF"/>
        <SolidColorBrush x:Key="ThemeLogContainerBackgroundBrush" Color="#0C000000"/>
        <SolidColorBrush x:Key="ThemeActionBarBackgroundBrush" Color="#12FFFFFF"/>
        <SolidColorBrush x:Key="ThemeActionBarBorderBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="ThemeOnAccentTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeSliderThumbBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ThemeComboPopupBackgroundBrush" Color="#1E1E30"/>
        <SolidColorBrush x:Key="ThemeComboItemHoverBrush" Color="#28FFFFFF"/>
        <SolidColorBrush x:Key="ThemeTabHoverBrush" Color="#28FFFFFF"/>
        <SolidColorBrush x:Key="ThemeActionExtractBrush" Color="#205B8FF9"/>
        <SolidColorBrush x:Key="ThemeActionSubtitleBrush" Color="#207C6BF8"/>
        <SolidColorBrush x:Key="ThemeActionWatermarkBrush" Color="#2014B8A6"/>
        <SolidColorBrush x:Key="ThemeActionConvertBrush" Color="#20A78BFA"/>
        <SolidColorBrush x:Key="ThemeActionTrimBrush" Color="#20EF4444"/>
        <SolidColorBrush x:Key="ThemeActionSnapshotBrush" Color="#20F59E0B"/>
        <SolidColorBrush x:Key="ThemeActionFolderVideoBrush" Color="#204ADE80"/>
        <SolidColorBrush x:Key="ThemeActionFolderFramesBrush" Color="#20F59E0B"/>
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeCardBorderBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ThemeCardBackgroundBrush}"/>
           
        </Style>
        <Style x:Key="InnerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ThemeInnerCardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInnerCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="TextElement.Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
        </Style>
        <Style x:Key="ValueBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#88EAF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"/>
                            <TextBlock Text="▾"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                       FontSize="10"/>
                            <ToggleButton x:Name="ToggleButton"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border Background="{DynamicResource ThemeComboPopupBackgroundBrush}"
                                        BorderBrush="{DynamicResource ThemeInputBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MaxHeight="200"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeComboItemHoverBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#60FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource ThemeInputForegroundBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource ThemeComboPopupBackgroundBrush}"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeComboItemHoverBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}"/>
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource ThemeInputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeInputForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ThemeInputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="{DynamicResource ThemeInputForegroundBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBoxStyle}"/>
        <Style TargetType="Slider" x:Key="ModernSliderStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" CornerRadius="2" Background="{DynamicResource ThemeTrackBackgroundBrush}" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="{DynamicResource ThemeAccentBrush}" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="{DynamicResource ThemeSliderThumbBrush}"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccentTextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="18" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetChipStyle" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource ThemeAccentBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PresetChipResetStyle" TargetType="Button" BasedOn="{StaticResource PresetChipStyle}">
            <Setter Property="Background" Value="#284B5563"/>
        </Style>
        <Style x:Key="PillTabNavStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0,7"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="6,7" Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                            <Setter TargetName="Bd" Property="Padding" Value="4,7"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ThemeTabHoverBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="11" Background="{DynamicResource ThemeTrackBackgroundBrush}" BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1"/>
                            <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="{DynamicResource ThemeSliderThumbBrush}" Margin="3" HorizontalAlignment="Left"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AspectRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource ThemeTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" CornerRadius="7" Padding="{TemplateBinding Padding}"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeAccentBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ThemeOnAccentTextBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource ThemeTabHoverBrush}"/>
                                <Setter Property="Foreground"
                                        Value="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="HeaderCardBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,8" Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:SvgViewboxEx x:Name="IconView" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display"/>
                    <TextBlock x:Name="VideoPathText" FontSize="10" Opacity="0.65" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" x:Name="ThemeModeButton" Height="30" MinWidth="40" Padding="10,0" Style="{DynamicResource SecondaryButton}" ToolTip="Đổi sáng/tối">
                    <TextBlock Text="☀"/>
                </Button>
                <Button Grid.Column="4" x:Name="ToggleNodeSizeButton" Height="30" MinWidth="40" Padding="10,0" Style="{DynamicResource SecondaryButton}" ToolTip="Phóng to/thu nhỏ node video">
                    <TextBlock Text="⤢"/>
                </Button>
                <Button Grid.Column="6" x:Name="RunProcessingButton" Height="30" MinWidth="84" Padding="14,0" Style="{DynamicResource PrimaryButton}" ToolTip="Chạy xử lý video qua FFmpeg">
                    <TextBlock Text="Chạy"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="260"/>
                <ColumnDefinition Width="3*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" x:Name="PreviewContainerBorder" Style="{StaticResource GlassCardStyle}" Margin="8,8,4,8" Padding="0" ClipToBounds="True" VerticalAlignment="Stretch">
                <Grid x:Name="VideoContainerGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="140"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Margin="8,8,8,4" Padding="6,4" Background="{DynamicResource ThemeTabNavBackgroundBrush}" CornerRadius="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="OpenVideoButton"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Height="28"
                                Padding="10,0"
                                Style="{DynamicResource PrimaryButton}"
                                Background="#CCDC2626"
                                Click="OpenVideoButton_Click"
                                Opacity="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" FontSize="10" Margin="0,0,4,0"/>
                                <TextBlock Text="Mở video" FontSize="10.5"/>
                            </StackPanel>
                        </Button>
                        <WrapPanel Grid.Column="1" HorizontalAlignment="Center">
                            <RadioButton x:Name="Aspect169" Content="16:9" GroupName="AspectRatio" IsChecked="True" Style="{StaticResource AspectRadioStyle}" ToolTip="Ngang chuẩn 16:9"/>
                            <RadioButton x:Name="Aspect916" Content="9:16" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Dọc 9:16"/>
                            <RadioButton x:Name="Aspect11" Content="1:1" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Vuông 1:1"/>
                            <RadioButton x:Name="Aspect32" Content="3:2" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Ngang 3:2"/>
                            <RadioButton x:Name="Aspect23" Content="2:3" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Dọc 2:3"/>
                            <RadioButton x:Name="AspectAuto" Content="Auto" GroupName="AspectRatio" Style="{StaticResource AspectRadioStyle}" ToolTip="Dùng kích thước video thật"/>
                        </WrapPanel>
                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Margin="8,0,0,0">
                            <Border x:Name="HwBadge"
                                    Background="{DynamicResource ThemeAccentBrush}" BorderBrush="{DynamicResource ThemeOverlayBorderBrush}"
                                    BorderThickness="1" CornerRadius="10"
                                    Padding="7,3" Margin="0,0,6,0" VerticalAlignment="Center">
                                <TextBlock x:Name="HwBadgeText" FontSize="9" FontWeight="Medium" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                            </Border>
                            <Border Padding="7,3" CornerRadius="8"
                                    Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                                    BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#4ADE80" Margin="0,0,5,0" VerticalAlignment="Center" x:Name="LiveDot" Visibility="Collapsed"/>
                                    <TextBlock Text="Preview" FontSize="9.5" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="ToggleBeforeAfterButton"
                                    Margin="6,0,0,0"
                                    Height="24"
                                    Padding="8,0"
                                    FontSize="9.5"
                                    Style="{DynamicResource SecondaryButton}"
                                    Content="Before/After"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Viewbox x:Name="VideoViewbox" Grid.Row="1" Stretch="Uniform" StretchDirection="Both" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <MediaElement x:Name="PreviewMedia"
                                  LoadedBehavior="Manual"
                                  UnloadedBehavior="Manual"
                                  Stretch="Uniform"
                                  Width="1280"
                                  Height="720"
                                  Volume="0.7"
                                  ScrubbingEnabled="False"
                                  Visibility="Collapsed"
                                  MouseLeftButtonUp="PreviewMedia_MouseLeftButtonUp"
                                  Cursor="Hand"/>
                </Viewbox>
                <Grid Grid.Row="1" x:Name="VideoAreaGrid">
                    <Grid x:Name="PreviewPlaceholder"
                          Panel.ZIndex="1"
                          Visibility="Visible">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Chưa chọn video"
                                   FontSize="11.5"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Nhấn 'Mở video' để bắt đầu"
                                   FontSize="10"
                                   Opacity="0.35"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                        <Button x:Name="OpenVideoInPlaceholderButton"
                                Height="32"
                                Margin="0,10,0,0"
                                Padding="16,0"
                                Background="#CCDC2626"
                                Click="OpenVideoInPlaceholderButton_Click"
                                Style="{DynamicResource PrimaryButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" Margin="0,0,6,0"/>
                                <TextBlock Text="Chọn video" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
                <Border x:Name="GradingOverlay"
                        Grid.Row="1"
                        Panel.ZIndex="2"
                        Background="Transparent"
                        IsHitTestVisible="False"/>
                <controls:OverlayCanvas x:Name="OverlayCanvasControl"
                                        Grid.Row="1"
                                        Panel.ZIndex="3"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"/>
                <Border x:Name="QuickGradingPanel"
                        Grid.Row="1"
                        Panel.ZIndex="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="8,0,0,8"
                        Padding="8,6"
                        CornerRadius="10"
                        Background="{DynamicResource ThemeOverlayBackgroundBrush}"
                        BorderBrush="{DynamicResource ThemeOverlayBorderBrush}" BorderThickness="1"
                        Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Quick Grade" FontSize="9" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Sáng" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickBrightnessSlider" Grid.Column="1" Minimum="-1" Maximum="1" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickBrightnessLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,0,0,3">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Tương phản" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickContrastSlider" Grid.Column="1" Minimum="0.1" Maximum="3" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickContrastLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="52"/><ColumnDefinition Width="80"/><ColumnDefinition Width="28"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Bão hòa" FontSize="9.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" VerticalAlignment="Center"/>
                            <Slider x:Name="QuickSaturationSlider" Grid.Column="1" Minimum="0" Maximum="3" Style="{StaticResource ModernSliderStyle}"/>
                            <TextBlock x:Name="QuickSaturationLabel" Grid.Column="2" FontSize="9" FontFamily="Consolas" Foreground="{DynamicResource ThemeTextSecondaryBrush}" HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <StackPanel Grid.Row="1"
                            Panel.ZIndex="5"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
