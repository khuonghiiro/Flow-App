                                    <Button x:Name="ClearLogButton" Content="Xóa" Height="22" Padding="8,0" FontSize="10" Style="{DynamicResource SecondaryButton}"/>
                                    <Button x:Name="CopyLogButton" Content="Copy" Height="22" Padding="8,0" FontSize="10" Style="{DynamicResource SecondaryButton}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="2">
                            <Grid>
                                <Border Background="{DynamicResource ThemeTrackBackgroundBrush}"/>
                                <Border x:Name="ProgressFill" HorizontalAlignment="Left" Background="{DynamicResource ThemeAccentBrush}" Width="0"/>
                            </Grid>
                        </Border>
