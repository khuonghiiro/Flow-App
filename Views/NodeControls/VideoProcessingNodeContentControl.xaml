                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="KHOẢNG CÁCH" FontSize="8.5" Foreground="{DynamicResource ThemeTextSecondaryBrush}" Margin="0,0,0,2"/>
                                                <TextBlock x:Name="EstFrameIntervalText" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource ThemeTextPrimaryBrush}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="FrameIndexPreviewText"
                                               Margin="0,6,0,0"
                                               FontSize="10"
                                               Foreground="{DynamicResource ThemeTextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
