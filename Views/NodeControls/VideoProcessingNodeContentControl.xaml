<UserControl x:Class="FlowMy.Views.NodeControls.VideoProcessingNodeContentControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:FlowMy.Controls"
             xmlns:models="clr-namespace:FlowMy.Models.Nodes"
             Background="#0F0F17"
             Foreground="#E8E8F0">
    <UserControl.Resources>
        <Style x:Key="GlassCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#35FFFFFF"/>
            <Setter Property="Background" Value="#1AFFFFFF"/>
           
        </Style>
        <Style x:Key="InnerCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#18000000"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="TextElement.Foreground" Value="#F0F4FF"/>
        </Style>
        <Style x:Key="ValueBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
        <Style x:Key="ReadableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EAF2FF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#88EAF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="Slider" x:Key="ModernSliderStyle">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="4" CornerRadius="2" Background="#33FFFFFF" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Background="#7C6BF8" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Background="Transparent" BorderThickness="0" Height="4" VerticalAlignment="Center"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="16" Height="16" Fill="White"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAFFFFFF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="Background" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PlayButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Background" Value="#7C6BF8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="18" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetChipStyle" TargetType="Button">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="Foreground" Value="#E8F0FF"/>
            <Setter Property="BorderBrush" Value="#30FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="20"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#7C6BF8"/>
                    <Setter Property="BorderBrush" Value="#7C6BF8"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="PresetChipResetStyle" TargetType="Button" BasedOn="{StaticResource PresetChipStyle}">
            <Setter Property="Background" Value="#284B5563"/>
        </Style>
        <Style x:Key="PillTabNavStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="0,7"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="#AAFFFFFF"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="8" Padding="2,7">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#7C6BF8"/>
                                            <Setter TargetName="Bd" Property="Padding" Value="4,7"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#28FFFFFF"/>
                                            <Setter Property="Foreground" Value="#EEFFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Track" CornerRadius="11" Background="#28FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1"/>
                            <Ellipse x:Name="Thumb" Width="16" Height="16" Fill="White" Margin="3" HorizontalAlignment="Left"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#7C6BF8"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Row 0: Header -->
            <RowDefinition Height="Auto"/> <!-- Row 1: Video preview -->
            <RowDefinition Height="Auto"/> <!-- Row 2: Tab nav -->
            <RowDefinition Height="Auto"/> <!-- Row 3: Tab content -->
            <RowDefinition Height="Auto"/> <!-- Row 4: Action buttons -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="HeaderCardBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,8" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <controls:SvgViewboxEx x:Name="IconView" Width="22" Height="22" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI Variable Display"/>
                    <TextBlock x:Name="VideoPathText" FontSize="10" Opacity="0.65" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>
                <Border Grid.Column="2" x:Name="HwBadge" Background="#2A7C6BF8" BorderBrush="#557C6BF8" BorderThickness="1" CornerRadius="12" Padding="8,3" VerticalAlignment="Center">
                    <TextBlock x:Name="HwBadgeText" FontSize="9.5" FontWeight="Medium" Foreground="#D0C8FF"/>
                </Border>
                <Button Grid.Column="4" x:Name="OpenVideoButton" Height="30" MinWidth="96" Padding="14,0" Style="{DynamicResource SecondaryButton}">
                    <TextBlock Text="Mở video"/>
                </Button>
                <Button Grid.Column="6" x:Name="RunProcessingButton" Height="30" MinWidth="84" Padding="14,0" Style="{DynamicResource PrimaryButton}" ToolTip="Chạy xử lý video qua FFmpeg">
                    <TextBlock Text="Run"/>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" x:Name="PreviewContainerBorder" Style="{StaticResource GlassCardStyle}" Margin="0,0,0,6" Padding="0" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <MediaElement x:Name="PreviewMedia"
                              Grid.Row="0"
                              LoadedBehavior="Manual"
                              UnloadedBehavior="Manual"
                              Stretch="Uniform"
                              Volume="0.7"
                              ScrubbingEnabled="True"
                              MinHeight="160"
                              Visibility="Collapsed"
                              MouseLeftButtonUp="PreviewMedia_MouseLeftButtonUp"
                              Cursor="Hand"/>
                <Grid Grid.Row="0"
                      x:Name="PreviewPlaceholder"
                      Panel.ZIndex="1"
                      Visibility="Visible">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False">
                        <TextBlock Text="Chưa chọn video"
                                   FontSize="11.5"
                                   Opacity="0.5"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Nhấn 'Mở video' để bắt đầu"
                                   FontSize="10"
                                   Opacity="0.35"
                                   HorizontalAlignment="Center"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
                <Border Grid.Row="0"
                        Panel.ZIndex="2"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="8"
                        Padding="7,3"
                        CornerRadius="8"
                        Background="#88000000"
                        BorderBrush="#30FFFFFF"
                        BorderThickness="1"
                        IsHitTestVisible="False">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="6" Height="6" Fill="#4ADE80" Margin="0,0,5,0" VerticalAlignment="Center" x:Name="LiveDot" Visibility="Collapsed"/>
                        <TextBlock Text="Preview" FontSize="9.5" Foreground="#DDFFFFFF"/>
                    </StackPanel>
                </Border>
                <Border x:Name="GradingOverlay"
                        Grid.Row="0"
                        Panel.ZIndex="2"
                        Background="Transparent"
                        IsHitTestVisible="False"/>
                <Border Grid.Row="1" Background="#EE0A0A18" Padding="10,6,10,8" CornerRadius="0,0,12,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TimeCurrentText" Text="00:00" FontSize="9.5" Foreground="#99FFFFFF" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,7,0"/>
                            <Grid Grid.Column="1" Height="14" Cursor="Hand" x:Name="ProgressBarHitArea"
                                  VerticalAlignment="Center"
                                  MouseDown="ProgressBarHitArea_MouseDown"
                                  MouseMove="ProgressBarHitArea_MouseMove"
                                  MouseEnter="ProgressBarHitArea_MouseEnter"
                                  MouseLeave="ProgressBarHitArea_MouseLeave">
                                <Border Background="#2AFFFFFF" CornerRadius="2" Height="3" VerticalAlignment="Center"/>
                                <Border x:Name="ProgressBarFill" Background="#7C6BF8" CornerRadius="2" Height="3" VerticalAlignment="Center" HorizontalAlignment="Left" Width="0"/>
                                <Canvas>
                                    <Ellipse x:Name="ProgressThumb" Width="12" Height="12" Fill="White" Visibility="Collapsed"/>
                                </Canvas>
                            </Grid>
                            <TextBlock x:Name="TimeTotalText" Grid.Column="2" Text="00:00" FontSize="9.5" Foreground="#99FFFFFF" FontFamily="Consolas" VerticalAlignment="Center" Margin="7,0,0,0"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="SkipBackButton" Grid.Column="0" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏮" FontSize="12" ToolTip="Lùi 5 giây"/>
                            <Button x:Name="PlayPauseButton" Grid.Column="2" Width="34" Height="34" Style="{StaticResource PlayButtonStyle}"/>
                            <Button x:Name="StopButton" Grid.Column="4" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏹" FontSize="12" ToolTip="Dừng"/>
                            <Button x:Name="SkipForwardButton" Grid.Column="6" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" Content="⏭" FontSize="12" ToolTip="Tiến 5 giây"/>
                            <Button x:Name="MuteButton" Grid.Column="8" Width="26" Height="26" Style="{StaticResource IconButtonStyle}" FontSize="11" ToolTip="Bật/Tắt âm"/>
                            <Slider x:Name="VolumeSlider" Grid.Column="9" Minimum="0" Maximum="1" Value="0.7" VerticalAlignment="Center" Margin="4,0" Style="{StaticResource ModernSliderStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" x:Name="TabNavBorder" Margin="0,0,0,6" Padding="4" Background="#0AFFFFFF" CornerRadius="12">
            <ListBox x:Name="TabNavList" Style="{StaticResource PillTabNavStyle}" SelectionMode="Single" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBoxItem Content="General" Tag="General"/>
                <ListBoxItem Content="Grading" Tag="Grading"/>
                <ListBoxItem Content="Filters" Tag="Filters"/>
                <ListBoxItem Content="Audio" Tag="Audio"/>
                <ListBoxItem Content="Export" Tag="Export"/>
                <ListBoxItem Content="Log" Tag="Log"/>
            </ListBox>
        </Border>

        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" x:Name="TabContentBorder" Style="{StaticResource GlassCardStyle}" Padding="12,10">
                <Grid>
                    <ScrollViewer x:Name="GeneralTabContent" VerticalScrollBarVisibility="Auto" Visibility="Visible">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0"><TextBlock Text="RESOLUTION" FontSize="9" Foreground="#99AABBCC"/><TextBlock x:Name="StatResolutionText" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEFF"/></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="FPS NGUỒN" FontSize="9" Foreground="#99AABBCC"/><TextBlock x:Name="StatFpsText" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEFF"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="THỜI LƯỢNG" FontSize="9" Foreground="#99AABBCC"/><TextBlock x:Name="StatDurationText" FontSize="13" FontWeight="SemiBold" Foreground="#EEEEFF"/></StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10" Padding="10,8">
                                <StackPanel>
                                    <TextBlock x:Name="CodecInfoText" FontSize="10.5" Foreground="#AAC4D4E8"/>
                                    <TextBlock x:Name="AudioSummaryText" FontSize="10.5" Foreground="#AAC4D4E8" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Frame Extract FPS" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                                <Slider x:Name="FpsSlider" Minimum="0.1" Maximum="30" Style="{StaticResource ModernSliderStyle}"/>
                                <Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}">
                                    <TextBlock x:Name="FpsValueText" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="Extract Frames" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <ComboBox x:Name="FrameFormatCombo" Height="28" Margin="0,0,6,0">
                                            <ComboBoxItem Content="PNG" Tag="png" IsSelected="True"/>
                                            <ComboBoxItem Content="JPEG" Tag="jpg"/>
                                            <ComboBoxItem Content="WebP" Tag="webp"/>
                                        </ComboBox>
                                        <Slider Grid.Column="1" x:Name="JpegQualitySlider" Minimum="0" Maximum="100" Value="90" Style="{StaticResource ModernSliderStyle}"/>
                                    </Grid>
                                    <CheckBox x:Name="ExtractAllFramesCheckBox" Content="Extract All Frames" Style="{StaticResource ReadableCheckBoxStyle}"/>
                                    <TextBlock x:Name="EstimatedFrameCountText" Margin="0,6,0,0" FontSize="10.5" Foreground="#99C0C8D8"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <CheckBox x:Name="OutputBase64CheckBox" Content="Output Base64" Grid.Column="0" VerticalAlignment="Center" Style="{StaticResource ReadableCheckBoxStyle}"/>
                                <CheckBox x:Name="PreferGpuCheckBox" Content="Prefer GPU" Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource ReadableCheckBoxStyle}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="GradingTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <TextBlock Text="Color Presets" FontSize="11.5" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <WrapPanel Margin="0,0,0,12">
                                <Button x:Name="PresetNeutralButton" Content="Neutral" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="PresetVividButton" Content="Vivid" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="PresetCinematicButton" Content="Cinematic" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="PresetBwButton" Content="B&amp;W" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="PresetWarmButton" Content="Warm" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="PresetCoolButton" Content="Cool" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="PresetFadeButton" Content="Fade" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="ResetGradingButton" Content="Reset" Style="{StaticResource PresetChipResetStyle}"/>
                            </WrapPanel>
                            <TextBlock Text="Brightness" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="BrightnessSlider" Minimum="-1" Maximum="1" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="BrightnessLabel" FontSize="10.5" FontFamily="Consolas" HorizontalAlignment="Center"/></Border></Grid>
                            <TextBlock Text="Contrast" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="ContrastSlider" Minimum="0.1" Maximum="3" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="ContrastLabel" FontSize="10.5" FontFamily="Consolas" HorizontalAlignment="Center"/></Border></Grid>
                            <TextBlock Text="Saturation" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="SaturationSlider" Minimum="0" Maximum="3" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="SaturationLabel" FontSize="10.5" FontFamily="Consolas" HorizontalAlignment="Center"/></Border></Grid>
                            <TextBlock Text="Hue Shift" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="HueSlider" Minimum="-180" Maximum="180" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="HueLabel" FontSize="10.5" FontFamily="Consolas" HorizontalAlignment="Center"/></Border></Grid>
                            <TextBlock Text="Gamma" FontSize="11" Opacity="0.7" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="GammaSlider" Minimum="0.1" Maximum="3" Value="1" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="GammaLabel" FontSize="10.5" FontFamily="Consolas" HorizontalAlignment="Center"/></Border></Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="FiltersTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Sharpen"/><ToggleButton x:Name="SharpenToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid></Border>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="SharpenSlider" Minimum="0" Maximum="5" Value="1" IsEnabled="False" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="SharpenLabel" HorizontalAlignment="Center"/></Border></Grid>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Denoise (hqdn3d)"/><ToggleButton x:Name="DenoiseToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid></Border>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="DenoiseSlider" Minimum="0" Maximum="10" Value="3" IsEnabled="False" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="DenoiseLabel" HorizontalAlignment="Center"/></Border></Grid>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Gaussian Blur"/><ToggleButton x:Name="BlurToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid></Border>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="BlurSlider" Minimum="1" Maximum="15" Value="3" IsEnabled="False" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="BlurLabel" HorizontalAlignment="Center"/></Border></Grid>
                            <WrapPanel Margin="0,0,0,8">
                                <Button x:Name="Rotate0Button" Content="0°" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Rotate90Button" Content="90° ↻" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Rotate180Button" Content="180°" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Rotate270Button" Content="270° ↺" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="FlipHButton" Content="Flip H" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="FlipVButton" Content="Flip V" Style="{StaticResource PresetChipStyle}"/>
                            </WrapPanel>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Stabilize"/><ToggleButton x:Name="StabilizeToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid></Border>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="SpeedSlider" Minimum="0.25" Maximum="4" Value="1" TickFrequency="0.25" IsSnapToTickEnabled="True" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="SpeedLabel" HorizontalAlignment="Center" Text="1.0x"/></Border></Grid>
                            <TextBlock Text="Watermark / Logo" FontSize="11.5" FontWeight="SemiBold" Margin="0,12,0,6"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Enable Image Overlay"/>
                                        <ToggleButton x:Name="WatermarkToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBox x:Name="WatermarkPathText" Background="#12FFFFFF" BorderBrush="#30FFFFFF" Height="28"/>
                                        <Button x:Name="BrowseWatermarkButton" Grid.Column="1" Content="..." Width="32" Style="{DynamicResource SecondaryButton}"/>
                                    </Grid>
                                    <ComboBox x:Name="WatermarkPositionCombo" Margin="0,8,0,0" Height="28">
                                        <ComboBoxItem Content="Top Left" Tag="TL"/><ComboBoxItem Content="Top Center" Tag="TC"/><ComboBoxItem Content="Top Right" Tag="TR"/>
                                        <ComboBoxItem Content="Middle Left" Tag="ML"/><ComboBoxItem Content="Middle Center" Tag="MC"/><ComboBoxItem Content="Middle Right" Tag="MR"/>
                                        <ComboBoxItem Content="Bottom Left" Tag="BL"/><ComboBoxItem Content="Bottom Center" Tag="BC"/><ComboBoxItem Content="Bottom Right" Tag="BR" IsSelected="True"/>
                                    </ComboBox>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions>
                                        <Slider x:Name="WatermarkOpacitySlider" Minimum="0" Maximum="1" Value="1" Style="{StaticResource ModernSliderStyle}"/>
                                        <Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="WatermarkOpacityLabel" HorizontalAlignment="Center"/></Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Text Overlay" FontSize="11.5" FontWeight="SemiBold" Margin="0,4,0,6"/>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8">
                                <StackPanel>
                                    <Grid><TextBlock Text="Enable Text"/><ToggleButton x:Name="TextOverlayToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid>
                                    <TextBox x:Name="OverlayTextBox" Margin="0,8,0,0" Height="28" Background="#12FFFFFF" BorderBrush="#30FFFFFF"/>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                        <ComboBox x:Name="TextFontCombo" Grid.Column="0" Height="26" Margin="0,0,4,0"><ComboBoxItem Content="Arial" IsSelected="True"/><ComboBoxItem Content="Segoe UI"/><ComboBoxItem Content="Consolas"/></ComboBox>
                                        <Slider x:Name="TextSizeSlider" Grid.Column="1" Minimum="10" Maximum="120" Value="32" Style="{StaticResource ModernSliderStyle}" Margin="4,0"/>
                                        <Border Grid.Column="2" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="TextSizeLabel" VerticalAlignment="Center" HorizontalAlignment="Center"/></Border>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="AudioTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Audio nguồn từ video"/><ToggleButton x:Name="SourceAudioToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/></Grid></Border>
                            <ItemsControl x:Name="AudioTracksList" Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                                    <TextBlock Text="Audio Track" Foreground="#DDEEF0FF" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Button HorizontalAlignment="Right" Content="✕" Width="22" Height="22" FontSize="10" Style="{DynamicResource SecondaryButton}" Tag="{Binding}" Click="RemoveAudioTrack_Click"/>
                                                </Grid>
                                                <Grid Grid.Row="1" Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox Height="26" FontSize="10.5" Padding="6,3" Background="#12FFFFFF" BorderBrush="#30FFFFFF" Foreground="#DDEEF0FF" Text="{Binding SourceOutputKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Tag="{Binding}"/>
                                                    <Button Grid.Column="1" Content="📁" Width="28" Height="26" Margin="4,0,0,0" Style="{DynamicResource SecondaryButton}" Tag="{Binding}" Click="BrowseAudioTrack_Click"/>
                                                </Grid>
                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="Volume %" FontSize="9.5" Foreground="#88C0C8D8" Margin="0,0,0,3"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="36"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Slider Minimum="0" Maximum="300" Value="{Binding VolumePercent, Mode=TwoWay}" Style="{StaticResource ModernSliderStyle}" VerticalAlignment="Center"/>
                                                            <Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}">
                                                                <TextBlock FontSize="9.5" FontFamily="Consolas" Foreground="#DDEEF0FF" HorizontalAlignment="Center" Text="{Binding VolumePercent, StringFormat={}{0:0}%}"/>
                                                            </Border>
                                                        </Grid>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock Text="Nếu ngắn hơn" FontSize="9.5" Foreground="#88C0C8D8" Margin="0,0,0,3"/>
                                                        <ComboBox Height="26" FontSize="10.5" SelectedValue="{Binding ShorterMode, Mode=TwoWay}" SelectedValuePath="Tag" Background="#12FFFFFF" BorderBrush="#30FFFFFF" Foreground="#DDEEF0FF">
                                                            <ComboBoxItem Content="Loop" Tag="{x:Static models:AudioSyncMode.Loop}"/>
                                                            <ComboBoxItem Content="Pad Silence" Tag="{x:Static models:AudioSyncMode.PadSilence}"/>
                                                            <ComboBoxItem Content="Stretch" Tag="{x:Static models:AudioSyncMode.Stretch}"/>
                                                            <ComboBoxItem Content="Trim" Tag="{x:Static models:AudioSyncMode.Trim}"/>
                                                        </ComboBox>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button x:Name="AddAudioTrackButton" Height="32" Style="{DynamicResource SecondaryButton}" Content="Thêm audio track"/>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="ExportTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8">
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0"><TextBlock Text="Format" FontSize="10" Opacity="0.6"/><ComboBox x:Name="OutputFormatCombo" Height="28"><ComboBoxItem Content="MP4 (H.264)" Tag="mp4_h264" IsSelected="True"/><ComboBoxItem Content="MP4 (H.265/HEVC)" Tag="mp4_h265"/><ComboBoxItem Content="WebM (VP9)" Tag="webm_vp9"/><ComboBoxItem Content="MOV (ProRes)" Tag="mov_prores"/><ComboBoxItem Content="AVI" Tag="avi"/><ComboBoxItem Content="GIF" Tag="gif"/></ComboBox></StackPanel>
                                    <StackPanel Grid.Column="1"><TextBlock Text="Preset" FontSize="10" Opacity="0.6"/><ComboBox x:Name="EncoderPresetCombo" Height="28"><ComboBoxItem Content="ultrafast"/><ComboBoxItem Content="veryfast"/><ComboBoxItem Content="fast"/><ComboBoxItem Content="medium" IsSelected="True"/><ComboBoxItem Content="slow"/></ComboBox></StackPanel>
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="48"/></Grid.ColumnDefinitions><Slider x:Name="CrfSlider" Minimum="0" Maximum="51" Value="23" Style="{StaticResource ModernSliderStyle}"/><Border Grid.Column="1" Style="{StaticResource ValueBadgeStyle}"><TextBlock x:Name="CrfLabel" HorizontalAlignment="Center"/></Border></Grid></Border>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Two-Pass Encoding (chất lượng cao hơn)"/><ToggleButton x:Name="TwoPassToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid></Border>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                    <StackPanel><TextBlock Text="Audio Codec" FontSize="10" Opacity="0.6"/><ComboBox x:Name="AudioCodecCombo" Height="28"><ComboBoxItem Content="AAC" Tag="aac" IsSelected="True"/><ComboBoxItem Content="MP3" Tag="mp3"/><ComboBoxItem Content="Opus" Tag="opus"/><ComboBoxItem Content="Copy" Tag="copy"/></ComboBox></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="Audio Bitrate" FontSize="10" Opacity="0.6"/><ComboBox x:Name="AudioBitrateCombo" Height="28"><ComboBoxItem Content="128k"/><ComboBoxItem Content="192k" IsSelected="True"/><ComboBoxItem Content="256k"/><ComboBoxItem Content="320k"/></ComboBox></StackPanel>
                                </Grid>
                            </Border>
                            <WrapPanel Margin="0,0,0,8">
                                <Button x:Name="Scale100Button" Content="100%" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Scale75Button" Content="75%" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Scale50Button" Content="50%" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Scale25Button" Content="25%" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Scale1080Button" Content="1080p" Style="{StaticResource PresetChipStyle}" Margin="0,0,6,6"/>
                                <Button x:Name="Scale720Button" Content="720p" Style="{StaticResource PresetChipStyle}"/>
                            </WrapPanel>
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8"><Grid><TextBlock Text="Trim Video"/><ToggleButton x:Name="TrimToggle" HorizontalAlignment="Right" Style="{StaticResource ToggleSwitchStyle}"/></Grid></Border>
                            <Grid Margin="0,0,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="16"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border Style="{StaticResource ValueBadgeStyle}" Grid.Column="0"><TextBlock x:Name="TrimStartText" HorizontalAlignment="Center" Text="00:00"/></Border><TextBlock Grid.Column="1" Text="→" HorizontalAlignment="Center"/><Border Style="{StaticResource ValueBadgeStyle}" Grid.Column="2"><TextBlock x:Name="TrimEndText" HorizontalAlignment="Center" Text="00:00"/></Border></Grid>
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="OutputPathText" Height="28" FontSize="10.5" Padding="6,4" Background="#12FFFFFF" BorderBrush="#30FFFFFF"/><Button x:Name="BrowseOutputButton" Grid.Column="1" Height="28" Margin="6,0,0,0" Content="..." Padding="8,0" Style="{DynamicResource SecondaryButton}"/></Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <ScrollViewer x:Name="LogTabContent" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel Margin="0,2,0,0">
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,0,8" Padding="10,10">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6"><TextBlock x:Name="ProgressStatusText" FontSize="11" FontWeight="Medium" Text="Chưa chạy"/><TextBlock x:Name="ProgressPercentText" HorizontalAlignment="Right" FontSize="11" FontFamily="Consolas" Opacity="0.8"/></Grid>
                                    <Grid><Border Background="#15FFFFFF" CornerRadius="4" Height="6"/><Border x:Name="ProgressFill" HorizontalAlignment="Left" Background="#7C6BF8" CornerRadius="4" Height="6" Width="0"/></Grid>
                                    <Grid Margin="0,6,0,0"><TextBlock x:Name="ElapsedTimeText" FontSize="10" Opacity="0.5" Text="Elapsed: --"/><TextBlock x:Name="EstimatedTimeText" HorizontalAlignment="Right" FontSize="10" Opacity="0.5" Text="ETA: --"/></Grid>
                                </StackPanel>
                            </Border>
                            <Border Background="#0C000000" BorderBrush="#22FFFFFF" BorderThickness="1" CornerRadius="8" Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                    <Border Grid.Row="0" Background="#12FFFFFF" CornerRadius="8,8,0,0" Padding="10,6">
                                        <Grid><TextBlock Text="FFmpeg Output" FontSize="10.5" FontWeight="Medium" Opacity="0.8"/><Button x:Name="ClearLogButton" Content="Clear" HorizontalAlignment="Right" Height="22" Padding="8,0" FontSize="10" Style="{DynamicResource SecondaryButton}"/></Grid>
                                    </Border>
                                    <ScrollViewer Grid.Row="1" x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto" MaxHeight="200">
                                        <TextBox x:Name="LogTextBox" IsReadOnly="True" Background="Transparent" BorderThickness="0" FontFamily="Consolas" FontSize="10" Foreground="#CCFFFFFF" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="4" x:Name="ActionButtonsBorder" Margin="0,4,0,0" Padding="10,8"
                Background="#12FFFFFF" CornerRadius="0,0,12,12"
                BorderBrush="#18FFFFFF" BorderThickness="0,1,0,0">
            <WrapPanel>
                <Button x:Name="ExtractFramesButton" Height="30" Margin="0,0,5,4" Padding="12,0" Style="{DynamicResource SecondaryButton}" ToolTip="Xuất từng frame thành ảnh PNG/JPG">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="🖼" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Extract" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="BurnSubtitleButton" Height="30" Margin="0,0,5,4" Padding="12,0" Style="{DynamicResource SecondaryButton}" ToolTip="Gắn subtitle vào video (burn-in)">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="💬" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Burn Subtitle" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="QuickWatermarkButton" Height="30" Margin="0,0,5,4" Padding="12,0" Style="{DynamicResource SecondaryButton}" ToolTip="Thêm logo/ảnh chìm vào video">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔖" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Watermark" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="ConvertFormatButton" Height="30" Margin="0,0,5,4" Padding="12,0" Style="{DynamicResource SecondaryButton}" ToolTip="Chuyển đổi định dạng video nhanh">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="🔄" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Convert" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="QuickTrimButton" Height="30" Margin="0,0,5,4" Padding="12,0" Style="{DynamicResource SecondaryButton}" ToolTip="Cắt video theo vị trí hiện tại trên timeline">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="✂" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Trim" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="SnapshotButton" Height="30" Margin="0,0,5,4" Padding="12,0" Style="{DynamicResource SecondaryButton}" ToolTip="Chụp frame hiện tại thành ảnh">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="📷" Margin="0,0,4,0" VerticalAlignment="Center"/><TextBlock Text="Snapshot" VerticalAlignment="Center"/></StackPanel>
                </Button>
                <Button x:Name="RunAllButton" Height="30" Margin="0,0,0,4" Padding="14,0" Style="{DynamicResource PrimaryButton}" ToolTip="Chạy toàn bộ pipeline xử lý">
                    <StackPanel Orientation="Horizontal"><TextBlock Text="▶▶" Margin="0,0,5,0" VerticalAlignment="Center" FontSize="10"/><TextBlock Text="Run All" VerticalAlignment="Center" FontWeight="SemiBold"/></StackPanel>
                </Button>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
