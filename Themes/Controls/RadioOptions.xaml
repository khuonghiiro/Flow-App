<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════ -->
    <!--  CUSTOM RadioButton — flat, clean dot indicator                 -->
    <!-- ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CustomRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Foreground"  Value="{DynamicResource TextBrush}"/>
        <Setter Property="Background"  Value="Transparent"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Padding"     Value="8"/>
        <Setter Property="Margin"      Value="0,2"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Border"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="Transparent"
                            Background="{TemplateBinding Background}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                            <!-- Radio indicator ring -->
                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                <!-- Outer ring -->
                                <Ellipse x:Name="OuterRing"
                                         Stroke="{DynamicResource ControlBorderBrush}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent"/>
                                <!-- Inner fill dot -->
                                <Ellipse x:Name="InnerDot"
                                         Width="8" Height="8"
                                         Fill="{DynamicResource PrimaryBrush}"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                            </Grid>

                            <!-- Label -->
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border"    Property="Background"   Value="{DynamicResource OptionHoverBrush}"/>
                            <Setter TargetName="OuterRing" Property="Stroke"       Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                        <!-- Checked -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="OuterRing" Property="Stroke"   Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="InnerDot"  Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Border"    Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="Border"    Property="Background"  Value="{DynamicResource PrimaryGlowBrush}"/>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>