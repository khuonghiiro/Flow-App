    <Style x:Key="InputTextBoxV2" TargetType="TextBox" BasedOn="{StaticResource BaseTextBox}">
        <!-- Ná»n, viá»n -->
        <Setter Property="Background" Value="{DynamicResource SurfaceColor}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>

        <!-- Padding & kÃ­ch thÆ°á»›c -->
        <Setter Property="Padding" Value="4"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>

        <!-- Hiá»ƒn thá»‹ text -->
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}"/>

        <!-- Cáº¥u hÃ¬nh nháº­p multiline -->
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>

        <!-- Hiá»ƒn thá»‹ sáº¯c nÃ©t -->
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>

        <!-- Validation -->
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <AdornedElementPlaceholder/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- Template hiá»ƒn thá»‹ -->
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="MainBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">

                        <!-- Hiá»‡u á»©ng bÃ³ng nháº¹ -->
                        <Border.Effect>
                            <DropShadowEffect 
                        ShadowDepth="1"
                        BlurRadius="3"
                        Opacity="0.05"
                        Color="Black"
                        RenderingBias="Quality"/>
                        </Border.Effect>

                        <ScrollViewer x:Name="PART_ContentHost"
                              Margin="{TemplateBinding Padding}"
                              SnapsToDevicePixels="True"
                              UseLayoutRounding="True"/>
                    </Border>

                    <!-- Triggers tráº¡ng thÃ¡i -->
                    <ControlTemplate.Triggers>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource TextBoxHoverBorderBrush}" />
                            <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource TextBoxHoverBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        </Trigger>

                        <!-- Focus -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource TextBoxFocusBorderBrush}" />
                            <Setter TargetName="MainBorder" Property="BorderThickness" Value="1" />
                            <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource TextBoxFocusBackground}" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            <Setter TargetName="MainBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect 
                                ShadowDepth="2"
                                BlurRadius="4"
                                Opacity="0.15"
                                Color="#000000"
                                RenderingBias="Quality"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="MainBorder" Property="Background" Value="{DynamicResource TextBoxDisabledBackground}" />
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>

                        <!-- Validation Error -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush" Value="#FFEF5350"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <Style x:Key="TextAreaTextBox" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxV2}">
       
        <Setter Property="Height" Value="80"/>
       
    </Style>


    <!-- SearchBox -->
    <Style x:Key="DefaultSearchBoxStyle" TargetType="TextBox" BasedOn="{StaticResource TextAreaTextBox}">
        <Setter Property="Background" Value="{DynamicResource SurfaceColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <!--tooltip-->
        <Setter Property="ToolTipService.InitialShowDelay" Value="800" />
        <Setter Property="ToolTipService.ShowDuration" Value="8000" />
        <Setter Property="ToolTipService.BetweenShowDelay" Value="100" />
        <Setter Property="ToolTipService.Placement" Value="Right" />
        
    </Style>
</ResourceDictionary>
