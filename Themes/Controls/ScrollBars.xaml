<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================ -->
    <!-- Äá»ŠNH NGHÄ¨A MÃ€U Sáº®C CHO SCROLLBAR -->
    <!-- ============================================ -->

    <!-- MÃ u track (ná»n) -->
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="Transparent"/>

    <!-- MÃ u thumb (thanh kÃ©o) - cÃ¡c tráº¡ng thÃ¡i -->
    <SolidColorBrush x:Key="ScrollBarThumbNormal" Color="#A00078D4"/>
    <SolidColorBrush x:Key="ScrollBarThumbHover" Color="#C00078D4"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressed" Color="#E00078D4"/>

    <!-- MÃ u cho UltraCompact style -->
    <SolidColorBrush x:Key="ScrollBarThumbGradientStart" Color="#FF0078D4"/>
    <SolidColorBrush x:Key="ScrollBarThumbGradientEnd" Color="#FF7A20C8"/>

    <!-- ============================================ -->
    <!-- INVISIBLE BUTTON STYLE - Must be defined before use -->
    <!-- ============================================ -->
    <Style x:Key="InvisibleScrollBarButtonStyle" TargetType="RepeatButton">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" Width="0" Height="0"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- COMPACT THUMB STYLE - Must be defined before use -->
    <!-- ============================================ -->
    <Style x:Key="CompactScrollBarThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="#888888"
                            CornerRadius="5"
                            Margin="2"
                            MinHeight="24"
                            MinWidth="8"
                            SnapsToDevicePixels="True"
                            BorderThickness="0">
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Hover: mÃ u Ä‘áº­m hÆ¡n rÃµ rÃ ng -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="ThumbBorder"
                                                  Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                  To="#555555" Duration="0:0:0.1"/>
                                    <ThicknessAnimation Storyboard.TargetName="ThumbBorder"
                                                      Storyboard.TargetProperty="Margin"
                                                      To="1.5" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Leave: quay vá» mÃ u ban Ä‘áº§u (váº«n rÃµ rÃ ng) -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <ColorAnimation Storyboard.TargetName="ThumbBorder"
                                                  Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                  To="#888888" Duration="0:0:0.15"/>
                                    <ThicknessAnimation Storyboard.TargetName="ThumbBorder"
                                                      Storyboard.TargetProperty="Margin"
                                                      To="2" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Pressed: mÃ u tá»‘i nháº¥t -->
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#333333"/>
                            <Setter TargetName="ThumbBorder" Property="Margin" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- COMPACT MODERN SCROLLBAR STYLE -->
    <!-- ============================================ -->
    <Style TargetType="ScrollBar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="MinWidth" Value="12"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="ScrollBarRoot" Background="Transparent">
                        <!-- Track background vá»›i mÃ u nháº¹ -->
                        <Border x:Name="TrackBackground"
                                Background="#10000000"
                                CornerRadius="6"
                                Margin="1"
                                Opacity="0.5"/>

                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True"
                               Focusable="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                              Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="ScrollThumb" 
                                       Style="{StaticResource CompactScrollBarThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                              Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover: tÄƒng Ä‘á»™ rÃµ -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                   To="1" Duration="0:0:0.15"/>
                                    <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.7" Duration="0:0:0.15"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Leave: giá»¯ opacity cao Ä‘á»ƒ dá»… nhÃ¬n -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                   To="0.8" Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.5" Duration="0:0:0.25"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- Horizontal ScrollBar -->
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Height" Value="12"/>
                <Setter Property="MinHeight" Value="12"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid x:Name="ScrollBarRoot" Background="Transparent">
                                <Border x:Name="TrackBackground"
                                        Background="#10000000"
                                        CornerRadius="6"
                                        Margin="1"
                                        Opacity="0.5"/>

                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False"
                                       Focusable="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineLeftCommand"
                                                      Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource CompactScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineRightCommand"
                                                      Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           To="1" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.7" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           To="0.8" Duration="0:0:0.25"/>
                                            <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.5" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================ -->
    <!-- CLEAN SCROLLVIEWER STYLE -->
    <!-- ============================================ -->
    <Style TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Rectangle x:Name="Corner" 
                                   Grid.Column="1" 
                                   Grid.Row="1" 
                                   Fill="Transparent"/>

                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Column="0" Grid.Row="0"
                                                Margin="{TemplateBinding Padding}"
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                CanHorizontallyScroll="False"
                                                CanVerticallyScroll="False"/>

                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   AutomationProperties.AutomationId="VerticalScrollBar"/>

                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1"
                                   Orientation="Horizontal"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                   AutomationProperties.AutomationId="HorizontalScrollBar"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- ULTRA COMPACT THUMB - Must be defined before use -->
    <!-- ============================================ -->
    <Style x:Key="UltraCompactScrollBarThumb" TargetType="Thumb">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!-- Glow effect -->
                        <Border x:Name="GlowBorder"
                                Background="#667eea"
                                CornerRadius="4"
                                Margin="0"
                                Opacity="0">
                            <Border.Effect>
                                <BlurEffect Radius="6"/>
                            </Border.Effect>
                        </Border>

                        <!-- Main thumb vá»›i gradient Ä‘áº¹p -->
                        <Border x:Name="ThumbBorder"
                                CornerRadius="4"
                                Margin="1"
                                MinHeight="24"
                                MinWidth="8"
                                SnapsToDevicePixels="True"
                                BorderThickness="0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#999999" Offset="0.0"/>
                                    <GradientStop Color="#AAAAAA" Offset="0.5"/>
                                    <GradientStop Color="#999999" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover: hiá»ƒn thá»‹ glow vÃ  Ä‘á»•i mÃ u -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.5" Duration="0:0:0.2"/>
                                    <ThicknessAnimation Storyboard.TargetName="ThumbBorder"
                                                      Storyboard.TargetProperty="Margin"
                                                      To="0.5" Duration="0:0:0.15">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Leave: áº©n glow nhÆ°ng giá»¯ mÃ u rÃµ rÃ ng -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0" Duration="0:0:0.25"/>
                                    <ThicknessAnimation Storyboard.TargetName="ThumbBorder"
                                                      Storyboard.TargetProperty="Margin"
                                                      To="1" Duration="0:0:0.2">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Dragging: gradient mÃ u Ä‘áº­m -->
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#667eea" Offset="0.0"/>
                                        <GradientStop Color="#764ba2" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="GlowBorder" Property="Opacity" Value="0.7"/>
                            <Setter TargetName="ThumbBorder" Property="Margin" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- ULTRA COMPACT SCROLLBAR - MÃ€U Äáº¸P HÆ N -->
    <!-- ============================================ -->
    <Style x:Key="UltraCompactScrollBar" TargetType="ScrollBar">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Margin" Value="2,0,0,0"/>
        <Setter Property="Opacity" Value="0.7"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="ScrollBarRoot" Background="Transparent">
                        <!-- Track background -->
                        <Border x:Name="TrackBackground"
                                Background="#15000000"
                                CornerRadius="4"
                                Margin="0"
                                Opacity="0.6"/>

                        <Track x:Name="PART_Track"
                               IsDirectionReversed="True"
                               Focusable="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineUpCommand"
                                              Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="ScrollThumb" 
                                       Style="{StaticResource UltraCompactScrollBarThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.LineDownCommand"
                                              Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover: má»Ÿ rá»™ng -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                                   To="12" Duration="0:0:0.2">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                   To="1" Duration="0:0:0.2"/>
                                    <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.8" Duration="0:0:0.2"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Leave: giá»¯ opacity cao -->
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Width"
                                                   To="8" Duration="0:0:0.3">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                   To="0.7" Duration="0:0:0.3"/>
                                    <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.6" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- Horizontal ScrollBar -->
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="MinHeight" Value="8"/>
                <Setter Property="Margin" Value="0,2,0,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid x:Name="ScrollBarRoot" Background="Transparent">
                                <Border x:Name="TrackBackground"
                                        Background="#15000000"
                                        CornerRadius="4"
                                        Margin="0"
                                        Opacity="0.6"/>

                                <Track x:Name="PART_Track"
                                       IsDirectionReversed="False"
                                       Focusable="False">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineLeftCommand"
                                                      Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource UltraCompactScrollBarThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="ScrollBar.LineRightCommand"
                                                      Style="{StaticResource InvisibleScrollBarButtonStyle}"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <EventTrigger RoutedEvent="MouseEnter">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                           To="12" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.8" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                                <EventTrigger RoutedEvent="MouseLeave">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Height"
                                                           To="8" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseInOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           To="0.7" Duration="0:0:0.3"/>
                                            <DoubleAnimation Storyboard.TargetName="TrackBackground" 
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.6" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================================ -->
    <!-- ULTRA COMPACT SCROLLVIEWER -->
    <!-- ============================================ -->
    <Style x:Key="UltraCompactScrollViewer" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid x:Name="Grid" Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                                Grid.Column="0" Grid.Row="0"
                                                Margin="{TemplateBinding Padding}"
                                                Content="{TemplateBinding Content}"
                                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"
                                                CanHorizontallyScroll="False"
                                                CanVerticallyScroll="False"/>

                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Style="{StaticResource UltraCompactScrollBar}"
                                   Grid.Column="1" Grid.Row="0"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   AutomationProperties.AutomationId="VerticalScrollBar"/>

                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Style="{StaticResource UltraCompactScrollBar}"
                                   Grid.Column="0" Grid.Row="1"
                                   Orientation="Horizontal"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                   AutomationProperties.AutomationId="HorizontalScrollBar"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================================ -->
    <!-- HIDDEN SCROLLVIEWER -->
    <!-- ============================================ -->
    <Style x:Key="HiddenAndDisabledScrollViewer" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

</ResourceDictionary>
