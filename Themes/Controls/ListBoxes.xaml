<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource TextBoxBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="4,2" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Name="Bd"
                    Background="{TemplateBinding Background}"
                    SnapsToDevicePixels="true">
                        <ContentPresenter
                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressedBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Modern Blue Theme -->
    <Style x:Key="ModernBlueContainer" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#3B82F6"/>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#3B82F6" Direction="315" ShadowDepth="8" Opacity="0.25" BlurRadius="15"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernBlueListBox" TargetType="ListBox">
        <Setter Property="Background" Value="#F8FAFC"/>
        <Setter Property="BorderBrush" Value="#E2E8F0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- Dark Theme -->
    <Style x:Key="DarkContainer" TargetType="Border">
        <Setter Property="Background" Value="#1F2937"/>
        <Setter Property="BorderBrush" Value="#374151"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Direction="315" ShadowDepth="5" Opacity="0.5" BlurRadius="12"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DarkListBox" TargetType="ListBox">
        <Setter Property="Background" Value="#111827"/>
        <Setter Property="BorderBrush" Value="#374151"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="8"/>
    </Style>

    <!-- Green Nature Theme -->
    <Style x:Key="GreenNatureContainer" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F0FDF4" Offset="0"/>
                    <GradientStop Color="#DCFCE7" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#16A34A"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24"/>
    </Style>

    <Style x:Key="GreenNatureListBox" TargetType="ListBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#BBF7D0"/>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Purple Premium Theme -->
    <Style x:Key="PurplePremiumContainer" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#FAF5FF" Offset="0"/>
                    <GradientStop Color="#F3E8FF" Offset="0.5"/>
                    <GradientStop Color="#E9D5FF" Offset="1"/>
                </LinearGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#A855F7"/>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="28"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#A855F7" Direction="315" ShadowDepth="10" Opacity="0.3" BlurRadius="20"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PurplePremiumListBox" TargetType="ListBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#DDD6FE"/>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <!-- Orange Warm Theme -->
    <Style x:Key="OrangeWarmContainer" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <RadialGradientBrush>
                    <GradientStop Color="#FFF7ED" Offset="0"/>
                    <GradientStop Color="#FFEDD5" Offset="1"/>
                </RadialGradientBrush>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush" Value="#EA580C"/>
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#FB923C" Direction="315" ShadowDepth="6" Opacity="0.4" BlurRadius="12"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="OrangeWarmListBox" TargetType="ListBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#FDBA74"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="10"/>
    </Style>

    <!-- Minimal Clean Theme -->
    <Style x:Key="MinimalCleanContainer" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="16"/>
    </Style>

    <Style x:Key="MinimalCleanListBox" TargetType="ListBox">
        <Setter Property="Background" Value="#FAFAFA"/>
        <Setter Property="BorderBrush" Value="#E5E7EB"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="4"/>
    </Style>

    <!-- Glass Morphism Theme -->
    <Style x:Key="GlassMorphismContainer" TargetType="Border">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="White" Opacity="0.7"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="White" Opacity="0.3"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="24"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="2"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GlassMorphismListBox" TargetType="ListBox">
        <Setter Property="Background">
            <Setter.Value>
                <SolidColorBrush Color="White" Opacity="0.5"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderBrush">
            <Setter.Value>
                <SolidColorBrush Color="Gray" Opacity="0.2"/>
            </Setter.Value>
        </Setter>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="Padding" Value="12"/>
    </Style>

    <!-- Style cho Radio ListBox -->
    <Style x:Key="DefaultRadioListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="{DynamicResource SurfaceColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="SelectionMode" Value="Single"/>

        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,1"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="ItemBorder"
                                   CornerRadius="6"
                                   Margin="6,1"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   SnapsToDevicePixels="True">

                                    <Grid>
                                        <!-- Selection indicator -->
                                        <Rectangle x:Name="SelectionIndicator"
                                              Width="3"
                                              HorizontalAlignment="Left"
                                              Margin="0,2,0,2"
                                              RadiusX="1.5" RadiusY="1.5"
                                              Fill="#3B82F6"
                                              Visibility="Collapsed"/>

                                        <ContentPresenter Margin="0"
                                                     HorizontalAlignment="Stretch"
                                                     RecognizesAccessKey="True"/>
                                    </Grid>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Hover - subtle background change only -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PopupHoverBrush}"/>
                                    </Trigger>

                                    <!-- Selected state - clean and minimal -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource PopupSelectedBackground}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                                        <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible"/>
                                    </Trigger>

                                    <!-- Focus state -->
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- Style cho ListBoxItem như RadioButton -->
    <Style x:Key="RadioButtonListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Name="Border" 
                                Padding="5" 
                                SnapsToDevicePixels="true"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Radio button circle -->
                            <Ellipse Grid.Column="0"
                                        Width="16" Height="16"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Stroke="{DynamicResource ControlBorderBrush}"
                                        StrokeThickness="1"
                                        Fill="{DynamicResource ControlBackground}"/>

                            <!-- Inner dot khi được chọn -->
                            <Ellipse Grid.Column="0"
                                        Name="InnerDot"
                                        Width="8" Height="8"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        Fill="{DynamicResource PrimaryBrush}"
                                        Visibility="Collapsed"/>

                            <!-- Content -->
                            <ContentPresenter Grid.Column="1"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Khi được chọn -->
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="InnerDot" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryGlowBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>

                        <!-- Khi hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Trigger>

                        <!-- Khi disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Style cho ListBox -->
    <Style x:Key="RadioButtonListBox" TargetType="ListBox">
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource CardColor}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource RadioButtonListBoxItem}"/>
    </Style>

    <!-- Style nâng cao với icon -->
    <Style x:Key="RadioButtonListBoxItemWithIcon" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border Name="Border" 
                                Padding="8" 
                                SnapsToDevicePixels="true"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="5"
                                Margin="2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Radio button -->
                            <Grid Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0">
                                <Ellipse Stroke="{DynamicResource ControlBorderBrush}" StrokeThickness="2" Fill="{DynamicResource ControlBackground}"/>
                                <Ellipse Name="InnerCircle" 
                                            Width="10" Height="10"
                                            Fill="#FF0078D4"
                                            Visibility="Collapsed"/>
                            </Grid>

                            <!-- Icon (optional) -->
                            <TextBlock Grid.Column="1"
                                          Name="IconText"
                                          FontFamily="Segoe MDL2 Assets"
                                          FontSize="16"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"
                                          Foreground="{DynamicResource TextMuted}"/>

                            <!-- Content -->
                            <ContentPresenter Grid.Column="2"
                                                VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="InnerCircle" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryGlowBrush}"/>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverBackground}"/>
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource HoverGlowBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TimeListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="border"
                        Background="{TemplateBinding Background}"
                        Height="40"
                        Padding="0">
                        <TextBlock Text="{TemplateBinding Content}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="border" Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource LavenderBrush}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="18"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True"/>
                                <Condition Property="IsSelected" Value="False"/>
                            </MultiTrigger.Conditions>
                            <Setter Property="Foreground" Value="{DynamicResource LavenderBrush}"/>
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>