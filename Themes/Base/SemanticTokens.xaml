<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    Semantic tokens — defaults aligned with Dark palette.
    Each *Theme.xaml loads: Common → SemanticTokens → Base/Colors/{Theme}.xaml (overrides).
    -->

    <!-- ── BUTTON (default / neutral) ── -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF2C2E33"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF25262B"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF495057"/>
    <SolidColorBrush x:Key="ButtonForegroundBrush" Color="#FFC1C2C5"/>

    <!-- ── TEXT ── -->
    <SolidColorBrush x:Key="TextBrush" Color="#FFC1C2C5"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FF868E96"/>
    <SolidColorBrush x:Key="TextDisabled" Color="#FF5C6370"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF868E96"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF1A1B1E"/>

    <!-- ── INPUT / TEXTBOX ── -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF2C2E33"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#50373A40"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#40373A40"/>
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF5C6370"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF228BE6"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF222426"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF252729"/>

    <!-- ── BORDERS ── -->
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF4C5563"/>

    <!-- ── SURFACE / WINDOW ── -->
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF25262B"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF25262B"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF1A1B1E"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF1A1B1E"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1A1B1E"/>
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF25262B"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF141517"/>

    <!-- ── DISABLED ── -->
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF222426"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#66909296"/>

    <!-- ── READ ONLY ── -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF252729"/>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush" Color="#FF495057"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FF909296"/>

    <!-- ── OVERLAY ── -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#BB1A1B1E"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>

    <!-- ── SCROLLBAR (controls use ScrollBarThumb*; ScrollThumb* = alias) ── -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#FF495057"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#FF5C6370"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#FF909296"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#FF495057"/>
    <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#FF5C6370"/>
    <SolidColorBrush x:Key="ScrollTrackBrush" Color="Transparent"/>

    <!-- ── DATAGRID ── -->
    <SolidColorBrush x:Key="DataGridHeaderBackground" Color="#FF25262B"/>
    <SolidColorBrush x:Key="DataGridRowBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="DataGridAltRowBackground" Color="#0AFFFFFF"/>
    <SolidColorBrush x:Key="DataGridRowHoverBackground" Color="#30228BE6"/>
    <SolidColorBrush x:Key="DataGridSelectionBackground" Color="#60228BE6"/>

    <!-- ── TAB ── -->
    <SolidColorBrush x:Key="TabItemBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="TabItemHoverBackground" Color="#FF373A40"/>
    <SolidColorBrush x:Key="TabItemSelectedBackground" Color="#FF25262B"/>
    <SolidColorBrush x:Key="TabItemSelectedBorderBrush" Color="#FF3AA0FF"/>

    <!-- ── CHECKBOX ── -->
    <SolidColorBrush x:Key="CheckBoxBorderBrush" Color="#FF4C5563"/>
    <SolidColorBrush x:Key="CheckBoxCheckedBackground" Color="#FF3AA0FF"/>
    <SolidColorBrush x:Key="CheckBoxCheckMarkBrush" Color="#FFFFFFFF"/>

    <!-- ── LIST ── -->
    <SolidColorBrush x:Key="ListItemHoverBackground" Color="#FF373A40"/>
    <SolidColorBrush x:Key="ListItemSelectedBackground" Color="#3A3AA0FF"/>

    <!-- ── PRIMARY ── -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#FF3AA0FF"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FF59B0FF"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#FF238EE8"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#33228BE6"/>

    <!-- ── SECONDARY ── -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#FF5F6B7F"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#FF73819A"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#FF516073"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#FFFFFFFF"/>

    <!-- ── SUCCESS ── -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#FF41C97E"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#FF5DD796"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#FF31B36D"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#FFE8FFF0"/>

    <!-- ── DANGER ── -->
    <SolidColorBrush x:Key="DangerBrush" Color="#FFFF6E6E"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FFFF8686"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#FFE95757"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#FF2A0B0B"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFFF6E6E"/>

    <!-- ── WARNING ── -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FFF6C453"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#FFFFD37A"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#FFE0B042"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#FF2A2113"/>

    <!-- ── INFO ── -->
    <SolidColorBrush x:Key="InfoBrush" Color="#FF37C7DD"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#FF59D6E8"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#FF22AEC3"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#FF082126"/>

    <!-- ── SHADOW (Color only; avoid heavy DropShadow on text hosts) ── -->
    <Color x:Key="ShadowColor">#AA000000</Color>
    <Color x:Key="PrimaryShadowColor">#401E293B</Color>
    <Color x:Key="NodeShadowColor">#70000000</Color>

</ResourceDictionary>
