<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  MONOKAI THEME — Classic code editor dark with warm tones   ║
    ║  Background: #272822  Surface: #3E3D32  Accent: #A6E22E     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF272822" Offset="0"/>
        <GradientStop Color="#FF3E3D32" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF98937F"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF98937F"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF1E1D18"/>
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC1E1D18"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF272822"/>

    <!-- PRIMARY — Monokai green -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#A6E22E"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#B8F24B"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#8FCC1E"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#272822"/>

    <!-- SECONDARY — Monokai gray -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#75715E"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#888470"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#62604D"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#F8F8F2"/>

    <!-- SUCCESS — Monokai green -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#A6E22E"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#B8F24B"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#8FCC1E"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#272822"/>

    <!-- DANGER — Monokai red/pink -->
    <SolidColorBrush x:Key="DangerBrush" Color="#F92672"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF4D8A"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#E01560"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#F8F8F2"/>

    <!-- WARNING — Monokai orange -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FD971F"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#FFAD40"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#E07C08"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#272822"/>

    <!-- INFO — Monokai cyan -->
    <SolidColorBrush x:Key="InfoBrush" Color="#66D9E8"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#80E6F4"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#50C9D5"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#272822"/>

    <!-- LIGHT / DARK -->
    <SolidColorBrush x:Key="LightBrush" Color="#3E3D32"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#515048"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#2B2A22"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#F8F8F2"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#1E1D18"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#28271F"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#141310"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#F8F8F2"/>

    <!-- WINDOW -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF272822"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF272822"/>

    <!-- TEXT -->
    <SolidColorBrush x:Key="TextBrush" Color="#F8F8F2"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF272822"/>

    <!-- INPUTS -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF98937F"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#60514F42"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#50514F42"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF2E2D26"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF35342B"/>
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF888470"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FFA6E22E"/>

    <!-- TEXT STATES -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#8875715E"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#8875715E"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF2E2D26"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFAAA895"/>

    <!-- GLOW -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#33A6E22E"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#22A6E22E"/>

    <!-- READONLY -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF35342B"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFAAA895"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFF8F8F2</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF98937F</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF62604D</SolidColorBrush>

    <!-- BUTTONS -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF3E3D32"/>
      <SolidColorBrush x:Key="ControlBackground" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF515048"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF2B2A22"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF98937F"/>

    <!-- SCROLLBAR -->
    <Color x:Key="ScrollBarThumbColor">#FF98937F</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF888470</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FFA6E22E</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- PROGRESS -->
    <SolidColorBrush x:Key="ProgressBackground">#FF3E3D32</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FFA6E22E</SolidColorBrush>

    <!-- SHADOW -->
    <Color x:Key="ShadowColor">#CC000000</Color>
    <Color x:Key="PrimaryShadowColor">#FF272822</Color>

    <!-- RADIO -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FFA6E22E"/>

    <!-- MISC -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF98937F"/>

    <!-- DATAGRID -->
    <SolidColorBrush x:Key="DataGridHeaderBrush">white</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF2B2A22</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF98937F</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverRowBackground">#40A6E22E</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedRowBackground">#80A6E22E</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#80A6E22E</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FF272822</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#40A6E22E"/>

    <!-- COMBOBOX -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFA6E22E"/>

    <!-- CARD -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF3E3D32"/>

    <!-- SEMANTIC -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FFB8F24B"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF66D9E8"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFF92672"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF272822"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFAAA895"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF98937F"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFF92672"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFFD971F"/>

    <!-- POPUP -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#40A6E22E"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF2B2A22"/>

    <!-- LAVENDER (ComboBox selection highlight) -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#30A6E22E"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#60A6E22E"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FF272822"/>

    <!-- ComboBox: field = WindowBackground; popup = WindowBody -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF272822"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF706B5C"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF313026"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF827C6A"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF313026"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF6A6556"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFD8D4C4"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF4D4A3E"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF454830"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF535636"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFF8F8F2"/>

    <!-- LISTVIEW HEADER -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF1E1D18"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#50514F42"/>

    <!-- CANVAS -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF25241F"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#888F8E7A"/>
    <Color x:Key="NodeShadowColor">#80000000</Color>

    <!-- FOCUS & INTERACTION -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#55A6E22E"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF3E3B32"/>
    <Color x:Key="ButtonShadowColor">#40A6E22E</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF3E3B32"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF3E3B32"/>

</ResourceDictionary>
