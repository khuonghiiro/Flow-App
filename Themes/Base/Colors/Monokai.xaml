<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  MONOKAI THEME — Classic code editor dark with warm tones   ║
    ║  Background: #1E1E1A  Surface: #272822  Accent: #F92672     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF1E1E1A" Offset="0"/>
        <GradientStop Color="#FF272822" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF75715E"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF272822"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF908B78"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF161612"/>
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC161612"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF1E1E1A"/>

    <!-- PRIMARY — Monokai pink/red (the iconic F92672) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#F92672"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FF4A8A"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#E01060"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>

    <!-- SECONDARY — Monokai warm gray -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#75715E"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#888472"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#625E4C"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#F8F8F2"/>

    <!-- SUCCESS — Monokai green -->
    <SolidColorBrush x:Key="SuccessBrush"        Color="#A6E22E"/>
    <SolidColorBrush x:Key="SuccessHoverBrush"   Color="#B8F244"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#8CC418"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush"  Color="#141E08"/>

    <!-- DANGER — Monokai red -->
    <SolidColorBrush x:Key="DangerBrush" Color="#F92672"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF4A8A"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#E01060"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#FFFFFF"/>

    <!-- WARNING — Monokai orange -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FD971F"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#FFAD44"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#E88010"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#1A1008"/>

    <!-- INFO — Monokai cyan -->
    <SolidColorBrush x:Key="InfoBrush"        Color="#66D9E8"/>
    <SolidColorBrush x:Key="InfoHoverBrush"   Color="#80E8F4"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#50C8D8"/>
    <SolidColorBrush x:Key="TextOnInfoBrush"  Color="#041820"/>

    <!-- LIGHT / DARK -->
    <SolidColorBrush x:Key="LightBrush" Color="#3E3D32"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#504F42"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#2C2B22"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#F8F8F2"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#161612"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#201F1A"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#0E0E0C"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#F8F8F2"/>

    <!-- WINDOW -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF272822"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF1E1E1A"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E1E1A"/>

    <!-- TEXT -->
    <SolidColorBrush x:Key="TextBrush" Color="#F8F8F2"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF1E1E1A"/>

    <!-- INPUTS -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF272822"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF75715E"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#50403F34"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#40403F34"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF222218"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF2A2920"/>
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF908B78"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FFF92672"/>

    <!-- TEXT STATES -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#8875715E"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#8875715E"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF222218"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFAAA895"/>

    <!-- GLOW -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#44F92672"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#28F92672"/>

    <!-- READONLY -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF2A2920"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFAAA895"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFF8F8F2</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF75715E</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF504E3E</SolidColorBrush>

    <!-- BUTTONS -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF272822"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#FF272822"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF1E1E1A"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF75715E"/>

    <!-- SCROLLBAR -->
    <Color x:Key="ScrollBarThumbColor">#FF75715E</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF908B78</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FFF92672</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- PROGRESS -->
    <SolidColorBrush x:Key="ProgressBackground">#FF3E3D32</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FFF92672</SolidColorBrush>

    <!-- SHADOW -->
    <Color x:Key="ShadowColor">#CC000000</Color>
    <Color x:Key="PrimaryShadowColor">#601E1E1A</Color>

    <!-- RADIO -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FFF92672"/>

    <!-- MISC -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF272822"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF908B78"/>

    <!-- DATAGRID -->
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#0AFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF222218</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF75715E</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#38F92672</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#70F92672</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#70F92672</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFF8F8F2</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#48F92672"/>

    <!-- COMBOBOX -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFF92672"/>

    <!-- CARD -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF272822"/>

    <!-- SEMANTIC -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FFF92672"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FFFF4A8A"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF66D9E8"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF1E1E1A"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF272822"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFCCCAB8"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF908B78"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFF92672"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FFA6E22E"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFFD971F"/>

    <!-- POPUP -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#38F92672"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF222218"/>

    <!-- LAVENDER (ComboBox selection highlight) -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#28F92672"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#58F92672"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFF8F8F2"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF1E1E1A"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF504E3E"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF252420"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF75715E"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF252420"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FFF92672"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF272822"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF504E3E"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFD8D4C4"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF3E3D32"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF3A2030"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF4A2840"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFF8F8F2"/>

    <!-- LISTVIEW HEADER -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF161612"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#40403F34"/>

    <!-- CANVAS -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF1B1B17"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#AE787468"/>
    <SolidColorBrush x:Key="ExecutionTraceGuideBrush" Color="#AA8A8270"/>
    <Color x:Key="NodeShadowColor">#88000000</Color>

    <!-- FOCUS & INTERACTION -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#55F92672"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF303028"/>
    <Color x:Key="ButtonShadowColor">#44F92672</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FFF92672"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF303028"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF303028"/>
    <!-- Toolbar / editor header — darkest Monokai bg -->
    <SolidColorBrush x:Key="HeaderBackgroundMainBrush" Color="#FF121210"/>

    <!-- Common palette overrides -->
    <SolidColorBrush x:Key="OceanBrush" Color="#66D9E8"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#80E8F4"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#50C8D8"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#041820"/>

    <SolidColorBrush x:Key="BrightPowerBrush" Color="#F92672"/>
    <SolidColorBrush x:Key="BrightPowerHoverBrush" Color="#FF4A8A"/>
    <SolidColorBrush x:Key="BrightPowerPressedBrush" Color="#E01060"/>
    <SolidColorBrush x:Key="TextOnBrightPowerBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="MagentaBloomBrush" Color="#E060D8"/>
    <SolidColorBrush x:Key="MagentaBloomHoverBrush" Color="#EC7AE4"/>
    <SolidColorBrush x:Key="MagentaBloomPressedBrush" Color="#CC48C4"/>
    <SolidColorBrush x:Key="TextOnMagentaBloomBrush" Color="#200E20"/>

    <SolidColorBrush x:Key="NavyDeepBrush" Color="#8898CC"/>
    <SolidColorBrush x:Key="NavyDeepHoverBrush" Color="#A0B0D8"/>
    <SolidColorBrush x:Key="NavyDeepPressedBrush" Color="#7080B8"/>
    <SolidColorBrush x:Key="TextOnNavyDeepBrush" Color="#101828"/>

    <SolidColorBrush x:Key="MidnightBlueBrush" Color="#7888C0"/>
    <SolidColorBrush x:Key="MidnightBlueHoverBrush" Color="#90A0CC"/>
    <SolidColorBrush x:Key="MidnightBluePressedBrush" Color="#6070AC"/>
    <SolidColorBrush x:Key="TextOnMidnightBlueBrush" Color="#101828"/>

    <SolidColorBrush x:Key="PrussianBlueBrush" Color="#6880B8"/>
    <SolidColorBrush x:Key="PrussianBlueHoverBrush" Color="#8098C8"/>
    <SolidColorBrush x:Key="PrussianBluePressedBrush" Color="#5870A4"/>
    <SolidColorBrush x:Key="TextOnPrussianBlueBrush" Color="#101828"/>

    <SolidColorBrush x:Key="CharcoalDarkBrush" Color="#808890"/>
    <SolidColorBrush x:Key="CharcoalDarkHoverBrush" Color="#98A0A8"/>
    <SolidColorBrush x:Key="CharcoalDarkPressedBrush" Color="#6C747C"/>
    <SolidColorBrush x:Key="TextOnCharcoalDarkBrush" Color="#141820"/>

    <SolidColorBrush x:Key="GraphiteGrayBrush" Color="#808078"/>
    <SolidColorBrush x:Key="GraphiteGrayHoverBrush" Color="#989890"/>
    <SolidColorBrush x:Key="GraphiteGrayPressedBrush" Color="#6C6C64"/>
    <SolidColorBrush x:Key="TextOnGraphiteGrayBrush" Color="#181810"/>

    <SolidColorBrush x:Key="BerryPurpleBrush" Color="#B890D8"/>
    <SolidColorBrush x:Key="BerryPurpleHoverBrush" Color="#C8A8E4"/>
    <SolidColorBrush x:Key="BerryPurplePressedBrush" Color="#A47CC4"/>
    <SolidColorBrush x:Key="TextOnBerryPurpleBrush" Color="#201030"/>

    <SolidColorBrush x:Key="CobaltBlueBrush" Color="#80A0DC"/>
    <SolidColorBrush x:Key="CobaltBlueHoverBrush" Color="#98B8E8"/>
    <SolidColorBrush x:Key="CobaltBluePressedBrush" Color="#6888C8"/>
    <SolidColorBrush x:Key="TextOnCobaltBlueBrush" Color="#101828"/>

    <SolidColorBrush x:Key="WineRedBrush" Color="#C08890"/>
    <SolidColorBrush x:Key="WineRedHoverBrush" Color="#D0A0A8"/>
    <SolidColorBrush x:Key="WineRedPressedBrush" Color="#AC747C"/>
    <SolidColorBrush x:Key="TextOnWineRedBrush" Color="#281018"/>

    <SolidColorBrush x:Key="EspressoBrownBrush" Color="#B49080"/>
    <SolidColorBrush x:Key="EspressoBrownHoverBrush" Color="#C4A494"/>
    <SolidColorBrush x:Key="EspressoBrownPressedBrush" Color="#A07C6C"/>
    <SolidColorBrush x:Key="TextOnEspressoBrownBrush" Color="#241810"/>

    <SolidColorBrush x:Key="AubergineBrush" Color="#A48898"/>
    <SolidColorBrush x:Key="AubergineHoverBrush" Color="#B8A0AC"/>
    <SolidColorBrush x:Key="AuberginePressedBrush" Color="#907484"/>
    <SolidColorBrush x:Key="TextOnAubergineBrush" Color="#241420"/>

    <SolidColorBrush x:Key="BambooGreenBrush" Color="#90A878"/>
    <SolidColorBrush x:Key="BambooGreenHoverBrush" Color="#A4BC8C"/>
    <SolidColorBrush x:Key="BambooGreenPressedBrush" Color="#7C9464"/>
    <SolidColorBrush x:Key="TextOnBambooGreenBrush" Color="#141E0C"/>

</ResourceDictionary>
