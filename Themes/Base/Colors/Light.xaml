<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  LIGHT THEME — Modern Windows 11 Light                      ║
    ║  Background: #F2F4F8  Surface: #FFFFFF  Depth: #E8ECF2     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                     RadiusX="1" RadiusY="1"
                     Center="0.5,0.5"
                     GradientOrigin="0.5,0.5">
        <GradientStop Color="#FFFFFFFF" Offset="0"/>
        <GradientStop Color="#FFEDF0F5" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FFCDD4DE"/>
    <SolidColorBrush x:Key="CardColor" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FFADB8C8"/>

    <!-- Header — white with subtle shadow -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFAFBFD"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#80FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#80000000"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FFF2F4F8"/>

    <!-- ===== PRIMARY — Windows 11 Blue ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#0067C0"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#0058A8"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#004A90"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>

    <!-- ===== SECONDARY ===== -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#5E6B7A"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#4E5B6A"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#404E5C"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="White"/>

    <!-- ===== SUCCESS ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#0E7A0E"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#0C690C"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#0A580A"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="White"/>

    <!-- ===== DANGER ===== -->
    <SolidColorBrush x:Key="DangerBrush" Color="#C0281A"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#AC2016"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#981C12"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="White"/>

    <!-- ===== WARNING ===== -->
    <SolidColorBrush x:Key="WarningBrush" Color="#985800"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#844D00"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#704200"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="White"/>

    <!-- ===== INFO ===== -->
    <SolidColorBrush x:Key="InfoBrush" Color="#006EB8"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#005EA0"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#004E88"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="White"/>

    <!-- ===== LIGHT / DARK variants ===== -->
    <SolidColorBrush x:Key="LightBrush" Color="#F2F4F8"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#E8ECF2"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#DCE2EC"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#1A2030"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#1A2030"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#141A28"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#0E1220"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="White"/>

    <!-- ===== WINDOW BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FFF2F4F8"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FFF2F4F8"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF2F4F8"/>

    <!-- ===== TEXT ===== -->
    <SolidColorBrush x:Key="TextBrush" Color="#FF141820"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FFEEEEEE"/>

    <!-- ===== INPUT BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FFB4BCC8"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#FFF8F9FB"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FFF5F7FA"/>

    <!-- ===== BORDER COLORS ===== -->
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF7E90A8"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF0067C0"/>

    <!-- ===== TEXT STATES ===== -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#FF96A0AE"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#FF96A0AE"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FF445568"/>

    <!-- ===== GLOW EFFECTS ===== -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#220067C0"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#150067C0"/>

    <!-- ===== READONLY ===== -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FFF5F7FA"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FF445568"/>
    <SolidColorBrush x:Key="BorderInverseColor">#60444E5C</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FFCDD4DE</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#40808080</SolidColorBrush>

    <!-- ===== BUTTON BRUSHES ===== -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFEEF2F8"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#FFEEF2F8"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FFE4EAF4"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FFD8E0EE"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FFB4C0D0"/>

    <!-- ===== SCROLLBAR ===== -->
    <Color x:Key="ScrollBarThumbColor">#880067C0</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#AA0067C0</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#CC0067C0</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- ===== PROGRESS ===== -->
    <SolidColorBrush x:Key="ProgressBackground">#FFE4EAF4</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF0067C0</SolidColorBrush>

    <!-- ===== SHADOW ===== -->
    <Color x:Key="ShadowColor">#38000000</Color>
    <Color x:Key="PrimaryShadowColor">#280000000</Color>

    <!-- ===== RADIO OPTIONS ===== -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FFE8ECF2"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF0067C0"/>

    <!-- ===== MISC ===== -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FFFAFBFD"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF4E5A6A"/>

    <!-- ===== DATAGRID ===== -->
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FF0F1828"/>
    <SolidColorBrush x:Key="DataGridRowBackground">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#FFEEF2F8</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FFE8ECF2</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FFCDD4DE</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#1A0067C0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#480067C0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#480067C0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#380067C0"/>

    <!-- ===== COMBOBOX ===== -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FFE8ECF2"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FF0067C0"/>

    <!-- ===== CARD ===== -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>

    <!-- ===== SEMANTIC ALIASES ===== -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FF0067C0"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF0058A8"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF0E7A0E"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FF7020C0"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF7020C0"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FFF2F4F8"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FF141820"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FF3C4858"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF4E5A6A"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFC0281A"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF0E7A0E"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FF985800"/>

    <!-- ===== POPUP ===== -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#E8F0FC"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="Transparent"/>

    <!-- ===== LAVENDER (ComboBox selection highlight) ===== -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#1A0067C0"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#480067C0"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FF0067C0"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FFF2F4F8"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF8898AC"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FFE8ECF4"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF607890"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FFF2F4F8"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF0067C0"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF94A4B8"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FF304060"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FFB8D4F4"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF90BEED"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF70A8E6"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FF002040"/>

    <!-- ===== LISTVIEW HEADER ===== -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF0067C0"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FF141820"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#EEF2F8"/>

    <!-- ===== CANVAS ===== -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FFF4F6FA"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#D09AA4B8"/>
    <SolidColorBrush x:Key="ExecutionTraceGuideBrush" Color="#C8788898"/>
    <Color x:Key="NodeShadowColor">#30000000</Color>

    <!-- ===== FOCUS & INTERACTION ===== -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#440067C0"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FFEEF2F8"/>
    <Color x:Key="ButtonShadowColor">#280067C0</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FF0067C0"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FFEEF2F8"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FFEEF2F8"/>
    <!-- Toolbar / editor header — deep navy for contrast on light theme -->
    <SolidColorBrush x:Key="HeaderBackgroundMainBrush" Color="#FF1A2540"/>

    <!-- Common palette overrides -->
    <SolidColorBrush x:Key="OceanBrush" Color="#0078A8"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#006894"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#005880"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="BrightPowerBrush" Color="#E0185E"/>
    <SolidColorBrush x:Key="BrightPowerHoverBrush" Color="#C81452"/>
    <SolidColorBrush x:Key="BrightPowerPressedBrush" Color="#B01046"/>
    <SolidColorBrush x:Key="TextOnBrightPowerBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="MagentaBloomBrush" Color="#B820C8"/>
    <SolidColorBrush x:Key="MagentaBloomHoverBrush" Color="#A01CB0"/>
    <SolidColorBrush x:Key="MagentaBloomPressedBrush" Color="#881898"/>
    <SolidColorBrush x:Key="TextOnMagentaBloomBrush" Color="#FFFFFF"/>

</ResourceDictionary>
