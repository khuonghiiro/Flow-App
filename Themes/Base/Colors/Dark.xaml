<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  DARK THEME — Modern Windows 11 Dark                        ║
    ║  Background: #1A1B1E  Surface: #25262B  Depth: #2C2E33     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF1A1B1E" Offset="0"/>
        <GradientStop Color="#FF25262B" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF25262B"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF373A40"/>

    <!-- Header — slightly lighter than background -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF141517"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#BB1A1B1E"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>

    <SolidColorBrush x:Key="BackgroundAll" Color="#FF1A1B1E"/>

    <!-- ===== PRIMARY — Modern blue (VS Code / Windows 11 accent) ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#228BE6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#339AF0"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1C7ED6"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="White"/>

    <!-- ===== SECONDARY ===== -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#495057"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#5C6370"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#3C4150"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="White"/>

    <!-- ===== SUCCESS ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#2DBE6C"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#40C97A"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#22A85F"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="White"/>

    <!-- ===== DANGER ===== -->
    <SolidColorBrush x:Key="DangerBrush" Color="#FA5252"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF6B6B"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#E03E3E"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="White"/>

    <!-- ===== WARNING ===== -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FAB005"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#FFC225"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#E09A00"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#1A1B1E"/>

    <!-- ===== INFO ===== -->
    <SolidColorBrush x:Key="InfoBrush" Color="#15AABF"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#22C7D9"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#0E8FA3"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="White"/>

    <!-- ===== LIGHT / DARK variants ===== -->
    <SolidColorBrush x:Key="LightBrush" Color="#2C2E33"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#373A40"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#25262B"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#C1C2C5"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#141517"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#1C1E22"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#101214"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="White"/>

    <!-- ===== WINDOW BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF25262B"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF1A1B1E"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1A1B1E"/>

    <!-- ===== TEXT ===== -->
    <SolidColorBrush x:Key="TextBrush" Color="#C1C2C5"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF1A1B1E"/>

    <!-- ===== INPUT BACKGROUNDS ===== -->
    <!-- Card-like: slightly lighter than base bg -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF2C2E33"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#50373A40"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#40373A40"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF222426"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF252729"/>

    <!-- ===== BORDER COLORS ===== -->
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF5C6370"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF228BE6"/>

    <!-- ===== TEXT STATES ===== -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#66909296"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#66909296"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF222426"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FF909296"/>

    <!-- ===== GLOW EFFECTS ===== -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#33228BE6"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#22228BE6"/>

    <!-- ===== READONLY ===== -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF252729"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FF909296"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFC1C2C5</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF373A40</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF495057</SolidColorBrush>

    <!-- ===== BUTTON BRUSHES ===== -->
    <!-- Softer dark button for general use -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF2C2E33"/>
      <SolidColorBrush x:Key="ControlBackground" Color="#FF2C2E33"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF25262B"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF495057"/>

    <!-- ===== SCROLLBAR ===== -->
    <Color x:Key="ScrollBarThumbColor">#FF495057</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF5C6370</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FF909296</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- ===== PROGRESS ===== -->
    <SolidColorBrush x:Key="ProgressBackground">#FF373A40</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF228BE6</SolidColorBrush>

    <!-- ===== SHADOW ===== -->
    <Color x:Key="ShadowColor">#AA000000</Color>
    <Color x:Key="PrimaryShadowColor">#FF1A1B1E</Color>

    <!-- ===== RADIO OPTIONS ===== -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF228BE6"/>

    <!-- ===== MISC ===== -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF25262B"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF909296"/>

    <!-- ===== DATAGRID ===== -->
    <SolidColorBrush x:Key="DataGridHeaderBrush">white</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#0AFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF25262B</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF373A40</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverRowBackground">#30228BE6</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedRowBackground">#60228BE6</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#60228BE6</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#40228BE6"/>

    <!-- ===== COMBOBOX ===== -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF373A40"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFFFFFFF"/>

    <!-- ComboBox: field = WindowBackground; popup = WindowBody; viền rõ trên LCD -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF5C636E"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF6D757F"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF4A8FD9"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF25262B"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF4A5058"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFC8CED4"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF383D47"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF323E4D"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF3D4A5C"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFF8FAFC"/>

    <!-- ===== CARD ===== -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF25262B"/>

    <!-- ===== SEMANTIC ALIASES ===== -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FF228BE6"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF339AF0"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF2DBE6C"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FF9775FA"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF1A1B1E"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF25262B"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFF1F3F5"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFADB5BD"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF868E96"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFFA5252"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF2DBE6C"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFFAB005"/>

    <!-- ===== POPUP ===== -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#FF2C2E33"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF25262B"/>

    <!-- ===== LAVENDER (ComboBox selection highlight) ===== -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#302DBE6C"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#602DBE6C"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFF1F3F5"/>

    <!-- ===== LISTVIEW HEADER ===== -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF1A1B1E"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFC1C2C5"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#50373A40"/>

    <!-- ===== CANVAS ===== -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF1A1D23"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#88546374"/>
    <Color x:Key="NodeShadowColor">#70000000</Color>

</ResourceDictionary>
