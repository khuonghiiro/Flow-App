    <SolidColorBrush x:Key="TextOnWineRedBrush" Color="#2A1419"/>

    <SolidColorBrush x:Key="EspressoBrownBrush" Color="#B08A7A"/>
    <SolidColorBrush x:Key="EspressoBrownHoverBrush" Color="#C1A091"/>
