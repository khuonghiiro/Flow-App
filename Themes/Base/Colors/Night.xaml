<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  NIGHT THEME — Nord-inspired cool blue-grey dark             ║
    ║  Background: #2E3440  Surface: #3B4252  Accent: #5E81AC     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF2E3440" Offset="0"/>
        <GradientStop Color="#FF3B4252" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF93A0B8"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FFA9B7D1"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF242933"/>
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC1E242F"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66ECEFF4"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF2E3440"/>

    <!-- PRIMARY — Nord blue -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#7E9BBC"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#8EABCA"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#6F8CAF"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#0F172A"/>

    <!-- SECONDARY -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#7B8CA5"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#55657C"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#ECEFF4"/>

    <!-- SUCCESS — Nord green -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#88B58D"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#99C79E"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#789F7C"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#0F172A"/>

    <!-- DANGER — Nord red -->
    <SolidColorBrush x:Key="DangerBrush" Color="#CF7A85"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#DB8E97"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#BE6973"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#0F172A"/>

    <!-- WARNING — Nord yellow -->
    <SolidColorBrush x:Key="WarningBrush" Color="#DDBF84"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#E8D0A2"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#CAAA69"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#2E3440"/>

    <!-- INFO — Nord frost -->
    <SolidColorBrush x:Key="InfoBrush" Color="#84B9C8"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#96CAD7"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#709FAE"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#10212A"/>

    <!-- LIGHT / DARK -->
    <SolidColorBrush x:Key="LightBrush" Color="#434C5E"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#505B6F"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#363D4D"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#ECEFF4"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#242933"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#2C3241"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#1C2029"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#ECEFF4"/>

    <!-- WINDOW -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF2E3440"/>

    <!-- TEXT -->
    <SolidColorBrush x:Key="TextBrush" Color="#ECEFF4"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF2E3440"/>

    <!-- INPUTS -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF93A0B8"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#604C566A"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#504C566A"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF323844"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF384050"/>
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF5C6880"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF88C0D0"/>

    <!-- TEXT STATES -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#884C566A"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#884C566A"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF323844"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFB0BDD4"/>

    <!-- GLOW -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#335E81AC"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#2288C0D0"/>

    <!-- READONLY -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF384050"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFB0BDD4"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFECEFF4</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF93A0B8</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF3C4556</SolidColorBrush>

    <!-- BUTTONS -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF3B4252"/>
      <SolidColorBrush x:Key="ControlBackground" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF434C5E"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF2E3642"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF93A0B8"/>

    <!-- SCROLLBAR -->
    <Color x:Key="ScrollBarThumbColor">#FF93A0B8</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF5C6880</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FF88C0D0</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- PROGRESS -->
    <SolidColorBrush x:Key="ProgressBackground">#FF3B4252</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF88C0D0</SolidColorBrush>

    <!-- SHADOW -->
    <Color x:Key="ShadowColor">#CC000000</Color>
    <Color x:Key="PrimaryShadowColor">#FF2E3440</Color>

    <!-- RADIO -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF434C5E"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF5E81AC"/>

    <!-- MISC -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF81A1C1"/>

    <!-- DATAGRID -->
    <SolidColorBrush x:Key="DataGridHeaderBrush">white</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF2E3440</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF93A0B8</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverRowBackground">#405E81AC</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedRowBackground">#705E81AC</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#705E81AC</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFECEFF4</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#505E81AC"/>

    <!-- COMBOBOX -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FF88C0D0"/>

    <!-- CARD -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF3B4252"/>

    <!-- SEMANTIC -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FF5E81AC"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF729DC8"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FFA3BE8C"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFB48EAD"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFB0BDD4"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF93A0B8"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFBF616A"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FFA3BE8C"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFEBCB8B"/>

    <!-- POPUP -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#405E81AC"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF2E3440"/>

    <!-- LAVENDER (ComboBox selection highlight) -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#305E81AC"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#605E81AC"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFECEFF4"/>

    <!-- ComboBox: field = WindowBackground; popup = WindowBody -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF566172"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF363C4A"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF647089"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF363C4A"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF88C0D0"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF58657A"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFD4DCE8"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF4A5666"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF3E4F62"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF4A5D72"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFECEFF4"/>

    <!-- LISTVIEW HEADER -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF242933"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#504C566A"/>

    <!-- CANVAS -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF2B3240"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#887185A3"/>
    <Color x:Key="NodeShadowColor">#80000000</Color>

    <!-- FOCUS & INTERACTION -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#5588C0D0"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF3B4252"/>
    <Color x:Key="ButtonShadowColor">#4088C0D0</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FF88C0D0"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF3B4252"/>

    <!-- Common palette overrides (fine-tuned for Night contrast) -->
    <SolidColorBrush x:Key="OceanBrush" Color="#78AED8"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#89BDDF"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#679BC7"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#0E1A26"/>

    <SolidColorBrush x:Key="OceanBlueBrush" Color="#6AA4D1"/>
    <SolidColorBrush x:Key="OceanBlueHoverBrush" Color="#7DB5DA"/>
    <SolidColorBrush x:Key="OceanBluePressedBrush" Color="#5A91BF"/>
    <SolidColorBrush x:Key="TextOnOceanBlueBrush" Color="#0E1A26"/>

    <SolidColorBrush x:Key="EmeraldBrush" Color="#74CC9A"/>
    <SolidColorBrush x:Key="EmeraldHoverBrush" Color="#8CDAAE"/>
    <SolidColorBrush x:Key="EmeraldPressedBrush" Color="#62B887"/>
    <SolidColorBrush x:Key="TextOnEmeraldBrush" Color="#102016"/>

    <SolidColorBrush x:Key="AmethystBrush" Color="#B59BE4"/>
    <SolidColorBrush x:Key="AmethystHoverBrush" Color="#C5B1EC"/>
    <SolidColorBrush x:Key="AmethystPressedBrush" Color="#A387D7"/>
    <SolidColorBrush x:Key="TextOnAmethystBrush" Color="#1F1730"/>

    <SolidColorBrush x:Key="ChocolateBrownBrush" Color="#B98A68"/>
    <SolidColorBrush x:Key="ChocolateBrownHoverBrush" Color="#C9A082"/>
    <SolidColorBrush x:Key="ChocolateBrownPressedBrush" Color="#A77754"/>
    <SolidColorBrush x:Key="TextOnChocolateBrownBrush" Color="#25180F"/>

    <SolidColorBrush x:Key="RoyalPurpleBrush" Color="#AA93D9"/>
    <SolidColorBrush x:Key="RoyalPurpleHoverBrush" Color="#B9A4E3"/>
    <SolidColorBrush x:Key="RoyalPurplePressedBrush" Color="#967ECC"/>
    <SolidColorBrush x:Key="TextOnRoyalPurpleBrush" Color="#1E1730"/>

    <SolidColorBrush x:Key="RubyRedBrush" Color="#E58A8A"/>
    <SolidColorBrush x:Key="RubyRedHoverBrush" Color="#EEA0A0"/>
    <SolidColorBrush x:Key="RubyRedPressedBrush" Color="#CF7777"/>
    <SolidColorBrush x:Key="TextOnRubyRedBrush" Color="#2A1111"/>

    <SolidColorBrush x:Key="TealCyanBrush" Color="#76C9C4"/>
    <SolidColorBrush x:Key="TealCyanHoverBrush" Color="#90D7D2"/>
    <SolidColorBrush x:Key="TealCyanPressedBrush" Color="#63B6B1"/>
    <SolidColorBrush x:Key="TextOnTealCyanBrush" Color="#0F2321"/>

    <!-- Deep-tone families from Common: raised contrast for Night -->
    <SolidColorBrush x:Key="NavyDeepBrush" Color="#7E98C8"/>
    <SolidColorBrush x:Key="NavyDeepHoverBrush" Color="#98AFD8"/>
    <SolidColorBrush x:Key="NavyDeepPressedBrush" Color="#6A84B5"/>
    <SolidColorBrush x:Key="TextOnNavyDeepBrush" Color="#0F1C2F"/>

    <SolidColorBrush x:Key="MidnightBlueBrush" Color="#6C8CC2"/>
    <SolidColorBrush x:Key="MidnightBlueHoverBrush" Color="#88A5D3"/>
    <SolidColorBrush x:Key="MidnightBluePressedBrush" Color="#5A79AE"/>
    <SolidColorBrush x:Key="TextOnMidnightBlueBrush" Color="#0E1A2A"/>

    <SolidColorBrush x:Key="PrussianBlueBrush" Color="#5C87B7"/>
    <SolidColorBrush x:Key="PrussianBlueHoverBrush" Color="#77A0CC"/>
    <SolidColorBrush x:Key="PrussianBluePressedBrush" Color="#4D729E"/>
    <SolidColorBrush x:Key="TextOnPrussianBlueBrush" Color="#0D1A27"/>

    <SolidColorBrush x:Key="CharcoalDarkBrush" Color="#7B8898"/>
