    <SolidColorBrush x:Key="TextOnPrussianBlueBrush" Color="#0E1828"/>

    <SolidColorBrush x:Key="CharcoalDarkBrush" Color="#6878A0"/>
    <SolidColorBrush x:Key="CharcoalDarkHoverBrush" Color="#8090B4"/>
