<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  NIGHT THEME — Nord-inspired cool blue-grey dark             ║
    ║  Background: #242933  Surface: #2E3440  Accent: #88C0D0     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF242933" Offset="0"/>
        <GradientStop Color="#FF2E3440" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF4C5668"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF5E6E88"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF1C2030"/>
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC1C2030"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66ECEFF4"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF242933"/>

    <!-- PRIMARY — Nord frost cyan (the signature Nord color) -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#88C0D0"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#9ECFDE"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#72AEBE"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#1C2A30"/>

    <!-- SECONDARY -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#4C5668"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#5E6E80"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#3C4458"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#ECEFF4"/>

    <!-- SUCCESS — Nord green -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#A3BE8C"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#B5D09E"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#8FAC78"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#141E0E"/>

    <!-- DANGER — Nord red -->
    <SolidColorBrush x:Key="DangerBrush" Color="#BF616A"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#D07880"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#AC4E58"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#FFFFFF"/>

    <!-- WARNING — Nord yellow -->
    <SolidColorBrush x:Key="WarningBrush" Color="#EBCB8B"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#F5DCA4"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#D8B870"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#1E1A0A"/>

    <!-- INFO — Nord frost blue -->
    <SolidColorBrush x:Key="InfoBrush" Color="#81A1C1"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#96B4D0"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#6C8EAE"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#101C28"/>

    <!-- LIGHT / DARK -->
    <SolidColorBrush x:Key="LightBrush" Color="#3B4252"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#434C5E"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#2E3440"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#ECEFF4"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#1C2030"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#242A3C"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#141828"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#ECEFF4"/>

    <!-- WINDOW -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF242933"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF242933"/>

    <!-- TEXT -->
    <SolidColorBrush x:Key="TextBrush" Color="#ECEFF4"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF242933"/>

    <!-- INPUTS -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF4C5668"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#503B4458"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#403B4458"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF282E3C"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF303848"/>
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF5E6E88"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF88C0D0"/>

    <!-- TEXT STATES -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#884C5668"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#884C5668"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF282E3C"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFA8B8D0"/>

    <!-- GLOW -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#4488C0D0"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#2888C0D0"/>

    <!-- READONLY -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF303848"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFA8B8D0"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFECEFF4</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF4C5668</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF3C4558</SolidColorBrush>

    <!-- BUTTONS -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF242933"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF4C5668"/>

    <!-- SCROLLBAR -->
    <Color x:Key="ScrollBarThumbColor">#FF4C5668</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF88C0D0</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FFAAD4E0</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- PROGRESS -->
    <SolidColorBrush x:Key="ProgressBackground">#FF3B4252</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF88C0D0</SolidColorBrush>

    <!-- SHADOW -->
    <Color x:Key="ShadowColor">#CC000000</Color>
    <Color x:Key="PrimaryShadowColor">#60242933</Color>

    <!-- RADIO -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF88C0D0"/>

    <!-- MISC -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF81A1C1"/>

    <!-- DATAGRID -->
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#0AFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF242933</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF4C5668</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#3088C0D0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#6088C0D0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#6088C0D0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FF1C2A30</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#4088C0D0"/>

    <!-- COMBOBOX -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FF88C0D0"/>

    <!-- CARD -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF2E3440"/>

    <!-- SEMANTIC -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FF88C0D0"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF9ECFDE"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FFA3BE8C"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFB48EAD"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FFB48EAD"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF242933"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFA8B8D0"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF81A1C1"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFBF616A"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FFA3BE8C"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFEBCB8B"/>

    <!-- POPUP -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#3088C0D0"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF242933"/>

    <!-- LAVENDER (ComboBox selection highlight) -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#2888C0D0"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#5888C0D0"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFECEFF4"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF242933"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF3C4558"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF2A3040"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF4C5668"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF2A3040"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF88C0D0"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF2E3440"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF3C4558"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFD0DCE8"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF3B4252"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF284050"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF305060"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFECEFF4"/>

    <!-- LISTVIEW HEADER -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF1C2030"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFECEFF4"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#403B4458"/>

    <!-- CANVAS -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF202838"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#704C5668"/>
    <Color x:Key="NodeShadowColor">#88000000</Color>

    <!-- FOCUS & INTERACTION -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#5588C0D0"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF343C4E"/>
    <Color x:Key="ButtonShadowColor">#4088C0D0</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FF88C0D0"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF343C4E"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF343C4E"/>

    <!-- Common palette overrides (fine-tuned for Night contrast) -->
    <SolidColorBrush x:Key="OceanBrush" Color="#88C0D0"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#9ECFDE"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#72AEBE"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#1C2A30"/>

    <SolidColorBrush x:Key="OceanBlueBrush" Color="#81A1C1"/>
    <SolidColorBrush x:Key="OceanBlueHoverBrush" Color="#96B4D0"/>
    <SolidColorBrush x:Key="OceanBluePressedBrush" Color="#6C8EAE"/>
    <SolidColorBrush x:Key="TextOnOceanBlueBrush" Color="#101C28"/>

    <SolidColorBrush x:Key="EmeraldBrush" Color="#A3BE8C"/>
    <SolidColorBrush x:Key="EmeraldHoverBrush" Color="#B5D09E"/>
    <SolidColorBrush x:Key="EmeraldPressedBrush" Color="#8FAC78"/>
    <SolidColorBrush x:Key="TextOnEmeraldBrush" Color="#141E0E"/>

    <SolidColorBrush x:Key="AmethystBrush" Color="#B48EAD"/>
    <SolidColorBrush x:Key="AmethystHoverBrush" Color="#C8A4C0"/>
    <SolidColorBrush x:Key="AmethystPressedBrush" Color="#A07898"/>
    <SolidColorBrush x:Key="TextOnAmethystBrush" Color="#1C1020"/>

    <SolidColorBrush x:Key="ChocolateBrownBrush" Color="#C09870"/>
    <SolidColorBrush x:Key="ChocolateBrownHoverBrush" Color="#D0AC88"/>
    <SolidColorBrush x:Key="ChocolateBrownPressedBrush" Color="#AC8458"/>
    <SolidColorBrush x:Key="TextOnChocolateBrownBrush" Color="#201408"/>

    <SolidColorBrush x:Key="RoyalPurpleBrush" Color="#B48EAD"/>
    <SolidColorBrush x:Key="RoyalPurpleHoverBrush" Color="#C8A4C0"/>
    <SolidColorBrush x:Key="RoyalPurplePressedBrush" Color="#A07898"/>
    <SolidColorBrush x:Key="TextOnRoyalPurpleBrush" Color="#1C1020"/>

    <SolidColorBrush x:Key="RubyRedBrush" Color="#BF616A"/>
    <SolidColorBrush x:Key="RubyRedHoverBrush" Color="#D07880"/>
    <SolidColorBrush x:Key="RubyRedPressedBrush" Color="#AC4E58"/>
    <SolidColorBrush x:Key="TextOnRubyRedBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="TealCyanBrush" Color="#8FBCBB"/>
    <SolidColorBrush x:Key="TealCyanHoverBrush" Color="#A4CCCC"/>
    <SolidColorBrush x:Key="TealCyanPressedBrush" Color="#7AACAA"/>
    <SolidColorBrush x:Key="TextOnTealCyanBrush" Color="#102020"/>

    <SolidColorBrush x:Key="NavyDeepBrush" Color="#7090C0"/>
    <SolidColorBrush x:Key="NavyDeepHoverBrush" Color="#88A8D0"/>
    <SolidColorBrush x:Key="NavyDeepPressedBrush" Color="#5C7CAC"/>
    <SolidColorBrush x:Key="TextOnNavyDeepBrush" Color="#0E1828"/>

    <SolidColorBrush x:Key="MidnightBlueBrush" Color="#5E81AC"/>
    <SolidColorBrush x:Key="MidnightBlueHoverBrush" Color="#7498C0"/>
    <SolidColorBrush x:Key="MidnightBluePressedBrush" Color="#4C6E98"/>
    <SolidColorBrush x:Key="TextOnMidnightBlueBrush" Color="#0E1828"/>

    <SolidColorBrush x:Key="PrussianBlueBrush" Color="#5070A0"/>
    <SolidColorBrush x:Key="PrussianBlueHoverBrush" Color="#6888B8"/>
