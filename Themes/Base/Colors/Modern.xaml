    <Color x:Key="ScrollBarThumbHoverColor">#C02563EB</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#E02563EB</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <SolidColorBrush x:Key="ProgressBackground">#FFE8EDF5</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF2563EB</SolidColorBrush>

    <Color x:Key="ShadowColor">#30000000</Color>
    <Color x:Key="PrimaryShadowColor">#402563EB</Color>

    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FFEDF2FF"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF2563EB"/>

    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FFFAFCFF"/>
