<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modern web-like light palette -->
    <RadialGradientBrush x:Key="CardRadialBackground"
                     RadiusX="1" RadiusY="1"
                     Center="0.5,0.5"
                     GradientOrigin="0.5,0.5">
        <GradientStop Color="#FFFFFFFF" Offset="0"/>
        <GradientStop Color="#FFF4F7FC" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FFD7DEE8"/>
    <SolidColorBrush x:Key="CardColor" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FFB6C3D3"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFAFCFF"/>

    <SolidColorBrush x:Key="OverlayBackground" Color="#80FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#80000000"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FFF7FAFF"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#3D73E6"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#3166D0"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#2A58B5"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#6C7C96"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#5A6C86"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#4B5C74"/>
