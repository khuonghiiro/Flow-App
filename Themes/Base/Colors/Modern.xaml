    <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FFF1F5F9"/>

    <SolidColorBrush x:Key="TextBoxBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FFC7D2E1"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FFF8FAFC"/>

    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF93A5BE"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF2563EB"/>

    <SolidColorBrush x:Key="PlaceholderBrush" Color="#FF94A3B8"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#FF94A3B8"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FF475569"/>

    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#222563EB"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#152563EB"/>
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FF475569"/>
    <SolidColorBrush x:Key="BorderInverseColor">#6055697A</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FFD7DEE8</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#4094A3B8</SolidColorBrush>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFEFF4FB"/>
      <SolidColorBrush x:Key="ControlBackground" Color="#FFEFF4FB"/>
