    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF94A8C0"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FF334155"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FFD0E4FF"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FFB0CCFF"/>
