    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#B45309"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#92400E"/>
