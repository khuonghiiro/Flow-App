<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Modern web-like light palette -->
    <RadialGradientBrush x:Key="CardRadialBackground"
                     RadiusX="1" RadiusY="1"
                     Center="0.5,0.5"
                     GradientOrigin="0.5,0.5">
        <GradientStop Color="#FFFFFFFF" Offset="0"/>
        <GradientStop Color="#FFF4F7FC" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FFD7DEE8"/>
    <SolidColorBrush x:Key="CardColor" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FFD7DEE8"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFFAFCFF"/>

    <SolidColorBrush x:Key="OverlayBackground" Color="#80FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#80000000"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FFF7FAFF"/>

    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#1E40AF"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#475569"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#334155"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#15803D"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#166534"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#B91C1C"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#991B1B"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#B45309"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#92400E"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="InfoBrush" Color="#0EA5E9"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#0284C7"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#0369A1"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="LightBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#EEF2F7"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="DarkBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#020617"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FFF7FAFF"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FFF7FAFF"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF7FAFF"/>

    <SolidColorBrush x:Key="TextBrush" Color="#FF0F172A"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FFF1F5F9"/>

    <SolidColorBrush x:Key="TextBoxBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FFC7D2E1"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FFF8FAFC"/>

    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF93A5BE"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF2563EB"/>

    <SolidColorBrush x:Key="PlaceholderBrush" Color="#FF94A3B8"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#FF94A3B8"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FFF1F5F9"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FF475569"/>

    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#222563EB"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#152563EB"/>
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FFF8FAFC"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FF475569"/>
    <SolidColorBrush x:Key="BorderInverseColor">#6055697A</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FFD7DEE8</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#4094A3B8</SolidColorBrush>

    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFEFF4FB"/>
      <SolidColorBrush x:Key="ControlBackground" Color="#FFEFF4FB"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FFE5ECF6"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FFD8E3F1"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FFBCC9DA"/>

    <Color x:Key="ScrollBarThumbColor">#A02563EB</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#C02563EB</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#E02563EB</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <SolidColorBrush x:Key="ProgressBackground">#FFE8EDF5</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF2563EB</SolidColorBrush>

    <Color x:Key="ShadowColor">#30000000</Color>
    <Color x:Key="PrimaryShadowColor">#402563EB</Color>

    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FFEDF2FF"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF2563EB"/>

    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FFFAFCFF"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF64748B"/>

    <SolidColorBrush x:Key="DataGridHeaderBrush">#FF0F172A</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowBackground">#08000000</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#FFF8FAFC</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FFF1F5F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FFD7DEE8</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverRowBackground">#202563EB</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedRowBackground">#502563EB</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#502563EB</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#402563EB"/>

    <SolidColorBrush x:Key="SelectionBrush" Color="#FFEAF0FA"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FF1D4ED8"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="PrimaryColor" Color="#FF2563EB"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF1D4ED8"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF16A34A"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FF7C3AED"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FFF7FAFF"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FF0F172A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FF475569"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF64748B"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFDC2626"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF16A34A"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFD97706"/>

    <SolidColorBrush x:Key="PopupHoverBrush" Color="#ECF2FF"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="Transparent"/>

    <!-- LAVENDER (ComboBox selection highlight) -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#202563EB"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#502563EB"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FF1D4ED8"/>

    <!-- LISTVIEW HEADER -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF2563EB"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FF0F172A"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#EEF2F7"/>

    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FFF8FAFD"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#C699AEC4"/>
    <Color x:Key="NodeShadowColor">#30000000</Color>

</ResourceDictionary>
