    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#1A2563EB"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#482563EB"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FF1D4ED8"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FFF8FAFF"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF94A8C0"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FFEEF4FC"/>
