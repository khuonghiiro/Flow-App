    <SolidColorBrush x:Key="DataGridHeaderBrush">#FF0F172A</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowBackground">#08000000</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#FFF8FAFC</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FFF1F5F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FFD7DEE8</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#202563EB</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#502563EB</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#502563EB</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#402563EB"/>

    <SolidColorBrush x:Key="SelectionBrush" Color="#FFEAF0FA"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FF1D4ED8"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFFFF"/>

    <SolidColorBrush x:Key="PrimaryColor" Color="#FF2563EB"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF1D4ED8"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF7C3AED"/>
