    <SolidColorBrush x:Key="InfoBrush" Color="#2E9DCF"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#288CB8"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#21779D"/>
