    <SolidColorBrush x:Key="SuccessColor" Color="#FF16A34A"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFD97706"/>

    <SolidColorBrush x:Key="PopupHoverBrush" Color="#EBF2FF"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="Transparent"/>

