    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FFF8FAFD"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#C699AEC4"/>
    <Color x:Key="NodeShadowColor">#30000000</Color>

