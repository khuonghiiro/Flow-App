    <SolidColorBrush x:Key="AccentBrush" Color="#FF7C3AED"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FFF7FAFF"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FF0F172A"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FF475569"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF64748B"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFDC2626"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF16A34A"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFD97706"/>

    <SolidColorBrush x:Key="PopupHoverBrush" Color="#ECF2FF"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="Transparent"/>

    <!-- LAVENDER (ComboBox selection highlight) -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#202563EB"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#502563EB"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FF1D4ED8"/>

    <!-- ComboBox: field = WindowBackground; popup nổi trắng -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FFF7FAFF"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF9AAEC4"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FFEEF3FA"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF7A8FA8"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FFF7FAFF"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF2563EB"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF9AAEC4"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FF334155"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FFD0E4FF"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FFB3D2FF"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF94BEFF"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FF0C1F45"/>

    <!-- LISTVIEW HEADER -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF2563EB"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FF0F172A"/>
