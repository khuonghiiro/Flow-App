    <SolidColorBrush x:Key="TextOnChocolateBrownBrush" Color="#2D1F15"/>

    <SolidColorBrush x:Key="RoyalPurpleBrush" Color="#C7A8FA"/>
    <SolidColorBrush x:Key="RoyalPurpleHoverBrush" Color="#D6C0FF"/>
    <SolidColorBrush x:Key="RoyalPurplePressedBrush" Color="#B492EC"/>
    <SolidColorBrush x:Key="TextOnRoyalPurpleBrush" Color="#221833"/>

    <SolidColorBrush x:Key="RubyRedBrush" Color="#FF8D9D"/>
    <SolidColorBrush x:Key="RubyRedHoverBrush" Color="#FFA5B1"/>
    <SolidColorBrush x:Key="RubyRedPressedBrush" Color="#EA7789"/>
    <SolidColorBrush x:Key="TextOnRubyRedBrush" Color="#33131C"/>

    <SolidColorBrush x:Key="TealCyanBrush" Color="#88DDD8"/>
