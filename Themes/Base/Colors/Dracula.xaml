<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  DRACULA THEME — Dark purple vampire aesthetic               ║
    ║  Background: #282A36  Surface: #44475A  Accent: #BD93F9     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <!-- === RADIAL BG === -->
    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF282A36" Offset="0"/>
        <GradientStop Color="#FF44475A" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF8B9DC9"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF44475A"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FFA3B4DD"/>

    <!-- Header -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF21222C"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC1D1F2B"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>

    <!-- Background all -->
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF282A36"/>

    <!-- === PRIMARY — Dracula purple === -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#D4B0FF"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#E0C5FF"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#BF99F0"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#221B2E"/>

    <!-- === SECONDARY === -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#8892C8"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#9BA5D8"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#7480B8"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#F8F8F2"/>

    <!-- === SUCCESS — Dracula green === -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#6AFB90"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#86FFAA"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#52E279"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#1D2420"/>

    <!-- === DANGER — Dracula red === -->
    <SolidColorBrush x:Key="DangerBrush" Color="#FF737A"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF8C92"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#E85E65"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#2A0D11"/>

    <!-- === WARNING — Dracula orange === -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC77D"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#FFD79B"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#E8B163"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#2E2213"/>

    <!-- === INFO — Dracula cyan === -->
    <SolidColorBrush x:Key="InfoBrush" Color="#9BEFFF"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#B4F4FF"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#84DDF3"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#1B2A32"/>

    <!-- === LIGHT / DARK variants === -->
    <SolidColorBrush x:Key="LightBrush" Color="#44475A"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#565970"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#3A3D50"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#F8F8F2"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#21222C"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#2B2D3E"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#1A1B24"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#F8F8F2"/>

    <!-- === WINDOW BACKGROUNDS === -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF44475A"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF282A36"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF282A36"/>

    <!-- === TEXT === -->
    <SolidColorBrush x:Key="TextBrush" Color="#F8F8F2"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF282A36"/>

    <!-- === INPUT BACKGROUNDS === -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF44475A"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF8B9DC9"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#60565975"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#50565975"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF383A4D"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF3F4155"/>

    <!-- === BORDER COLORS === -->
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF7585B7"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FFBD93F9"/>

    <!-- === TEXT STATES === -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#886272A4"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#886272A4"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF383A4D"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFADB7CE"/>

    <!-- === GLOW EFFECTS === -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#33BD93F9"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#22BD93F9"/>

    <!-- === READONLY === -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF3F4155"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFADB7CE"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFF8F8F2</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF8B9DC9</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF5A6690</SolidColorBrush>

    <!-- === BUTTON BRUSHES === -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF44475A"/>
      <SolidColorBrush x:Key="ControlBackground" Color="#FF44475A"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF565970"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF383A4D"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF8B9DC9"/>

    <!-- === SCROLLBAR === -->
    <Color x:Key="ScrollBarThumbColor">#FF8B9DC9</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF7585B7</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FFBD93F9</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- === PROGRESS === -->
    <SolidColorBrush x:Key="ProgressBackground">#FF44475A</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FFBD93F9</SolidColorBrush>

    <!-- === SHADOW === -->
    <Color x:Key="ShadowColor">#CC000000</Color>
    <Color x:Key="PrimaryShadowColor">#FF282A36</Color>

    <!-- === RADIO OPTIONS === -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF44475A"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FFBD93F9"/>

    <!-- === MISC === -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF44475A"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF8B9DC9"/>

    <!-- === DATAGRID === -->
    <SolidColorBrush x:Key="DataGridHeaderBrush">white</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF3A3D50</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF8B9DC9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#40BD93F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#80BD93F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#80BD93F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFF8F8F2</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#50BD93F9"/>

    <!-- === COMBOBOX === -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF44475A"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFBD93F9"/>

    <!-- === CARD === -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF44475A"/>

    <!-- === SEMANTIC COLORS === -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FFBD93F9"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FFCFB3FF"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF50FA7B"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFFF79C6"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFF79C6"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF282A36"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF44475A"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFADB7CE"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF8B9DC9"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFFF5555"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF50FA7B"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFFFB86C"/>

    <!-- === POPUP === -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#40BD93F9"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF3A3D50"/>

    <!-- === LAVENDER (ComboBox selection highlight) === -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#30BD93F9"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#60BD93F9"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFF8F8F2"/>

    <!-- ComboBox: field = WindowBackground; popup = WindowBody -->
     <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF282A36"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF555A72"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF30323F"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF6B7088"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF30323F"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FFBD93F9"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF44475A"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF5A5F78"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFD0D6EC"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF505570"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF4A5068"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF565C78"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFF8F8F2"/>

    <!-- === LISTVIEW HEADER === -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF21222C"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#50565975"/>

    <!-- === CANVAS === -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF292B37"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#887E94C2"/>
    <Color x:Key="NodeShadowColor">#80000000</Color>

    <!-- === FOCUS & INTERACTION === -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#55BD93F9"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF3A3C4E"/>
    <Color x:Key="ButtonShadowColor">#40BD93F9</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FFBD93F9"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF3A3C4E"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF3A3C4E"/>

    <!-- Common palette overrides (fine-tuned for Dracula contrast) -->
    <SolidColorBrush x:Key="OceanBrush" Color="#8FD6FF"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#A8E1FF"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#78C4EB"/>
