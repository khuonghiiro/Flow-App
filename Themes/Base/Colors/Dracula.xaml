<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  DRACULA THEME — Dark purple vampire aesthetic               ║
    ║  Background: #1E1F29  Surface: #282A36  Accent: #BD93F9     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <!-- === RADIAL BG === -->
    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF1E1F29" Offset="0"/>
        <GradientStop Color="#FF282A36" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF6272A4"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF282A36"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF7A8EC0"/>

    <!-- Header -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF191A24"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#CC191A24"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>

    <!-- Background all -->
    <SolidColorBrush x:Key="BackgroundAll" Color="#FF1E1F29"/>

    <!-- === PRIMARY — Dracula purple (brighter, more vivid) === -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#CDA8FF"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#A87EE8"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#1A1228"/>

    <!-- === SECONDARY === -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#6272A4"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#7585B8"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#526090"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="#F8F8F2"/>

    <!-- === SUCCESS — Dracula green === -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#6AFF92"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#3AE066"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#0A1E12"/>

    <!-- === DANGER — Dracula red === -->
    <SolidColorBrush x:Key="DangerBrush" Color="#FF5555"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#FF7070"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#E83E3E"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#FFFFFF"/>

    <!-- === WARNING — Dracula orange === -->
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB86C"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#FFCA88"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#E8A050"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#1E1408"/>

    <!-- === INFO — Dracula cyan === -->
    <SolidColorBrush x:Key="InfoBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#A4F0FF"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#72D8F0"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#0A2028"/>

    <!-- === LIGHT / DARK variants === -->
    <SolidColorBrush x:Key="LightBrush" Color="#44475A"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#565970"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#383B4E"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#F8F8F2"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#191A24"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#22243A"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#14151E"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="#F8F8F2"/>

    <!-- === WINDOW BACKGROUNDS === -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF282A36"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF1E1F29"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1E1F29"/>

    <!-- === TEXT === -->
    <SolidColorBrush x:Key="TextBrush" Color="#F8F8F2"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF1E1F29"/>

    <!-- === INPUT BACKGROUNDS === -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF282A36"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF6272A4"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#50383B50"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#40383B50"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF252636"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF2C2E3E"/>

    <!-- === BORDER COLORS === -->
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF7585B8"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FFBD93F9"/>

    <!-- === TEXT STATES === -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#886272A4"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#886272A4"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF252636"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFA0AECE"/>

    <!-- === GLOW EFFECTS === -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#44BD93F9"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#28BD93F9"/>

    <!-- === READONLY === -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF2C2E3E"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFA0AECE"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFF8F8F2</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF6272A4</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#FF4A5580</SolidColorBrush>

    <!-- === BUTTON BRUSHES === -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF282A36"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#FF282A36"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF383B50"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF1E2030"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF6272A4"/>

    <!-- === SCROLLBAR === -->
    <Color x:Key="ScrollBarThumbColor">#FF6272A4</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF7585B8</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FFBD93F9</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- === PROGRESS === -->
    <SolidColorBrush x:Key="ProgressBackground">#FF383B50</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FFBD93F9</SolidColorBrush>

    <!-- === SHADOW === -->
    <Color x:Key="ShadowColor">#CC000000</Color>
    <Color x:Key="PrimaryShadowColor">#601E1F29</Color>

    <!-- === RADIO OPTIONS === -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF383B50"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FFBD93F9"/>

    <!-- === MISC === -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF282A36"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF8090C0"/>

    <!-- === DATAGRID === -->
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#0AFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF252636</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF6272A4</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#38BD93F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#70BD93F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#70BD93F9</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FF1A1228</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#48BD93F9"/>

    <!-- === COMBOBOX === -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF383B50"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFBD93F9"/>

    <!-- === CARD === -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF282A36"/>

    <!-- === SEMANTIC COLORS === -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FFBD93F9"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FFCDA8FF"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF50FA7B"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFFF79C6"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FFFF79C6"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF1E1F29"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF282A36"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFA0AECE"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF8090C0"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFFF5555"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF50FA7B"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFFFB86C"/>

    <!-- === POPUP === -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#38BD93F9"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF252636"/>

    <!-- === LAVENDER (ComboBox selection highlight) === -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#28BD93F9"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#58BD93F9"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFF8F8F2"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF1E1F29"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF4A5580"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF252636"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF6272A4"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF252636"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FFBD93F9"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF282A36"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF4A5580"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFD0D8F0"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF383B50"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF3A3060"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF483870"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFF8F8F2"/>

    <!-- === LISTVIEW HEADER === -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF191A24"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFF8F8F2"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#40383B50"/>

    <!-- === CANVAS === -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF1C1D28"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#806272A4"/>
    <Color x:Key="NodeShadowColor">#88000000</Color>

    <!-- === FOCUS & INTERACTION === -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#55BD93F9"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF303348"/>
    <Color x:Key="ButtonShadowColor">#44BD93F9</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FFBD93F9"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF303348"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF303348"/>

    <!-- Common palette overrides (fine-tuned for Dracula contrast) -->
    <SolidColorBrush x:Key="OceanBrush" Color="#8BE9FD"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#A4F0FF"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#72D8F0"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#0A2028"/>

    <SolidColorBrush x:Key="OceanBlueBrush" Color="#80CFFF"/>
    <SolidColorBrush x:Key="OceanBlueHoverBrush" Color="#98DAFF"/>
    <SolidColorBrush x:Key="OceanBluePressedBrush" Color="#68BFEE"/>
    <SolidColorBrush x:Key="TextOnOceanBlueBrush" Color="#0A1E2E"/>

    <SolidColorBrush x:Key="EmeraldBrush" Color="#50FA7B"/>
    <SolidColorBrush x:Key="EmeraldHoverBrush" Color="#6AFF92"/>
    <SolidColorBrush x:Key="EmeraldPressedBrush" Color="#3AE066"/>
    <SolidColorBrush x:Key="TextOnEmeraldBrush" Color="#0A1E12"/>

    <SolidColorBrush x:Key="AmethystBrush" Color="#BD93F9"/>
    <SolidColorBrush x:Key="AmethystHoverBrush" Color="#CDA8FF"/>
    <SolidColorBrush x:Key="AmethystPressedBrush" Color="#A87EE8"/>
    <SolidColorBrush x:Key="TextOnAmethystBrush" Color="#1A1228"/>

    <SolidColorBrush x:Key="ChocolateBrownBrush" Color="#D4A880"/>
    <SolidColorBrush x:Key="ChocolateBrownHoverBrush" Color="#E0BC98"/>
    <SolidColorBrush x:Key="ChocolateBrownPressedBrush" Color="#C09468"/>
    <SolidColorBrush x:Key="TextOnChocolateBrownBrush" Color="#281A0E"/>

    <SolidColorBrush x:Key="RoyalPurpleBrush" Color="#C8A8FF"/>
    <SolidColorBrush x:Key="RoyalPurpleHoverBrush" Color="#D8BCFF"/>
    <SolidColorBrush x:Key="RoyalPurplePressedBrush" Color="#B494F0"/>
    <SolidColorBrush x:Key="TextOnRoyalPurpleBrush" Color="#1A1030"/>

    <SolidColorBrush x:Key="RubyRedBrush" Color="#FF8080"/>
    <SolidColorBrush x:Key="RubyRedHoverBrush" Color="#FF9898"/>
    <SolidColorBrush x:Key="RubyRedPressedBrush" Color="#E86868"/>
    <SolidColorBrush x:Key="TextOnRubyRedBrush" Color="#280A0A"/>

    <SolidColorBrush x:Key="TealCyanBrush" Color="#80E8E0"/>
    <SolidColorBrush x:Key="TealCyanHoverBrush" Color="#98F0E8"/>
    <SolidColorBrush x:Key="TealCyanPressedBrush" Color="#68D8D0"/>
    <SolidColorBrush x:Key="TextOnTealCyanBrush" Color="#0A2220"/>

    <SolidColorBrush x:Key="NavyDeepBrush" Color="#90A8E0"/>
    <SolidColorBrush x:Key="NavyDeepHoverBrush" Color="#A8BCEC"/>
    <SolidColorBrush x:Key="NavyDeepPressedBrush" Color="#7894CC"/>
    <SolidColorBrush x:Key="TextOnNavyDeepBrush" Color="#141828"/>

    <SolidColorBrush x:Key="MidnightBlueBrush" Color="#80A0D8"/>
    <SolidColorBrush x:Key="MidnightBlueHoverBrush" Color="#98B8E4"/>
    <SolidColorBrush x:Key="MidnightBluePressedBrush" Color="#6888C4"/>
    <SolidColorBrush x:Key="TextOnMidnightBlueBrush" Color="#101828"/>

    <SolidColorBrush x:Key="PrussianBlueBrush" Color="#7898CC"/>
    <SolidColorBrush x:Key="PrussianBlueHoverBrush" Color="#90B0DC"/>
    <SolidColorBrush x:Key="PrussianBluePressedBrush" Color="#6080B8"/>
    <SolidColorBrush x:Key="TextOnPrussianBlueBrush" Color="#101828"/>

    <SolidColorBrush x:Key="CharcoalDarkBrush" Color="#8898B0"/>
    <SolidColorBrush x:Key="CharcoalDarkHoverBrush" Color="#A0B0C4"/>
