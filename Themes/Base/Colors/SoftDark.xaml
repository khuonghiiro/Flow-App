<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  SOFT DARK — Warm charcoal + jade teal                       ║
    ║  Background: #1A1918  Surface: #252320  Accent: #6BBFB0     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                  RadiusX="1" RadiusY="1"
                  Center="0.5,0.5"
                  GradientOrigin="0.5,0.5">
        <GradientStop Color="#FF1A1918" Offset="0"/>
        <GradientStop Color="#FF252320" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FF3A3630"/>
    <SolidColorBrush x:Key="CardColor" Color="#FF252320"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FF504A42"/>

    <!-- Header — warm dark -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FF121110"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#BB1A1918"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#66FFFFFF"/>

    <SolidColorBrush x:Key="BackgroundAll" Color="#FF1A1918"/>

    <!-- ===== PRIMARY — jade teal (more vivid) ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#5FB0A4"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#78C4B8"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#52A396"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#0A1E1C"/>

    <!-- ===== SECONDARY ===== -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#5C6470"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#6E7888"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#4C5460"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="White"/>

    <!-- ===== SUCCESS ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#4DC880"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#66D898"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#38B46C"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="#081A10"/>

    <!-- ===== DANGER ===== -->
    <SolidColorBrush x:Key="DangerBrush" Color="#F07070"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#F88888"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#D85858"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="#FFFFFF"/>

    <!-- ===== WARNING ===== -->
    <SolidColorBrush x:Key="WarningBrush" Color="#E8B84A"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#F0CC6E"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#D4A030"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="#1A1400"/>

    <!-- ===== INFO ===== -->
    <SolidColorBrush x:Key="InfoBrush" Color="#60B0A8"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#78C4BC"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#4C9C94"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="#081C1A"/>

    <!-- ===== LIGHT / DARK variants ===== -->
    <SolidColorBrush x:Key="LightBrush" Color="#2E2C28"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#383430"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#252320"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#D8D2CC"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#121110"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#1A1918"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#0C0B0A"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="White"/>

    <!-- ===== WINDOW BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FF252320"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FF1A1918"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF1A1918"/>

    <!-- ===== TEXT ===== -->
    <SolidColorBrush x:Key="TextBrush" Color="#D8D2CC"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FF1A1918"/>

    <!-- ===== INPUT BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FF2E2C28"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FF3A3630"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#FF383430"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#FF3C3834"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FF201E1C"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FF282624"/>

    <!-- ===== BORDER COLORS ===== -->
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF585048"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF6BBFB0"/>

    <!-- ===== TEXT STATES ===== -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#88888078"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#88888078"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FF201E1C"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FFA8A098"/>

    <!-- ===== GLOW EFFECTS ===== -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#446BBFB0"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#286BBFB0"/>

    <!-- ===== READONLY ===== -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FF282624"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FFA8A098"/>
    <SolidColorBrush x:Key="BorderInverseColor">#FFD8D2CC</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FF3A3630</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush" Color="#FF4A4640"/>

    <!-- ===== BUTTON BRUSHES ===== -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FF2E2C28"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#FF2E2C28"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FF383430"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FF252320"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FF4A4640"/>

    <!-- ===== SCROLLBAR ===== -->
    <Color x:Key="ScrollBarThumbColor">#FF4A8880</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#FF6BBFB0</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#FF84CFC2</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- ===== PROGRESS ===== -->
    <SolidColorBrush x:Key="ProgressBackground">#FF383430</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF6BBFB0</SolidColorBrush>

    <!-- ===== SHADOW ===== -->
    <Color x:Key="ShadowColor">#AA000000</Color>
    <Color x:Key="PrimaryShadowColor">#601A1918</Color>

    <!-- ===== RADIO OPTIONS ===== -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FF383430"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF6BBFB0"/>

    <!-- ===== MISC ===== -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FF252320"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FFA0988E"/>

    <!-- ===== DATAGRID ===== -->
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FFD8D2CC"/>
    <SolidColorBrush x:Key="DataGridRowBackground">Transparent</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#0AFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FF252320</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FF3A3630</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#306BBFB0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#606BBFB0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#606BBFB0</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FF0A1E1C</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#486BBFB0"/>

    <!-- ===== COMBOBOX ===== -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FF383430"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FFA8E8DC"/>

    <!-- ComboBox -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="#FF1A1918"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FF4A4640"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="#FF201E1C"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF585048"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="#FF201E1C"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF6BBFB0"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FF252320"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FF3A3630"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FFC8C0B8"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FF383430"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FF203830"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FF284840"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FFE8F4F0"/>

    <!-- ===== CARD ===== -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FF252320"/>

    <!-- ===== SEMANTIC ALIASES ===== -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FF6BBFB0"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF84CFC2"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF4DC880"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FFD4956A"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD4956A"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FF1A1918"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FF252320"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FFE4DED8"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FFB4ACA4"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FFA0988E"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFF07070"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF4DC880"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FFE8B84A"/>

    <!-- ===== POPUP ===== -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#FF383430"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="#FF252320"/>

    <!-- ===== LAVENDER (list highlight — jade) ===== -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#306BBFB0"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#606BBFB0"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FFE4F4F0"/>

    <!-- ===== LISTVIEW HEADER ===== -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF1A1918"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FFD8D2CC"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#40383430"/>

    <!-- ===== CANVAS ===== -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FF1A1918"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#B080786E"/>
    <SolidColorBrush x:Key="ExecutionTraceGuideBrush" Color="#AA8F8780"/>
    <Color x:Key="NodeShadowColor">#80000000</Color>

    <!-- ===== FOCUS & INTERACTION ===== -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#556BBFB0"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FF2E2C28"/>
    <Color x:Key="ButtonShadowColor">#446BBFB0</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FF6BBFB0"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FF2E2C28"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FF2E2C28"/>

    <!-- Common palette overrides -->
    <SolidColorBrush x:Key="OceanBrush" Color="#60B0C8"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#78C4D8"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#4C9CB4"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#081820"/>

    <SolidColorBrush x:Key="BrightPowerBrush" Color="#E83060"/>
    <SolidColorBrush x:Key="BrightPowerHoverBrush" Color="#F05080"/>
    <SolidColorBrush x:Key="BrightPowerPressedBrush" Color="#CC2050"/>
    <SolidColorBrush x:Key="TextOnBrightPowerBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="MagentaBloomBrush" Color="#C870C8"/>
    <SolidColorBrush x:Key="MagentaBloomHoverBrush" Color="#D888D8"/>
    <SolidColorBrush x:Key="MagentaBloomPressedBrush" Color="#B45CB4"/>
    <SolidColorBrush x:Key="TextOnMagentaBloomBrush" Color="#200C20"/>

    <SolidColorBrush x:Key="NavyDeepBrush" Color="#6888C0"/>
    <SolidColorBrush x:Key="NavyDeepHoverBrush" Color="#80A0CC"/>
    <SolidColorBrush x:Key="NavyDeepPressedBrush" Color="#5474AC"/>
    <SolidColorBrush x:Key="TextOnNavyDeepBrush" Color="#0C1828"/>

    <SolidColorBrush x:Key="MidnightBlueBrush" Color="#5878B0"/>
    <SolidColorBrush x:Key="MidnightBlueHoverBrush" Color="#7090C0"/>
    <SolidColorBrush x:Key="MidnightBluePressedBrush" Color="#48649C"/>
    <SolidColorBrush x:Key="TextOnMidnightBlueBrush" Color="#0C1828"/>

    <SolidColorBrush x:Key="PrussianBlueBrush" Color="#5070A8"/>
    <SolidColorBrush x:Key="PrussianBlueHoverBrush" Color="#6888BC"/>
    <SolidColorBrush x:Key="PrussianBluePressedBrush" Color="#3C5C94"/>
    <SolidColorBrush x:Key="TextOnPrussianBlueBrush" Color="#0C1828"/>

    <SolidColorBrush x:Key="CharcoalDarkBrush" Color="#607080"/>
    <SolidColorBrush x:Key="CharcoalDarkHoverBrush" Color="#788898"/>
    <SolidColorBrush x:Key="CharcoalDarkPressedBrush" Color="#4C5C6C"/>
    <SolidColorBrush x:Key="TextOnCharcoalDarkBrush" Color="#101820"/>

    <SolidColorBrush x:Key="GraphiteGrayBrush" Color="#686870"/>
    <SolidColorBrush x:Key="GraphiteGrayHoverBrush" Color="#808088"/>
    <SolidColorBrush x:Key="GraphiteGrayPressedBrush" Color="#54545C"/>
    <SolidColorBrush x:Key="TextOnGraphiteGrayBrush" Color="#141418"/>

    <SolidColorBrush x:Key="BerryPurpleBrush" Color="#A880C8"/>
    <SolidColorBrush x:Key="BerryPurpleHoverBrush" Color="#BC98D8"/>
    <SolidColorBrush x:Key="BerryPurplePressedBrush" Color="#946CB4"/>
    <SolidColorBrush x:Key="TextOnBerryPurpleBrush" Color="#1C1028"/>

    <SolidColorBrush x:Key="CobaltBlueBrush" Color="#6090CC"/>
    <SolidColorBrush x:Key="CobaltBlueHoverBrush" Color="#78A8D8"/>
    <SolidColorBrush x:Key="CobaltBluePressedBrush" Color="#4C7CB8"/>
    <SolidColorBrush x:Key="TextOnCobaltBlueBrush" Color="#0C1828"/>

    <SolidColorBrush x:Key="WineRedBrush" Color="#B07880"/>
    <SolidColorBrush x:Key="WineRedHoverBrush" Color="#C09098"/>
    <SolidColorBrush x:Key="WineRedPressedBrush" Color="#9C646C"/>
    <SolidColorBrush x:Key="TextOnWineRedBrush" Color="#281018"/>

    <SolidColorBrush x:Key="EspressoBrownBrush" Color="#A88070"/>
    <SolidColorBrush x:Key="EspressoBrownHoverBrush" Color="#BC9888"/>
    <SolidColorBrush x:Key="EspressoBrownPressedBrush" Color="#946C5C"/>
    <SolidColorBrush x:Key="TextOnEspressoBrownBrush" Color="#201410"/>

    <SolidColorBrush x:Key="AubergineBrush" Color="#987888"/>
    <SolidColorBrush x:Key="AubergineHoverBrush" Color="#AC909C"/>
    <SolidColorBrush x:Key="AuberginePressedBrush" Color="#846474"/>
    <SolidColorBrush x:Key="TextOnAubergineBrush" Color="#201420"/>

    <SolidColorBrush x:Key="BambooGreenBrush" Color="#7C9C68"/>
    <SolidColorBrush x:Key="BambooGreenHoverBrush" Color="#90B07C"/>
    <SolidColorBrush x:Key="BambooGreenPressedBrush" Color="#688854"/>
    <SolidColorBrush x:Key="TextOnBambooGreenBrush" Color="#141E0C"/>

</ResourceDictionary>
