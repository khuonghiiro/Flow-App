<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  SOFT LIGHT — Warm cream paper + teal sage                   ║
    ║  Background: #F0EDE8  Surface: #FAF8F4  Accent: #3D8A7C     ║
    ╚══════════════════════════════════════════════════════════════╝
    -->

    <RadialGradientBrush x:Key="CardRadialBackground"
                     RadiusX="1" RadiusY="1"
                     Center="0.5,0.5"
                     GradientOrigin="0.5,0.5">
        <GradientStop Color="#FFFCFAF7" Offset="0"/>
        <GradientStop Color="#FFEDE9E2" Offset="1"/>
    </RadialGradientBrush>

    <SolidColorBrush x:Key="BorderBrush" Color="#FFCCC4BA"/>
    <SolidColorBrush x:Key="CardColor" Color="#FFFAF8F4"/>
    <SolidColorBrush x:Key="BorderColor" Color="#FFADA49A"/>

    <!-- Header — warm cream -->
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFF5F2EC"/>

    <!-- Overlay -->
    <SolidColorBrush x:Key="OverlayBackground" Color="#80FFFFFF"/>
    <SolidColorBrush x:Key="OverlayBackgroundReverse" Color="#80000000"/>
    <SolidColorBrush x:Key="BackgroundAll" Color="#FFF0EDE8"/>

    <!-- ===== PRIMARY — teal sage (deeper, more readable) ===== -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#3D8A7C"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#33786C"/>
    <SolidColorBrush x:Key="PrimaryPressedBrush" Color="#29665C"/>
    <SolidColorBrush x:Key="TextOnPrimaryBrush" Color="#FFFFFF"/>

    <!-- ===== SECONDARY ===== -->
    <SolidColorBrush x:Key="SecondaryBrush" Color="#6C757D"/>
    <SolidColorBrush x:Key="SecondaryHoverBrush" Color="#5C636A"/>
    <SolidColorBrush x:Key="SecondaryPressedBrush" Color="#4C535A"/>
    <SolidColorBrush x:Key="TextOnSecondaryBrush" Color="White"/>

    <!-- ===== SUCCESS ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#0E7A0E"/>
    <SolidColorBrush x:Key="SuccessHoverBrush" Color="#0C690C"/>
    <SolidColorBrush x:Key="SuccessPressedBrush" Color="#0A580A"/>
    <SolidColorBrush x:Key="TextOnSuccessBrush" Color="White"/>

    <!-- ===== DANGER ===== -->
    <SolidColorBrush x:Key="DangerBrush" Color="#C0281A"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#AC2016"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#981C12"/>
    <SolidColorBrush x:Key="TextOnDangerBrush" Color="White"/>

    <!-- ===== WARNING ===== -->
    <SolidColorBrush x:Key="WarningBrush" Color="#985800"/>
    <SolidColorBrush x:Key="WarningHoverBrush" Color="#844D00"/>
    <SolidColorBrush x:Key="WarningPressedBrush" Color="#704200"/>
    <SolidColorBrush x:Key="TextOnWarningBrush" Color="White"/>

    <!-- ===== INFO ===== -->
    <SolidColorBrush x:Key="InfoBrush" Color="#2A7898"/>
    <SolidColorBrush x:Key="InfoHoverBrush" Color="#226888"/>
    <SolidColorBrush x:Key="InfoPressedBrush" Color="#1A5878"/>
    <SolidColorBrush x:Key="TextOnInfoBrush" Color="White"/>

    <!-- ===== LIGHT / DARK variants ===== -->
    <SolidColorBrush x:Key="LightBrush" Color="#EAE6E0"/>
    <SolidColorBrush x:Key="LightHoverBrush" Color="#E0DCD4"/>
    <SolidColorBrush x:Key="LightPressedBrush" Color="#D4CFC8"/>
    <SolidColorBrush x:Key="TextOnLightBrush" Color="#302C28"/>

    <SolidColorBrush x:Key="DarkBrush" Color="#302C28"/>
    <SolidColorBrush x:Key="DarkHoverBrush" Color="#282420"/>
    <SolidColorBrush x:Key="DarkPressedBrush" Color="#201C18"/>
    <SolidColorBrush x:Key="TextOnDarkBrush" Color="White"/>

    <!-- ===== WINDOW BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="WindowBodyBackground" Color="#FFF0EDE8"/>
    <SolidColorBrush x:Key="WindowBackground" Color="#FFF0EDE8"/>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FFF0EDE8"/>

    <!-- ===== TEXT ===== -->
    <SolidColorBrush x:Key="TextBrush" Color="#FF302C28"/>
    <SolidColorBrush x:Key="TextBrushReverse" Color="#FFEEEEEE"/>

    <!-- ===== INPUT BACKGROUNDS ===== -->
    <SolidColorBrush x:Key="TextBoxBackground" Color="#FFFCFBF9"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#FFB8B0A6"/>
    <SolidColorBrush x:Key="TextBoxHoverBackground" Color="#FFF5F2EE"/>
    <SolidColorBrush x:Key="TextBoxFocusBackground" Color="#FFFCFBF9"/>
    <SolidColorBrush x:Key="TextBoxDisabledBackground" Color="#FFE8E4DE"/>
    <SolidColorBrush x:Key="TextBoxReadOnlyBackground" Color="#FFF4F1EC"/>

    <!-- ===== BORDER COLORS ===== -->
    <SolidColorBrush x:Key="TextBoxHoverBorderBrush" Color="#FF908880"/>
    <SolidColorBrush x:Key="TextBoxFocusBorderBrush" Color="#FF3D8A7C"/>

    <!-- ===== TEXT STATES ===== -->
    <SolidColorBrush x:Key="PlaceholderBrush" Color="#FF989088"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#FF989088"/>
    <SolidColorBrush x:Key="DisabledBackground" Color="#FFE8E4DE"/>
    <SolidColorBrush x:Key="ReadOnlyTextBrush" Color="#FF504C48"/>

    <!-- ===== GLOW EFFECTS ===== -->
    <SolidColorBrush x:Key="PrimaryGlowBrush" Color="#223D8A7C"/>
    <SolidColorBrush x:Key="HoverGlowBrush" Color="#153D8A7C"/>

    <!-- ===== READONLY ===== -->
    <SolidColorBrush x:Key="ReadOnlyBackground" Color="#FFF4F1EC"/>
    <SolidColorBrush x:Key="ReadOnlyForeground" Color="#FF504C48"/>
    <SolidColorBrush x:Key="BorderInverseColor">#60504C48</SolidColorBrush>
    <SolidColorBrush x:Key="ControlBorderColor">#FFCCC4BA</SolidColorBrush>
    <SolidColorBrush x:Key="ReadOnlyBorderBrush">#40808080</SolidColorBrush>

    <!-- ===== BUTTON BRUSHES ===== -->
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#FFF0EBE4"/>
    <SolidColorBrush x:Key="ControlBackground" Color="#FFF0EBE4"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#FFE6E0D8"/>
    <SolidColorBrush x:Key="ButtonPressedBrush" Color="#FFDCD4CC"/>
    <SolidColorBrush x:Key="ButtonBorderBrush" Color="#FFC0B8AE"/>

    <!-- ===== SCROLLBAR ===== -->
    <Color x:Key="ScrollBarThumbColor">#903D8A7C</Color>
    <Color x:Key="ScrollBarThumbHoverColor">#B03D8A7C</Color>
    <Color x:Key="ScrollBarThumbPressedColor">#D03D8A7C</Color>
    <Color x:Key="ScrollBarTrackColor">Transparent</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    <SolidColorBrush x:Key="ScrollBarTrackBackground" Color="{StaticResource ScrollBarTrackColor}"/>

    <!-- ===== PROGRESS ===== -->
    <SolidColorBrush x:Key="ProgressBackground">#FFE0DCD4</SolidColorBrush>
    <SolidColorBrush x:Key="ProgressFill">#FF3D8A7C</SolidColorBrush>

    <!-- ===== SHADOW ===== -->
    <Color x:Key="ShadowColor">#38000000</Color>
    <Color x:Key="PrimaryShadowColor">#28000000</Color>

    <!-- ===== RADIO OPTIONS ===== -->
    <SolidColorBrush x:Key="OptionHoverBrush" Color="#FFE0DCD4"/>
    <SolidColorBrush x:Key="OptionSelectedBrush" Color="#FF3D8A7C"/>

    <!-- ===== MISC ===== -->
    <SolidColorBrush x:Key="TitleBackgroundBrush" Color="#FFF5F2EC"/>
    <SolidColorBrush x:Key="TextNoteBrush" Color="#FF6C6460"/>

    <!-- ===== DATAGRID ===== -->
    <SolidColorBrush x:Key="DataGridHeaderBrush" Color="#FF201C18"/>
    <SolidColorBrush x:Key="DataGridRowBackground">#08000000</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridAltRowBackground">#FFF5F2EC</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHeaderBackground">#FFE4E0D8</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridBorderBrush">#FFCCC4BA</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridRowHoverBackground">#203D8A7C</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectionBackground">#583D8A7C</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedCellBackground">#583D8A7C</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridSelectedTextBrush">#FFFFFFFF</SolidColorBrush>
    <SolidColorBrush x:Key="DataGridHoverCellBackground" Color="#383D8A7C"/>

    <!-- ===== COMBOBOX ===== -->
    <SolidColorBrush x:Key="SelectionBrush" Color="#FFE0E8E4"/>
    <SolidColorBrush x:Key="SelectedTextBrush" Color="#FF3D8A7C"/>

    <!-- ===== CARD ===== -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFAF8F4"/>

    <!-- ===== SEMANTIC ALIASES ===== -->
    <SolidColorBrush x:Key="PrimaryColor" Color="#FF3D8A7C"/>
    <SolidColorBrush x:Key="PrimaryHover" Color="#FF33786C"/>
    <SolidColorBrush x:Key="SecondaryColor" Color="#FF0E7A0E"/>
    <SolidColorBrush x:Key="AccentColor" Color="#FF7020B8"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF7020B8"/>
    <SolidColorBrush x:Key="BackgroundColor" Color="#FFF0EDE8"/>
    <SolidColorBrush x:Key="SurfaceColor" Color="#FFFAF8F4"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#FF302C28"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#FF5C5854"/>
    <SolidColorBrush x:Key="TextMuted" Color="#FF6C6460"/>
    <SolidColorBrush x:Key="DangerColor" Color="#FFC0281A"/>
    <SolidColorBrush x:Key="SuccessColor" Color="#FF0E7A0E"/>
    <SolidColorBrush x:Key="WarningColor" Color="#FF985800"/>

    <!-- ===== POPUP ===== -->
    <SolidColorBrush x:Key="PopupHoverBrush" Color="#FFE4EDE8"/>
    <SolidColorBrush x:Key="PopupSelectedBackground" Color="Transparent"/>

    <!-- ===== LAVENDER (ComboBox selection highlight) ===== -->
    <SolidColorBrush x:Key="LavenderHoverBrush"   Color="#203D8A7C"/>
    <SolidColorBrush x:Key="LavenderPressedBrush" Color="#583D8A7C"/>
    <SolidColorBrush x:Key="TextOnLavenderBrush"  Color="#FF29584E"/>

    <!-- ===== COMBOBOX ===== -->
    <SolidColorBrush x:Key="ComboBoxFieldBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ComboBoxFieldBorderBrush" Color="#FFA8A098"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ComboBoxFieldHoverBorderBrush" Color="#FF807870"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBackground" Color="Transparent"/>
    <SolidColorBrush x:Key="ComboBoxFieldFocusBorderBrush" Color="#FF3D8A7C"/>
    <SolidColorBrush x:Key="ComboBoxPopupBackground" Color="#FFFCFAF7"/>
    <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#FFBCB4AA"/>
    <SolidColorBrush x:Key="ComboBoxGlyphBrush" Color="#FF504C48"/>
    <SolidColorBrush x:Key="ComboBoxItemHoverBrush" Color="#FFD8E8E4"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedBrush" Color="#FFC0D8D0"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedHoverBrush" Color="#FFA8C8C0"/>
    <SolidColorBrush x:Key="ComboBoxItemSelectedForegroundBrush" Color="#FF183028"/>

    <!-- ===== LISTVIEW HEADER ===== -->
    <SolidColorBrush x:Key="ListViewHeaderBrush"  Color="#FF3D8A7C"/>
    <SolidColorBrush x:Key="ListViewItemBrush"    Color="#FF302C28"/>
    <SolidColorBrush x:Key="HoverBackground"      Color="#E4E0D8"/>

    <!-- ===== CANVAS ===== -->
    <SolidColorBrush x:Key="CanvasBackgroundBrush" Color="#FFEBE9E5"/>
    <SolidColorBrush x:Key="CanvasGridBrush" Color="#D0A89E94"/>
    <SolidColorBrush x:Key="ExecutionTraceGuideBrush" Color="#C8827A72"/>
    <Color x:Key="NodeShadowColor">#30000000</Color>

    <!-- ===== FOCUS & INTERACTION ===== -->
    <SolidColorBrush x:Key="FocusRingBrush" Color="#443D8A7C"/>
    <SolidColorBrush x:Key="CardHoverBackground" Color="#FFE8E4DC"/>
    <Color x:Key="ButtonShadowColor">#283D8A7C</Color>
    <SolidColorBrush x:Key="TabIndicatorBrush" Color="#FF3D8A7C"/>
    <SolidColorBrush x:Key="DataGridHeaderHoverBackground" Color="#FFE8E4DC"/>
    <SolidColorBrush x:Key="MenuItemHoverBackgroundBrush" Color="#FFE8E4DC"/>

    <!-- Common palette overrides -->
    <SolidColorBrush x:Key="OceanBrush" Color="#2A7898"/>
    <SolidColorBrush x:Key="OceanHoverBrush" Color="#226888"/>
    <SolidColorBrush x:Key="OceanPressedBrush" Color="#1A5878"/>
    <SolidColorBrush x:Key="TextOnOceanBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="BrightPowerBrush" Color="#D81858"/>
    <SolidColorBrush x:Key="BrightPowerHoverBrush" Color="#C0144C"/>
    <SolidColorBrush x:Key="BrightPowerPressedBrush" Color="#A81040"/>
    <SolidColorBrush x:Key="TextOnBrightPowerBrush" Color="#FFFFFF"/>

    <SolidColorBrush x:Key="MagentaBloomBrush" Color="#A820B8"/>
    <SolidColorBrush x:Key="MagentaBloomHoverBrush" Color="#901CA0"/>
    <SolidColorBrush x:Key="MagentaBloomPressedBrush" Color="#781888"/>
    <SolidColorBrush x:Key="TextOnMagentaBloomBrush" Color="#FFFFFF"/>

</ResourceDictionary>
