<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="CenterTextBlockStyle" TargetType="TextBlock">
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    </Style>

    <!--Nút ẩn hiện mật khẩu-->
    <Style x:Key="FlatToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Light card/popup shadow (keep subtle: avoid large BlurRadius on UI near text) -->
    <DropShadowEffect x:Key="DropShadowEffect"
                      Color="#000000"
                      Opacity="0.1"
                      ShadowDepth="1"
                      BlurRadius="3"/>

    <!-- Style cho Button có thể select như RadioButton -->
    <Style x:Key="SelectableOptionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="#10000000"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,5"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Border"
                            Padding="15"
                            CornerRadius="12"
                            Background="{TemplateBinding Background}"
                            BorderBrush="#FFCCCCCC"
                            BorderThickness="2"
                            MinHeight="60">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Vòng tròn với chữ cái -->
                            <Border Grid.Column="0"
                                    x:Name="OptionCircle"
                                    Width="28" Height="28"
                                    CornerRadius="14"
                                    Background="Transparent"
                                    BorderBrush="#FFCCCCCC"
                                    BorderThickness="2"
                                    VerticalAlignment="Center"
                                    Margin="0,0,15,0">
                                <TextBlock x:Name="OptionLetter"
                                           Text="{Binding Value}"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <!-- Text content với wrapping -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Text}"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Justify"
                                       FontSize="16"
                                       LineHeight="25"
                                        Margin="0,0,0,0"
                                       Foreground="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover Effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#803B82F6" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="#50FFFFFF" />
                            <Setter TargetName="OptionCircle" Property="BorderBrush" Value="#50FFFFFF" />
                        </Trigger>

                        <!-- Pressed Effect -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Property="Background" Value="#3B82F6" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <!-- Style triggers for selected state -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Border"
                                    Padding="15"
                                    CornerRadius="12"
                                    Background="#EFF6FF"
                                    BorderBrush="#3B82F6"
                                    BorderThickness="2"
                                    MinHeight="60">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Selected circle -->
                                    <Border Grid.Column="0"
                                            Width="28" Height="28"
                                            CornerRadius="14"
                                            Background="#3B82F6"
                                            VerticalAlignment="Center"
                                            Margin="0,0,15,0">
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="14"
                                                   FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- Text content -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               TextAlignment="Justify"
                                               FontSize="16"
                                               Foreground="Black"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Border" Property="Background" Value="#DBEAFE" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Modern Gradient Brushes -->
    <LinearGradientBrush x:Key="ModernGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#667eea" Offset="0"/>
        <GradientStop Color="#764ba2" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WindowBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#f8fafc" Offset="0"/>
        <GradientStop Color="#e2e8f0" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#ffffff" Offset="0"/>
        <GradientStop Color="#f1f5f9" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
