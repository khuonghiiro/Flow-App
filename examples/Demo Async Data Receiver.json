      "Properties": {
        "FloatingWidget": "{\u0022IsEnabled\u0022:true,\u0022WidgetName\u0022:\u0022\\uD83D\\uDCE1 Async Dashboard\u0022,\u0022IdleShape\u0022:0,\u0022IdleSize\u0022:48,\u0022IdleIconText\u0022:\u0022html5 brands\u0022,\u0022IdleOpacity\u0022:0.85,\u0022IdleAnimation\u0022:2,\u0022IdleBackgroundColor\u0022:\u0022#804040\u0022,\u0022IdleForegroundColor\u0022:null,\u0022ExpandedWidth\u0022:400,\u0022ExpandedHeight\u0022:300,\u0022AllowResize\u0022:true,\u0022MinExpandedWidth\u0022:200,\u0022MinExpandedHeight\u0022:150,\u0022MaxExpandedWidth\u0022:1200,\u0022MaxExpandedHeight\u0022:900,\u0022UseRatioSize\u0022:false,\u0022WidthRatio\u0022:0.3,\u0022HeightRatio\u0022:0.35,\u0022MinWidthRatio\u0022:0.15,\u0022MinHeightRatio\u0022:0.15,\u0022MaxWidthRatio\u0022:0.9,\u0022MaxHeightRatio\u0022:0.9,\u0022AllowDrag\u0022:true,\u0022SnapToEdge\u0022:true,\u0022PreferredEdge\u0022:2,\u0022SnapMargin\u0022:0,\u0022SavedX\u0022:-38.55,\u0022SavedY\u0022:317.55,\u0022AutoCollapseWhenIdle\u0022:false,\u0022IdleTimeoutSeconds\u0022:10,\u0022CollapseWhenClickOutsideExpanded\u0022:true,\u0022PinnedNoAutoHide\u0022:false,\u0022SlideToEdgeWhenIdle\u0022:true,\u0022EdgeDockAsSquare\u0022:true,\u0022EdgeDockSquareSize\u0022:28,\u0022SlideHidePercent\u0022:0,\u0022AlwaysOnTop\u0022:true,\u0022LockPosition\u0022:false,\u0022ShowInTaskbar\u0022:false,\u0022TaskbarIconShape\u0022:3,\u0022TaskbarIconSize\u0022:40,\u0022ShowTitleBar\u0022:true,\u0022AutoHideTitleBar\u0022:false,\u0022TitleBarHideTimeoutSeconds\u0022:3,\u0022ShowSideActionButton\u0022:false,\u0022DisplayMode\u0022:0,\u0022MonitorIndex\u0022:-1,\u0022ShowOnAllMonitors\u0022:false}",
        "TitleDisplayMode": "Always",
        "TitleColorMode": "NodeColor",
        "TitleColorKey": "NodeColor",
        "InputMappings": "[{\u0022SourceNodeId\u0022:null,\u0022SourceOutputKey\u0022:null,\u0022InputKeyOverride\u0022:null,\u0022ShouldReExecute\u0022:false,\u0022AutoRefreshEnabled\u0022:false,\u0022AutoRefreshInterval\u0022:1000,\u0022AutoRefreshUnit\u0022:\u0022ms\u0022}]",
        "HtmlCode": "\u003C!DOCTYPE html\u003E\n\u003Chtml\u003E\n\u003Chead\u003E\n    \u003Cmeta charset=\u0022UTF-8\u0022\u003E\n    \u003Ctitle\u003EAsync Data Receiver Demo\u003C/title\u003E\n\u003C/head\u003E\n\u003Cbody\u003E\n    \u003Cdiv class=\u0022container\u0022\u003E\n        \u003Ch1\u003E\uD83D\uDCE1 Async Data Receiver\u003C/h1\u003E\n        \u003Cp class=\u0022desc\u0022\u003ED\u1EEF li\u1EC7u t\u1EEB AsyncTask s\u1EBD xu\u1EA5t hi\u1EC7n realtime b\u00EAn d\u01B0\u1EDBi.\n            Nh\u1EA5n \u003Ckbd\u003EF5\u003C/kbd\u003E \u0111\u1EC3 reload \u2014 d\u1EEF li\u1EC7u \u0111\u00E3 nh\u1EADn s\u1EBD t\u1EF1 push l\u1EA1i.\u003C/p\u003E\n\n        \u003C!-- Status --\u003E\n        \u003Cdiv class=\u0022status-bar\u0022\u003E\n            \u003Cspan id=\u0022statusIcon\u0022\u003E\u23F3\u003C/span\u003E\n            \u003Cspan id=\u0022statusText\u0022\u003E\u0110ang ch\u1EDD d\u1EEF li\u1EC7u...\u003C/span\u003E\n            \u003Cspan id=\u0022itemCount\u0022 class=\u0022badge\u0022\u003E0 items\u003C/span\u003E\n        \u003C/div\u003E\n\n        \u003C!-- Progress --\u003E\n        \u003Cdiv class=\u0022progress-wrap\u0022\u003E\n            \u003Cdiv id=\u0022progressBar\u0022 class=\u0022progress-bar\u0022 style=\u0022width: 0%\u0022\u003E\u003C/div\u003E\n        \u003C/div\u003E\n\n        \u003C!-- Item list --\u003E\n        \u003Cdiv id=\u0022itemList\u0022 class=\u0022item-list\u0022\u003E\n            \u003Cdiv class=\u0022empty-state\u0022\u003E\u2B50 Ch\u01B0a c\u00F3 d\u1EEF li\u1EC7u. H\u00E3y ch\u1EA1y workflow!\u003C/div\u003E\n        \u003C/div\u003E\n\n        \u003C!-- Last received raw --\u003E\n        \u003Cdiv class=\u0022raw-section\u0022\u003E\n            \u003Ch3\u003E\uD83D\uDD0D Raw data (key: item)\u003C/h3\u003E\n            \u003Cpre id=\u0022rawData\u0022\u003Enull\u003C/pre\u003E\n        \u003C/div\u003E\n    \u003C/div\u003E\n\u003C/body\u003E\n\u003C/html\u003E",
        "JsCode": "// =============================================================\n// DEMO: window.hostAsync \u2014 Async Data Receiver\n// =============================================================\n\nvar receivedItems = [];\nvar totalExpected = 5; // s\u1ED1 l\u01B0\u1EE3ng iteration c\u1EE7a AsyncTask\n\n// C\u00E1ch 1: Nh\u1EADn 1 key c\u1EE5 th\u1EC3 (\u0027item\u0027)\nwindow.hostAsync.on(\u0027item\u0027, function(value) {\n    console.log(\u0027Received item:\u0027, value);\n    \n    // L\u01B0u v\u00E0o list\n    receivedItems.push(value);\n    \n    // Update UI\n    updateDashboard(value);\n});\n\n// C\u00E1ch 2 (optional): Nh\u1EADn T\u1EA4T C\u1EA2 data \u2014 h\u00E0m n\u00E0y g\u1ECDi m\u1ED7i l\u1EA7n b\u1EA5t k\u1EF3 key n\u00E0o \u0111\u01B0\u1EE3c push\n// window.hostAsync.on(function(allData) {\n//     console.log(\u0027All async data:\u0027, JSON.stringify(allData));\n// });\n\nfunction updateDashboard(latestValue) {\n    // Status\n    var icon = document.getElementById(\u0027statusIcon\u0027);\n    var text = document.getElementById(\u0027statusText\u0027);\n    var count = document.getElementById(\u0027itemCount\u0027);\n    var progress = document.getElementById(\u0027progressBar\u0027);\n    var list = document.getElementById(\u0027itemList\u0027);\n    var raw = document.getElementById(\u0027rawData\u0027);\n    \n    var n = receivedItems.length;\n    var pct = Math.min(100, Math.round((n / totalExpected) * 100));\n    \n    icon.textContent = pct \u003E= 100 ? \u0027\u2705\u0027 : \u0027\u26A1\u0027;\n    text.textContent = pct \u003E= 100 ? \u0027Ho\u00E0n th\u00E0nh!\u0027 : \u0027\u0110ang nh\u1EADn d\u1EEF li\u1EC7u...\u0027;\n    count.textContent = n \u002B \u0027 items\u0027;\n    progress.style.width = pct \u002B \u0027%\u0027;\n    progress.textContent = pct \u002B \u0027%\u0027;\n    \n    if (pct \u003E= 100) {\n        progress.classList.add(\u0027done\u0027);\n    }\n    \n    // Raw data\n    raw.textContent = latestValue;\n    \n    // Render list\n    var html = \u0027\u0027;\n    for (var i = receivedItems.length - 1; i \u003E= 0; i--) {\n        var item = receivedItems[i];\n        var ts = new Date().toLocaleTimeString();\n        html \u002B= \u0027\u003Cdiv class=\u0022item-row\u0022\u003E\u0027 \u002B\n            \u0027\u003Cspan class=\u0022item-idx\u0022\u003E#\u0027 \u002B (i \u002B 1) \u002B \u0027\u003C/span\u003E\u0027 \u002B\n            \u0027\u003Cspan class=\u0022item-val\u0022\u003E\u0027 \u002B escapeHtml(item) \u002B \u0027\u003C/span\u003E\u0027 \u002B\n            \u0027\u003Cspan class=\u0022item-time\u0022\u003E\u0027 \u002B ts \u002B \u0027\u003C/span\u003E\u0027 \u002B\n            \u0027\u003C/div\u003E\u0027;\n    }\n    list.innerHTML = html;\n}\n\nfunction escapeHtml(str) {\n    var d = document.createElement(\u0027div\u0027);\n    d.textContent = str;\n    return d.innerHTML;\n}\n\n// C\u00E1ch 3: \u0110\u1ECDc tr\u1EF1c ti\u1EBFp (polling) \u2014 kh\u00F4ng c\u1EA7n callback\n// var val = window.hostAsync.values[\u0027item\u0027];\n",
        "CssCode": "body {\n    font-family: \u0027Segoe UI\u0027, system-ui, sans-serif;\n    margin: 0; padding: 0;\n    background: #0f172a;\n    color: #e2e8f0;\n}\n.container { padding: 20px; }\nh1 { margin: 0 0 4px; font-size: 20px; color: #38bdf8; }\n.desc { font-size: 12px; color: #94a3b8; margin: 0 0 16px; }\nkbd {\n    background: #1e293b; border: 1px solid #334155;\n    border-radius: 4px; padding: 1px 6px; font-size: 11px;\n    color: #38bdf8;\n}\n\n/* Status */\n.status-bar {\n    display: flex; align-items: center; gap: 8px;\n    background: #1e293b; border-radius: 8px;\n    padding: 10px 14px; margin-bottom: 12px;\n    font-size: 14px;\n}\n#statusIcon { font-size: 18px; }\n.badge {\n    margin-left: auto;\n    background: #0ea5e9; color: #fff;\n    border-radius: 12px; padding: 2px 10px;\n    font-size: 12px; font-weight: 600;\n}\n\n/* Progress */\n.progress-wrap {\n    background: #1e293b; border-radius: 6px;\n    height: 22px; margin-bottom: 16px; overflow: hidden;\n}\n.progress-bar {\n    height: 100%; background: linear-gradient(90deg, #0ea5e9, #6366f1);\n    border-radius: 6px; transition: width 0.4s ease;\n    display: flex; align-items: center; justify-content: center;\n    font-size: 11px; font-weight: 600; color: #fff;\n    min-width: 0;\n}\n.progress-bar.done {\n    background: linear-gradient(90deg, #10b981, #34d399);\n}\n\n/* Item list */\n.item-list {\n    background: #1e293b; border-radius: 8px;\n    padding: 8px; max-height: 200px;\n    overflow-y: auto; margin-bottom: 16px;\n}\n.empty-state {\n    text-align: center; color: #64748b;\n    padding: 20px; font-size: 13px;\n}\n.item-row {\n    display: flex; align-items: center; gap: 10px;\n    padding: 6px 10px; border-radius: 6px;\n    margin-bottom: 4px;\n    background: #0f172a;\n    animation: fadeIn 0.3s ease;\n}\n@keyframes fadeIn {\n    from { opacity: 0; transform: translateY(-4px); }\n    to { opacity: 1; transform: translateY(0); }\n}\n.item-idx {\n    color: #0ea5e9; font-weight: 700;\n    font-size: 12px; min-width: 30px;\n}\n.item-val {\n    flex: 1; font-size: 13px;\n    color: #e2e8f0;\n    overflow: hidden; text-overflow: ellipsis;\n    white-space: nowrap;\n}\n.item-time {\n    color: #64748b; font-size: 11px;\n    white-space: nowrap;\n}\n\n/* Raw */\n.raw-section {\n    background: #1e293b; border-radius: 8px;\n    padding: 12px;\n}\n.raw-section h3 {\n    margin: 0 0 6px; font-size: 13px;\n    color: #94a3b8; font-weight: 600;\n}\npre {\n    margin: 0; font-size: 12px;\n    color: #fbbf24; font-family: \u0027Cascadia Code\u0027, Consolas, monospace;\n    white-space: pre-wrap; word-break: break-all;\n}\n",
